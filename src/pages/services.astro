---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServiceGrid from "../components/sections/ServiceGrid.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import { pageMeta, solutionLinks } from "../data/site.js";

const services = solutionLinks.map((link) => ({
  ...link,
  title: link.label,
  summary: link.summary
}));
---

<BaseLayout title={pageMeta.services.title} description={pageMeta.services.description}>
  <section class="hero-padding bg-gradient-to-b from-kharon-black to-kharon-charcoal kharon-environment kharon-logo-watermark">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 kharon-h1">
        Fire Protection Services
      </h1>
      <p class="text-xl text-kharon-light/80 max-w-2xl mx-auto leading-relaxed">
        Commercial fire detection, clean-agent gas suppression, compliance maintenance and integrated security services.
      </p>
    </div>
  </section>

  <ServiceGrid services={services} />
  
  <section class="section-padding bg-gradient-to-b from-kharon-charcoal to-kharon-black">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <SectionHeading
        title="Engineered Solutions"
        subtitle="Technical Authority"
        description="All fire protection systems are positioned around relevant industry regulation, installation standards and maintainable handover evidence."
        center={true}
      />
      
      <div class="mt-12 prose prose-invert max-w-none">
        <p class="text-kharon-light/80 text-lg leading-relaxed">
          Our services are structured around engineered solutions that prioritize reliability, maintainability, and compliance in critical operational contexts. Each service is designed to integrate with your existing infrastructure while meeting the highest industry standards.
        </p>
      </div>
    </div>
  </section>

  <section class="section-padding bg-gradient-to-b from-kharon-black to-kharon-charcoal relative overflow-hidden">
    <div class="hero-cinematic__atmosphere opacity-30"></div>
    <div class="mx-auto max-w-6xl px-6 relative z-10">
      <SectionHeading
        title="National Coverage"
        subtitle="Service Area"
        description="Providing critical technical field services and compliance maintenance across South Africa."
        center={true}
      />
      
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {['Gauteng', 'Western Cape', 'KwaZulu-Natal', 'Eastern Cape'].map((province) => (
          <div class="rounded-lg border border-kharon-purple/20 bg-kharon-black p-6 flex items-center justify-between group hover:border-kharon-purple/50 transition-colors">
            <span class="text-white font-medium">{province}</span>
            <div class="h-2 w-2 rounded-full bg-kharon-purple"></div>
          </div>
        ))}
      </div>
      <div class="mt-8 text-center">
        <p class="text-kharon-light/70 text-sm">Specialized regional teams available for emergency support and scheduled maintenance.</p>
      </div>
    </div>
  </section>
</BaseLayout>
