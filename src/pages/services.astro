---
import BaseLayout from "../layouts/BaseLayout.astro";
import { pageMeta, solutionLinks } from "../data/site.js";
---

<BaseLayout title={pageMeta.services.title} description={pageMeta.services.description}>
  <main>
    <section class="bg-kharon-black text-white">
      <div class="mx-auto grid max-w-7xl gap-6 lg:gap-10 px-6 py-16 lg:grid-cols-2 lg:px-8">
        <div>
          <p class="text-sm font-bold uppercase tracking-widest text-kharon-cyan">Services</p>
          <h1 class="mt-5 max-w-3xl text-4xl font-bold">
            Fire protection services for accountable operational environments.
          </h1>
          <p class="mt-6 max-w-2xl leading-7 text-white/75">
            Kharon combines engineered detection, clean-agent suppression, compliance maintenance and operational support into a lifecycle service model for commercial, industrial and critical infrastructure sites.
          </p>
        </div>
        <div class="grid gap-4">
          {solutionLinks.map((service) => (
            <a href={service.href} class="group border border-white/15 bg-white/5 p-5 hover:bg-white/10">
              <span class="text-xs font-bold uppercase tracking-widest text-kharon-cyan">Explore</span>
              <h2 class="mt-3 text-xl font-bold">{service.label}</h2>
              <p class="mt-3 text-sm leading-6 text-white/70">{service.summary}</p>
              <span class="mt-5 inline-block text-sm font-bold text-white group-hover:text-kharon-cyan">View service -&gt;</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section-padding bg-white">
      <div class="mx-auto grid max-w-7xl gap-6 px-6 lg:grid-cols-3 lg:px-8">
        <article class="border border-kharon-border p-6">
          <p class="text-sm font-bold uppercase tracking-widest text-kharon-purple">Design</p>
          <h2 class="mt-3 text-2xl font-bold text-kharon-black">Risk-led system architecture</h2>
          <p class="mt-4 text-sm leading-6 text-kharon-grey">System scope is shaped around protected spaces, occupancy, assets, response logic, integration points and continuity consequence.</p>
        </article>
        <article class="border border-kharon-border p-6">
          <p class="text-sm font-bold uppercase tracking-widest text-kharon-purple">Maintain</p>
          <h2 class="mt-3 text-2xl font-bold text-kharon-black">Lifecycle service records</h2>
          <p class="mt-4 text-sm leading-6 text-kharon-grey">Inspection, servicing, defect escalation and certificate records are structured so site owners can prove operational control.</p>
        </article>
        <article class="border border-kharon-border p-6">
          <p class="text-sm font-bold uppercase tracking-widest text-kharon-purple">Operate</p>
          <h2 class="mt-3 text-2xl font-bold text-kharon-black">Portal-backed field work</h2>
          <p class="mt-4 text-sm leading-6 text-kharon-grey">Technician, client, finance and admin workspaces connect field activity to job status, documents, requests and audit trails.</p>
        </article>
      </div>
    </section>
  </main>
  
</BaseLayout>
