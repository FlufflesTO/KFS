---
/**
 * Solutions hub — grouped index of every service.
 * Structure: SolutionHero → one section per solutionGroup with a card grid → WhatHappensNext.
 * Cards are enriched from solutionLinks (summary, icon, SANS) by matching href.
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import SolutionHero from "../components/sections/SolutionHero.astro";
import WhatHappensNext from "../components/sections/WhatHappensNext.astro";
import { pageMeta, solutionGroups, solutionLinks } from "../data/site.js";

const linkByHref = new Map(solutionLinks.map((link) => [link.href, link]));
---

<BaseLayout title={pageMeta.services.title} description={pageMeta.services.description}>
  <SolutionHero
    subtitle="Solutions"
    title="Our Solutions"
    description="Fire protection, security and compliance systems — designed, installed and maintained to the relevant SANS standards for commercial and industrial sites."
    icon="/brand/icons/service-engineering.svg"
  />

  {solutionGroups.map((group) => (
    <section class="section-padding bg-kharon-black border-b border-kharon-purple/10">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-10 max-w-2xl">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-kharon-cyan">Solutions</p>
          <h2 class="kharon-h2 mt-3 text-white">{group.label}</h2>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {group.items.map((item) => {
            const detail = linkByHref.get(item.href);
            return (
              <a
                href={item.href}
                class="group flex flex-col rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/30 p-7 transition-all hover:border-kharon-purple/40 hover:bg-kharon-charcoal/50"
              >
                {detail?.icon && (
                  <div class="h-12 w-12 rounded-xl border border-kharon-purple/20 bg-kharon-black/40 p-3 transition-colors group-hover:bg-kharon-purple/10">
                    <img loading="lazy" decoding="async" src={detail.icon} alt="" class="h-full w-full object-contain" />
                  </div>
                )}
                <h3 class="mt-5 text-lg font-black text-white">{item.label}</h3>
                {detail?.summary && (
                  <p class="mt-3 flex-1 text-sm leading-relaxed text-kharon-light/70">{detail.summary}</p>
                )}
                {detail?.sans && detail.sans.length > 0 && (
                  <div class="mt-5 flex flex-wrap gap-2">
                    {detail.sans.map((std) => (
                      <span class="rounded border border-kharon-purple/20 bg-kharon-black px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide text-kharon-cyan">
                        {std}
                      </span>
                    ))}
                  </div>
                )}
                <span class="mt-6 inline-flex items-center gap-2 text-xs font-black uppercase tracking-widest text-kharon-cyan transition-colors group-hover:text-white">
                  View
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
                </span>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  ))}

  <WhatHappensNext intent="site-assessment" />
</BaseLayout>
