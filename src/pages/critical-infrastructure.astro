---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import SplitFeature from "../components/sections/SplitFeature.astro";
import ProofGrid from "../components/sections/ProofGrid.astro";
import ContextualInquiry from "../components/sections/ContextualInquiry.astro";
import EngineeringSystems from "../components/sections/EngineeringSystems.astro";
import { pageMeta } from "../data/site.js";
---

<BaseLayout title={pageMeta.criticalInfrastructure.title} description={pageMeta.criticalInfrastructure.description}>
  <Hero 
    title="Critical Infrastructure" 
    subtitle="Engineered safety protocols for data centers, telecommunications, and essential services."
    systemType="suppression"
  />

  <EngineeringSystems />

  <SplitFeature 
    title="Zero Downtime Objective"
    description="In critical environments, fire protection is about more than just safety—it's about continuity. Our gaseous suppression systems are designed to extinguish fires without damaging sensitive electronics or requiring clean-up."
    reversed={false}
  />

  <ProofGrid 
    title="Infrastructure Resilience"
    items={[
      { title: "Non-Conductive", description: "Clean agents that won't short-circuit your critical server racks." },
      { title: "Rapid Discharge", description: "Reach design concentration in seconds to suppress fire at its inception." },
      { title: "Oxygen Safe", description: "Breathable atmospheres for occupied spaces during discharge." },
      { title: "Environmentally Conscious", description: "Zero ozone depletion potential and low global warming impact." }
    ]}
  />

  <ContextualInquiry 
    title="Protect Your Infrastructure"
    requestType="Critical Infrastructure"
  />

  
</BaseLayout>
