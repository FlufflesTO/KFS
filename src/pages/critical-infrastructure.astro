---
/**
 * Project Sentinel - Critical Infrastructure Page
 * Purpose: Public page presenting critical infrastructure protection (data centres, control rooms) and technical blocks.
 * Dependencies: BaseLayout.astro, SectionHeading.astro, InfrastructureTechnicalBlocks.astro, site data
 * Structural Role: Main informational page for critical infrastructure protection services.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import InfrastructureTechnicalBlocks from "../components/sections/InfrastructureTechnicalBlocks.astro";
import { pageMeta } from "../data/site.js";
---

<BaseLayout title={pageMeta.criticalInfrastructure.title} description={pageMeta.criticalInfrastructure.description}>
  <section class="hero-padding bg-gradient-to-b from-kharon-black to-kharon-charcoal kharon-environment kharon-logo-watermark">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 kharon-h1">
        Critical Infrastructure Protection
      </h1>
      <p class="text-xl text-kharon-light/80 max-w-2xl mx-auto leading-relaxed">
        Infrastructure protection for data centres, control rooms, electrical rooms and high-consequence operational sites.
      </p>
    </div>
  </section>

  <section class="section-padding bg-gradient-to-b from-kharon-charcoal to-kharon-black">
    <div class="mx-auto max-w-4xl px-6">
      <SectionHeading
        title="Mission-Critical Systems"
        subtitle="Infrastructure Authority"
        description="Engineered solutions for environments where system failure has high consequences."
        center={true}
      />
      
      <div class="mt-12 prose prose-invert max-w-none">
        <p class="text-kharon-light/80 text-lg leading-relaxed">
          Critical infrastructure environments demand the highest levels of protection and reliability. Our solutions are engineered specifically for environments where system failure could have significant operational, financial, or safety consequences.
        </p>
        
        <div class="mt-8 grid gap-6 md:grid-cols-2">
          <div class="rounded-lg border border-kharon-purple/15 bg-kharon-surface-elevated p-6 backdrop-blur-sm kharon-surface">
            <h3 class="text-lg font-semibold text-white mb-3">Data Centres</h3>
            <p class="text-kharon-light/70">
              Clean-agent suppression systems designed for server rooms and technical spaces where water-based systems would cause catastrophic damage.
            </p>
          </div>
          
          <div class="rounded-lg border border-kharon-purple/15 bg-kharon-surface-elevated p-6 backdrop-blur-sm kharon-surface">
            <h3 class="text-lg font-semibold text-white mb-3">Control Rooms</h3>
            <p class="text-kharon-light/70">
              Fire detection and suppression architecture for spaces coordinating wider site response with continuity-sensitive operations.
            </p>
          </div>
          
          <div class="rounded-lg border border-kharon-purple/15 bg-kharon-surface-elevated p-6 backdrop-blur-sm kharon-surface">
            <h3 class="text-lg font-semibold text-white mb-3">Electrical Rooms</h3>
            <p class="text-kharon-light/70">
              Rapid detection and asset protection with suppression methods that limit collateral damage to critical electrical infrastructure.
            </p>
          </div>
          
          <div class="rounded-lg border border-kharon-purple/15 bg-kharon-surface-elevated p-6 backdrop-blur-sm kharon-surface">
            <h3 class="text-lg font-semibold text-white mb-3">High-Consequence Sites</h3>
            <p class="text-kharon-light/70">
              Risk-segmented zones with rugged detection choices and maintenance access planning for critical operational environments.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical uptime model, escalation path and risk-tier matrix component -->
  <InfrastructureTechnicalBlocks />

  <section class="section-padding bg-gradient-to-b from-kharon-black to-kharon-charcoal">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <SectionHeading
        title="Continuity-Sensitive Protection"
        subtitle="Reliability Framework"
        description="Systems engineered to maintain operational continuity in high-consequence environments."
        center={true}
      />
      
      <div class="mt-12 prose prose-invert max-w-none">
        <p class="text-kharon-light/80 text-lg leading-relaxed">
          In critical infrastructure environments, protection systems must not only prevent fires but also maintain operational continuity. Our solutions are designed to minimize disruption while maximizing protection in environments where downtime has severe consequences.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
