---
/**
 * Project Sentinel - Critical Infrastructure Page
 * Purpose: Public profile detailing mission-critical fire and safety infrastructure capabilities
 * Dependencies: BaseLayout, SolutionHero, InfrastructureTechnicalBlocks, SectionHeading, pageMeta
 * Structural Role: Specialized solution detailing critical infrastructure protection
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import SolutionHero from "../components/sections/SolutionHero.astro";
import InfrastructureTechnicalBlocks from "../components/sections/InfrastructureTechnicalBlocks.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import { pageMeta } from "../data/site.js";

const infrastructureCategories = [
  {
    title: "Data Centres",
    text: "Clean-agent suppression systems designed for technical spaces where residue or water would cause catastrophic damage.",
    icon: "/brand/icons/sector-server-rack.svg"
  },
  {
    title: "Control Rooms",
    text: "Detection and suppression architecture for spaces coordinating wider site response with continuity-sensitive operations.",
    icon: "/brand/icons/sector-control-room.svg"
  },
  {
    title: "Electrical Rooms",
    text: "Rapid detection and asset protection that limits collateral damage to critical HV/LV electrical infrastructure.",
    icon: "/brand/icons/sector-switchgear.svg"
  },
  {
    title: "High-Consequence Sites",
    text: "Risk-segmented zones with rugged detection and maintenance planning for critical operational environments.",
    icon: "/brand/icons/sector-factory.svg"
  }
];
---

<BaseLayout title={pageMeta.criticalInfrastructure.title} description={pageMeta.criticalInfrastructure.description}>
  <SolutionHero 
    title="Critical Infrastructure" 
    subtitle="Infrastructure Authority" 
    description="Engineered fire protection for high-consequence environments where downtime is unacceptable and assets are mission-critical."
    icon="/brand/icons/sector-server-rack.svg"
  />

  <section class="section-padding bg-kharon-black">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid gap-8 md:grid-cols-2">
        {infrastructureCategories.map((item) => (
          <div class="group relative rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/30 p-8 transition-all hover:border-kharon-purple/40 hover:bg-kharon-charcoal/50">
            <div class="flex items-center gap-6 mb-6">
              <div class="h-14 w-14 flex-none rounded-xl bg-kharon-black/40 border border-kharon-purple/20 p-3 group-hover:bg-kharon-purple/10 transition-colors">
                <img loading="lazy" decoding="async" src={item.icon} alt="" class="h-full w-full object-contain" />
              </div>
              <h3 class="text-xl font-bold text-white tracking-tight leading-tight">{item.title}</h3>
            </div>
            <p class="text-kharon-light/60 leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <InfrastructureTechnicalBlocks />

  <section class="section-padding bg-kharon-black border-t border-kharon-purple/10">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <SectionHeading
        title="Zero-Tolerance for Failure"
        subtitle="Operational Continuity"
        description="Our infrastructure solutions are built for reliability, ensuring that protection systems never become the source of downtime."
        center={true}
      />
      <div class="mt-10 flex justify-center gap-4">
        <a href="/contact?intent=site-assessment" class="kharon-command-button px-10 py-5 text-sm">
          Request Infrastructure Audit
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
