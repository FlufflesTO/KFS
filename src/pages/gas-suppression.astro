---
/**
 * Project Kharon - Gas Suppression Page
 * Purpose: Renders the Gas Suppression service details page with detailed technical blocks.
 * Dependencies: ServicePage layout, SuppressionTechnicalBlocks component, services data.
 * Structural Role: Solution details route.
 */

import ServicePage from "../layouts/ServicePage.astro";
import SuppressionTechnicalBlocks from "../components/sections/SuppressionTechnicalBlocks.astro";
import { services } from "../data/services.js";
const s = services["gas-suppression"];
---
<ServicePage
  meta={s.meta}
  hero={s.hero}
  overview={s.overview}
  problem={s.problem}
  capabilities={s.capabilities}
  standards={s.standards}
  intent={s.intent}
  faqs={s.faqs}
  caseStudySlug={s.caseStudySlug}
  disclaimerVariant={s.disclaimerVariant}
>
  <SuppressionTechnicalBlocks />
</ServicePage>
