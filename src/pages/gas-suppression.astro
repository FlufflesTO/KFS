---
import BaseLayout from "../layouts/BaseLayout.astro";
import SolutionHero from "../components/sections/SolutionHero.astro";
import ComplianceStrip from "../components/sections/ComplianceStrip.astro";
import SuppressionTechnicalBlocks from "../components/sections/SuppressionTechnicalBlocks.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import { pageMeta } from "../data/site.js";

/**
 * Project Sentinel - Gas Suppression Specialized View
 * Purpose: Provides a deep dive into clean-agent suppression systems.
 */
---

<BaseLayout title={pageMeta.gasSuppression.title} description={pageMeta.gasSuppression.description}>
  <SolutionHero 
    title="Gas Suppression" 
    subtitle="Engineered Protection" 
    description="Mission-critical protection using clean agents (FM-200, Novec 1230) for high-value technical assets and sensitive electronics."
    icon="/brand/icons/service-fire-suppression.svg"
  />

  <ComplianceStrip />

  <section class="section-padding bg-kharon-black">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeading
        title="Command & Control"
        subtitle="Specialist Systems"
        description="We design and maintain engineered suppression systems that provide rapid response without residue, ensuring business continuity."
        center={true}
      />
      
      <div class="mt-16 grid gap-8 md:grid-cols-2">
        <div class="group relative rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/30 p-8 transition-all hover:border-kharon-purple/40 hover:bg-kharon-charcoal/50">
          <h3 class="text-xl font-bold text-white mb-4">Total Flooding Systems</h3>
          <p class="text-kharon-light/60 leading-relaxed">
            Engineered volume-protection for server rooms, control centres and archives. These systems reach design concentration within 10 seconds to suppress fire at the molecular level.
          </p>
        </div>
        <div class="group relative rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/30 p-8 transition-all hover:border-kharon-purple/40 hover:bg-kharon-charcoal/50">
          <h3 class="text-xl font-bold text-white mb-4">In-Cabinet Protection</h3>
          <p class="text-kharon-light/60 leading-relaxed">
            Localised protection for high-value electrical switchgear and server racks. Detects and suppresses fires within the cabinet before they escalate to the wider environment.
          </p>
        </div>
      </div>
    </div>
  </section>

  <SuppressionTechnicalBlocks />

  <section class="section-padding bg-kharon-black border-t border-kharon-purple/10">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <SectionHeading
        title="Protect your mission-critical assets."
        subtitle="Consultation"
        description="Get an engineered assessment of your site's suppression requirements and SANS 14520 compliance status."
        center={true}
      />
      <div class="mt-10 flex justify-center gap-4">
        <a href="/contact?intent=site-assessment" class="kharon-command-button px-10 py-5 text-sm">
          Request Site Audit
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
