---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import SuppressionAuthority from "../components/sections/SuppressionAuthority.astro";
import { pageMeta } from "../data/site.js";

const suppressionCapabilities = [
  {
    title: "Clean-agent precision",
    items: [
      "FM-200 systems for server rooms and electrical equipment spaces",
      "Inergen and ProInert systems for occupied and sensitive environments",
      "Novec 1230 systems for environmentally sensitive applications",
      "Argonite and Stat-X systems for specific risk profiles",
      "Fireeater and Rotarax specialist suppression agents",
      "CO2 systems for industrial applications with appropriate safety measures"
    ]
  },
  {
    title: "Mission-critical protection",
    items: [
      "Zero-damage suppression for sensitive electronic equipment",
      "Rapid discharge systems for immediate fire suppression",
      "Pressure relief calculations for enclosed spaces",
      "Room integrity testing to verify enclosure performance",
      "Kitchen suppression systems for commercial catering environments",
      "Generator suppression systems for critical power infrastructure"
    ]
  },
  {
    title: "Engineered release logic",
    items: [
      "Pre-discharge warnings with configurable timing",
      "Automatic release upon confirmed detection",
      "Manual release stations with appropriate safety protocols",
      "Cylinder recertification and refill services",
      "Suppression system test and servicing schedules"
    ]
  }
];
---

<BaseLayout title={pageMeta.gasSuppression.title} description={pageMeta.gasSuppression.description}>
  <section class="hero-padding bg-gradient-to-b from-kharon-black to-kharon-charcoal kharon-environment kharon-logo-watermark">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 kharon-h1">
        Gas Suppression Systems
      </h1>
      <p class="text-xl text-kharon-light/80 max-w-2xl mx-auto leading-relaxed">
        Clean-agent and engineered suppression systems for server rooms, electrical rooms and sensitive operational assets.
      </p>
    </div>
  </section>

  <SuppressionAuthority capabilities={suppressionCapabilities} />
  
  <section class="section-padding bg-gradient-to-b from-kharon-charcoal to-kharon-black">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <SectionHeading
        title="Clean-Agent Mission-Critical Precision"
        subtitle="Precision Suppression"
        description="Engineered gas suppression systems that protect critical assets without causing additional damage."
        center={true}
      />
      
      <div class="mt-12 prose prose-invert max-w-none">
        <p class="text-kharon-light/80 text-lg leading-relaxed">
          Our gas suppression systems are engineered specifically for environments where traditional water-based systems would cause catastrophic damage. Clean-agent systems provide rapid fire suppression without residue, allowing for immediate resumption of operations after incident resolution.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
