---
import BaseLayout from "../layouts/BaseLayout.astro";
import SolutionHero from "../components/sections/SolutionHero.astro";
import RouteMatrix from "../components/sections/RouteMatrix.astro";
import AuthorityEvidence from "../components/sections/AuthorityEvidence.astro";
import ComplianceStrip from "../components/sections/ComplianceStrip.astro";
import ServiceIcons from "../components/sections/ServiceIcons.astro";
import Testimonials from "../components/trust/Testimonials.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import { pageMeta } from "../data/site.js";

/**
 * Project Sentinel - Gas Suppression Specialized View
 * Purpose: Provides a deep dive into clean-agent suppression systems.
 */
---

<BaseLayout title={pageMeta.gasSuppression.title} description={pageMeta.gasSuppression.description}>
  <SolutionHero 
    title="Gas Suppression" 
    subtitle="Engineered Protection" 
    description="Mission-critical protection using clean agents (FM-200, Novec 1230) for high-value technical assets and sensitive electronics."
    icon="/brand/icons/service-fire-suppression.svg"
  />

  <ComplianceStrip />

  <section class="section-padding bg-kharon-black">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeading
        title="Technical Capability Matrix"
        subtitle="Specialist Systems"
        description="We design and maintain engineered suppression systems that provide rapid response without residue."
        center={true}
      />
      <ServiceIcons />
    </div>
  </section>

  <RouteMatrix />
  <AuthorityEvidence />
  <Testimonials />

  <section class="section-padding bg-kharon-black border-t border-kharon-purple/10">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <SectionHeading
        title="Ready to protect your server room?"
        subtitle="Consultation"
        description="Get an engineered assessment of your site's suppression requirements and compliance status."
        center={true}
      />
      <div class="mt-10 flex justify-center gap-4">
        <a href="/contact?intent=site-assessment" class="kharon-command-button px-10 py-5 text-sm">
          Request Site Audit
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
