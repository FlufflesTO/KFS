---
/**
 * Project Sentinel - About Page
 * Purpose: Public profile detailing company authority, regulatory competence, and standards alignment
 * Dependencies: BaseLayout, SectionHeading, SolutionHero, site data
 * Structural Role: Information page for the company
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import SolutionHero from "../components/sections/SolutionHero.astro";
import { pageMeta } from "../data/site.js";

const capabilityProof = [
  {
    title: "SAQCC competency signals",
    text: "Registered with SAQCC Fire and SAQCC Gas, enabling authorized design, installation, commissioning and maintenance across fire alarm and suppression workstreams.",
    icon: "/brand/icons/severity-urgent.svg"
  },
  {
    title: "Registered fire-system work",
    text: "Certified to design, install, commission and maintain fire alarm and evacuation systems, suppression systems, and specialist detection platforms.",
    icon: "/brand/icons/service-fire-detection.svg"
  },
  {
    title: "Standards-led delivery",
    text: "All works carried out to SANS 10139, SANS 10400, SANS 14520, and SANS 322 as applicable. Full documentation for regulatory handover.",
    icon: "/brand/icons/service-engineering.svg"
  }
];

const serviceCategories = [
  {
    title: "Fire Alarm & Evacuation",
    items: [
      "Fire detection and evacuation system design and installation",
      "Fire detection system maintenance and repairs",
      "Fire alarm system compliance, documentation and training",
      "Specialist systems — aspiration detection, flame detection, linear detection",
      "Evacuation system testing (PA and system based)"
    ]
  },
  {
    title: "Fire Suppression",
    items: [
      "Design depending on suppression agent (Inergen, ProInert, FM200, Argonite, Fireeater, Stat-X, Rotarax)",
      "Suppression system installation, maintenance and repairs",
      "Cylinder recertification and refill",
      "Room integrity testing",
      "Kitchen and generator suppression systems"
    ]
  },
  {
    title: "Access Control",
    items: [
      "Design, supply and installation based on Lenel, Impro, Paxton, Idemia, Gallagher platforms",
      "Integration to existing suite systems for local authority compliance",
      "Software health — upgrades, relicensing, tokens",
      "Preventative service and maintenance",
      "Break-fix services"
    ]
  },
  {
    title: "CCTV Systems",
    items: [
      "Design, supply and installation based on Milestone, Bosch, Lenel, Truvision platforms",
      "Software health — upgrades, relicensing, tokens",
      "Preventative service and maintenance",
      "Break-fix services"
    ]
  },
  {
    title: "Security & Locking Systems",
    items: [
      "Design, supply and installation based on Paradox, Centurion, IDS platforms",
      "Electronic locking — SEP, CISA, Stanley, Assa Abloy",
      "Supply and installation of panic escape hardware",
      "Custom manufacturing of strike plates and lock brackets",
      "Service and maintenance of Assa Abloy EL lock series"
    ]
  }
];

const standardsWorkedTo = [
  {
    code: "SANS 10139",
    title: "Fire Detection Systems",
    text: "Design, installation, commissioning and maintenance of fire detection systems."
  },
  {
    code: "SANS 14520",
    title: "Gas Suppression Systems",
    text: "Selection, design, installation and maintenance of gaseous fire suppression systems."
  },
  {
    code: "SANS 10222",
    title: "CCTV Surveillance",
    text: "Planning, design, installation and maintenance of CCTV surveillance systems."
  },
  {
    code: "SANS 10400-T",
    title: "Fire Protection (Buildings)",
    text: "Fire protection requirements for buildings including detection and suppression."
  }
];
---

<BaseLayout title={pageMeta.about.title} description={pageMeta.about.description}>

  <SolutionHero
    title="About Kharon"
    subtitle="Company Ethos"
    description="Established in 2016 with the vision to provide installation and maintenance of electronic safety and security systems to relevant industry standards."
    icon="/brand/icons/service-engineering.svg"
  />

  <section class="py-16 lg:py-24 bg-kharon-black">
    <div class="mx-auto max-w-4xl px-6">
      <SectionHeading
        title="Engineered Fire Protection"
        subtitle="Technical Authority"
        description="Specialized in commercial and industrial fire protection systems with engineered solutions."
        center={true}
      />
      <div class="mt-10 space-y-6 text-kharon-light/70 text-lg leading-relaxed">
        <p>
          <strong class="text-white">Kharon Fire and Security Solutions</strong> was established in 2016 to deliver engineered fire protection and security systems to South African national standards. Based in Cape Town, we provide mission-critical support to commercial and industrial sites across Southern Africa.
        </p>
        <ul class="space-y-3 pt-2">
          {[
            "Design, installation, commissioning and maintenance of fire detection and suppression systems",
            "SAQCC-registered technicians for authorized fire and gas suppression work",
            "3rd-party support for national and international service providers",
            "Structured compliance frameworks with inspection-ready documentation",
            "Lifecycle maintenance with service records and documentation outputs"
          ].map((item) => (
            <li class="flex gap-3">
              <span class="text-kharon-cyan font-black flex-none">›</span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="pb-16 lg:pb-24 bg-kharon-black">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid gap-8 md:grid-cols-2">
        <div class="rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/30 p-8 sm:p-12 relative overflow-hidden group hover:border-kharon-purple/40 transition-all">
          <div class="absolute top-0 left-0 h-1 w-full bg-gradient-to-r from-kharon-purple to-transparent opacity-50"></div>
          <h3 class="text-sm font-black uppercase tracking-[0.2em] text-kharon-purple mb-4">Our Mission</h3>
          <p class="text-kharon-light/60 leading-relaxed text-lg font-medium">
            Create a synergy between human and automated safety and security systems. We provide an environmentally sustainable and safe approach to our business operations, ensuring our work leaves a positive footprint.
          </p>
        </div>
        <div class="rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/30 p-8 sm:p-12 relative overflow-hidden group hover:border-kharon-cyan/40 transition-all">
          <div class="absolute top-0 left-0 h-1 w-full bg-gradient-to-r from-kharon-cyan to-transparent opacity-50"></div>
          <h3 class="text-sm font-black uppercase tracking-[0.2em] text-kharon-cyan mb-4">Our Dedication</h3>
          <p class="text-kharon-light/60 leading-relaxed text-lg font-medium">
            We are dedicated to our clients' satisfaction and our team's welfare. Profit is seen as a welcome by-product of sustainable practices and successful system implementation within the company.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24 bg-kharon-charcoal border-y border-kharon-purple/10">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeading
        title="Capability Proof Points"
        subtitle="Verification Matrix"
        description="Demonstrated competencies and registered capabilities that establish our technical authority."
        center={true}
      />
      <div class="mt-12 grid gap-8 md:grid-cols-3">
        {capabilityProof.map((item) => (
          <div class="group relative rounded-2xl border border-kharon-purple/20 bg-kharon-black/40 p-8 transition-all hover:border-kharon-purple/40 hover:bg-kharon-black/60 shadow-lg">
            <div class="h-14 w-14 mb-6 rounded-xl bg-kharon-charcoal border border-kharon-purple/20 p-3 group-hover:bg-kharon-purple/10 transition-colors">
              <img src={item.icon} loading="lazy" decoding="async" class="w-full h-full object-contain" alt="" aria-hidden="true" />
            </div>
            <h3 class="text-sm font-black uppercase tracking-widest text-white mb-3">{item.title}</h3>
            <p class="text-kharon-light/60 text-sm leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24 bg-kharon-black border-b border-kharon-purple/10">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeading
        title="Standards We Work To"
        subtitle="Regulatory Baseline"
        description="Every installation and maintenance engagement is governed by the relevant South African National Standard."
        center={true}
      />
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {standardsWorkedTo.map((std) => (
          <div class="rounded-xl border border-kharon-purple/20 bg-kharon-charcoal/40 p-6 hover:border-kharon-purple/40 transition-all">
            <p class="text-base font-black text-kharon-cyan tracking-tight mb-1">{std.code}</p>
            <h3 class="text-xs font-black text-white uppercase tracking-widest mb-3">{std.title}</h3>
            <p class="text-xs text-kharon-light/60 leading-relaxed">{std.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24 bg-kharon-black">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeading
        title="Service Disciplines"
        subtitle="Operational Scope"
        description="Full lifecycle capability across fire protection, suppression and security system disciplines."
        center={true}
      />
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {serviceCategories.map((cat) => (
          <div class="rounded-xl border border-kharon-purple/10 bg-kharon-charcoal/40 p-8 hover:border-kharon-purple/30 transition-all">
            <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple mb-6 border-b border-kharon-purple/10 pb-4">{cat.title}</h3>
            <ul class="space-y-4">
              {cat.items.map((item) => (
                <li class="flex gap-3 text-sm text-kharon-light/70 leading-relaxed font-medium">
                  <span class="text-kharon-cyan font-black">›</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24 bg-kharon-black border-t border-kharon-purple/10">
    <div class="mx-auto max-w-5xl px-6">
      <SectionHeading
        title="Compliance & Accreditation"
        subtitle="Operational Integrity"
        description="Our work is strictly governed by South African national standards and recognized industry bodies."
        center={true}
      />
      <div class="mt-12 grid gap-8 md:grid-cols-3">
        {[
          { code: "SAQCC", title: "SAQCC Fire & Gas", text: "All technicians registered and certified for authorized fire and gas suppression work across all disciplines." },
          { code: "SABS", title: "SANS Compliant", text: "Installations to SANS 10139, SANS 10400, SANS 14520, and SANS 322 national standards as applicable." },
          { code: "BEE", title: "B-BBEE Level 4", text: "Committed to South African economic empowerment. Level 4 Contributor, supporting enterprise procurement requirements." }
        ].map(item => (
          <div class="rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/30 p-8 flex flex-col items-center text-center hover:border-kharon-purple/40 transition-all">
            <div class="h-16 w-16 mb-6 flex items-center justify-center rounded-full bg-kharon-purple/10 border border-kharon-purple/20">
              <span class="text-kharon-cyan font-black text-xs uppercase tracking-tighter">{item.code}</span>
            </div>
            <h3 class="text-base font-black text-white mb-2 uppercase tracking-widest">{item.title}</h3>
            <p class="text-kharon-light/50 text-sm leading-relaxed font-medium">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
