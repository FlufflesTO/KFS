---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import { pageMeta } from "../data/site.js";

const capabilityProof = [
  {
    title: "SAQCC competency signals",
    text: "Registered with SAQCC Fire and SAQCC Gas, enabling authorized design, installation, commissioning and maintenance across fire alarm and suppression workstreams.",
    icon: "/brand/icons/severity-planned.svg"
  },
  {
    title: "Registered fire-system work",
    text: "Certified to design, install, commission and maintain fire alarm and evacuation systems, suppression systems, and specialist detection platforms.",
    icon: "/brand/icons/service-fire-detection.svg"
  },
  {
    title: "Standards-led delivery",
    text: "All works carried out to SANS 10139, SANS 10400, SANS 14520, and SANS 322 as applicable. Full documentation for regulatory handover.",
    icon: "/brand/icons/service-engineering.svg"
  }
];

const serviceCategories = [
  {
    title: "Fire Alarm & Evacuation",
    items: [
      "Fire detection and evacuation system design and installation",
      "Fire detection system maintenance and repairs",
      "Fire alarm system compliance, documentation and training",
      "Specialist systems — aspiration detection, flame detection, linear detection",
      "Evacuation system testing (PA and system based)"
    ]
  },
  {
    title: "Fire Suppression",
    items: [
      "Design depending on suppression agent (Inergen, ProInert, FM200, Argonite, Fireeater, Stat-X, Rotarax)",
      "Suppression system installation, maintenance and repairs",
      "Cylinder recertification and refill",
      "Room integrity testing",
      "Kitchen and generator suppression systems"
    ]
  },
  {
    title: "Access Control",
    items: [
      "Design, supply and installation based on Lenel, Impro, Paxton, Idemia, Gallagher platforms",
      "Integration to existing suite systems for local authority compliance",
      "Software health — upgrades, relicensing, tokens",
      "Preventative service and maintenance",
      "Break-fix services"
    ]
  },
  {
    title: "CCTV Systems",
    items: [
      "Design, supply and installation based on Milestone, Bosch, Lenel, Truvision platforms",
      "Software health — upgrades, relicensing, tokens",
      "Preventative service and maintenance",
      "Break-fix services"
    ]
  },
  {
    title: "Security & Locking Systems",
    items: [
      "Design, supply and installation based on Paradox, Centurion, IDS platforms",
      "Electronic locking — SEP, CISA, Stanley, Assa Abloy",
      "Supply and installation of panic escape hardware",
      "Custom manufacturing of strike plates and lock brackets",
      "Service and maintenance of Assa Abloy EL lock series"
    ]
  }
];
---

<BaseLayout title={pageMeta.about.title} description={pageMeta.about.description}>

  <!-- Hero -->
  <section class="hero-padding bg-gradient-to-b from-kharon-black to-kharon-charcoal kharon-environment kharon-logo-watermark">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 kharon-h1">About Kharon</h1>
      <p class="text-xl text-kharon-light/80 max-w-2xl mx-auto leading-relaxed">
        Established in 2016 with the vision to provide installation and maintenance of electronic safety and security systems to relevant industry standards.
      </p>
    </div>
  </section>

  <!-- Company overview -->
  <section class="section-padding bg-gradient-to-b from-kharon-charcoal to-kharon-black">
    <div class="mx-auto max-w-4xl px-6">
      <SectionHeading
        title="Engineered Fire Protection"
        subtitle="Technical Authority"
        description="Specialized in commercial and industrial fire protection systems with engineered solutions."
        center={true}
      />
      <div class="mt-10 space-y-5 text-kharon-light/80 text-base leading-relaxed">
        <p>
          <strong class="text-white">Kharon Fire and Security Solutions</strong> was established in 2016 with the vision to provide installation and maintenance of electronic safety and security systems to relevant industry standards. We are located in Cape Town, South Africa and provide services to clients as far reaching as Botswana and Malawi.
        </p>
        <p>
          Kharon designs, builds and maintains electronic safety, surveillance and security systems to the client's requirements, based on the relevant industry regulation and installation standards. Our service department and small works division also provides 3rd party support for national and international service providers.
        </p>
        <p>
          Our compliance and maintenance services ensure that your fire protection systems remain accountable, with inspection schedules, service records, and documentation outputs that serve as operational evidence.
        </p>
      </div>
    </div>
  </section>

  <!-- Mission / Aim / Dedication -->
  <section class="section-padding bg-gradient-to-b from-kharon-black to-kharon-charcoal">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeading
        title="Our Mission"
        subtitle="Operational Purpose"
        description="Create a synergy between human and automated safety and security systems."
        center={true}
      />
      <div class="mt-12 grid gap-6 md:grid-cols-2">
        <div class="rounded-lg border border-kharon-purple/20 bg-kharon-graphite p-7">
          <h3 class="text-sm font-bold uppercase tracking-widest text-kharon-purple mb-3">Our Aim</h3>
          <p class="text-kharon-light/80 leading-relaxed">
            Provide an environmentally sustainable and safe approach to our business operations. Our teams are encouraged to participate in these activities wherever possible, ensuring our work leaves a positive environmental footprint.
          </p>
        </div>
        <div class="rounded-lg border border-kharon-purple/20 bg-kharon-graphite p-7">
          <h3 class="text-sm font-bold uppercase tracking-widest text-kharon-purple mb-3">Our Dedication</h3>
          <p class="text-kharon-light/80 leading-relaxed">
            We are dedicated to our clients' satisfaction and our team's welfare. Profit is seen as a welcome by-product of sustainable practices and successful system implementation within the company.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Capability proof points -->
  <section class="section-padding bg-gradient-to-b from-kharon-charcoal to-kharon-black">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeading
        title="Capability Proof Points"
        subtitle="Verification Matrix"
        description="Demonstrated competencies and registered capabilities that establish our technical authority."
        center={true}
      />
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {capabilityProof.map((item) => (
          <div class="rounded-lg border border-kharon-purple/15 bg-kharon-surface-elevated p-6 backdrop-blur-sm kharon-surface flex flex-col justify-between">
            <div>
              {item.icon && (
                <div class="w-12 h-12 rounded-lg bg-kharon-purple/10 flex items-center justify-center mb-4 overflow-hidden">
                  <img src={item.icon} class="w-full h-full object-contain" alt="" aria-hidden="true" />
                </div>
              )}
              <h3 class="text-sm font-bold uppercase tracking-widest text-kharon-purple mb-3">{item.title}</h3>
              <p class="text-kharon-light/70 text-sm leading-relaxed">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services overview -->
  <section class="section-padding bg-gradient-to-b from-kharon-black to-kharon-charcoal">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeading
        title="Service Disciplines"
        subtitle="Operational Scope"
        description="Full lifecycle capability across fire protection, suppression and security system disciplines."
        center={true}
      />
      <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {serviceCategories.map((cat) => (
          <div class="rounded-lg border border-kharon-purple/20 bg-kharon-graphite p-6">
            <h3 class="text-sm font-bold uppercase tracking-widest text-kharon-purple mb-4">{cat.title}</h3>
            <ul class="space-y-2">
              {cat.items.map((item) => (
                <li class="flex gap-2 text-sm text-kharon-light/70 leading-snug">
                  <span class="text-kharon-purple mt-0.5 flex-none">›</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Accreditation -->
  <section class="section-padding bg-gradient-to-b from-kharon-charcoal to-kharon-black">
    <div class="mx-auto max-w-4xl px-6">
      <SectionHeading
        title="Compliance & Accreditation"
        subtitle="Operational Integrity"
        description="Our work is strictly governed by South African national standards and recognized industry bodies."
        center={true}
      />
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {[
          { code: "SAQCC", title: "SAQCC Fire & Gas", text: "All technicians registered and certified for authorized fire and gas suppression work across all disciplines." },
          { code: "SABS", title: "SANS Compliant", text: "Installations to SANS 10139, SANS 10400, SANS 14520, and SANS 322 national standards as applicable." },
          { code: "BEE", title: "B-BBEE Level 4", text: "Committed to South African economic empowerment. Level 4 Contributor, supporting enterprise procurement requirements." }
        ].map(item => (
          <div class="rounded-lg border border-kharon-purple/30 bg-kharon-black p-6 flex flex-col items-center text-center">
            <div class="h-14 w-14 mb-4 flex items-center justify-center rounded-full bg-kharon-purple/10 border border-kharon-purple/20">
              <span class="text-kharon-purple font-bold text-sm">{item.code}</span>
            </div>
            <h3 class="text-base font-semibold text-white mb-2">{item.title}</h3>
            <p class="text-kharon-light/60 text-sm leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
