---
import GuidePage from "../../layouts/GuidePage.astro";
import { getFaqs } from "../../data/faqs.js";

const faqs = getFaqs();
---
<GuidePage
  meta={{
    title: "Fire & Security FAQs | Kharon",
    description:
      "Answers to common questions about commercial fire detection, gas suppression, fire doors, CCTV and compliance — covering responsibilities, SANS standards, maintenance cadence, system choice and documentation."
  }}
  hero={{
    subtitle: "Resources",
    title: "Frequently Asked Questions",
    description:
      "Straight answers to the questions facilities managers, building owners and consultants ask before specifying or maintaining fire and security systems.",
    icon: "/brand/icons/service-engineering.svg"
  }}
  intro="These are the questions we are asked most often by responsible persons, building owners, consultants and contractors. They cover compliance and responsibilities, maintenance, and how the main systems are chosen. If your question is not here, speak to an engineer — we will give you a direct, technical answer."
  sections={[]}
  faqs={faqs}
  related={[
    { label: "SANS Compliance", href: "/compliance" },
    { label: "Maintenance Checklists", href: "/resources/maintenance-checklists" },
    { label: "Fire Detection Guides", href: "/resources/fire-detection-guides" },
    { label: "Gas Suppression Guides", href: "/resources/gas-suppression-guides" },
    { label: "CCTV & Security Guides", href: "/resources/cctv-security-guides" }
  ]}
  intent="general"
/>
