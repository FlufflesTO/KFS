---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SolutionHero from "../../components/sections/SolutionHero.astro";
import WhatHappensNext from "../../components/sections/WhatHappensNext.astro";
import { resourceLinks } from "../../data/site.js";

const summaries: Record<string, string> = {
  "/compliance":
    "Practical reference on SANS 10139 and SANS 14520 maintenance, service-report structure and defect classification.",
  "/resources/maintenance-checklists":
    "Inspection and servicing checklists for fire detection, gas suppression, emergency lighting and fire doors, by cadence.",
  "/resources/fire-detection-guides":
    "Addressable vs conventional, detector selection, zoning and cause-and-effect under SANS 10139.",
  "/resources/gas-suppression-guides":
    "Agent selection, design concentration, room integrity and release logic under SANS 14520.",
  "/resources/fire-door-guides":
    "Ratings, the certified assembly, common inspection failures and remedial work under SANS 1253.",
  "/resources/cctv-security-guides":
    "Coverage planning, footage retention, intrusion grading and access control under SANS 62676, 50131 and 60839.",
  "/resources/faqs":
    "Straight answers on responsibilities, maintenance cadence, system choice and documentation.",
  "/resources/case-studies":
    "Representative engagements showing problem, system, intervention, documentation and outcome."
};
---

<BaseLayout
  title="Resources & Guides | Kharon"
  description="Buyer-focused guides, maintenance checklists, FAQs and case studies for commercial and industrial fire detection, gas suppression, fire doors, CCTV and compliance — grounded in the relevant SANS standards."
>
  <SolutionHero
    subtitle="Resources"
    title="Resources & Guides"
    description="Technical, buyer-focused guidance on fire and security systems — what the standards require, how systems are chosen, and how compliance is maintained."
    icon="/brand/icons/service-engineering.svg"
  />

  <section class="section-padding bg-kharon-black">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {resourceLinks.map((link) => (
          <a
            href={link.href}
            class="group flex min-h-[44px] flex-col rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/30 p-6 transition-colors hover:border-kharon-cyan/40"
          >
            <h2 class="text-base font-bold text-white group-hover:text-kharon-cyan">{link.label}</h2>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-kharon-light/70">
              {summaries[link.href] ?? "Guidance and reference material for buyers and responsible persons."}
            </p>
            <span class="mt-4 text-xs font-bold uppercase tracking-widest text-kharon-cyan">Read more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <WhatHappensNext intent="site-assessment" ctaLabel="Request Site Assessment" />
</BaseLayout>
