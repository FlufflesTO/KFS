---
import BaseLayout from "../layouts/BaseLayout.astro";
import SolutionHero from "../components/sections/SolutionHero.astro";
import DetectionTechnicalBlocks from "../components/sections/DetectionTechnicalBlocks.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import { pageMeta } from "../data/site.js";

const detectionCapabilities = [
  {
    title: "Addressable detection",
    text: "Addressable detection systems with individual device addressing for precise fault location and maintainable layouts.",
    icon: "/brand/icons/service-fire-detection.svg"
  },
  {
    title: "Specialist detection",
    text: "Aspiration detection, flame detection, and linear detection for environments requiring enhanced sensitivity.",
    icon: "/brand/icons/service-fire-detection.svg"
  },
  {
    title: "Cause-and-effect logic",
    text: "Programmed response logic defining specific detection events leading to specific response actions.",
    icon: "/brand/icons/service-engineering.svg"
  },
  {
    title: "Control panel integration",
    text: "Centralized monitoring and control with event logging, fault diagnostics and remote access capability.",
    icon: "/brand/icons/service-fire-detection.svg"
  }
];
---

<BaseLayout title={pageMeta.fireDetection.title} description={pageMeta.fireDetection.description}>
  <SolutionHero 
    title="Fire Detection Systems" 
    subtitle="Precision Engineering" 
    description="Advanced addressable detection and control systems designed for early identification and rapid response in high-value environments."
    icon="/brand/icons/service-fire-detection.svg"
  />

<div class="mt-10 grid gap-8 md:grid-cols-2">
        {detectionCapabilities.map((capability) => (
          <div class="group relative rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/30 p-8 transition-all hover:border-kharon-purple/40 hover:bg-kharon-charcoal/50">
            <div class="flex items-center gap-6 mb-6">
              <div class="h-14 w-14 flex-none rounded-xl bg-kharon-black/40 border border-kharon-purple/20 p-3 group-hover:bg-kharon-purple/10 transition-colors">
                <img src={capability.icon} alt="" class="h-full w-full object-contain" />
              </div>
              <h3 class="text-xl font-bold text-white tracking-tight leading-tight">{capability.title}</h3>
            </div>
            <p class="text-kharon-light/60 leading-relaxed">{capability.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <DetectionTechnicalBlocks />

  <section class="section-padding bg-kharon-black border-t border-kharon-purple/10">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <SectionHeading
        title="Reliability by Design"
        subtitle="The Kharon Standard"
        description="Our systems are engineered to exceed SANS 10139 standards, providing documented peace of mind for facility managers and site owners."
        center={true}
      />
      <div class="mt-10 flex justify-center gap-4">
        <a href="/contact?intent=site-assessment" class="kharon-command-button px-10 py-5 text-sm">
          Consult an Engineer
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
