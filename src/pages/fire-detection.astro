---
/**
 * Project Sentinel - Fire Detection Page
 * Purpose: Public page presenting fire detection systems, addressable panels, cause-and-effect matrix, and zoning.
 * Dependencies: BaseLayout.astro, SectionHeading.astro, DetectionTechnicalBlocks.astro, site data
 * Structural Role: Main informational page for fire detection services.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import DetectionTechnicalBlocks from "../components/sections/DetectionTechnicalBlocks.astro";
import { pageMeta } from "../data/site.js";

const detectionCapabilities = [
  {
    title: "Addressable detection",
    text: "Addressable detection systems with individual device addressing for precise fault location and maintainable layouts across commercial and industrial sites."
  },
  {
    title: "Specialist detection",
    text: "Aspiration detection, flame detection, and linear detection for environments requiring enhanced sensitivity or coverage beyond conventional point detection."
  },
  {
    title: "Cause-and-effect logic",
    text: "Programmed response logic defining specific detection events leading to specific response actions — aligned to occupancy, operations and suppression requirements."
  },
  {
    title: "Control panel integration",
    text: "Centralized monitoring and control with event logging, fault diagnostics and remote access capability to SANS 10139 standards."
  },
  {
    title: "Zone management",
    text: "Configurable detection zones aligned to operational areas, evacuation paths and response requirements with documented zone schedules."
  },
  {
    title: "Evacuation & PA systems",
    text: "Evacuation system design, installation and testing — including PA and system-based evacuation in compliance with SANS 10400 and SANS 322."
  }
];
---

<BaseLayout title={pageMeta.fireDetection.title} description={pageMeta.fireDetection.description}>
  <section class="hero-padding bg-gradient-to-b from-kharon-black to-kharon-charcoal kharon-environment kharon-logo-watermark">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 kharon-h1">
        Fire Detection Systems
      </h1>
      <p class="text-xl text-kharon-light/80 max-w-2xl mx-auto leading-relaxed">
        Addressable detection, control panels, response zones and fault diagnostics for commercial and industrial sites.
      </p>
    </div>
  </section>

  <section class="section-padding bg-gradient-to-b from-kharon-charcoal to-kharon-black">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeading
        title="Addressable Detection Engineering"
        subtitle="Cause-and-Effect Logic"
        description="Precision-engineered detection systems with maintainable layouts and comprehensive diagnostics."
        center={true}
      />
      
      <div class="mt-12 grid gap-8 md:grid-cols-2">
        {detectionCapabilities.map((capability) => (
          <div class="rounded-xl border border-kharon-purple/15 bg-gradient-to-br from-kharon-surface-elevated to-kharon-charcoal p-0.5 kharon-surface-strong">
            <div class="bg-kharon-surface-elevated rounded-xl p-6 h-full">
              <div class="w-12 h-12 rounded-lg bg-kharon-blue/10 flex items-center justify-center mb-5">
                <div class="w-6 h-6 bg-kharon-purple rounded"></div>
              </div>
              <h3 class="text-xl font-bold text-white mb-3">{capability.title}</h3>
              <p class="text-kharon-light/70">{capability.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Technical tables and flowchart matrix component -->
  <DetectionTechnicalBlocks />

  <section class="section-padding bg-gradient-to-b from-kharon-black to-kharon-charcoal">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <SectionHeading
        title="Precision Detection Architecture"
        subtitle="Engineering Focus"
        description="Systems engineered for reliable performance and maintainable operation in commercial and industrial environments."
        center={true}
      />
      
      <div class="mt-12 prose prose-invert max-w-none">
        <p class="text-kharon-light/80 text-lg leading-relaxed">
          Our fire detection systems are built around addressable detection technology that provides precise device identification and maintainable layouts. Each system incorporates cause-and-effect logic that defines specific detection events leading to specific response actions, ensuring reliable and predictable system performance.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
