---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import SplitFeature from "../components/sections/SplitFeature.astro";
import ProofGrid from "../components/sections/ProofGrid.astro";
import ContextualInquiry from "../components/sections/ContextualInquiry.astro";
import DetectionTechnicalBlocks from "../components/sections/DetectionTechnicalBlocks.astro";
import Footer from "../components/layout/Footer.astro";
import { pageMeta } from "../data/site.js";
---

<BaseLayout title={pageMeta.fireDetection.title} description={pageMeta.fireDetection.description}>
  <Hero 
    title="Commercial Fire Detection" 
    subtitle="Precision detection and control infrastructure for complex environments."
    systemType="fire"
  />

  <DetectionTechnicalBlocks />

  <SplitFeature 
    title="Addressable Intelligence"
    description="Modern fire detection goes beyond simple alarms. Our systems provide granular device-level data, allowing for precise location identification and sophisticated cause-and-effect logic."
    reversed={true}
  />

  <ProofGrid 
    title="Detection Reliability"
    items={[
      { title: "Point Identification", description: "Know exactly which detector triggered the event." },
      { title: "Fault Isolation", description: "Loop isolators ensure system continuity during wiring faults." },
      { title: "False Alarm Filter", description: "Multi-sensor technology reduces disruptive false alarms." },
      { title: "Integrations", description: "Automatic HVAC shutdown and lift grounding on detection." }
    ]}
  />

  <ContextualInquiry 
    title="Request Detection Review"
    requestType="Fire Detection"
  />

  <Footer />
</BaseLayout>
