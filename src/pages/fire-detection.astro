---
/**
 * Project Kharon - Fire Detection Page
 * Purpose: Renders the Fire Detection service details page with detailed technical blocks.
 * Dependencies: ServicePage layout, DetectionTechnicalBlocks component, services data.
 * Structural Role: Solution details route.
 */

import ServicePage from "../layouts/ServicePage.astro";
import DetectionTechnicalBlocks from "../components/sections/DetectionTechnicalBlocks.astro";
import { services } from "../data/services.js";
const s = services["fire-detection"];
---
<ServicePage
  meta={s.meta}
  hero={s.hero}
  overview={s.overview}
  problem={s.problem}
  capabilities={s.capabilities}
  standards={s.standards}
  intent={s.intent}
  faqs={s.faqs}
  caseStudySlug={s.caseStudySlug}
  disclaimerVariant={s.disclaimerVariant}
>
  <DetectionTechnicalBlocks />
</ServicePage>
