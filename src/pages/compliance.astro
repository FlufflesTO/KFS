---
/**
 * Project Sentinel - Compliance Page
 * Purpose: Compliance guidance hub and reference page
 * Dependencies: BaseLayout.astro, SectionHeading.astro, ProofGrid.astro, site data
 * Structural Role: Public compliance information page
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import ProofGrid from "../components/sections/ProofGrid.astro";
import { pageMeta } from "../data/site.js";

const complianceSignals = [
  "SANS 10139 alignment",
  "SANS 14520 alignment", 
  "SAQCC proof signals",
  "Inspection-ready documentation",
  "Commercial & industrial only"
];

const proofItems = [
  {
    title: "SANS 10139 Alignment",
    text: "Fire detection systems designed and maintained according to South African National Standards for fire detection."
  },
  {
    title: "SANS 14520 Alignment", 
    text: "Gas suppression systems engineered and serviced in compliance with South African National Standards for gaseous fire suppression."
  },
  {
    title: "SAQCC Proof Signals",
    text: "Certified competence through the South African Qualifications and Certification Committee for Fire and Gas systems."
  },
  {
    title: "Inspection-Ready Documentation",
    text: "All systems maintained with comprehensive documentation ready for regulatory inspection."
  }
];
---

<BaseLayout title={pageMeta.complianceHub.title} description={pageMeta.complianceHub.description}>
  <section class="hero-padding bg-gradient-to-b from-kharon-black to-kharon-charcoal kharon-environment kharon-logo-watermark">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 kharon-h1">
        Protection System Compliance
      </h1>
      <p class="text-xl text-kharon-light/80 max-w-2xl mx-auto leading-relaxed">
        Practical guidance on SANS 10139 and SANS 14520 maintenance requirements, service report structure, maintenance cadence and defect classification for commercial fire detection and gas suppression systems.
      </p>
    </div>
  </section>

  <ProofGrid items={proofItems} title="Compliance Framework" subtitle="Regulatory Alignment" />
  
  <section class="section-padding bg-gradient-to-b from-kharon-charcoal to-kharon-black">
    <div class="mx-auto max-w-4xl px-6">
      <SectionHeading
        title="Forensic Compliance Approach"
        subtitle="Inspection-Ready Systems"
        description="Systems maintained with the rigor required for regulatory compliance and operational accountability."
        center={true}
      />
      
      <div class="mt-12 grid gap-6 md:grid-cols-2">
        {complianceSignals.map((signal) => (
          <div class="rounded-lg border border-kharon-cyan/15 bg-kharon-surface-elevated p-6 backdrop-blur-sm kharon-surface">
            <div class="flex items-center">
              <div class="mr-3 w-8 h-8 rounded-md bg-kharon-cyan/10 flex items-center justify-center">
                <svg class="w-4 h-4 text-kharon-cyan" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </div>
              <span class="text-white font-medium">{signal}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-gradient-to-b from-kharon-black to-kharon-charcoal">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <SectionHeading
        title="Evidence-Led Maintenance"
        subtitle="Accountability Framework"
        description="Every maintenance action creates verifiable evidence for compliance and operational review."
        center={true}
      />
      
      <div class="mt-12 prose prose-invert max-w-none">
        <p class="text-kharon-light/80 text-lg leading-relaxed">
          Our compliance approach is forensic in nature, with every maintenance activity creating verifiable evidence that can be presented for regulatory inspection. We maintain comprehensive records of all system states, maintenance activities, and compliance checks.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
