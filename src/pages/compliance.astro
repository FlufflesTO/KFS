---
import BaseLayout from "../layouts/BaseLayout.astro";
import SolutionHero from "../components/sections/SolutionHero.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import ProofGrid from "../components/sections/ProofGrid.astro";
import SansReferenceMatrix from "../components/compliance/SansReferenceMatrix.astro";
import ComplianceTechnicalBlocks from "../components/sections/ComplianceTechnicalBlocks.astro";
import { pageMeta } from "../data/site.js";

const complianceSignals = [
  "SANS 10139 alignment",
  "SANS 14520 alignment", 
  "SAQCC proof signals",
  "Inspection-ready documentation",
  "Commercial & industrial only"
];

const proofItems = [
  {
    title: "SANS 10139 Alignment",
    text: "Fire detection systems designed and maintained according to South African National Standards for fire detection."
  },
  {
    title: "SANS 14520 Alignment", 
    text: "Gas suppression systems engineered and serviced in compliance with South African National Standards for gaseous fire suppression."
  },
  {
    title: "SAQCC Proof Signals",
    text: "Certified competence through the South African Qualifications and Certification Committee for Fire and Gas systems."
  },
  {
    title: "Inspection-Ready Documentation",
    text: "All systems maintained with comprehensive documentation ready for regulatory inspection."
  }
];
---

<BaseLayout title={pageMeta.complianceHub.title} description={pageMeta.complianceHub.description}>
  <SolutionHero 
    title="Protection Compliance" 
    subtitle="Regulatory Discipline" 
    description="Engineered maintenance and documentation frameworks ensuring absolute alignment with SANS 10139 and SANS 14520 standards."
    icon="/brand/icons/service-engineering.svg"
  />

  <ProofGrid items={proofItems} title="Compliance Framework" subtitle="Regulatory Alignment" />
  
  <section class="section-padding bg-kharon-black">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeading
        title="Forensic Compliance Approach"
        subtitle="Inspection-Ready Systems"
        description="Systems maintained with the rigor required for regulatory compliance and operational accountability."
        center={true}
      />
      
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {complianceSignals.map((signal) => (
          <div class="rounded-xl border border-kharon-purple/20 bg-kharon-charcoal/40 p-6 backdrop-blur-sm group hover:border-kharon-purple/40 transition-all">
            <div class="flex items-center">
              <div class="mr-3 h-10 w-10 rounded-lg bg-kharon-purple/10 flex items-center justify-center border border-kharon-purple/20 group-hover:bg-kharon-purple/20 transition-colors">
                <svg class="w-5 h-5 text-kharon-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-white font-bold text-sm uppercase tracking-wider">{signal}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-kharon-black border-t border-kharon-purple/10">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeading
        title="Regulatory Standards Reference"
        subtitle="SANS Compliance Matrix"
        description="Comprehensive mapping of South African National Standards governing fire safety and technical infrastructure."
        center={true}
      />
      <SansReferenceMatrix />
    </div>
  </section>

  <section class="section-padding bg-kharon-black border-t border-kharon-purple/10">
    <div class="mx-auto max-w-4xl px-6">
      <SectionHeading
        title="Regulatory Deep-Dives"
        subtitle="Technical Specifications"
        description="Mandated maintenance procedures under South African National Standards."
        center={true}
      />
      
      <div class="mt-12 space-y-12">
        <div class="rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/60 p-8 sm:p-12 relative overflow-hidden">
          <div class="absolute top-0 right-0 h-24 w-24 bg-kharon-red/5 rounded-bl-full pointer-events-none"></div>
          <h3 class="text-2xl font-black text-white mb-6 flex items-center gap-4">
            <span class="px-3 py-1 rounded-lg text-xs font-black uppercase bg-kharon-red/10 text-kharon-red border border-kharon-red/20">SANS 10139</span>
            Fire Detection & Alarm
          </h3>
          <div class="grid gap-10 md:grid-cols-2">
            <div class="space-y-4">
              <h4 class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple">Mandated Cadence</h4>
              <ul class="space-y-4 text-xs text-kharon-light/60">
                <li class="flex gap-3"><strong class="text-white flex-none w-16 uppercase">Daily</strong> Verify panel indicators and log active faults.</li>
                <li class="flex gap-3"><strong class="text-white flex-none w-16 uppercase">Weekly</strong> Trigger manual call point to test sounders.</li>
                <li class="flex gap-3"><strong class="text-white flex-none w-16 uppercase">Annual</strong> Comprehensive test of 100% of devices.</li>
              </ul>
            </div>
            <div class="space-y-4">
              <h4 class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple">Handover Proof</h4>
              <ul class="space-y-4 text-xs text-kharon-light/60">
                <li class="flex gap-3"><strong class="text-white flex-none w-16 uppercase">Logbook</strong> Record of all tests and false alarms.</li>
                <li class="flex gap-3"><strong class="text-white flex-none w-16 uppercase">Design</strong> Declares coverage zones and categories.</li>
                <li class="flex gap-3"><strong class="text-white flex-none w-16 uppercase">Cert</strong> Proves system meets SANS design limits.</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/60 p-8 sm:p-12 relative overflow-hidden">
          <div class="absolute top-0 right-0 h-24 w-24 bg-kharon-cyan/5 rounded-bl-full pointer-events-none"></div>
          <h3 class="text-2xl font-black text-white mb-6 flex items-center gap-4">
            <span class="px-3 py-1 rounded-lg text-xs font-black uppercase bg-kharon-cyan/10 text-kharon-cyan border border-kharon-cyan/20">SANS 14520</span>
            Gaseous Suppression
          </h3>
          <div class="grid gap-10 md:grid-cols-2">
            <div class="space-y-4">
              <h4 class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple">Integrity Focus</h4>
              <ul class="space-y-4 text-xs text-kharon-light/60">
                <li class="flex gap-3"><strong class="text-white flex-none w-20 uppercase">Agents</strong> Strict volume calculations for clean-agents.</li>
                <li class="flex gap-3"><strong class="text-white flex-none w-20 uppercase">Door Fan</strong> Mandatory annual test for retention time.</li>
                <li class="flex gap-3"><strong class="text-white flex-none w-20 uppercase">Retention</strong> Must hold concentration for 10 minutes.</li>
              </ul>
            </div>
            <div class="space-y-4">
              <h4 class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple">Service Intervals</h4>
              <ul class="space-y-4 text-xs text-kharon-light/60">
                <li class="flex gap-3"><strong class="text-white flex-none w-20 uppercase">6-Month</strong> Verify cylinder weights and pressure logs.</li>
                <li class="flex gap-3"><strong class="text-white flex-none w-20 uppercase">10-Year</strong> Hydrostatic stretch testing of storage.</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ComplianceTechnicalBlocks />

  <section class="section-padding bg-kharon-black border-t border-kharon-purple/10">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <SectionHeading
        title="Evidence-Led Maintenance"
        subtitle="Accountability Framework"
        description="Every maintenance action creates verifiable evidence for compliance and operational review."
        center={true}
      />
      <div class="mt-10 flex justify-center gap-4">
        <a href="/portal" class="kharon-command-button px-10 py-5 text-sm">
          Access Compliance Vault
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
