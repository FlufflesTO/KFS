---
/**
 * Project Sentinel - Compliance Hub Page
 * Purpose: Public profile detailing company compliance frameworks, SANS matrix references, and SAQCC signals
 * Dependencies: BaseLayout, SolutionHero, SectionHeading, ProofGrid, SansReferenceMatrix, pageMeta
 * Structural Role: Compliance overview page
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import SolutionHero from "../components/sections/SolutionHero.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import ComplianceTechnicalBlocks from "../components/sections/ComplianceTechnicalBlocks.astro";
import DisclaimerNote from "../components/sections/DisclaimerNote.astro";
import { pageMeta } from "../data/site.js";

const complianceSignals = [
  "SANS 10139 alignment",
  "SANS 14520 alignment",
  "SAQCC proof signals",
  "Inspection-ready documentation",
  "Commercial & industrial only"
];

const sansStandards = [
  {
    code: "SANS 10139",
    title: "Fire Detection Systems",
    scope: "Design, installation, commissioning and maintenance of fire detection systems.",
    bullets: [
      "Quarterly functional tests required",
      "Annual full test with panel verification",
      "Commissioning certificate and maintenance logbook required"
    ],
    area: "Fire Detection"
  },
  {
    code: "SANS 14520",
    title: "Gas Suppression Systems",
    scope: "Selection, design, installation and maintenance of gaseous fire suppression systems.",
    bullets: [
      "Room integrity tests (door fan test) required",
      "Agent quantity calculations and cylinder weighing on schedule",
      "6-monthly inspection, annual discharge readiness check"
    ],
    area: "Gas Suppression"
  },
  {
    code: "SANS 10400-T",
    title: "Fire Protection (Buildings)",
    scope: "Requirements for fire protection installations in buildings, including detection and suppression.",
    bullets: [
      "Prescribes detector spacing and placement rules",
      "Requires system compliance certification before occupation",
      "Governs interface between detection and building fire systems"
    ],
    area: "Fire Detection"
  },
  {
    code: "SANS 10142-1",
    title: "Electrical Wiring (Low Voltage)",
    scope: "Wiring requirements relevant to power supplies for fire protection equipment.",
    bullets: [
      "Dedicated protected circuits for fire panel power",
      "Battery standby calculations and testing",
      "Cable routing separation from general electrical"
    ],
    area: "Supporting Standard"
  },
  {
    code: "SANS 54 (EN 54)",
    title: "Detection Components",
    scope: "Product standards for detectors, manual call points and control and indicating equipment.",
    bullets: [
      "Type testing and approval requirements",
      "Component selection and compatibility",
      "Performance verification on commissioning"
    ],
    area: "Fire Detection"
  },
  {
    code: "SANS 62676",
    title: "CCTV Surveillance Systems",
    scope: "Planning, design, installation and maintenance of CCTV surveillance systems.",
    bullets: [
      "Camera placement and coverage calculations",
      "Recording retention and data storage requirements",
      "Maintenance and testing intervals"
    ],
    area: "Integrated Security"
  },
  {
    code: "SANS 60839-11-1",
    title: "Access Control Systems",
    scope: "Installation and operation of access control systems in buildings.",
    bullets: [
      "Integration requirements with fire systems (fail-safe on alarm)",
      "Audit log requirements",
      "Commissioning and handover documentation"
    ],
    area: "Integrated Security"
  },
  {
    code: "SANS 10114-2",
    title: "Emergency Lighting",
    scope: "Emergency escape lighting and exit signs in buildings.",
    bullets: [
      "1-hour emergency lighting duration minimum",
      "Monthly functional test, annual 1-hour duration test",
      "Maintained and non-maintained fitting categories"
    ],
    area: "Supporting Standard"
  }
];

const timelineItems = [
  { label: "Monthly", tasks: "Visual inspection, panel status check", color: "bg-kharon-cyan", text: "text-kharon-cyan" },
  { label: "Quarterly", tasks: "Functional test of detectors, battery check", color: "bg-kharon-blue", text: "text-kharon-blue" },
  { label: "Annually", tasks: "Full system test, documentation review, agent cylinder weighing", color: "bg-kharon-purple", text: "text-kharon-purple" },
  { label: "5-Year", tasks: "Full system audit, room integrity re-test for gas systems", color: "bg-kharon-amber", text: "text-kharon-amber" }
];

const defectSeverities = [
  {
    severity: "Critical",
    description: "System impaired, detection or suppression offline",
    response: "Priority dispatch subject to site location, access and support agreement",
    rowClass: "border-kharon-red/30",
    badge: "bg-kharon-red/10 border-kharon-red/40 text-kharon-red"
  },
  {
    severity: "Major",
    description: "Significant fault affecting coverage or monitoring",
    response: "Targeted 24-hour response subject to agreement",
    rowClass: "border-kharon-amber/30",
    badge: "bg-kharon-amber/10 border-kharon-amber/40 text-kharon-amber"
  },
  {
    severity: "Minor",
    description: "Isolated fault, system operational but degraded",
    response: "Scheduled visit within 14 days",
    rowClass: "border-kharon-purple/20",
    badge: "bg-kharon-purple/10 border-kharon-purple/30 text-kharon-purple"
  },
  {
    severity: "Advisory",
    description: "Documentation gap or non-urgent improvement",
    response: "Next planned maintenance visit",
    rowClass: "border-white/10",
    badge: "bg-white/5 border-white/10 text-white/50"
  }
];
---

<BaseLayout title={pageMeta.complianceHub.title} description={pageMeta.complianceHub.description}>
  <SolutionHero
    title="SANS Compliance"
    subtitle="Compliance Framework"
    description="Engineered maintenance and documentation frameworks that keep your fire and security systems aligned with national standards."
    icon="/brand/icons/service-engineering.svg"
  />

  <section class="section-padding bg-kharon-black">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeading
        title="Inspection-Ready Compliance"
        subtitle="Inspection-Ready Systems"
        description="Systems maintained with the rigour required for regulatory compliance and operational accountability."
        center={true}
      />

      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {complianceSignals.map((signal) => (
          <div class="rounded-xl border border-kharon-purple/20 bg-kharon-charcoal/40 p-6 backdrop-blur-sm group hover:border-kharon-purple/40 transition-all">
            <div class="flex items-center">
              <div class="mr-3 h-10 w-10 rounded-lg bg-kharon-purple/10 flex items-center justify-center border border-kharon-purple/20 group-hover:bg-kharon-purple/20 transition-colors">
                <svg class="w-5 h-5 text-kharon-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-white font-bold text-sm uppercase tracking-wider">{signal}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ComplianceTechnicalBlocks />

  <section class="section-padding bg-kharon-black border-t border-kharon-purple/10">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeading
        title="SANS Standards Deep-Dive"
        subtitle="Regulatory Reference"
        description="South African National Standards governing fire safety, suppression and integrated security systems."
        center={true}
      />

      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {sansStandards.map((std) => (
          <div class="rounded-xl border border-kharon-purple/20 bg-kharon-charcoal/40 p-6 flex flex-col hover:border-kharon-purple/40 transition-all">
            <div class="flex items-start justify-between gap-2 mb-4">
              <span class="inline-block px-2.5 py-1 rounded text-xs font-black uppercase tracking-wide bg-kharon-purple/10 border border-kharon-purple/20 text-kharon-cyan">
                {std.code}
              </span>
              <span class="inline-block px-2 py-1 rounded text-[9px] font-bold uppercase tracking-wide bg-kharon-black border border-white/10 text-white/40 text-right leading-tight">
                {std.area}
              </span>
            </div>
            <h3 class="text-sm font-black text-white uppercase tracking-wide mb-2">{std.title}</h3>
            <p class="text-xs text-kharon-light/60 leading-relaxed mb-4">{std.scope}</p>
            <ul class="space-y-2 mt-auto">
              {std.bullets.map((b) => (
                <li class="flex gap-2 text-xs text-kharon-light/70 leading-relaxed">
                  <span class="text-kharon-cyan font-black flex-none">›</span>
                  {b}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-kharon-charcoal border-t border-kharon-purple/10">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeading
        title="Maintenance Schedule Timeline"
        subtitle="Service Cadence"
        description="Required inspection and service intervals across all protection system types."
        center={true}
      />

      <div class="mt-12 relative">
        <div class="hidden md:block absolute top-5 left-0 right-0 h-0.5 bg-kharon-purple/20 mx-16"></div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {timelineItems.map((item) => (
            <div class="flex flex-col items-center text-center">
              <div class={`relative z-10 h-10 w-10 rounded-full ${item.color} flex items-center justify-center mb-4 ring-4 ring-kharon-charcoal`}>
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <p class={`text-xs font-black uppercase tracking-widest mb-2 ${item.text}`}>{item.label}</p>
              <p class="text-xs text-kharon-light/60 leading-relaxed">{item.tasks}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-kharon-black border-t border-kharon-purple/10">
    <div class="mx-auto max-w-5xl px-6">
      <SectionHeading
        title="Defect Severity Classification"
        subtitle="Response Framework"
        description="Every defect is classified by severity to determine the required response timeframe and escalation path."
        center={true}
      />

      <div class="mt-10 overflow-x-auto">
        <table class="w-full min-w-[480px] border-collapse text-sm">
          <thead>
            <tr class="border-b border-kharon-purple/20">
              <th class="py-3 pr-4 text-left text-xs font-black uppercase tracking-widest text-kharon-purple">Severity</th>
              <th class="py-3 px-4 text-left text-xs font-black uppercase tracking-widest text-kharon-purple">Description</th>
              <th class="py-3 pl-4 text-left text-xs font-black uppercase tracking-widest text-kharon-purple">Response Target</th>
            </tr>
          </thead>
          <tbody>
            {defectSeverities.map((row) => (
              <tr class={`border-b ${row.rowClass}`}>
                <td class="py-4 pr-4">
                  <span class={`inline-block px-2.5 py-1 rounded text-xs font-black uppercase tracking-wide border ${row.badge}`}>
                    {row.severity}
                  </span>
                </td>
                <td class="py-4 px-4 text-kharon-light/70 font-medium">{row.description}</td>
                <td class="py-4 pl-4 text-white font-bold">{row.response}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section-padding bg-kharon-black border-t border-kharon-purple/10">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <SectionHeading
        title="Evidence-Led Maintenance"
        subtitle="Accountability Framework"
        description="Every maintenance action creates verifiable evidence for compliance and operational review."
        center={true}
      />
      <div class="mt-10 flex justify-center gap-4">
        <a href="https://portal.tequit.co.za/portal/login" class="kharon-command-button px-10 py-5 text-sm">
          Access Client Portal
        </a>
      </div>
      <DisclaimerNote variant="sans" />
    </div>
  </section>
</BaseLayout>
