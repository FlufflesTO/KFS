---
import BaseLayout from "../layouts/BaseLayout.astro";
import SolutionHero from "../components/sections/SolutionHero.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import { pageMeta } from "../data/site.js";

const securityCapabilities = [
  {
    title: "Video Surveillance",
    text: "High-definition IP surveillance with AI analytics, perimeter protection, and low-light capability for absolute site visibility.",
    icon: "/brand/icons/service-cctv.svg"
  },
  {
    title: "Access Control",
    text: "Biometric and contactless access management integrated with fire alarm overrides for life-safety priority.",
    icon: "/brand/icons/service-access-control.svg"
  },
  {
    title: "System Integration",
    text: "Unified management platforms combining video, access, and fire events into a single operational interface.",
    icon: "/brand/icons/service-engineering.svg"
  },
  {
    title: "Perimeter Protection",
    text: "Engineered detection layers for site boundaries, preventing unauthorized entry before internal breach occurs.",
    icon: "/brand/icons/service-cctv.svg"
  }
];
---

<BaseLayout title={pageMeta.securitySystems.title} description={pageMeta.securitySystems.description}>
  <SolutionHero 
    title="Integrated Security" 
    subtitle="Enterprise Intelligence" 
    description="Engineered security infrastructure providing intelligent surveillance, biometric access, and seamless site protection layers."
    icon="/brand/icons/service-cctv.svg"
  />

  <section class="section-padding bg-kharon-black">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid gap-8 md:grid-cols-2">
        {securityCapabilities.map((capability) => (
          <div class="group relative rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/30 p-8 transition-all hover:border-kharon-purple/40 hover:bg-kharon-charcoal/50">
            <div class="flex items-center gap-6 mb-6">
              <div class="h-14 w-14 flex-none rounded-xl bg-kharon-black/40 border border-kharon-purple/20 p-3 group-hover:bg-kharon-purple/10 transition-colors">
                <img src={capability.icon} alt="" loading="lazy" decoding="async" class="h-full w-full object-contain" />
              </div>
              <h3 class="text-xl font-bold text-white tracking-tight leading-tight">{capability.title}</h3>
            </div>
            <p class="text-kharon-light/60 leading-relaxed">{capability.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-kharon-black border-t border-kharon-purple/10">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <SectionHeading
        title="Security with Life-Safety Discipline"
        subtitle="The Kharon Advantage"
        description="We understand that security must never compromise fire safety. Our systems are designed to work in harmony with emergency pathways."
        center={true}
      />
      <div class="mt-10 flex justify-center gap-4">
        <a href="/contact?intent=site-assessment" class="kharon-command-button px-10 py-5 text-sm">
          Secure Your Site
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
