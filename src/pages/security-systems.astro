---
/**
 * Project Kharon - Security Systems Page
 * Purpose: Renders the Integrated Security Systems service details page with detailed technical blocks.
 * Dependencies: ServicePage layout, SecurityTechnicalBlocks component, services data.
 * Structural Role: Solution details route.
 */

import ServicePage from "../layouts/ServicePage.astro";
import SecurityTechnicalBlocks from "../components/sections/SecurityTechnicalBlocks.astro";
import { services } from "../data/services.js";
const s = services["security-systems"];
---
<ServicePage
  meta={s.meta}
  hero={s.hero}
  overview={s.overview}
  problem={s.problem}
  capabilities={s.capabilities}
  standards={s.standards}
  intent={s.intent}
  faqs={s.faqs}
  caseStudySlug={s.caseStudySlug}
  disclaimerVariant={s.disclaimerVariant}
>
  <SecurityTechnicalBlocks />
</ServicePage>
