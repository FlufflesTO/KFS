---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import { pageMeta } from "../data/site.js";

const securityCapabilities = [
  {
    title: "Access control systems",
    text: "Integrated access control solutions with configurable permissions, audit trails and emergency override capabilities."
  },
  {
    title: "Perimeter security",
    text: "Comprehensive perimeter protection with detection, deterrence and verification systems for critical site boundaries."
  },
  {
    title: "CCTV surveillance",
    text: "High-definition surveillance systems with remote monitoring, event recording and intelligent analytics."
  },
  {
    title: "Integration with fire systems",
    text: "Coordinated response between security and fire protection systems for comprehensive site protection."
  }
];
---

<BaseLayout title={pageMeta.securitySystems.title} description={pageMeta.securitySystems.description}>
  <section class="hero-padding bg-gradient-to-b from-kharon-black to-kharon-charcoal kharon-environment kharon-logo-watermark">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 kharon-h1">
        Security Systems
      </h1>
      <p class="text-xl text-kharon-light/80 max-w-2xl mx-auto leading-relaxed">
        Integrated security solutions for commercial and industrial environments with focus on access control, surveillance and intrusion detection.
      </p>
    </div>
  </section>

  <section class="section-padding bg-gradient-to-b from-kharon-charcoal to-kharon-black">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeading
        title="Integrated Security Solutions"
        subtitle="Comprehensive Protection"
        description="Engineered security systems that integrate with fire protection for holistic site protection."
        center={true}
      />
      
      <div class="mt-12 grid gap-8 md:grid-cols-2">
        {securityCapabilities.map((capability, index) => (
          <div key={index} class="rounded-xl border border-kharon-cyan/15 bg-gradient-to-br from-kharon-surface-elevated to-kharon-charcoal p-0.5 kharon-surface-strong">
            <div class="bg-kharon-surface-elevated rounded-xl p-6 h-full">
              <div class="w-12 h-12 rounded-lg bg-kharon-amber/10 flex items-center justify-center mb-5">
                <div class="w-6 h-6 bg-kharon-cyan rounded"></div>
              </div>
              <h3 class="text-xl font-bold text-white mb-3">{capability.title}</h3>
              <p class="text-kharon-light/70">{capability.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-gradient-to-b from-kharon-black to-kharon-charcoal">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <SectionHeading
        title="Holistic Protection Architecture"
        subtitle="Integrated Systems"
        description="Security and fire protection systems designed to work together for comprehensive site protection."
        center={true}
      />
      
      <div class="mt-12 prose prose-invert max-w-none">
        <p class="text-kharon-light/80 text-lg leading-relaxed">
          Our security systems are designed to integrate seamlessly with fire protection systems, providing comprehensive site protection that addresses both security threats and fire hazards. This integrated approach ensures coordinated response and optimal protection outcomes.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>