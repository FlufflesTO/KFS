---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page Not Found | Kharon"
  description="The requested page could not be found."
  noindex={true}
>
  <section class="hero-padding bg-kharon-black text-white">
    <div class="mx-auto max-w-7xl px-6 reveal">
      <p class="mb-4 text-sm font-bold uppercase text-kharon-cyan">404</p>
      <h1 class="kharon-h1 max-w-4xl">Page not found.</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-white/70">
        The page may have moved or no longer exists. Continue to core solutions or request a site assessment.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href="/" class="rounded-md bg-kharon-purple px-6 py-4 font-semibold text-white hover:bg-kharon-blue">
          Back to Home
        </a>
        <a href="/contact?intent=site-assessment" class="rounded-md border border-white/20 px-6 py-4 font-semibold text-white hover:bg-white/10">
          Request Site Assessment
        </a>
      </div>
    </div>
  </section>
  
</BaseLayout>
