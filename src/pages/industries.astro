---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectorRiskGrid from "../components/sections/SectorRiskGrid.astro";
import SolutionHero from "../components/sections/SolutionHero.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import { pageMeta, industries } from "../data/site.js";

const sectors = industries;
---

<BaseLayout title={pageMeta.industries.title} description={pageMeta.industries.description}>
  <SolutionHero 
    title="Industries Served" 
    subtitle="Sector Expertise" 
    description="Specialized fire and security strategies tailored to the unique risk profiles of commercial, industrial, and technical sectors."
    icon="/brand/icons/sector-factory.svg"
  />

  <SectorRiskGrid sectors={sectors} />
  
  <section class="section-padding bg-kharon-black border-t border-kharon-purple/10">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <SectionHeading
        title="Sector-Specific Engineering"
        subtitle="Risk Intelligence"
        description="We understand the distinct regulatory and operational pressures of your industry, from SANS 10139 compliance to ISO 9001 quality discipline."
        center={true}
      />
      <div class="mt-10 flex justify-center gap-4">
        <a href="/contact?intent=site-assessment" class="kharon-command-button px-10 py-5 text-sm">
          Discuss Your Sector Requirements
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
