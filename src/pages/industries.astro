---
/**
 * Project Sentinel - Industries Served Page
 * Purpose: Display the critical infrastructure sectors served by Kharon, their risk profiles, and relevant SANS standards.
 * Dependencies: BaseLayout.astro, SectorRiskGrid.astro, SectionHeading.astro, industries from site.ts
 * Structural Role: Main page for listing industries and sector-specific risk profiles.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import SectorRiskGrid from "../components/sections/SectorRiskGrid.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import { pageMeta, industries } from "../data/site.js";

const sectors = industries;
---

<BaseLayout title={pageMeta.industries.title} description={pageMeta.industries.description}>
  <section class="hero-padding bg-gradient-to-b from-kharon-black to-kharon-charcoal kharon-environment kharon-logo-watermark">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 kharon-h1">
        Industries Served
      </h1>
      <p class="text-xl text-kharon-light/80 max-w-2xl mx-auto leading-relaxed">
        Fire detection, gas suppression and maintenance strategies for data centres, manufacturing sites, warehousing, utilities and industrial facilities.
      </p>
    </div>
  </section>

  <SectorRiskGrid sectors={sectors} />
  
  <section class="section-padding bg-gradient-to-b from-kharon-charcoal to-kharon-black">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <SectionHeading
        title="Sector-Specific Protection"
        subtitle="Risk Analysis"
        description="Engineered fire protection strategies tailored to the unique requirements of each industry sector."
        center={true}
      />
      
      <div class="mt-12 prose prose-invert max-w-none">
        <p class="text-kharon-light/80 text-lg leading-relaxed">
          Each industry presents unique fire protection challenges that require specialized approaches. Our solutions are engineered to address the specific risks and operational requirements of each sector while maintaining the highest safety standards.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
