---
/**
 * Sectors hub — routes each audience to the right sector page.
 * Sector descriptions are hub-only copy; routes come from src/data/site.ts sectorLinks.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import SolutionHero from "../../components/sections/SolutionHero.astro";
import WhatHappensNext from "../../components/sections/WhatHappensNext.astro";
import SectorRiskGrid from "../../components/sections/SectorRiskGrid.astro";
import { sectorLinks, industries } from "../../data/site.js";

const hrefMap: Record<string, string> = {
  "server-rack": "/sectors/data-centres",
  "switchgear": "/sectors/electrical-rooms",
  "warehouse": "/sectors/warehousing-logistics",
  "factory": "/sectors/industrial-facilities",
  "control-room": "/sectors/control-rooms",
  "radio-tower": "/sectors/control-rooms",
  "healthcare": "/sectors/healthcare-commercial",
  "power-grid": "/critical-infrastructure"
};

const sectorsWithLinks = industries.map((ind) => {
  const matchKey = Object.keys(hrefMap).find(key => ind.icon?.includes(key));
  return {
    ...ind,
    href: matchKey ? hrefMap[matchKey] : "/sectors"
  };
});

const meta = {
  title: "Sectors We Protect | Kharon",
  description:
    "Fire detection, gas suppression and integrated security tailored to data centres, electrical rooms, warehousing, industrial facilities, control rooms, healthcare and critical infrastructure."
};
---

<BaseLayout title={meta.title} description={meta.description}>
  <SolutionHero
    subtitle="Sectors"
    title="Sectors We Protect"
    description="Every environment carries a different fire and security risk. Choose your sector to see the systems, standards and approach we recommend."
    icon="/brand/icons/sector-server-rack.svg"
  />

  <SectorRiskGrid sectors={sectorsWithLinks} />

  <WhatHappensNext intent="site-assessment" ctaLabel="Request Site Assessment" />
</BaseLayout>
