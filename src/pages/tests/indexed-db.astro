---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="IndexedDB Test">
  <div id="test-results" class="p-8 text-2xl font-bold">Testing...</div>

  <script>
    import { KharonDB } from "../../lib/offline/indexed-db";

    async function runTest() {
      const results = document.getElementById("test-results");
      try {
        const db = new KharonDB("KharonTestDB", 1);
        await db.open([{ name: "test-store" }]);
        
        await db.put("test-store", { id: 1, name: "Test Item" });
        const item = await db.get<{ id: number; name: string }>("test-store", 1);
        
        if (item?.name === "Test Item") {
          results!.innerText = "SUCCESS";
          results!.classList.add("text-green-500");
        } else {
          results!.innerText = "FAILURE: Item mismatch";
          results!.classList.add("text-red-500");
        }
      } catch (error: any) {
        results!.innerText = `ERROR: ${error.message}`;
        results!.classList.add("text-red-500");
      }
    }

    runTest();
  </script>
</BaseLayout>
