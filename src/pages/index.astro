---
import BaseLayout from "../layouts/BaseLayout.astro";
import SentinelHero from "../components/sections/SentinelHero.astro";
import SolutionPathways from "../components/sections/SolutionPathways.astro";
import ComplianceStrip from "../components/sections/ComplianceStrip.astro";
import SectorRiskGrid from "../components/sections/SectorRiskGrid.astro";
import AuthorityEvidence from "../components/sections/AuthorityEvidence.astro";
import Testimonials from "../components/trust/Testimonials.astro";
import { pageMeta } from "../data/site.js";

const localBusinessJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Kharon Fire & Security",
  "image": "https://www.tequit.co.za/og/kharon-og.png",
  "@id": "https://www.tequit.co.za",
  "url": "https://www.tequit.co.za",
  "telephone": "+27615458830",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Unit 58, M5 Freeway Park, Cnr Uppercamp & Berkley Rd",
    "addressLocality": "Ndabeni, Maitland",
    "addressRegion": "Western Cape",
    "postalCode": "7405",
    "addressCountry": "ZA"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -33.9298,
    "longitude": 18.4907
  }
});
---

<BaseLayout title={pageMeta.home.title} description={pageMeta.home.description}>
  <script is:inline type="application/ld+json" set:html={localBusinessJsonLd}></script>
  
  <SentinelHero />
  <ComplianceStrip />
  <SolutionPathways />
  <SectorRiskGrid />
  <AuthorityEvidence />
  <Testimonials />

  <section class="section-padding bg-kharon-black border-t border-kharon-purple/10">
    <div class="container mx-auto max-w-4xl px-6 text-center">
      <h2 class="kharon-h2 text-white">Ready to secure your mission-critical space?</h2>
      <p class="mt-6 text-kharon-light/60 text-lg">
        Join the organizations trusting Kharon for engineered protection and compliance discipline.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="/contact?intent=site-assessment" class="kharon-command-button px-10 py-5 text-sm">
          Book Site Assessment
        </a>
        <a href="/about" class="kharon-secondary-button px-10 py-5 text-sm">
          Learn Our Ethos
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
