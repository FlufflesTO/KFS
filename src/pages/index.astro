---
/**
 * Project Sentinel - Homepage
 * Purpose: Top-level landing page featuring industrial command layout and extreme vertical density.
 * Dependencies: BaseLayout, SentinelHero, SolutionPathways, SectorRiskGrid, AuthorityEvidence, Testimonials
 * Structural Role: Entry point for the public website
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import SentinelHero from "../components/sections/SentinelHero.astro";
import SolutionPathways from "../components/sections/SolutionPathways.astro";
import ComplianceStrip from "../components/sections/ComplianceStrip.astro";
import SectorRiskGrid from "../components/sections/SectorRiskGrid.astro";
import AuthorityEvidence from "../components/sections/AuthorityEvidence.astro";
import Testimonials from "../components/trust/Testimonials.astro";
import { pageMeta, solutionLinks, industries } from "../data/site.js";

const localBusinessJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Kharon Fire & Security",
  "image": "https://www.tequit.co.za/og/kharon-og.png",
  "@id": "https://www.tequit.co.za",
  "url": "https://www.tequit.co.za",
  "telephone": "+27615458830",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Unit 58, M5 Freeway Park, Cnr Uppercamp & Berkley Rd",
    "addressLocality": "Ndabeni, Maitland",
    "addressRegion": "Western Cape",
    "postalCode": "7405",
    "addressCountry": "ZA"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -33.9298,
    "longitude": 18.4907
  }
});
---

<BaseLayout title={pageMeta.home.title} description={pageMeta.home.description}>
  <script is:inline nonce={Astro.locals.nonce} type="application/ld+json" set:html={localBusinessJsonLd}></script>
  
  <SentinelHero />
  <ComplianceStrip />

  <section class="section-padding bg-kharon-black border-b border-kharon-purple/10 pt-4">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mb-6 text-center">
        <p class="text-[0.55rem] font-black uppercase tracking-[0.3em] text-kharon-purple mb-1">Services Overview</p>
        <h2 class="text-xl font-black text-white tracking-tighter uppercase">Protection Portfolio</h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
        {solutionLinks.map((solution) => (
          <a href={solution.href} class="group rounded-xl border border-kharon-purple/20 bg-kharon-charcoal/30 p-5 flex flex-col hover:border-kharon-purple/40 hover:bg-kharon-charcoal/50 transition-all">
            <div class="h-10 w-10 rounded-lg bg-kharon-black/40 border border-kharon-purple/20 p-2.5 mb-4 group-hover:bg-kharon-purple/10 transition-colors">
              <img loading="lazy" decoding="async" src={solution.icon} alt="" class="h-full w-full object-contain" />
            </div>
            <h3 class="text-xs font-black text-white uppercase tracking-wider mb-2">{solution.label}</h3>
            <p class="text-[0.65rem] text-kharon-light/50 leading-relaxed flex-1">{solution.summary}</p>
            <span class="mt-4 text-[9px] font-black uppercase tracking-widest text-kharon-cyan group-hover:text-white transition-colors">
              Explore &rsaquo;
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <SolutionPathways />
  <SectorRiskGrid sectors={industries} />
  <AuthorityEvidence />
  <Testimonials />

  <section class="section-padding bg-kharon-black border-t border-kharon-purple/10">
    <div class="container mx-auto max-w-4xl px-6 text-center">
      <h2 class="kharon-h2 text-white">Ready to secure your mission-critical space?</h2>
      <p class="mt-6 text-kharon-light/60 text-lg">
        Join the organizations trusting Kharon for engineered protection and compliance discipline.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="/contact?intent=site-assessment" class="kharon-command-button px-10 py-5 text-sm">
          Book Site Assessment
        </a>
        <a href="/about" class="kharon-secondary-button px-10 py-5 text-sm">
          Learn Our Ethos
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
