---
/**
 * Project Sentinel - Compliance Maintenance Page
 * Purpose: Overview of lifecycle inspection schedules, site assessments, and SANS audit standards
 * Dependencies: BaseLayout, SectionHeading, site data
 * Structural Role: Overview of compliance maintenance frameworks for client sites
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import ComplianceStrip from "../components/sections/ComplianceStrip.astro";
import MaintenanceTechnicalBlocks from "../components/sections/MaintenanceTechnicalBlocks.astro";
import { pageMeta } from "../data/site.js";

const assuranceItems = [
  {
    title: "Site assessment",
    text: "Requirements start with the protected room, asset value, occupancy, detection risk and continuity requirement.",
    status: "Assess",
    icon: "/brand/icons/severity-planned.svg"
  },
  {
    title: "Detection and release logic",
    text: "Addressable detection, alarm signalling, suppression release and response paths are structured around maintainable cause-and-effect design.",
    status: "Design",
    icon: "/brand/icons/service-fire-detection.svg"
  },
  {
    title: "Documented servicing",
    text: "Inspection, testing, servicing and reporting are treated as part of the protection system, not an afterthought.",
    status: "Maintain",
    icon: "/brand/icons/service-engineering.svg"
  }
];
---

<BaseLayout title={pageMeta.compliance.title} description={pageMeta.compliance.description}>
  <section class="hero-padding bg-gradient-to-b from-kharon-black to-kharon-charcoal kharon-environment kharon-logo-watermark">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 kharon-h1">
        Compliance & Maintenance
      </h1>
      <p class="text-xl text-kharon-light/80 max-w-2xl mx-auto leading-relaxed">
        Inspection, servicing, reporting and lifecycle maintenance for accountable fire-system ownership.
      </p>
    </div>
  </section>

  <ComplianceStrip />

  <section class="section-padding bg-gradient-to-b from-kharon-charcoal to-kharon-black">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeading
        title="Accountable Fire-System Ownership"
        subtitle="Maintenance Assurance"
        description="Structured approach to fire system compliance and maintenance that ensures continuous protection."
        center={true}
      />
      
      <div class="mt-12 grid gap-8 md:grid-cols-3">
        {assuranceItems.map((item) => (
          <div class="rounded-xl border border-kharon-purple/15 bg-gradient-to-br from-kharon-surface-elevated to-kharon-charcoal p-0.5 kharon-surface-strong">
            <div class="bg-kharon-surface-elevated rounded-xl p-6 h-full">
              <div class="w-12 h-12 rounded-lg bg-kharon-purple/10 flex items-center justify-center mb-5 overflow-hidden">
                {item.icon ? (
                  <img loading="lazy" decoding="async" src={item.icon} class="w-full h-full object-contain" alt="" aria-hidden="true" />
                ) : (
                  <div class="w-6 h-6 bg-kharon-purple rounded"></div>
                )}
              </div>
              <h3 class="text-xl font-bold text-white mb-3">{item.title}</h3>
              <p class="text-kharon-light/70 mb-4">{item.text}</p>
              <span class="inline-block text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full bg-kharon-purple/20 text-kharon-purple">
                {item.status}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <MaintenanceTechnicalBlocks />

  <section class="section-padding bg-gradient-to-b from-kharon-black to-kharon-charcoal">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <SectionHeading
        title="Inspection-Ready Documentation"
        subtitle="Compliance Records"
        description="All maintenance activities create verifiable records for regulatory compliance and operational review."
        center={true}
      />

      <div class="mt-12 prose prose-invert max-w-none">
        <p class="text-kharon-light/80 text-lg leading-relaxed">
          Our maintenance approach treats inspection, testing, and reporting as integral parts of the protection system. Every service visit generates comprehensive documentation that demonstrates ongoing compliance and system integrity.
        </p>
      </div>

      <div class="mt-10 flex justify-center gap-4">
        <a href="/contact?intent=site-assessment" class="kharon-command-button px-10 py-5 text-sm">
          Request a Maintenance Assessment
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
