---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import SplitFeature from "../components/sections/SplitFeature.astro";
import ProofGrid from "../components/sections/ProofGrid.astro";
import TrustModules from "../components/sections/TrustModules.astro";
import EngineeringSystems from "../components/sections/EngineeringSystems.astro";
import ContextualInquiry from "../components/sections/ContextualInquiry.astro";
import ComplianceTechnicalBlocks from "../components/sections/ComplianceTechnicalBlocks.astro";
import Footer from "../components/layout/Footer.astro";
import { pageMeta, trustModules } from "../data/site.js";

const proofItems = [
  {
    title: "Service interval control",
    text: "Recurring inspections and maintenance dates are tracked against system type, site risk and overdue exposure.",
    status: "Control 01"
  },
  {
    title: "Jobcard evidence",
    text: "Service activity, technician comments, customer signatures and documentation paths are captured as operational proof.",
    status: "Control 02"
  },
  {
    title: "Defect classification",
    text: "Faults and defects should be separated by urgency, affected system and required follow-up instead of disappearing into general notes.",
    status: "Control 03"
  },
  {
    title: "Lifecycle due-date governance",
    text: "Completed service work advances the next due date so compliance visibility remains tied to actual field activity.",
    status: "Control 04"
  }
];
---

<BaseLayout title={pageMeta.compliance.title} description={pageMeta.compliance.description}>
  <Hero
    title="Compliance and maintenance with operational discipline."
    text="Structured inspection, servicing and reporting for fire detection, gas suppression and integrated protection systems."
  />

  <SplitFeature
    eyebrow="Reliability"
    title="Maintenance processes that support accountability."
    text="Compliance is visible evidence that critical systems are being managed responsibly and consistently."
    bullets={[
      "Scheduled inspection and servicing",
      "Maintenance reporting",
      "Lifecycle support",
      "Operational risk reduction"
    ]}
    visual="compliance"
    imageAlt="Schematic showing inspection, service record and lifecycle planning"
  />

  <ProofGrid
    eyebrow="Compliance Evidence"
    title="Maintenance is an operating control."
    text="A protection system is only as trustworthy as the inspection, service record and lifecycle decisions around it."
    items={proofItems}
  />

  <TrustModules items={trustModules} />

  <section class="bg-white pb-16">
    <div class="mx-auto max-w-7xl px-6">
      <div class="max-w-3xl rounded-lg border border-kharon-border bg-kharon-light p-6">
        <p class="text-sm font-bold uppercase text-kharon-purple">South Africa Context</p>
        <p class="mt-3 leading-7 text-kharon-grey">
          Compliance programs are shaped around South African statutory duties, site risk classification, and applicable SANS-aligned requirements where incorporated by contract, permit, or policy.
        </p>
      </div>
    </div>
  </section>

  <ComplianceTechnicalBlocks />

  <EngineeringSystems />

  <ContextualInquiry
    eyebrow="Compliance Assessment"
    title="Request a compliance and lifecycle assessment."
    text="Capture audit readiness, inspection concerns, service backlog and documentation status for fire detection or suppression systems."
    requestType="Compliance assessment"
    fields={[
      { label: "Audit Readiness", name: "audit_readiness", options: ["Upcoming audit", "Inspection overdue", "Records incomplete", "Insurance query", "Internal review"] },
      { label: "System Scope", name: "system_scope", options: ["Fire detection", "Gas suppression", "Both", "Integrated security support", "Unknown"] },
      { label: "Maintenance Backlog", name: "maintenance_backlog", options: ["None known", "Minor defects", "Recurring faults", "Major service required", "Unknown"] },
      { label: "Documentation Status", name: "documentation_status", options: ["Current", "Partial", "Missing", "Requires consolidation", "Unknown"] }
    ]}
  />
  <Footer />
</BaseLayout>
