---
/**
 * Project Sentinel - Portal Finance Dashboard
 * Purpose: Provides finance control panel for managing invoices, payments, and Sage integration
 * Dependencies: PortalLayout, bindings, financial-utils
 * Structural Role: Finance control view
 */
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import { formatCurrency, formatCurrencyCompact } from "../../../lib/utils/financial-utils.ts";
import type {
  DbFinancialRecord,
  DbInvoiceRequiredJob,
  DbLinkableJob,
  DbSite,
} from "../../../lib/types/sentinel.ts";

export const prerender = false;

// Local aliases kept for backward compatibility with existing template references.
type FinancialRecord    = DbFinancialRecord;
type InvoiceRequiredJob = DbInvoiceRequiredJob;

const user = Astro.locals.user;
const searchParams = Astro.url.searchParams;
const page = parseInt(searchParams.get("page") || "1", 10);
const limit = 50;
const offset = (page - 1) * limit;

let records:        FinancialRecord[]    = [];
let payments:       FinancialRecord[]    = [];
let pendingApproval: FinancialRecord[]   = [];
let overduePayments: FinancialRecord[]   = [];
let sageStatuses:   { status: string; count: number; records: FinancialRecord[] }[] = [];
let sites:          Pick<DbSite, "id" | "owner_company_name">[] = [];
let linkableJobs:   DbLinkableJob[] = [];
let invoiceRequired: InvoiceRequiredJob[] = [];

let stats = {
  totalPending: 0,
  totalOverdue: 0,
  totalAmount: 0,
  pendingAmount: 0,
  overdueAmount: 0,
  totalPayments: 0,
  totalRecords: 0,
  totalSageAmountExVat: 0,
  totalSageVatAmount: 0,
  totalSageAmountIncVat: 0
};
let totalPages = 1;
let loadError = "";
const today = new Date().toISOString().slice(0, 10);

try {
  const db = getDatabase();

  const [recordsQuery, statsQuery, statusCountsQuery, recentRecordsQuery, sitesQuery, linkableJobsQuery, invoiceRequiredQuery] = await db.batch([
    db.prepare(`
      SELECT financial_records.*, sites.owner_company_name,
             CAST(julianday('now') - julianday(COALESCE(financial_records.distribution_date, financial_records.created_at)) AS INTEGER) AS age_days
      FROM financial_records
      INNER JOIN sites ON sites.id = financial_records.site_id
      ORDER BY financial_records.distribution_date DESC
      LIMIT ? OFFSET ?
    `).bind(limit, offset),
    db.prepare(`
      SELECT 
        COUNT(CASE WHEN payment_status = 'Pending Approval' THEN 1 END) as totalPending,
        SUM(CASE WHEN payment_status = 'Pending Approval' THEN amount ELSE 0 END) as pendingAmount,
        COUNT(CASE WHEN payment_status = 'Unpaid' AND sage_due_date < date('now') THEN 1 END) as totalOverdue,
        SUM(CASE WHEN payment_status = 'Unpaid' AND sage_due_date < date('now') THEN amount ELSE 0 END) as overdueAmount,
        SUM(amount) as totalAmount,
        COUNT(CASE WHEN item_type = 'Payment' THEN 1 END) as totalPayments,
        SUM(sage_amount_ex_vat) as totalSageAmountExVat,
        SUM(sage_vat_amount) as totalSageVatAmount,
        SUM(sage_amount_inc_vat) as totalSageAmountIncVat,
        COUNT(*) as totalRecords
      FROM financial_records
    `),
    db.prepare(`
      SELECT COALESCE(finance_task_status, 'No Status') as status, COUNT(*) as count
      FROM financial_records
      GROUP BY finance_task_status
    `),
    db.prepare(`
      SELECT financial_records.*, sites.owner_company_name
      FROM financial_records
      INNER JOIN sites ON sites.id = financial_records.site_id
      ORDER BY financial_records.created_at DESC
      LIMIT 200
    `),
    db.prepare(`SELECT id, owner_company_name FROM sites ORDER BY owner_company_name`),
    db.prepare(`
      SELECT jobs.id, sites.id AS site_id, jobs.status, jobs.scheduled_date,
             systems.coverage_area
      FROM jobs
      INNER JOIN systems ON systems.id = jobs.system_id
      INNER JOIN sites   ON sites.id   = systems.site_id
      WHERE jobs.status IN ('Completed', 'Invoiced')
      ORDER BY jobs.completed_at DESC
      LIMIT 500
    `),
    db.prepare(`
      SELECT jobs.id, jobs.completed_at, sites.owner_company_name, systems.system_type, systems.coverage_area,
             users.name AS assigned_technician_name
      FROM jobs
      INNER JOIN systems ON systems.id = jobs.system_id
      INNER JOIN sites ON sites.id = systems.site_id
      LEFT JOIN users ON users.id = jobs.assigned_technician_id
      WHERE jobs.status = 'Completed' AND jobs.documentation_path IS NOT NULL
      ORDER BY jobs.completed_at DESC
    `)
  ]);

  records = (recordsQuery.results || []) as FinancialRecord[];
  
  type StatsRow = { totalPending: number; totalOverdue: number; pendingAmount: number; overdueAmount: number; totalAmount: number; totalPayments: number; totalSageAmountExVat: number; totalSageVatAmount: number; totalSageAmountIncVat: number; totalRecords: number };
  const statsRes = ((statsQuery.results?.[0] as StatsRow | undefined) ?? {}) as Partial<StatsRow>;
  stats = {
    totalPending: Number(statsRes.totalPending || 0),
    totalOverdue: Number(statsRes.totalOverdue || 0),
    totalAmount: Number(statsRes.totalAmount || 0),
    pendingAmount: Number(statsRes.pendingAmount || 0),
    overdueAmount: Number(statsRes.overdueAmount || 0),
    totalPayments: Number(statsRes.totalPayments || 0),
    totalRecords: Number(statsRes.totalRecords || 0),
    totalSageAmountExVat: Number(statsRes.totalSageAmountExVat || 0),
    totalSageVatAmount: Number(statsRes.totalSageVatAmount || 0),
    totalSageAmountIncVat: Number(statsRes.totalSageAmountIncVat || 0)
  };
  totalPages = Math.max(1, Math.ceil(stats.totalRecords / limit));

  sites        = (sitesQuery.results        ?? []) as Pick<DbSite, "id" | "owner_company_name">[];
  linkableJobs = (linkableJobsQuery.results ?? []) as DbLinkableJob[];
  invoiceRequired = (invoiceRequiredQuery.results ?? []) as InvoiceRequiredJob[];

  const allRecent = (recentRecordsQuery.results || []) as FinancialRecord[];
  pendingApproval = allRecent.filter(r => r.payment_status === 'Pending Approval');
  overduePayments = allRecent.filter(r => r.payment_status === 'Unpaid' && r.sage_due_date !== null && r.sage_due_date.localeCompare(today) === -1);
  payments = allRecent.filter(r => r.item_type === 'Payment');

  const statusCounts = (statusCountsQuery.results ?? []) as { status: string; count: number }[];
  sageStatuses = statusCounts.map((sc) => ({
    status: sc.status,
    count: sc.count,
    records: allRecent.filter((r) => (r.finance_task_status ?? "No Status") === sc.status),
  }));

} catch (error) {
  console.error("finance dashboard failed", error);
  loadError = "Finance data could not be loaded.";
}
---

<PortalLayout title="Finance Ledger | Kharon Portal" active="finance" user={user}>
  <section class="bg-gradient-to-r from-[#0B0D0F] to-[#1A1F26] px-4 py-10 text-white sm:px-6 sm:py-12 shadow-inner">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-bold uppercase tracking-wider text-kharon-cyan">Finance Control Panel</p>
      <h1 class="mt-2 text-2xl font-bold sm:text-3xl tracking-tight">Sage Control Register</h1>
      <p class="mt-3 max-w-3xl text-sm text-white/60">Manage invoices, payments, and Sage integration with VAT compliance tracking.</p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto grid max-w-7xl gap-6">
      {loadError && <p class="border border-red-300 bg-red-50 p-4 text-red-800">{loadError}</p>}

      <div id="finance-jobs-data" hidden aria-hidden="true" data-jobs={JSON.stringify(linkableJobs)}></div>

      <details class="rounded-xl border border-kharon-border bg-white shadow-sm">
        <summary class="flex cursor-pointer list-none items-center justify-between px-4 py-4 sm:px-5">
          <span class="text-sm font-bold uppercase text-kharon-purple">Create financial record</span>
          <span class="text-xs text-kharon-grey">Quote or invoice</span>
        </summary>
        <div class="border-t border-kharon-border p-4 sm:p-5">
          <form id="finance-create-form" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            <label class="grid gap-2 text-sm font-semibold text-kharon-black">
              Item type
              <select name="itemType" class="rounded-md border border-kharon-border px-3 py-2 font-normal">
                <option value="Quote">Quote</option>
                <option value="Invoice">Invoice</option>
              </select>
            </label>
            <label class="grid gap-2 text-sm font-semibold text-kharon-black">
              Client site
              <select id="finance-site-id" name="siteId" class="rounded-md border border-kharon-border px-3 py-2 font-normal" required>
                <option value="">Select client site</option>
                {sites.map((s) => (
                  <option value={s.id}>{s.owner_company_name}</option>
                ))}
              </select>
            </label>
            <label class="grid gap-2 text-sm font-semibold text-kharon-black">
              Link to job <span class="font-normal text-kharon-grey">(optional)</span>
              <select id="finance-job-id" name="jobId" class="rounded-md border border-kharon-border px-3 py-2 font-normal" disabled>
                <option value="">Select site first</option>
              </select>
            </label>
            <label class="grid gap-2 text-sm font-semibold text-kharon-black">
              Amount ex VAT (ZAR)
              <input type="number" name="amountExVat" class="rounded-md border border-kharon-border px-3 py-2 font-normal" min="0" max="9999999" step="0.01" placeholder="0.00" required />
            </label>
            <label class="grid gap-2 text-sm font-semibold text-kharon-black">
              VAT amount (ZAR) <span class="font-normal text-kharon-grey">(auto 15%)</span>
              <input id="finance-vat-amount" type="number" name="vatAmount" class="rounded-md border border-kharon-border px-3 py-2 font-normal" min="0" max="9999999" step="0.01" placeholder="0.00" />
            </label>
            <label class="grid gap-2 text-sm font-semibold text-kharon-black">
              Amount inc VAT (ZAR)
              <input id="finance-amount-inc-vat" type="number" name="amountIncVat" class="rounded-md border border-kharon-border px-3 py-2 font-normal" min="0" max="9999999" step="0.01" placeholder="0.00" />
            </label>
            <label class="grid gap-2 text-sm font-semibold text-kharon-black">
              Distribution date
              <input id="finance-dist-date" type="date" name="distributionDate" class="rounded-md border border-kharon-border px-3 py-2 font-normal" required />
            </label>
            <label class="grid gap-2 text-sm font-semibold text-kharon-black">
              Sage document date <span class="font-normal text-kharon-grey">(optional)</span>
              <input type="date" name="sageDocumentDate" class="rounded-md border border-kharon-border px-3 py-2 font-normal" />
            </label>
            <label class="grid gap-2 text-sm font-semibold text-kharon-black">
              Due date <span class="font-normal text-kharon-grey">(optional)</span>
              <input type="date" name="sageDueDate" class="rounded-md border border-kharon-border px-3 py-2 font-normal" />
            </label>
            <label class="grid gap-2 text-sm font-semibold text-kharon-black">
              Reference <span class="font-normal text-kharon-grey">(optional)</span>
              <input type="text" name="reference" class="rounded-md border border-kharon-border px-3 py-2 font-normal" maxlength="120" placeholder="PO number, quote ref…" />
            </label>
            <label class="grid gap-2 text-sm font-semibold text-kharon-black lg:col-span-2">
              Finance notes <span class="font-normal text-kharon-grey">(optional)</span>
              <input type="text" name="financeNotes" class="rounded-md border border-kharon-border px-3 py-2 font-normal" maxlength="500" placeholder="Internal finance notes…" />
            </label>
            <div class="flex flex-wrap items-center gap-3 lg:col-span-3">
              <button id="finance-create-submit" class="rounded-md bg-kharon-purple px-5 py-3 text-sm font-semibold text-white hover:bg-kharon-blue">
                Create record
              </button>
              <p id="finance-create-result" class="hidden text-sm font-semibold" aria-live="polite"></p>
            </div>
          </form>
        </div>
      </details>

      {/* Quick Stats Row */}
      <div class="grid gap-4 grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 mb-6">
        <div class="rounded-xl border border-kharon-border bg-white p-4 shadow-sm flex flex-col justify-between">
          <div>
            <p class="text-xs font-bold uppercase text-kharon-purple">Total Records</p>
            <p class="mt-2 text-2xl font-bold text-kharon-black">{records.length}</p>
          </div>
        </div>
        <div class={`rounded-xl border p-4 shadow-sm flex flex-col justify-between ${stats.totalPending > 0 ? "border-amber-200 bg-amber-50/50" : "border-kharon-border bg-white"}`}>
          <div>
            <p class={`text-xs font-bold uppercase ${stats.totalPending > 0 ? "text-amber-600" : "text-kharon-grey"}`}>Pending Approval</p>
            <p class="mt-2 text-2xl font-bold text-kharon-black">{stats.totalPending}</p>
            <p class="mt-1 text-xs text-kharon-grey">{formatCurrency(stats.pendingAmount)}</p>
          </div>
        </div>
        <div class={`rounded-xl border p-4 shadow-sm flex flex-col justify-between ${stats.totalOverdue > 0 ? "border-red-200 bg-red-50/50" : "border-kharon-border bg-white"}`}>
          <div>
            <p class={`text-xs font-bold uppercase ${stats.totalOverdue > 0 ? "text-kharon-red" : "text-kharon-grey"}`}>Overdue Payments</p>
            <p class="mt-2 text-2xl font-bold text-kharon-black">{stats.totalOverdue}</p>
            <p class="mt-1 text-xs text-kharon-red">{formatCurrency(stats.overdueAmount)}</p>
          </div>
        </div>
        <div class="rounded-xl border border-kharon-border bg-white p-4 shadow-sm flex flex-col justify-between">
          <div>
            <p class="text-xs font-bold uppercase text-kharon-blue">Total Value</p>
            <p class="mt-2 text-2xl font-bold text-kharon-black">{formatCurrencyCompact(stats.totalAmount)}</p>
          </div>
        </div>
        <div class="rounded-xl border border-kharon-border bg-white p-4 shadow-sm flex flex-col justify-between">
          <div>
            <p class="text-xs font-bold uppercase text-kharon-cyan">Recent Payments</p>
            <p class="mt-2 text-2xl font-bold text-kharon-black">{payments.length}</p>
          </div>
        </div>
      </div>

      <div class="grid gap-6 lg:grid-cols-2">
        {/* Left Column - Pending Approvals and Overdue Items */}
        <div class="space-y-6">
          {/* Pending Approvals */}
          <div class="rounded-xl border border-kharon-border bg-white p-5 shadow-sm">
            <div class="flex items-center justify-between border-b border-kharon-border pb-4 mb-4">
              <div>
                <p class="text-xs font-bold uppercase tracking-wider text-amber-600">Finance Review</p>
                <h2 class="text-lg font-bold text-kharon-black">Pending Approvals</h2>
              </div>
              <span class="rounded-full bg-amber-100 px-2.5 py-0.5 text-[10px] font-bold uppercase text-amber-800">{stats.totalPending}</span>
            </div>

            <div class="space-y-3">
              {pendingApproval.length === 0 ? (
                <p class="text-sm text-kharon-grey italic py-2">No pending approvals.</p>
              ) : (
                pendingApproval.map((record) => (
                  <article class="flex items-start justify-between gap-4 p-4 rounded-lg border border-amber-200 bg-amber-50/30">
                    <div class="min-w-0 flex-1">
                      <div class="flex items-center justify-between">
                        <span class="font-semibold text-kharon-black">{record.owner_company_name}</span>
                        <span class="rounded bg-amber-100 px-1.5 py-0.5 text-[9px] font-bold uppercase text-amber-800">Quote</span>
                      </div>
                      <p class="text-sm text-kharon-grey mt-0.5">{record.item_type} / {record.reference || "No ref"}</p>
                      <p class="mt-2 text-xs text-kharon-black font-semibold">{formatCurrency(record.amount)}</p>
                      {record.distribution_date && (
                        <p class="mt-1 text-[10px] text-kharon-grey">Distributed: {record.distribution_date}</p>
                      )}
                    </div>
                    <div class="flex flex-col gap-2">
                      <a href={`/portal/api/file/${record.id}`} class="rounded border border-kharon-blue bg-white px-3 py-1.5 text-[10px] font-bold text-kharon-blue hover:bg-kharon-blue hover:text-white transition-colors">
                        View
                      </a>
                    </div>
                  </article>
                ))
              )}
            </div>
          </div>

          {/* Overdue Payments */}
          <div class="rounded-xl border border-kharon-border bg-white p-5 shadow-sm">
            <div class="flex items-center justify-between border-b border-kharon-border pb-4 mb-4">
              <div>
                <p class="text-xs font-bold uppercase tracking-wider text-kharon-red">Collections</p>
                <h2 class="text-lg font-bold text-kharon-black">Overdue Payments</h2>
              </div>
              <span class="rounded-full bg-red-100 px-2.5 py-0.5 text-[10px] font-bold uppercase text-red-800">{stats.totalOverdue}</span>
            </div>

            <div class="space-y-3">
              {overduePayments.length === 0 ? (
                <p class="text-sm text-kharon-grey italic py-2">No overdue payments.</p>
              ) : (
                overduePayments.map((record) => (
                  <article class="flex items-start justify-between gap-4 p-4 rounded-lg border border-red-200 bg-red-50/30">
                    <div class="min-w-0 flex-1">
                      <div class="flex items-center justify-between">
                        <span class="font-semibold text-kharon-black">{record.owner_company_name}</span>
                        <span class="rounded bg-red-100 px-1.5 py-0.5 text-[9px] font-bold uppercase text-red-800">Overdue</span>
                      </div>
                      <p class="text-sm text-kharon-grey mt-0.5">Invoice #{record.sage_invoice_number || "N/A"}</p>
                      <p class="mt-2 text-xs text-kharon-black font-semibold">{formatCurrency(record.amount)}</p>
                      <p class="mt-1 text-[10px] text-kharon-red">Due: {record.sage_due_date}</p>
                    </div>
                    <div class="flex flex-col gap-2">
                      <a href={`/portal/api/file/${record.id}`} class="rounded border border-kharon-blue bg-white px-3 py-1.5 text-[10px] font-bold text-kharon-blue hover:bg-kharon-blue hover:text-white transition-colors">
                        Send Reminder
                      </a>
                    </div>
                  </article>
                ))
              )}
            </div>
            </div>
          </div>

          {/* Finance Exception Queue: Missing Sage Invoices */}
          <div class="rounded-xl border border-kharon-border bg-white p-5 shadow-sm">
            <div class="flex items-center justify-between border-b border-kharon-border pb-4 mb-4">
              <div>
                <p class="text-xs font-bold uppercase tracking-wider text-kharon-purple">Exception Queue</p>
                <h2 class="text-lg font-bold text-kharon-black">Completed Jobs Awaiting Sage Invoice</h2>
              </div>
              <span class="rounded-full bg-kharon-purple px-2.5 py-0.5 text-[10px] font-bold uppercase text-white">{invoiceRequired.length}</span>
            </div>

            <div class="space-y-3">
              {invoiceRequired.length === 0 ? (
                <p class="text-sm text-kharon-grey italic py-2">All completed jobs have been invoiced.</p>
              ) : (
                invoiceRequired.map((job) => (
                  <article class="flex items-start justify-between gap-4 p-4 rounded-lg border border-kharon-border bg-kharon-light/30">
                    <div class="min-w-0 flex-1">
                      <div class="flex items-center justify-between">
                        <span class="font-semibold text-kharon-black">{job.owner_company_name}</span>
                        <span class="rounded bg-kharon-light px-1.5 py-0.5 text-[9px] font-bold uppercase text-kharon-grey">Missing</span>
                      </div>
                      <p class="text-sm text-kharon-grey mt-0.5">{job.system_type} / {job.coverage_area}</p>
                      <p class="mt-2 text-xs text-kharon-grey font-semibold">Completed: {job.completed_at || "N/A"}</p>
                      <p class="mt-1 text-[10px] text-kharon-grey">Tech: {job.assigned_technician_name || "Unknown"}</p>
                    </div>
                    <div class="flex flex-col gap-2">
                      <a href={`/portal/api/file/${job.id}`} class="rounded border border-kharon-purple bg-white px-3 py-1.5 text-[10px] font-bold text-kharon-purple hover:bg-kharon-purple hover:text-white transition-colors text-center">
                        View Jobcard
                      </a>
                    </div>
                  </article>
                ))
              )}
            </div>
          </div>
        </div>

        {/* Right Column - Sage Status Tracking and Recent Activity */}
        <div class="space-y-6">
          {/* Sage Status Tracking */}
          <div class="rounded-xl border border-kharon-border bg-white p-5 shadow-sm">
            <div class="flex items-center justify-between border-b border-kharon-border pb-4 mb-4">
              <div>
                <p class="text-xs font-bold uppercase tracking-wider text-kharon-purple">Sage Pipeline</p>
                <h2 class="text-lg font-bold text-kharon-black">Task Status Tracking</h2>
              </div>
            </div>

            <div class="space-y-3 max-h-96 overflow-y-auto">
              {sageStatuses.length === 0 ? (
                <p class="text-sm text-kharon-grey italic py-2">No records to track.</p>
              ) : (
                sageStatuses.map((statusGroup) => (
                  <details class="group">
                    <summary class="flex items-center justify-between cursor-pointer p-3 rounded-lg border border-kharon-border bg-white hover:bg-kharon-light transition-colors">
                      <span class="font-semibold text-kharon-black group-open:font-bold">{statusGroup.status}</span>
                      <span class="rounded-full bg-kharon-purple px-2 py-0.5 text-xs font-bold text-white">{statusGroup.count}</span>
                    </summary>
                    <div class="mt-2 pl-4 border-l-2 border-kharon-border space-y-2">
                      {statusGroup.records.slice(0, 5).map((record) => (
                        <div class="flex items-center justify-between p-2 bg-kharon-light/30 rounded">
                          <div>
                            <p class="text-xs font-semibold text-kharon-black truncate">{record.owner_company_name}</p>
                            <p class="text-[10px] text-kharon-grey">{record.item_type} • {formatCurrency(record.amount)}</p>
                          </div>
                          <span class="text-[10px] text-kharon-grey">{record.sage_invoice_number || record.sage_quote_number || "No Sage ref"}</span>
                        </div>
                      ))}
                      {statusGroup.records.length > 5 && (
                        <p class="text-xs text-kharon-grey pl-2">+{statusGroup.records.length - 5} more records</p>
                      )}
                    </div>
                  </details>
                ))
              )}
            </div>
          </div>

          {/* VAT Compliance Summary */}
          <div class="rounded-xl border border-kharon-border bg-white p-5 shadow-sm">
            <div class="flex items-center justify-between border-b border-kharon-border pb-4 mb-4">
              <div>
                <p class="text-xs font-bold uppercase tracking-wider text-kharon-cyan">VAT Compliance</p>
                <h2 class="text-lg font-bold text-kharon-black">Tax Reporting Summary</h2>
              </div>
            </div>

            <div class="space-y-4">
              <div class="grid grid-cols-2 gap-4">
                <div class="rounded-lg border border-kharon-border p-3">
                  <p class="text-xs font-bold text-kharon-grey uppercase">Excl VAT</p>
                  <p class="mt-1 text-sm font-bold text-kharon-black">
                    {formatCurrency(stats.totalSageAmountExVat)}
                  </p>
                </div>
                <div class="rounded-lg border border-kharon-border p-3">
                  <p class="text-xs font-bold text-kharon-grey uppercase">VAT Amount</p>
                  <p class="mt-1 text-sm font-bold text-kharon-black">
                    {formatCurrency(stats.totalSageVatAmount)}
                  </p>
                </div>
              </div>
              
              <div class="rounded-lg border border-kharon-border p-3">
                <p class="text-xs font-bold text-kharon-grey uppercase">Incl VAT</p>
                <p class="mt-1 text-sm font-bold text-kharon-black">
                  {formatCurrency(stats.totalSageAmountIncVat)}
                </p>
              </div>

              <div class="pt-3 border-t border-kharon-border/60">
                <p class="text-xs text-kharon-grey">VAT Rate: 15%</p>
                <p class="text-[10px] text-kharon-grey/70 mt-1">All amounts are in ZAR and comply with South African tax regulations.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <script>
    // Handle finance actions
    async function postJson(url, payload) {
      const response = await window.kharonPortalFetch(url, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload)
      });
      const body = await response.json();
      if (!response.ok || !body.ok) throw new Error(body.message || "Request failed.");
      return body;
    }

    // Add functionality for handling finance tasks
    document.querySelectorAll('.finance-task-btn').forEach(button => {
      button.addEventListener('click', async function() {
        const recordId = this.dataset.recordId;
        const action = this.dataset.action;
        
        if (!confirm(`Are you sure you want to ${action} this record?`)) return;
        
        try {
          const result = await postJson('/portal/api/finance/records', {
            action,
            id: recordId
          });
          
          // Refresh the page or update UI accordingly
          location.reload();
        } catch (error) {
          alert(`Error: ${error.message}`);
        }
      });
    });
  </script>

      <div class="sticky top-0 z-10 bg-kharon-light pb-2 flex flex-wrap items-center justify-between gap-3">
