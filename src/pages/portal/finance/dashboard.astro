  <script>
    // ── Ledger search / filter ──────────────────────────────────────────────
    const financeSearch       = document.getElementById("finance-search") as HTMLInputElement | null;
    const financeStatusFilter = document.getElementById("finance-status-filter") as HTMLSelectElement | null;
    const financeTypeFilter   = document.getElementById("finance-type-filter") as HTMLSelectElement | null;
    const financeTbody        = document.getElementById("finance-tbody");
    const financeNoResults    = document.getElementById("finance-no-results");

    function applyFinanceFilter() {
      if (!financeTbody) return;
      const q  = (financeSearch?.value  || "").toLowerCase().trim();
      const sv = financeStatusFilter?.value || "";
      const tv = financeTypeFilter?.value   || "";
      const rows = financeTbody.querySelectorAll<HTMLTableRowElement>("tr[data-search]");
      let visible = 0;
      for (const row of rows) {
        const text = (row.dataset.search ?? "").toLowerCase();
        const show =
          (!q  || text.includes(q)) &&
          (!sv || (row.dataset.status ?? "") === sv) &&
          (!tv || (row.dataset.type   ?? "") === tv);
        row.style.display = show ? "" : "none";
        if (show) visible++;
      }
      if (financeNoResults) financeNoResults.style.display = visible === 0 ? "" : "none";
    }

    financeSearch?.addEventListener("input",  applyFinanceFilter);
    financeStatusFilter?.addEventListener("change", applyFinanceFilter);
    financeTypeFilter?.addEventListener("change",   applyFinanceFilter);

    // ── Sage reference forms ────────────────────────────────────────────────
    for (const form of document.querySelectorAll(".sage-ref-form")) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const result        = form.querySelector(".sage-ref-result");
        const recordId      = form.dataset.recordId;
        const itemType      = form.dataset.itemType;
        const sageNumber        = (form.querySelector("[name='sageNumber']")?.value        ?? "").trim();
        const sageCustomerCode  = (form.querySelector("[name='sageCustomerCode']")?.value  ?? "").trim();
        const sageAmountExVat   = (form.querySelector("[name='sageAmountExVat']")?.value   ?? "").trim();
        const sageVatAmount     = (form.querySelector("[name='sageVatAmount']")?.value     ?? "").trim();
        const sageAmountIncVat  = (form.querySelector("[name='sageAmountIncVat']")?.value  ?? "").trim();
        const sageDocumentDate  = (form.querySelector("[name='sageDocumentDate']")?.value  ?? "").trim();
        const sageDueDate       = (form.querySelector("[name='sageDueDate']")?.value       ?? "").trim();
        const financeNotes      = (form.querySelector("[name='financeNotes']")?.value      ?? "").trim();
        const financeTaskStatus = (form.querySelector("[name='financeTaskStatus']")?.value ?? "").trim();

        const payload = { recordId };
        if (itemType === "Invoice") { payload.sageInvoiceNumber = sageNumber || null; }
        else                        { payload.sageQuoteNumber   = sageNumber || null; }
        if (sageCustomerCode)  payload.sageCustomerCode  = sageCustomerCode;
        if (sageAmountExVat)   payload.sageAmountExVat   = parseFloat(sageAmountExVat);
        if (sageVatAmount)     payload.sageVatAmount     = parseFloat(sageVatAmount);
        if (sageAmountIncVat)  payload.sageAmountIncVat  = parseFloat(sageAmountIncVat);
        if (sageDocumentDate)  payload.sageDocumentDate  = sageDocumentDate;
        if (sageDueDate)       payload.sageDueDate       = sageDueDate;
        if (financeNotes)      payload.financeNotes      = financeNotes;
        if (financeTaskStatus) payload.financeTaskStatus = financeTaskStatus;

        if (result) result.textContent = "Saving…";
        const response = await window.kharonPortalFetch("/portal/api/finance/sage-reference", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload)
        });
        const body = await response.json().catch(() => ({ ok: false, message: "Save failed." }));
        if (result) result.textContent = body.ok ? "Saved." : (body.message || "Save failed.");
        if (body.ok) setTimeout(() => window.location.reload(), 700);
      });
    }

    // ── Finance quick-status buttons (No Charge / On Hold) ─────────────────
    for (const btn of document.querySelectorAll(".finance-quick-status")) {
      btn.addEventListener("click", async () => {
        const recordId = (btn as HTMLElement).dataset.recordId;
        const status   = (btn as HTMLElement).dataset.status;
        if (!recordId || !status) return;
        if (!window.confirm(`Mark this record as "${status}"? You can change it later.`)) return;
        (btn as HTMLButtonElement).disabled = true;
        const response = await window.kharonPortalFetch("/portal/api/finance/sage-reference", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ recordId, financeTaskStatus: status })
        });
        const body = await response.json().catch(() => ({ ok: false }));
        if (body.ok) {
          window.location.reload();
        } else {
          alert(body.message || "Status update failed.");
          (btn as HTMLButtonElement).disabled = false;
        }
      });
    }

    // ── Credit Note buttons ────────────────────────────────────────────────
    for (const btn of document.querySelectorAll(".credit-note-btn")) {
      btn.addEventListener("click", async () => {
        const recordId = (btn as HTMLElement).dataset.recordId;
        const itemType = (btn as HTMLElement).dataset.itemType;
        if (!recordId) return;
        const reason = window.prompt(`Enter reason for credit note (${itemType} reversal):`);
        if (!reason || !reason.trim()) return;
        (btn as HTMLButtonElement).disabled = true;
        const response = await window.kharonPortalFetch("/portal/api/finance/credit-note", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ originalRecordId: recordId, reason: reason.trim() })
        });
        const body = await response.json().catch(() => ({ ok: false }));
        if (body.ok) {
          window.location.reload();
        } else {
          alert(body.message || "Credit note creation failed.");
          (btn as HTMLButtonElement).disabled = false;
        }
      });
    }

    // ── Payment forms ───────────────────────────────────────────────────────
    for (const form of document.querySelectorAll(".payment-form")) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const result = form.querySelector(".payment-result");
        const refInput = form.querySelector("[name='paymentReference']");
        const ref = refInput?.value?.trim() || "";
        const confirmed = window.confirm(
          `Record this payment in Sage?\n\nSage payment reference: ${ref || "(none entered)"}\n\nThis action cannot be undone.`
        );
        if (!confirmed) return;
        const payload = Object.fromEntries(new FormData(form).entries());
        payload.recordId = form.dataset.recordId;
        result.textContent = "Recording in Sage...";

        const response = await window.kharonPortalFetch("/portal/api/finance/payments", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload)
        });
        const body = await response.json().catch(() => ({ ok: false, message: "Payment capture failed." }));
        result.textContent = body.ok ? `Recorded in Sage: ${body.paymentReference}` : body.message || "Payment capture failed.";
        if (body.ok) window.location.reload();
      });
    }

    // Create financial record form
    const financeSiteSelect = document.getElementById("finance-site-id");
    const financeJobSelect = document.getElementById("finance-job-id");
    const financeCreateForm = document.getElementById("finance-create-form");
    const financeCreateResult = document.getElementById("finance-create-result");
    const financeCreateSubmit = document.getElementById("finance-create-submit");
    const financeDistDate = document.getElementById("finance-dist-date");
    const financeVatAmount = document.getElementById("finance-vat-amount");
    const financeAmountIncVat = document.getElementById("finance-amount-inc-vat");
    const financeJobsData = JSON.parse(document.getElementById("finance-jobs-data")?.getAttribute("data-jobs") || "[]");

    // Auto-calculate VAT (15%) and amount inc VAT when amount ex VAT changes
    const amountExVatInput = document.querySelector("[name='amountExVat']");
    amountExVatInput?.addEventListener("input", () => {
      const exVat = parseFloat((amountExVatInput as HTMLInputElement).value) || 0;
      const vat = +(exVat * 0.15).toFixed(2);
      const incVat = +(exVat + vat).toFixed(2);
      if (financeVatAmount) (financeVatAmount as HTMLInputElement).value = vat > 0 ? String(vat) : "";
      if (financeAmountIncVat) (financeAmountIncVat as HTMLInputElement).value = incVat > 0 ? String(incVat) : "";
    });

    if (financeDistDate && !financeDistDate.value) {
      financeDistDate.value = new Date().toISOString().split("T")[0];
    }

    financeSiteSelect?.addEventListener("change", () => {
      const siteId = financeSiteSelect.value;
      if (siteId) {
        const siteJobs = financeJobsData.filter((j) => j.site_id === siteId);
        const defaultOpt = document.createElement("option");
        defaultOpt.value = "";
        defaultOpt.textContent = "No job (standalone record)";
        financeJobSelect.replaceChildren(defaultOpt);
        for (const job of siteJobs) {
          const opt = document.createElement("option");
          opt.value = job.id;
          opt.textContent = `${job.coverage_area} / ${job.status} / ${job.scheduled_date || ""}`;
          financeJobSelect.appendChild(opt);
        }
        financeJobSelect.disabled = false;
      } else {
        financeJobSelect.disabled = true;
        const defaultOpt = document.createElement("option");
        defaultOpt.value = "";
        defaultOpt.textContent = "Select site first";
        financeJobSelect.replaceChildren(defaultOpt);
      }
    });

    financeCreateForm?.addEventListener("submit", async (event) => {
      event.preventDefault();
      financeCreateSubmit.disabled = true;
      financeCreateSubmit.textContent = "Creating…";
      financeCreateResult.className = "hidden text-sm font-semibold";

      const data = new FormData(financeCreateForm);
      const jobId = data.get("jobId");
      const reference = data.get("reference");
      const payload = {
        itemType: data.get("itemType"),
        siteId: data.get("siteId"),
        amountExVat: data.get("amountExVat"),
        vatAmount: data.get("vatAmount") || null,
        amountIncVat: data.get("amountIncVat") || null,
        distributionDate: data.get("distributionDate"),
        sageDocumentDate: data.get("sageDocumentDate") || null,
        sageDueDate: data.get("sageDueDate") || null,
        ...(jobId && { jobId }),
        ...(reference && { reference }),
        ...(data.get("financeNotes") && { financeNotes: data.get("financeNotes") })
      };

      const response = await window.kharonPortalFetch("/portal/api/finance/records", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload)
      });
      const body = await response.json().catch(() => ({ ok: false, message: "Request failed." }));

      if (body.ok) {
        financeCreateResult.textContent = `${body.itemType} created — ${body.paymentStatus} / R ${(Number(body.amount) / 100).toFixed(2)}`;
        financeCreateResult.className = "text-sm font-semibold text-kharon-blue";
        financeCreateForm.reset();
        financeJobSelect.disabled = true;
        const defaultOpt = document.createElement("option");
        defaultOpt.value = "";
        defaultOpt.textContent = "Select site first";
        financeJobSelect.replaceChildren(defaultOpt);
        if (financeDistDate) financeDistDate.value = new Date().toISOString().split("T")[0];
        setTimeout(() => window.location.reload(), 2000);
      } else {
        financeCreateResult.textContent = body.message || "Record could not be created.";
        financeCreateResult.className = "text-sm font-semibold text-red-700";
        financeCreateSubmit.disabled = false;
        financeCreateSubmit.textContent = "Create record";
      }
    });
  </script>
</PortalLayout>
