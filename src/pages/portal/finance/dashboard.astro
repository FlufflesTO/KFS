---
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";

export const prerender = false;

const user = Astro.locals.user;
let records = [];
let sites = [];
let linkableJobs = [];
let totals = { unpaid: 0, pending: 0, settled: 0 };
let aging = { current: 0, thirty: 0, sixty: 0 };
let loadError = "";

try {
  const db = getDatabase();

  const [aggResult, recordsResult, sitesResult, jobsResult] = await db.batch([
    db.prepare(`
      SELECT
        COALESCE(SUM(CASE WHEN payment_status = 'Unpaid' THEN amount ELSE 0 END), 0)             AS unpaid,
        COALESCE(SUM(CASE WHEN payment_status = 'Pending Approval' THEN amount ELSE 0 END), 0)   AS pending,
        COALESCE(SUM(CASE WHEN payment_status = 'Settled' THEN amount ELSE 0 END), 0)             AS settled,
        COALESCE(SUM(CASE WHEN payment_status NOT IN ('Settled')
          AND (julianday('now') - julianday(distribution_date)) < 30  THEN amount ELSE 0 END), 0) AS age_current,
        COALESCE(SUM(CASE WHEN payment_status NOT IN ('Settled')
          AND (julianday('now') - julianday(distribution_date)) >= 30
          AND (julianday('now') - julianday(distribution_date)) < 60  THEN amount ELSE 0 END), 0) AS age_thirty,
        COALESCE(SUM(CASE WHEN payment_status NOT IN ('Settled')
          AND (julianday('now') - julianday(distribution_date)) >= 60 THEN amount ELSE 0 END), 0) AS age_sixty
      FROM financial_records
    `),
    db.prepare(
      `SELECT financial_records.id, financial_records.amount, financial_records.item_type,
              financial_records.payment_status, financial_records.distribution_date, financial_records.reference,
              sites.owner_company_name, jobs.status AS job_status
       FROM financial_records
       INNER JOIN sites ON sites.id = financial_records.site_id
       LEFT JOIN jobs ON jobs.id = financial_records.job_id
       ORDER BY financial_records.distribution_date DESC
       LIMIT 80`
    ),
    db.prepare(
      `SELECT id, owner_company_name FROM sites ORDER BY owner_company_name`
    ),
    db.prepare(
      `SELECT jobs.id, jobs.scheduled_date, jobs.status, systems.coverage_area, systems.site_id
       FROM jobs
       INNER JOIN systems ON systems.id = jobs.system_id
       WHERE jobs.status IN ('Scheduled', 'In Progress', 'Completed')
       ORDER BY jobs.scheduled_date DESC
       LIMIT 150`
    )
  ]);

  const agg = (aggResult.results[0] as any) || {};
  totals = {
    unpaid:  Number(agg.unpaid  ?? 0),
    pending: Number(agg.pending ?? 0),
    settled: Number(agg.settled ?? 0)
  };
  aging = {
    current: Number(agg.age_current ?? 0),
    thirty:  Number(agg.age_thirty  ?? 0),
    sixty:   Number(agg.age_sixty   ?? 0)
  };
  records      = recordsResult.results || [];
  sites        = sitesResult.results   || [];
  linkableJobs = jobsResult.results    || [];

  // Per-row age (days) for table display only
  for (const record of records) {
    record.age_days = record.payment_status !== "Settled"
      ? Math.max(0, Math.floor((Date.now() - new Date(`${record.distribution_date}T00:00:00Z`).getTime()) / 86400000))
      : 0;
  }
} catch (error) {
  console.error("finance dashboard failed", error);
  loadError = "Finance ledger could not be loaded.";
}
---

<PortalLayout title="Finance Ledger | Kharon Portal" active="finance" user={user}>
  <section class="bg-kharon-black px-4 py-8 text-white sm:px-6 sm:py-10">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-bold uppercase text-kharon-cyan">Finance workspace</p>
      <h1 class="mt-3 text-2xl font-bold sm:text-3xl">Commercial ledger tied to field dispatches</h1>
      <p class="mt-4 max-w-3xl text-white/65">Pending customer invoices, quote approvals, payments recorded in Sage and dispatch-linked revenue visibility.</p>
      <a class="mt-6 inline-flex rounded-md border border-white/20 px-5 py-3 text-sm font-semibold text-white/80 hover:border-white/40 hover:text-white" href="/portal/api/finance/export">
        Export ledger CSV
      </a>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto grid max-w-7xl gap-6">
      {loadError && <p class="border border-red-300 bg-red-50 p-4 text-red-800">{loadError}</p>}

      <div id="finance-jobs-data" hidden aria-hidden="true" data-jobs={JSON.stringify(linkableJobs)}></div>

      <details class="border border-kharon-border bg-white">
        <summary class="flex cursor-pointer list-none items-center justify-between px-4 py-4 sm:px-5">
          <span class="text-sm font-bold uppercase text-kharon-purple">Create financial record</span>
          <span class="text-xs text-kharon-grey">Quote or invoice</span>
        </summary>
        <div class="border-t border-kharon-border p-4 sm:p-5">
          <form id="finance-create-form" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            <label class="grid gap-2 text-sm font-semibold text-kharon-black">
              Item type
              <select name="itemType" class="rounded-md border border-kharon-border px-3 py-2 font-normal">
                <option value="Quote">Quote</option>
                <option value="Invoice">Invoice</option>
              </select>
            </label>
            <label class="grid gap-2 text-sm font-semibold text-kharon-black">
              Client site
              <select id="finance-site-id" name="siteId" class="rounded-md border border-kharon-border px-3 py-2 font-normal" required>
                <option value="">Select client site</option>
                {sites.map((s) => (
                  <option value={s.id}>{s.owner_company_name}</option>
                ))}
              </select>
            </label>
            <label class="grid gap-2 text-sm font-semibold text-kharon-black">
              Link to job <span class="font-normal text-kharon-grey">(optional)</span>
              <select id="finance-job-id" name="jobId" class="rounded-md border border-kharon-border px-3 py-2 font-normal" disabled>
                <option value="">Select site first</option>
              </select>
            </label>
            <label class="grid gap-2 text-sm font-semibold text-kharon-black">
              Amount (ZAR)
              <input type="number" name="amount" class="rounded-md border border-kharon-border px-3 py-2 font-normal" min="0" max="9999999" step="0.01" placeholder="0.00" required />
            </label>
            <label class="grid gap-2 text-sm font-semibold text-kharon-black">
              Distribution date
              <input id="finance-dist-date" type="date" name="distributionDate" class="rounded-md border border-kharon-border px-3 py-2 font-normal" required />
            </label>
            <label class="grid gap-2 text-sm font-semibold text-kharon-black">
              Reference <span class="font-normal text-kharon-grey">(optional)</span>
              <input type="text" name="reference" class="rounded-md border border-kharon-border px-3 py-2 font-normal" maxlength="120" placeholder="PO number, quote ref…" />
            </label>
            <div class="flex flex-wrap items-center gap-3 lg:col-span-3">
              <button id="finance-create-submit" class="rounded-md bg-kharon-purple px-5 py-3 text-sm font-semibold text-white hover:bg-kharon-blue">
                Create record
              </button>
              <p id="finance-create-result" class="hidden text-sm font-semibold" aria-live="polite"></p>
            </div>
          </form>
        </div>
      </details>

      <div class="grid gap-4 md:grid-cols-3">
        <article class="border border-kharon-border bg-white p-4 sm:p-5"><p class="text-xs font-bold uppercase text-kharon-purple">Unpaid</p><p class="mt-2 text-2xl font-bold">R {totals.unpaid.toFixed(2)}</p></article>
        <article class="border border-kharon-border bg-white p-4 sm:p-5"><p class="text-xs font-bold uppercase text-kharon-purple">Pending approval</p><p class="mt-2 text-2xl font-bold">R {totals.pending.toFixed(2)}</p></article>
        <article class="border border-kharon-border bg-white p-4 sm:p-5"><p class="text-xs font-bold uppercase text-kharon-purple">Paid in Sage</p><p class="mt-2 text-2xl font-bold">R {totals.settled.toFixed(2)}</p></article>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        <article class="border border-kharon-border bg-white p-4 sm:p-5"><p class="text-xs font-bold uppercase text-kharon-blue">Open 0-29 days</p><p class="mt-2 text-xl font-bold">R {aging.current.toFixed(2)}</p></article>
        <article class="border border-kharon-border bg-white p-4 sm:p-5"><p class="text-xs font-bold uppercase text-kharon-purple">Open 30-59 days</p><p class="mt-2 text-xl font-bold">R {aging.thirty.toFixed(2)}</p></article>
        <article class="border border-kharon-border bg-white p-4 sm:p-5"><p class="text-xs font-bold uppercase text-kharon-red">Open 60+ days</p><p class="mt-2 text-xl font-bold">R {aging.sixty.toFixed(2)}</p></article>
      </div>

      <div class="sticky top-0 z-10 bg-kharon-light pb-2 flex flex-wrap items-center gap-3">
        <input
          id="finance-search"
          type="search"
          class="rounded-md border border-kharon-border bg-white px-3 py-2 text-sm"
          placeholder="Search client or reference…"
          size="26"
        />
        <select id="finance-status-filter" class="rounded-md border border-kharon-border bg-white px-3 py-2 text-sm">
          <option value="">All statuses</option>
          <option value="Unpaid">Unpaid</option>
          <option value="Pending Approval">Pending Approval</option>
          <option value="Settled">Paid in Sage</option>
        </select>
        <select id="finance-type-filter" class="rounded-md border border-kharon-border bg-white px-3 py-2 text-sm">
          <option value="">All types</option>
          <option value="Quote">Quote</option>
          <option value="Invoice">Invoice</option>
        </select>
      </div>
      <p id="finance-no-results" class="hidden py-3 text-sm text-kharon-grey">No records match your filter.</p>

      <div class="portal-scroll-x border border-kharon-border bg-white">
        <table class="w-full min-w-[760px] border-collapse text-left text-sm">
          <thead class="bg-kharon-charcoal text-white">
            <tr>
              <th class="p-4">Client</th>
              <th class="p-4">Type</th>
              <th class="p-4">Status</th>
              <th class="p-4">Amount</th>
              <th class="p-4">Date</th>
              <th class="p-4">Age</th>
              <th class="p-4">Reference</th>
              <th class="p-4">Action</th>
            </tr>
          </thead>
          <tbody id="finance-tbody">
            {records.map((record) => (
              <tr
                class="border-t border-kharon-border"
                data-search={`${record.owner_company_name} ${record.reference || ""} ${record.item_type}`}
                data-status={record.payment_status}
                data-type={record.item_type}
              >
                <td class="p-4 font-semibold">{record.owner_company_name}</td>
                <td class="p-4">{record.item_type}</td>
                <td class="p-4">{record.payment_status === "Settled" ? "Paid in Sage" : record.payment_status}</td>
                <td class="p-4">R {Number(record.amount).toFixed(2)}</td>
                <td class="p-4">{record.distribution_date}</td>
                <td class="p-4">{record.payment_status === "Settled" ? "-" : `${record.age_days}d`}</td>
                <td class="p-4">{record.reference || record.id}</td>
                <td class="p-4">
                  {record.item_type === "Invoice" && record.payment_status === "Unpaid" ? (
                    <form class="payment-form flex min-w-56 flex-col gap-2" data-record-id={record.id}>
                      <label class="sr-only" for={`payment-${record.id}`}>Payment reference</label>
                      <input id={`payment-${record.id}`} class="rounded-md border border-kharon-border px-3 py-2 text-sm" name="paymentReference" maxlength="80" placeholder="Sage payment reference" />
                      <button class="rounded-md bg-kharon-purple px-3 py-2 text-sm font-semibold text-white hover:bg-kharon-blue">Record Paid in Sage</button>
                      <p class="payment-result text-xs text-kharon-grey" aria-live="polite"></p>
                    </form>
                  ) : (
                    <span class="text-xs uppercase text-kharon-grey/70">No action</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>
  <script>
    // ── Ledger search / filter ──────────────────────────────────────────────
    const financeSearch       = document.getElementById("finance-search") as HTMLInputElement | null;
    const financeStatusFilter = document.getElementById("finance-status-filter") as HTMLSelectElement | null;
    const financeTypeFilter   = document.getElementById("finance-type-filter") as HTMLSelectElement | null;
    const financeTbody        = document.getElementById("finance-tbody");
    const financeNoResults    = document.getElementById("finance-no-results");

    function applyFinanceFilter() {
      if (!financeTbody) return;
      const q  = (financeSearch?.value  || "").toLowerCase().trim();
      const sv = financeStatusFilter?.value || "";
      const tv = financeTypeFilter?.value   || "";
      const rows = financeTbody.querySelectorAll<HTMLTableRowElement>("tr[data-search]");
      let visible = 0;
      for (const row of rows) {
        const text = (row.dataset.search ?? "").toLowerCase();
        const show =
          (!q  || text.includes(q)) &&
          (!sv || (row.dataset.status ?? "") === sv) &&
          (!tv || (row.dataset.type   ?? "") === tv);
        row.style.display = show ? "" : "none";
        if (show) visible++;
      }
      if (financeNoResults) financeNoResults.style.display = visible === 0 ? "" : "none";
    }

    financeSearch?.addEventListener("input",  applyFinanceFilter);
    financeStatusFilter?.addEventListener("change", applyFinanceFilter);
    financeTypeFilter?.addEventListener("change",   applyFinanceFilter);

    // ── Payment forms ───────────────────────────────────────────────────────
    for (const form of document.querySelectorAll(".payment-form")) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const result = form.querySelector(".payment-result");
        const refInput = form.querySelector("[name='paymentReference']");
        const ref = refInput?.value?.trim() || "";
        const confirmed = window.confirm(
          `Record this payment in Sage?\n\nSage payment reference: ${ref || "(none entered)"}\n\nThis action cannot be undone.`
        );
        if (!confirmed) return;
        const payload = Object.fromEntries(new FormData(form).entries());
        payload.recordId = form.dataset.recordId;
        result.textContent = "Recording in Sage...";

        const response = await window.kharonPortalFetch("/portal/api/finance/payments", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload)
        });
        const body = await response.json().catch(() => ({ ok: false, message: "Payment capture failed." }));
        result.textContent = body.ok ? `Recorded in Sage: ${body.paymentReference}` : body.message || "Payment capture failed.";
        if (body.ok) window.location.reload();
      });
    }

    // Create financial record form
    const financeSiteSelect = document.getElementById("finance-site-id");
    const financeJobSelect = document.getElementById("finance-job-id");
    const financeCreateForm = document.getElementById("finance-create-form");
    const financeCreateResult = document.getElementById("finance-create-result");
    const financeCreateSubmit = document.getElementById("finance-create-submit");
    const financeDistDate = document.getElementById("finance-dist-date");
    const financeJobsData = JSON.parse(document.getElementById("finance-jobs-data")?.getAttribute("data-jobs") || "[]");

    if (financeDistDate && !financeDistDate.value) {
      financeDistDate.value = new Date().toISOString().split("T")[0];
    }

    financeSiteSelect?.addEventListener("change", () => {
      const siteId = financeSiteSelect.value;
      if (siteId) {
        const siteJobs = financeJobsData.filter((j) => j.site_id === siteId);
        financeJobSelect.innerHTML = '<option value="">No job (standalone record)</option>';
        for (const job of siteJobs) {
          const opt = document.createElement("option");
          opt.value = job.id;
          opt.textContent = `${job.coverage_area} / ${job.status} / ${job.scheduled_date || ""}`;
          financeJobSelect.appendChild(opt);
        }
        financeJobSelect.disabled = false;
      } else {
        financeJobSelect.disabled = true;
        financeJobSelect.innerHTML = '<option value="">Select site first</option>';
      }
    });

    financeCreateForm?.addEventListener("submit", async (event) => {
      event.preventDefault();
      financeCreateSubmit.disabled = true;
      financeCreateSubmit.textContent = "Creating…";
      financeCreateResult.className = "hidden text-sm font-semibold";

      const data = new FormData(financeCreateForm);
      const jobId = data.get("jobId");
      const reference = data.get("reference");
      const payload = {
        itemType: data.get("itemType"),
        siteId: data.get("siteId"),
        amount: data.get("amount"),
        distributionDate: data.get("distributionDate"),
        ...(jobId && { jobId }),
        ...(reference && { reference })
      };

      const response = await window.kharonPortalFetch("/portal/api/finance/records", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload)
      });
      const body = await response.json().catch(() => ({ ok: false, message: "Request failed." }));

      if (body.ok) {
        financeCreateResult.textContent = `${body.itemType} created — ${body.paymentStatus} / R ${Number(body.amount).toFixed(2)}`;
        financeCreateResult.className = "text-sm font-semibold text-kharon-blue";
        financeCreateForm.reset();
        financeJobSelect.disabled = true;
        financeJobSelect.innerHTML = '<option value="">Select site first</option>';
        if (financeDistDate) financeDistDate.value = new Date().toISOString().split("T")[0];
        setTimeout(() => window.location.reload(), 2000);
      } else {
        financeCreateResult.textContent = body.message || "Record could not be created.";
        financeCreateResult.className = "text-sm font-semibold text-red-700";
        financeCreateSubmit.disabled = false;
        financeCreateSubmit.textContent = "Create record";
      }
    });
  </script>
</PortalLayout>
