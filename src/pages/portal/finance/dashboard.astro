---
import { auditError } from "../../../lib/server/audit.js";
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import FinanceCreateForm from "../../../components/portal/finance/FinanceCreateForm.astro";
import FinanceStatsPanel from "../../../components/portal/finance/FinanceStatsPanel.astro";
import FinanceExceptionPanel from "../../../components/portal/finance/FinanceExceptionPanel.astro";
import FinanceSagePanel from "../../../components/portal/finance/FinanceSagePanel.astro";
import FinanceLedgerTable from "../../../components/portal/finance/FinanceLedgerTable.astro";
import type {
  DbFinancialRecord,
  DbInvoiceRequiredJob,
  DbLinkableJob,
  DbSite,
} from "@sentinel/types";

export const prerender = false;

const user = Astro.locals.user;
const page = Math.max(1, parseInt(Astro.url.searchParams.get("page") ?? "1", 10));
const limit = 50;
const offset = (page - 1) * limit;

let records: DbFinancialRecord[] = [];
let pendingApproval: DbFinancialRecord[] = [];
let overduePayments: DbFinancialRecord[] = [];
let sageStatuses: { status: string; count: number; records: DbFinancialRecord[] }[] = [];
let sites: Pick<DbSite, "id" | "owner_company_name">[] = [];
let linkableJobs: DbLinkableJob[] = [];
let invoiceRequired: DbInvoiceRequiredJob[] = [];
let paymentsCount = 0;

let stats = {
  totalPending: 0, totalOverdue: 0, totalAmount: 0,
  pendingAmount: 0, overdueAmount: 0, totalRecords: 0,
  totalSageAmountExVat: 0, totalSageVatAmount: 0, totalSageAmountIncVat: 0,
};
let totalPages = 1;
let loadError = "";

try {
  const db = getDatabase();

  const [
    recordsResult, statsResult, statusCountsResult,
    pendingResult, overdueResult, paymentsCountResult, sagePipelineResult,
    sitesResult, linkableJobsResult, invoiceRequiredResult,
  ] = await db.batch([
    // 1. Paginated ledger
    db.prepare(`
      SELECT financial_records.*, sites.owner_company_name,
             CAST(julianday('now') - julianday(COALESCE(financial_records.distribution_date, financial_records.created_at)) AS INTEGER) AS age_days
      FROM financial_records
      INNER JOIN sites ON sites.id = financial_records.site_id
      ORDER BY financial_records.distribution_date DESC
      LIMIT ? OFFSET ?
    `).bind(limit, offset),
    // 2. Aggregate stats
    db.prepare(`
      SELECT
        COUNT(CASE WHEN payment_status = 'Pending Approval' THEN 1 END) AS totalPending,
        SUM(CASE WHEN payment_status = 'Pending Approval' THEN amount ELSE 0 END) AS pendingAmount,
        COUNT(CASE WHEN payment_status = 'Unpaid' AND sage_due_date < date('now') THEN 1 END) AS totalOverdue,
        SUM(CASE WHEN payment_status = 'Unpaid' AND sage_due_date < date('now') THEN amount ELSE 0 END) AS overdueAmount,
        SUM(amount) AS totalAmount,
        SUM(sage_amount_ex_vat) AS totalSageAmountExVat,
        SUM(sage_vat_amount) AS totalSageVatAmount,
        SUM(sage_amount_inc_vat) AS totalSageAmountIncVat,
        COUNT(*) AS totalRecords
      FROM financial_records
    `),
    // 3. Sage task status counts
    db.prepare(`
      SELECT COALESCE(finance_task_status, 'No Status') AS status, COUNT(*) AS count
      FROM financial_records
      GROUP BY finance_task_status
    `),
    // 4. Pending approval records (targeted — replaces LIMIT 200 scan)
    db.prepare(`
      SELECT financial_records.*, sites.owner_company_name
      FROM financial_records
      INNER JOIN sites ON sites.id = financial_records.site_id
      WHERE financial_records.payment_status = 'Pending Approval'
      ORDER BY financial_records.distribution_date DESC
      LIMIT 50
    `),
    // 5. Overdue payments (targeted)
    db.prepare(`
      SELECT financial_records.*, sites.owner_company_name
      FROM financial_records
      INNER JOIN sites ON sites.id = financial_records.site_id
      WHERE financial_records.payment_status = 'Unpaid' AND financial_records.sage_due_date < date('now')
      ORDER BY financial_records.sage_due_date ASC
      LIMIT 50
    `),
    // 6. Payment count (scalar — no row fetch needed)
    db.prepare(`SELECT COUNT(*) AS cnt FROM financial_records WHERE item_type = 'Payment'`),
    // 7. Sage pipeline records for task status panel
    db.prepare(`
      SELECT financial_records.*, sites.owner_company_name
      FROM financial_records
      INNER JOIN sites ON sites.id = financial_records.site_id
      WHERE financial_records.finance_task_status IS NOT NULL
      ORDER BY financial_records.distribution_date DESC
      LIMIT 100
    `),
    // 8. Sites for create form
    db.prepare(`SELECT id, owner_company_name FROM sites ORDER BY owner_company_name`),
    // 9. Linkable jobs for create form
    db.prepare(`
      SELECT jobs.id, sites.id AS site_id, jobs.status, jobs.scheduled_date, systems.coverage_area
      FROM jobs
      INNER JOIN systems ON systems.id = jobs.system_id
      INNER JOIN sites   ON sites.id   = systems.site_id
      WHERE jobs.deleted_at IS NULL AND systems.deleted_at IS NULL
        AND jobs.status IN ('Completed', 'Invoiced')
      ORDER BY jobs.completed_at DESC
      LIMIT 500
    `),
    // 10. Completed jobs awaiting Sage invoice
    db.prepare(`
      SELECT jobs.id, jobs.completed_at, sites.owner_company_name,
             systems.system_type, systems.coverage_area,
             users.name AS assigned_technician_name
      FROM jobs
      INNER JOIN systems ON systems.id = jobs.system_id
      INNER JOIN sites   ON sites.id   = systems.site_id
      LEFT JOIN  users   ON users.id   = jobs.assigned_technician_id
      WHERE jobs.deleted_at IS NULL AND systems.deleted_at IS NULL
        AND jobs.status = 'Completed' AND jobs.documentation_path IS NOT NULL
      ORDER BY jobs.completed_at DESC
      LIMIT 100
    `),
  ]);

  records = (recordsResult.results ?? []) as DbFinancialRecord[];

  type StatsRow = {
    totalPending: number; totalOverdue: number; pendingAmount: number; overdueAmount: number;
    totalAmount: number; totalSageAmountExVat: number; totalSageVatAmount: number;
    totalSageAmountIncVat: number; totalRecords: number;
  };
  const sr = ((statsResult.results?.[0] as StatsRow | undefined) ?? {}) as Partial<StatsRow>;
  stats = {
    totalPending:          Number(sr.totalPending          ?? 0),
    totalOverdue:          Number(sr.totalOverdue          ?? 0),
    totalAmount:           Number(sr.totalAmount           ?? 0),
    pendingAmount:         Number(sr.pendingAmount         ?? 0),
    overdueAmount:         Number(sr.overdueAmount         ?? 0),
    totalRecords:          Number(sr.totalRecords          ?? 0),
    totalSageAmountExVat:  Number(sr.totalSageAmountExVat  ?? 0),
    totalSageVatAmount:    Number(sr.totalSageVatAmount    ?? 0),
    totalSageAmountIncVat: Number(sr.totalSageAmountIncVat ?? 0),
  };
  totalPages = Math.max(1, Math.ceil(stats.totalRecords / limit));

  pendingApproval = (pendingResult.results    ?? []) as DbFinancialRecord[];
  overduePayments = (overdueResult.results    ?? []) as DbFinancialRecord[];
  paymentsCount   = Number((paymentsCountResult.results?.[0] as { cnt: number } | undefined)?.cnt ?? 0);

  const sagePipelineRecords = (sagePipelineResult.results ?? []) as DbFinancialRecord[];
  const statusCounts = (statusCountsResult.results ?? []) as { status: string; count: number }[];
  sageStatuses = statusCounts.map((sc) => ({
    status:  sc.status,
    count:   sc.count,
    records: sagePipelineRecords.filter((r) => (r.finance_task_status ?? "No Status") === sc.status),
  }));

  sites           = (sitesResult.results          ?? []) as Pick<DbSite, "id" | "owner_company_name">[];
  linkableJobs    = (linkableJobsResult.results   ?? []) as DbLinkableJob[];
  invoiceRequired = (invoiceRequiredResult.results ?? []) as DbInvoiceRequiredJob[];

} catch (error) {
  await auditError(typeof db !== "undefined" ? db : Astro.locals.db, Astro.request, error, { user: typeof user !== "undefined" ? user : Astro.locals.user, metadata: { message: "finance dashboard failed" } });
  loadError = "Finance data could not be loaded.";
}
---

<PortalLayout title="Finance Ledger | Kharon Portal" active="finance" user={user}>
  <section class="bg-gradient-to-r from-[#0B0D0F] to-[#1A1F26] px-4 py-10 text-white sm:px-6 sm:py-12 shadow-inner">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-bold uppercase tracking-wider text-kharon-cyan">Finance Control Panel</p>
      <h1 class="mt-2 text-2xl font-bold sm:text-3xl tracking-tight">Sage Control Register</h1>
      <p class="mt-3 max-w-3xl text-sm text-white/60">Manage invoices, payments, and Sage integration with VAT compliance tracking.</p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto max-w-7xl space-y-6">
      {loadError && <p class="rounded border border-red-300 bg-red-50 p-4 text-sm text-red-800">{loadError}</p>}

      <FinanceCreateForm {sites} {linkableJobs} />

      <FinanceStatsPanel {stats} paymentsCount={paymentsCount} />

      <div class="grid gap-6 lg:grid-cols-2">
        <FinanceExceptionPanel
          {pendingApproval}
          {overduePayments}
          {invoiceRequired}
          stats={{ totalPending: stats.totalPending, totalOverdue: stats.totalOverdue }}
        />
        <FinanceSagePanel
          {sageStatuses}
          stats={{
            totalSageAmountExVat:  stats.totalSageAmountExVat,
            totalSageVatAmount:    stats.totalSageVatAmount,
            totalSageAmountIncVat: stats.totalSageAmountIncVat,
          }}
        />
      </div>

      <FinanceLedgerTable {records} {page} {totalPages} />
    </div>
  </section>
</PortalLayout>
