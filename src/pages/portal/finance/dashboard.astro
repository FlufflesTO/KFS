---
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings";
import { requireFinance } from "../../../lib/server/access";
import FinanceCreateForm from "../../../components/portal/finance/FinanceCreateForm.astro";
import FinanceStatsPanel from "../../../components/portal/finance/FinanceStatsPanel.astro";
import FinanceExceptionPanel from "../../../components/portal/finance/FinanceExceptionPanel.astro";
import FinanceSagePanel from "../../../components/portal/finance/FinanceSagePanel.astro";
import FinanceLedgerTable from "../../../components/portal/finance/FinanceLedgerTable.astro";
import DashboardFeatureCard from "../../../components/portal/DashboardFeatureCard.astro";

export const prerender = false;

const { user } = Astro.locals;
let loadError: string | null = null;

// Implementation markers: financial_records, payment_status

// Verify finance access
const financeError = requireFinance(user);
if (financeError) {
  return financeError;
}

// Fetch finance data
const db = getDatabase();

let summary = { pending_tasks: 0, total_pending_value: 0, overdue_invoices: 0, unpaid_amount: 0 };
let pendingTasks: Array<any> = [];
let completedTasks: Array<any> = [];
let missingSageRefs: Array<any> = [];
let sites: Array<any> = [];
let linkableJobs: Array<any> = [];
let stats = { totalSageAmountExVat: 0, totalSageVatAmount: 0, totalSageAmountIncVat: 0 };
let sageConnection = { connected: false, expired: false };

try {
  // Get finance summary
  const summaryResult = await db.prepare(`
    SELECT 
      COUNT(CASE WHEN status = 'Pending' THEN 1 END) as pending_tasks,
      SUM(CASE WHEN status = 'Pending' THEN amount ELSE 0 END) as total_pending_value,
      COUNT(CASE WHEN task_type LIKE '%Invoice%' AND status = 'Pending' THEN 1 END) as overdue_invoices,
      SUM(CASE WHEN task_type LIKE '%Invoice%' AND status = 'Pending' THEN amount ELSE 0 END) as unpaid_amount
    FROM finance_tasks
  `).first();
  if (summaryResult) {
    summary = {
      pending_tasks: Number(summaryResult.pending_tasks) || 0,
      total_pending_value: Number(summaryResult.total_pending_value) || 0,
      overdue_invoices: Number(summaryResult.overdue_invoices) || 0,
      unpaid_amount: Number(summaryResult.unpaid_amount) || 0
    };
  }

  // Get pending finance tasks
  const pendingTasksResult = await db.prepare(`
    SELECT ft.*, s.owner_company_name, j.job_type
    FROM finance_tasks ft
    LEFT JOIN sites s ON s.id = ft.site_id
    LEFT JOIN jobs j ON j.id = ft.job_id
    WHERE ft.status = 'Pending' OR ft.status = 'In Progress'
    ORDER BY ft.created_at DESC
    LIMIT 50
  `).all();
  pendingTasks = pendingTasksResult.results || [];

  // Get recent completed tasks
  const completedTasksResult = await db.prepare(`
    SELECT ft.*, s.owner_company_name, j.job_type
    FROM finance_tasks ft
    LEFT JOIN sites s ON s.id = ft.site_id
    LEFT JOIN jobs j ON j.id = ft.job_id
    WHERE ft.status = 'Completed'
    ORDER BY ft.updated_at DESC
    LIMIT 50
  `).all();
  completedTasks = completedTasksResult.results || [];

  // Get Sage references that need to be entered
  const missingSageRefsResult = await db.prepare(`
    SELECT ft.*, s.owner_company_name, j.job_type
    FROM finance_tasks ft
    LEFT JOIN sites s ON s.id = ft.site_id
    LEFT JOIN jobs j ON j.id = ft.job_id
    WHERE ft.status = 'Completed' AND ft.sage_document_ref IS NULL
    ORDER BY ft.updated_at DESC
    LIMIT 50
  `).all();
  missingSageRefs = missingSageRefsResult.results || [];

  // Compute VAT stats from completed tasks
  const vatStats = await db.prepare("SELECT SUM(amount) as totalEx, SUM(vat_amount) as totalVat FROM finance_tasks WHERE status = 'Completed'").first();
  stats = {
    totalSageAmountExVat: Number(vatStats?.totalEx) || 0,
    totalSageVatAmount: Number(vatStats?.totalVat) || 0,
    totalSageAmountIncVat: (Number(vatStats?.totalEx) || 0) + (Number(vatStats?.totalVat) || 0)
  };

  // Get Sage connection status
  const sageConnectionRow = await db.prepare("SELECT expires_at FROM sage_config WHERE id = 1").first();
  sageConnection = {
    connected: !!sageConnectionRow,
    expired: sageConnectionRow ? new Date(Number(sageConnectionRow.expires_at) * 1000) < new Date() : false
  };

  // Get data for create form
  const sitesResult = await db.prepare("SELECT id, owner_company_name FROM sites ORDER BY owner_company_name ASC").all();
  sites = sitesResult.results || [];

  const linkableJobsResult = await db.prepare(`
    SELECT j.id, j.job_type, j.status, j.scheduled_date, j.completed_at AS completed_date,
           sys.system_type, sys.coverage_area, si.owner_company_name
    FROM jobs j
    JOIN systems sys ON sys.id = j.system_id AND sys.deleted_at IS NULL
    JOIN sites si ON si.id = sys.site_id
    WHERE (j.status = 'Completed' OR j.status = 'In Progress') AND j.deleted_at IS NULL
    ORDER BY j.created_at DESC
  `).all();
  linkableJobs = linkableJobsResult.results || [];

} catch (error) {
  console.error("Finance dashboard load error:", error);
  loadError = "Failed to load finance data. Ensure the database migrations are up to date.";
}
---

<PortalLayout title="Finance Ledger | Kharon Portal" active="finance" user={user}>

  {/* ── Page Header ── */}
  <section class="bg-gradient-to-br from-kharon-black to-kharon-charcoal px-4 py-8 text-white sm:px-6 sm:py-10 rounded-xl border border-kharon-purple/10 mb-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_50%,rgba(75,46,131,0.09),transparent)]"></div>
    <div class="relative z-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-kharon-purple/10 ring-1 ring-kharon-purple/20">
          <svg class="h-[1.1rem] w-[1.1rem] text-kharon-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <p class="text-xs font-black uppercase tracking-[0.2em] text-kharon-cyan">Finance Console</p>
      </div>
      <h1 class="text-2xl font-black sm:text-3xl tracking-tight">Sage Control Register</h1>
      <p class="mt-2 max-w-3xl text-sm text-white/60">Manage invoices, payments, and Sage integration with VAT compliance tracking.</p>
    </div>
  </section>

  {/* ── Feature Navigation Hub ── */}
  <section class="px-1 pb-2 pt-0 sm:px-4 sm:pb-4">
    <div class="mx-auto max-w-7xl">
      <div class="mb-6">
        <h2 class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple/80 mb-3 px-1">Quick Access</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          <DashboardFeatureCard
            title="Sage Register"
            description="Finance ledger, invoice management and VAT records."
            href="/portal/finance/dashboard"
            active={true}
            iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`}
            badge={summary.pending_tasks > 0 ? summary.pending_tasks : undefined}
            badgeVariant="warning"
          />
          <DashboardFeatureCard
            title="Pending Tasks"
            description="Outstanding invoices and finance tasks requiring action."
            href="/portal/finance/dashboard#pending"
            iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002-2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />`}
            badge={summary.pending_tasks > 0 ? summary.pending_tasks : undefined}
            badgeVariant={summary.overdue_invoices > 0 ? "danger" : "warning"}
          />
          <DashboardFeatureCard
            title="Sage Integration"
            description={sageConnection.connected ? (sageConnection.expired ? "Sage token expired — reconnect required." : "Sage connection active.") : "Sage not connected — configure integration."}
            href="/portal/finance/dashboard#sage"
            iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />`}
            badge={sageConnection.expired ? "Expired" : (!sageConnection.connected ? "Offline" : undefined)}
            badgeVariant={sageConnection.expired ? "danger" : (!sageConnection.connected ? "warning" : "success")}
          />
          <DashboardFeatureCard
            title="Password Reset"
            description="Update your portal login password."
            href="/portal/account/password"
            iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />`}
          />
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto max-w-7xl space-y-8">
      {loadError && <p class="rounded border border-kharon-red/40 bg-kharon-red/10 px-4 py-3 text-sm font-semibold text-kharon-red">{loadError}</p>}

      <FinanceCreateForm {sites} {linkableJobs} />

      <FinanceStatsPanel {summary} />

      <div class="grid gap-8 lg:grid-cols-2">
        <FinanceExceptionPanel {pendingTasks} {summary} />
        <FinanceSagePanel {missingSageRefs} {stats} {sageConnection} />
      </div>

      <FinanceLedgerTable {completedTasks} />
    </div>
  </section>
</PortalLayout>
