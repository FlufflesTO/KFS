---
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";

export const prerender = false;

const user = Astro.locals.user;
let records = [];
let totals = { unpaid: 0, pending: 0, settled: 0 };
let aging = { current: 0, thirty: 0, sixty: 0 };
let loadError = "";

try {
  const db = getDatabase();
  records = (await db.prepare(
    `SELECT financial_records.id, financial_records.amount, financial_records.item_type,
            financial_records.payment_status, financial_records.distribution_date, financial_records.reference,
            sites.owner_company_name, jobs.status AS job_status
     FROM financial_records
     INNER JOIN sites ON sites.id = financial_records.site_id
     LEFT JOIN jobs ON jobs.id = financial_records.job_id
     ORDER BY financial_records.distribution_date DESC
     LIMIT 80`
  ).all()).results || [];

  for (const record of records) {
    const amount = Number(record.amount || 0);
    if (record.payment_status === "Unpaid") totals.unpaid += amount;
    if (record.payment_status === "Pending Approval") totals.pending += amount;
    if (record.payment_status === "Settled") totals.settled += amount;

    if (record.payment_status !== "Settled") {
      const ageDays = Math.max(0, Math.floor((Date.now() - new Date(`${record.distribution_date}T00:00:00Z`).getTime()) / 86400000));
      if (ageDays >= 60) aging.sixty += amount;
      else if (ageDays >= 30) aging.thirty += amount;
      else aging.current += amount;
      record.age_days = ageDays;
    } else {
      record.age_days = 0;
    }
  }
} catch (error) {
  console.error("finance dashboard failed", error);
  loadError = "Finance ledger could not be loaded.";
}
---

<PortalLayout title="Finance Ledger | Kharon Portal" active="finance" user={user}>
  <section class="bg-kharon-black px-4 py-8 text-white sm:px-6 sm:py-10">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-bold uppercase text-kharon-cyan">Finance workspace</p>
      <h1 class="mt-3 text-2xl font-bold sm:text-3xl">Commercial ledger tied to field dispatches</h1>
      <p class="mt-4 max-w-3xl text-white/65">Pending customer invoices, quote approvals, settled payments and dispatch-linked revenue visibility.</p>
      <a class="mt-6 inline-flex rounded-md border border-white/20 px-5 py-3 text-sm font-semibold text-white/80 hover:border-white/40 hover:text-white" href="/portal/api/finance/export">
        Export ledger CSV
      </a>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto grid max-w-7xl gap-6">
      {loadError && <p class="border border-red-300 bg-red-50 p-4 text-red-800">{loadError}</p>}

      <div class="grid gap-4 md:grid-cols-3">
        <article class="border border-kharon-border bg-white p-4 sm:p-5"><p class="text-xs font-bold uppercase text-kharon-purple">Unpaid</p><p class="mt-2 text-2xl font-bold">R {totals.unpaid.toFixed(2)}</p></article>
        <article class="border border-kharon-border bg-white p-4 sm:p-5"><p class="text-xs font-bold uppercase text-kharon-purple">Pending approval</p><p class="mt-2 text-2xl font-bold">R {totals.pending.toFixed(2)}</p></article>
        <article class="border border-kharon-border bg-white p-4 sm:p-5"><p class="text-xs font-bold uppercase text-kharon-purple">Settled</p><p class="mt-2 text-2xl font-bold">R {totals.settled.toFixed(2)}</p></article>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        <article class="border border-kharon-border bg-white p-4 sm:p-5"><p class="text-xs font-bold uppercase text-kharon-blue">Open 0-29 days</p><p class="mt-2 text-xl font-bold">R {aging.current.toFixed(2)}</p></article>
        <article class="border border-kharon-border bg-white p-4 sm:p-5"><p class="text-xs font-bold uppercase text-kharon-purple">Open 30-59 days</p><p class="mt-2 text-xl font-bold">R {aging.thirty.toFixed(2)}</p></article>
        <article class="border border-kharon-border bg-white p-4 sm:p-5"><p class="text-xs font-bold uppercase text-kharon-red">Open 60+ days</p><p class="mt-2 text-xl font-bold">R {aging.sixty.toFixed(2)}</p></article>
      </div>

      <div class="portal-scroll-x border border-kharon-border bg-white">
        <table class="w-full min-w-[760px] border-collapse text-left text-sm">
          <thead class="bg-kharon-charcoal text-white">
            <tr>
              <th class="p-4">Client</th>
              <th class="p-4">Type</th>
              <th class="p-4">Status</th>
              <th class="p-4">Amount</th>
              <th class="p-4">Date</th>
              <th class="p-4">Age</th>
              <th class="p-4">Reference</th>
              <th class="p-4">Action</th>
            </tr>
          </thead>
          <tbody>
            {records.map((record) => (
              <tr class="border-t border-kharon-border">
                <td class="p-4 font-semibold">{record.owner_company_name}</td>
                <td class="p-4">{record.item_type}</td>
                <td class="p-4">{record.payment_status}</td>
                <td class="p-4">R {Number(record.amount).toFixed(2)}</td>
                <td class="p-4">{record.distribution_date}</td>
                <td class="p-4">{record.payment_status === "Settled" ? "-" : `${record.age_days}d`}</td>
                <td class="p-4">{record.reference || record.id}</td>
                <td class="p-4">
                  {record.item_type === "Invoice" && record.payment_status === "Unpaid" ? (
                    <form class="payment-form flex min-w-56 flex-col gap-2" data-record-id={record.id}>
                      <label class="sr-only" for={`payment-${record.id}`}>Payment reference</label>
                      <input id={`payment-${record.id}`} class="rounded-md border border-kharon-border px-3 py-2 text-sm" name="paymentReference" maxlength="80" placeholder="Payment reference" />
                      <button class="rounded-md bg-kharon-purple px-3 py-2 text-sm font-semibold text-white hover:bg-kharon-blue">Mark settled</button>
                      <p class="payment-result text-xs text-kharon-grey" aria-live="polite"></p>
                    </form>
                  ) : (
                    <span class="text-xs uppercase text-kharon-grey/70">No action</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>
  <script>
    for (const form of document.querySelectorAll(".payment-form")) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const result = form.querySelector(".payment-result");
        const refInput = form.querySelector("[name='paymentReference']");
        const ref = refInput?.value?.trim() || "";
        const confirmed = window.confirm(
          `Mark this invoice as settled?\n\nPayment reference: ${ref || "(none entered)"}\n\nThis action cannot be undone.`
        );
        if (!confirmed) return;
        const payload = Object.fromEntries(new FormData(form).entries());
        payload.recordId = form.dataset.recordId;
        result.textContent = "Capturing payment...";

        const response = await window.kharonPortalFetch("/portal/api/finance/payments", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload)
        });
        const body = await response.json().catch(() => ({ ok: false, message: "Payment capture failed." }));
        result.textContent = body.ok ? `Settled: ${body.paymentReference}` : body.message || "Payment capture failed.";
        if (body.ok) window.location.reload();
      });
    }
  </script>
</PortalLayout>
