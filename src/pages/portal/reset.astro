---
import "../../styles/global.css";

export const prerender = false;

const token = Astro.url.searchParams.get("token") || "";
import CsrfInput from "../../components/ui/CsrfInput.astro";
---

<!doctype html>
<html lang="en-ZA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Kharon Portal Password Reset</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="kharon-page-shell kharon-environment kharon-logo-watermark min-h-screen text-white">
    <main class="grid min-h-screen place-items-center px-6 py-12">
      <section class="w-full max-w-md kharon-surface-strong p-6 sm:p-8">
        <img src="/brand/kharon-mark.svg" alt="Kharon Emblem" aria-hidden="true" width="42" height="57" class="mb-6 opacity-80" />
        <p class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Secure operations portal</p>
        <h1 class="mt-3 text-2xl font-bold tracking-tight text-white">Reset Portal Password</h1>
        <p class="mt-3 text-sm leading-relaxed text-kharon-light/70">
          Enter a new password for the issued reset link. You will be asked to rotate it again after sign-in if account policy requires it.
        </p>

        <form id="reset-form" class="mt-6 grid gap-5">
          <CsrfInput />
          <input type="hidden" name="token" value={token} />
          
          <div class="grid gap-2">
            <label for="reset-password" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">New Password</label>
            <input id="reset-password" class="kharon-field" name="password" type="password" minlength="14" autocomplete="new-password" required placeholder="Min 14 characters" />
          </div>

          <div class="grid gap-2">
            <label for="reset-confirmPassword" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Confirm Password</label>
            <input id="reset-confirmPassword" class="kharon-field" name="confirmPassword" type="password" minlength="14" autocomplete="new-password" required placeholder="Confirm new password" />
          </div>

          <p
            id="reset-result"
            role="alert"
            aria-live="polite"
            class="hidden rounded px-4 py-3 text-sm font-semibold"
          ></p>
          
          <button id="reset-submit-btn" class="w-full kharon-command-button py-4 mt-2">
            Reset Password
          </button>
        </form>
      </section>
    </main>

    <script>
      const form = document.querySelector<HTMLFormElement>("#reset-form");
      const result = document.querySelector<HTMLElement>("#reset-result");

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();
        result?.classList.add("hidden");
        const formData = new FormData(form);
        if (formData.get("password") !== formData.get("confirmPassword")) {
          if (result) {
            result.textContent = "Passwords do not match.";
            result.className = "rounded border border-kharon-red bg-kharon-red/10 px-4 py-3 text-sm font-semibold text-red-200";
            result.classList.remove("hidden");
          }
          return;
        }

        const response = await fetch("/portal/api/reset-password", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            token: formData.get("token"),
            password: formData.get("password")
          })
        });
        const body = await response.json() as { ok?: boolean; message?: string; redirectTo?: string } | null;
        if (!response.ok || !body?.ok) {
          if (result) {
            result.textContent = body?.message || "Password reset failed.";
            result.className = "rounded border border-kharon-red bg-kharon-red/10 px-4 py-3 text-sm font-semibold text-red-200";
            result.classList.remove("hidden");
          }
          return;
        }
        if (result) {
          result.textContent = "Password reset. Redirecting to login...";
          result.className = "rounded border border-kharon-green bg-kharon-green/10 px-4 py-3 text-sm font-semibold text-green-200";
          result.classList.remove("hidden");
        }
        window.setTimeout(() => {
          window.location.href = body?.redirectTo || "/portal/login";
        }, 900);
      });
    </script>
  </body>
</html>
