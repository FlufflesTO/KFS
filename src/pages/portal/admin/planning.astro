---
import { auditError } from "../../../lib/server/audit.js";
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";

export const prerender = false;

const user = Astro.locals.user;
const today = new Date();
const todayIso = today.toISOString().slice(0, 10);
const ninetyDaysFromNow = new Date(today.getTime() + 90 * 86400000).toISOString().slice(0, 10);
const params = Astro.url.searchParams;
const schedulePage = Math.max(1, Math.min(999, parseInt(params.get("schedulePage") || "1", 10) || 1));
const lifecyclePage = Math.max(1, Math.min(999, parseInt(params.get("lifecyclePage") || "1", 10) || 1));
const planningPageSize = 30;
const scheduleOffset = (schedulePage - 1) * planningPageSize;
const lifecycleOffset = (lifecyclePage - 1) * planningPageSize;

interface PlanningJob {
  id: string;
  status: string;
  scheduled_date: string;
  job_type: string;
  assigned_technician_id: string | null;
  priority: string;
  is_emergency: number;
  required_by_date: string | null;
  technician_name: string | null;
  system_type: string;
  coverage_area: string;
  owner_company_name: string;
  physical_address: string;
}

interface TechLoad {
  id: string;
  name: string;
  scheduled_count: number;
  in_progress_count: number;
  next_dispatch_date: string | null;
}

interface SystemLifecycle {
  id: string;
  system_type: string;
  coverage_area: string;
  manufacturer: string | null;
  model_reference: string | null;
  last_service_date: string | null;
  next_due_date: string;
  owner_company_name: string;
  physical_address: string;
}

interface OpenRequest {
  id: string;
  request_type: string;
  priority: string;
  status: string;
  subject: string;
  created_at: string;
  owner_company_name: string;
  coverage_area: string | null;
}

let scheduled: PlanningJob[] = [];
let technicianLoad: TechLoad[] = [];
let lifecycle: SystemLifecycle[] = [];
let openRequests: OpenRequest[] = [];
let scheduledTotal = 0;
let lifecycleTotal = 0;
let management = {
  scheduledJobs: 0,
  inProgressJobs: 0,
  overdueSystems: 0,
  dueSoonSystems: 0,
  openCriticalRequests: 0,
  unassignedJobs: 0,
  slaBreachJobs: 0,
  slaWarningJobs: 0
};
let loadError = "";
let db: any = null;

function daysUntil(dateText: string): number | null {
  if (!dateText) return null;
  const target = new Date(`${dateText}T00:00:00Z`).getTime();
  if (Number.isNaN(target)) return null;
  return Math.ceil((target - Date.now()) / 86400000);
}

function riskForDueDate(dateText: string): { label: string; className: string } {
  const days = daysUntil(dateText);
  if (days === null) return { label: "Unknown", className: "border-kharon-purple/20 bg-white/5 text-white/50" };
  if (days < 0) return { label: "Overdue", className: "border-kharon-red/30 bg-kharon-red/20 text-kharon-red" };
  if (days <= 30) return { label: "Due <=30d", className: "border-kharon-amber/35 bg-kharon-amber/20 text-kharon-amber" };
  if (days <= 90) return { label: "Due <=90d", className: "border-kharon-blue/40 bg-kharon-blue/20 text-kharon-cyan" };
  return { label: "Scheduled", className: "border-kharon-green/35 bg-kharon-green/20 text-kharon-green" };
}

function priorityBadge(p: string): string {
  if (p === "Critical") return "bg-kharon-red/20 text-kharon-red border border-kharon-red/30";
  if (p === "High") return "bg-kharon-amber/20 text-kharon-amber border border-kharon-amber/35";
  if (p === "Low") return "bg-white/5 text-white/50 border border-white/10";
  return "bg-kharon-purple/20 text-kharon-cyan border border-kharon-purple/30";
}

function slaLabel(requiredByDate: string | null): { text: string; cls: string } | null {
  if (!requiredByDate) return null;
  const days = daysUntil(requiredByDate);
  if (days === null) return null;
  if (days < 0) return { text: `${-days}d overdue`, cls: "text-kharon-red font-bold" };
  if (days <= 3) return { text: `${days}d`, cls: "text-amber-700 font-semibold" };
  return { text: `${days}d`, cls: "text-emerald-700" };
}

try {
  db = getDatabase();

  const [
    jobAggResult, scheduleCountResult, lifecycleCountResult,
    systemAggResult, requestAggResult,
    scheduledResult, technicianLoadResult, lifecycleResult, openRequestsResult
  ] = await db.batch([
    // ── Full-dataset job counters ────────────────────────────────────────
    db.prepare(`
      SELECT
        SUM(CASE WHEN status = 'Scheduled'   THEN 1 ELSE 0 END) AS scheduled_count,
        SUM(CASE WHEN status = 'In Progress' THEN 1 ELSE 0 END) AS in_progress_count,
        SUM(CASE WHEN status IN ('Scheduled','In Progress') AND assigned_technician_id IS NULL THEN 1 ELSE 0 END) AS unassigned_count,
        SUM(CASE WHEN required_by_date IS NOT NULL AND date(required_by_date) < date('now') AND status IN ('Scheduled','In Progress') THEN 1 ELSE 0 END) AS sla_breach_count,
        SUM(CASE WHEN required_by_date IS NOT NULL AND date(required_by_date) >= date('now') AND date(required_by_date) <= date('now','+3 days') AND status IN ('Scheduled','In Progress') THEN 1 ELSE 0 END) AS sla_warning_count
      FROM jobs
      WHERE deleted_at IS NULL
    `),
    db.prepare(`SELECT COUNT(*) AS total FROM jobs WHERE deleted_at IS NULL AND status IN ('Scheduled', 'In Progress')`),
    db.prepare(`SELECT COUNT(*) AS total FROM systems WHERE deleted_at IS NULL AND date(next_due_date) <= date(?1)`).bind(ninetyDaysFromNow),
    // ── Full-dataset system counters ─────────────────────────────────────
    db.prepare(`
      SELECT
        SUM(CASE WHEN date(next_due_date) < date('now') THEN 1 ELSE 0 END) AS overdue_count,
        SUM(CASE WHEN date(next_due_date) >= date('now') AND date(next_due_date) <= date('now','+30 days') THEN 1 ELSE 0 END) AS due_soon_count
      FROM systems
      WHERE deleted_at IS NULL
    `),
    // ── Full-dataset critical request counter ────────────────────────────
    db.prepare(`
      SELECT COUNT(*) AS count
      FROM maintenance_requests
      WHERE status IN ('New','Reviewing') AND priority = 'Critical'
    `),
    // ── Display lists (paged) ────────────────────────────────────────────
    db.prepare(
      `SELECT jobs.id, jobs.status, jobs.scheduled_date, jobs.job_type, jobs.assigned_technician_id,
              jobs.priority, jobs.is_emergency, jobs.required_by_date,
              users.name AS technician_name, systems.system_type, systems.coverage_area,
              sites.owner_company_name, sites.physical_address
       FROM jobs
       INNER JOIN systems ON systems.id = jobs.system_id
       INNER JOIN sites ON sites.id = systems.site_id
       LEFT JOIN users ON users.id = jobs.assigned_technician_id
       WHERE jobs.deleted_at IS NULL AND systems.deleted_at IS NULL
         AND jobs.status IN ('Scheduled', 'In Progress')
       ORDER BY
         CASE jobs.priority WHEN 'Critical' THEN 1 WHEN 'High' THEN 2 WHEN 'Normal' THEN 3 ELSE 4 END,
         jobs.scheduled_date ASC, sites.owner_company_name ASC
       LIMIT ?1 OFFSET ?2`
    ).bind(planningPageSize, scheduleOffset),
    db.prepare(
      `SELECT users.id, users.name,
              SUM(CASE WHEN jobs.status = 'Scheduled' THEN 1 ELSE 0 END)   AS scheduled_count,
              SUM(CASE WHEN jobs.status = 'In Progress' THEN 1 ELSE 0 END) AS in_progress_count,
              MIN(jobs.scheduled_date) AS next_dispatch_date
       FROM users
       LEFT JOIN jobs ON jobs.assigned_technician_id = users.id AND jobs.deleted_at IS NULL AND jobs.status IN ('Scheduled','In Progress')
       WHERE users.role = 'tech' AND users.is_active = 1
       GROUP BY users.id, users.name
       ORDER BY scheduled_count DESC, in_progress_count DESC, users.name ASC`
    ),
    db.prepare(
      `SELECT systems.id, systems.system_type, systems.coverage_area, systems.manufacturer,
              systems.model_reference, systems.last_service_date, systems.next_due_date,
              sites.owner_company_name, sites.physical_address
       FROM systems
       INNER JOIN sites ON sites.id = systems.site_id
       WHERE systems.deleted_at IS NULL AND date(systems.next_due_date) <= date(?1)
       ORDER BY systems.next_due_date ASC, sites.owner_company_name ASC
       LIMIT ?2 OFFSET ?3`
    ).bind(ninetyDaysFromNow, planningPageSize, lifecycleOffset),
    db.prepare(
      `SELECT maintenance_requests.id, maintenance_requests.request_type, maintenance_requests.priority,
              maintenance_requests.status, maintenance_requests.subject, maintenance_requests.created_at,
              sites.owner_company_name, systems.coverage_area
       FROM maintenance_requests
       INNER JOIN sites ON sites.id = maintenance_requests.site_id
       LEFT JOIN systems ON systems.id = maintenance_requests.system_id AND systems.deleted_at IS NULL
       WHERE maintenance_requests.status IN ('New', 'Reviewing')
       ORDER BY
         CASE maintenance_requests.priority WHEN 'Critical' THEN 1 WHEN 'Urgent' THEN 2 ELSE 3 END,
         maintenance_requests.created_at ASC
       LIMIT 24`
    )
  ]);

  interface JobAgg {
    scheduled_count?: number;
    in_progress_count?: number;
    unassigned_count?: number;
    sla_breach_count?: number;
    sla_warning_count?: number;
  }
  interface SystemAgg {
    overdue_count?: number;
    due_soon_count?: number;
  }
  interface RequestAgg {
    count?: number;
  }

  const jAgg = (jobAggResult.results[0] as JobAgg | undefined) || {};
  const sAgg = (systemAggResult.results[0] as SystemAgg | undefined) || {};
  const rAgg = (requestAggResult.results[0] as RequestAgg | undefined) || {};

  management = {
    scheduledJobs:        Number(jAgg.scheduled_count   ?? 0),
    inProgressJobs:       Number(jAgg.in_progress_count ?? 0),
    unassignedJobs:       Number(jAgg.unassigned_count  ?? 0),
    overdueSystems:       Number(sAgg.overdue_count     ?? 0),
    dueSoonSystems:       Number(sAgg.due_soon_count    ?? 0),
    openCriticalRequests: Number(rAgg.count             ?? 0),
    slaBreachJobs:        Number(jAgg.sla_breach_count  ?? 0),
    slaWarningJobs:       Number(jAgg.sla_warning_count ?? 0)
  };

  scheduled      = (scheduledResult.results      || []) as PlanningJob[];
  technicianLoad = (technicianLoadResult.results || []) as TechLoad[];
  lifecycle      = (lifecycleResult.results      || []) as SystemLifecycle[];
  openRequests   = (openRequestsResult.results   || []) as OpenRequest[];
  scheduledTotal = Number((scheduleCountResult.results[0] as { total: number } | undefined)?.total ?? 0);
  lifecycleTotal = Number((lifecycleCountResult.results[0] as { total: number } | undefined)?.total ?? 0);
} catch (error) {
  await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "admin_planning" });
  loadError = "Planning data could not be loaded.";
}

const scheduleTotalPages = Math.max(1, Math.ceil(scheduledTotal / planningPageSize));
const lifecycleTotalPages = Math.max(1, Math.ceil(lifecycleTotal / planningPageSize));
---

<PortalLayout title="Planning | Kharon Portal" active="planning" user={user}>
  <section class="bg-gradient-to-br from-kharon-black to-kharon-charcoal px-4 py-8 text-white sm:px-6 sm:py-10 kharon-environment rounded-xl border border-kharon-purple/10 mb-6 shadow-inner relative overflow-hidden">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-bold uppercase text-kharon-purple">Operational planning</p>
      <h1 class="mt-3 text-2xl font-bold sm:text-3xl">Dispatch load and lifecycle due calendar</h1>
      <p class="mt-4 max-w-3xl text-white/60">
        Admin planning view for scheduled jobs, technician load, lifecycle exposure and unresolved client requests.
      </p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto grid max-w-7xl gap-6">
      {loadError && <p class="rounded border border-kharon-red/40 bg-kharon-red/10 px-4 py-3 text-sm font-semibold text-kharon-red">{loadError}</p>}

      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <article class="rounded-lg border border-kharon-purple/20 bg-kharon-surface-elevated p-4 backdrop-blur-sm text-white">
          <p class="text-xs font-bold uppercase text-kharon-purple">Scheduled</p>
          <p class="mt-2 text-2xl font-bold text-white">{management.scheduledJobs}</p>
        </article>
        <article class="rounded-lg border border-kharon-purple/20 bg-kharon-surface-elevated p-4 backdrop-blur-sm text-white">
          <p class="text-xs font-bold uppercase text-kharon-cyan">In progress</p>
          <p class="mt-2 text-2xl font-bold text-white">{management.inProgressJobs}</p>
        </article>
        <article class={`rounded-lg border p-4 backdrop-blur-sm ${management.overdueSystems > 0 ? "border-kharon-red/30 bg-kharon-surface-elevated text-white" : "border-kharon-purple/20 bg-kharon-surface-elevated text-white"}`}>
          <p class={`text-xs font-bold uppercase ${management.overdueSystems > 0 ? "text-kharon-red" : "text-kharon-purple"}`}>Overdue systems</p>
          <p class="mt-2 text-2xl font-bold text-white">{management.overdueSystems}</p>
        </article>
        <article class="rounded-lg border border-kharon-purple/20 bg-kharon-surface-elevated p-4 backdrop-blur-sm text-white">
          <p class="text-xs font-bold uppercase text-kharon-purple">Due within 30d</p>
          <p class="mt-2 text-2xl font-bold text-white">{management.dueSoonSystems}</p>
        </article>
        <article class={`rounded-lg border p-4 backdrop-blur-sm ${management.openCriticalRequests > 0 ? "border-kharon-red/30 bg-kharon-surface-elevated text-white" : "border-kharon-purple/20 bg-kharon-surface-elevated text-white"}`}>
          <p class={`text-xs font-bold uppercase ${management.openCriticalRequests > 0 ? "text-kharon-red" : "text-kharon-purple"}`}>Critical requests</p>
          <p class="mt-2 text-2xl font-bold text-white">{management.openCriticalRequests}</p>
        </article>
        <article class={`rounded-lg border p-4 backdrop-blur-sm ${management.unassignedJobs > 0 ? "border-kharon-amber/30 bg-kharon-surface-elevated text-white" : "border-kharon-purple/20 bg-kharon-surface-elevated text-white"}`}>
          <p class={`text-xs font-bold uppercase ${management.unassignedJobs > 0 ? "text-kharon-amber" : "text-kharon-purple"}`}>Unassigned jobs</p>
          <p class="mt-2 text-2xl font-bold text-white">{management.unassignedJobs}</p>
          <a href="/portal/admin/dispatch" class="mt-2 block text-xs font-semibold text-kharon-cyan hover:underline">Dispatch board →</a>
        </article>
        <article class={`rounded-lg border p-4 backdrop-blur-sm ${management.slaBreachJobs > 0 ? "border-kharon-red/30 bg-kharon-surface-elevated text-white" : "border-kharon-purple/20 bg-kharon-surface-elevated text-white"}`}>
          <p class={`text-xs font-bold uppercase ${management.slaBreachJobs > 0 ? "text-kharon-red" : "text-kharon-purple"}`}>SLA breached</p>
          <p class="mt-2 text-2xl font-bold text-white">{management.slaBreachJobs}</p>
          <p class="mt-1 text-xs text-white/50">required-by date passed</p>
        </article>
        <article class={`rounded-lg border p-4 backdrop-blur-sm ${management.slaWarningJobs > 0 ? "border-kharon-amber/30 bg-kharon-surface-elevated text-white" : "border-kharon-purple/20 bg-kharon-surface-elevated text-white"}`}>
          <p class={`text-xs font-bold uppercase ${management.slaWarningJobs > 0 ? "text-kharon-amber" : "text-kharon-purple"}`}>SLA warning</p>
          <p class="mt-2 text-2xl font-bold text-white">{management.slaWarningJobs}</p>
          <p class="mt-1 text-xs text-white/50">due within 3 days</p>
        </article>
      </div>

      <section class="grid gap-6 xl:grid-cols-2">
        <article class="rounded-xl border border-kharon-purple/20 bg-kharon-surface-elevated p-4 sm:p-5 backdrop-blur-sm text-white">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <p class="text-xs font-bold uppercase text-kharon-purple">Dispatch planner</p>
              <h2 class="mt-2 text-xl font-bold text-white">Active schedule</h2>
            </div>
            <a class="rounded-md border border-kharon-purple/40 bg-kharon-charcoal/60 px-4 py-2 text-sm font-semibold text-kharon-cyan hover:bg-kharon-purple/20 hover:text-white transition-all hover:border-kharon-purple" href="/portal/admin/operations">
              Create or adjust job
            </a>
          </div>

          <div class="mt-5 flex flex-wrap items-center gap-3 mb-3">
            <input
              id="schedule-search"
              type="search"
              class="kharon-field text-sm sm:w-auto"
              placeholder="Search site or area…"
              size="22"
            />
            <select id="schedule-status-filter" class="kharon-field text-sm sm:w-auto">
              <option value="">All statuses</option>
              <option value="Scheduled">Scheduled</option>
              <option value="In Progress">In progress</option>
            </select>
          </div>
          <div id="schedule-list" class="grid gap-3">
            {scheduled.length === 0 && <p class="text-white/50 italic py-2 text-sm">No scheduled or in-progress dispatches.</p>}
            {scheduled.map((job) => {
              const jPriority = job.priority || "Normal";
              const jEmergency = job.is_emergency === 1;
              const jSla = slaLabel(job.required_by_date ?? null);
              const jSlaBreached = jSla !== null && jSla.cls.includes("red");
              const jSlaWarning  = jSla !== null && jSla.cls.includes("amber");
              const jBorderCls   = jSlaBreached ? "border-l-4 border-kharon-red bg-red-950/10 border-kharon-red/20 text-white"
                                 : jSlaWarning  ? "border-l-4 border-kharon-amber bg-amber-950/10 border-kharon-amber/20 text-white"
                                 : "border-l-4 border-kharon-blue bg-kharon-black/35 border-kharon-purple/10 text-white";
              return (
                <article
                  class={`grid gap-3 ${jBorderCls} p-4 rounded-lg lg:grid-cols-2`}
                  data-search={`${job.owner_company_name} ${job.coverage_area} ${job.technician_name || ""} ${job.job_type || ""}`}
                  data-status={job.status}
                >
                  <div class="min-w-0">
                    <div class="mb-1 flex flex-wrap gap-2">
                      {jPriority !== "Normal" && (
                        <span class={`rounded px-2 py-0.5 text-xs font-bold ${priorityBadge(jPriority)}`}>{jPriority}</span>
                      )}
                      {jEmergency && (
                        <span class="rounded bg-kharon-red px-2 py-0.5 text-xs font-bold text-white">Emergency</span>
                      )}
                    </div>
                    <p class="font-semibold text-white">{job.owner_company_name}</p>
                    <p class="mt-1 text-sm text-white/60">{job.system_type} / {job.coverage_area}</p>
                    <p class="mt-1 text-sm text-white/50">{job.physical_address}</p>
                  </div>
                  <dl class="grid gap-2 text-sm sm:grid-cols-2">
                    <div><dt class="font-bold uppercase text-white/40">Date</dt><dd class="text-white/80">{job.scheduled_date}</dd></div>
                    <div><dt class="font-bold uppercase text-white/40">Status</dt><dd class="text-white/80">{job.status}</dd></div>
                    <div><dt class="font-bold uppercase text-white/40">Technician</dt><dd class="text-white/80">{job.technician_name || "Unassigned"}</dd></div>
                    <div><dt class="font-bold uppercase text-white/40">Type</dt><dd class="text-white/80">{job.job_type}</dd></div>
                    {jSla && (
                      <div class="col-span-2">
                        <dt class="font-bold uppercase text-white/40">Required by</dt>
                        <dd class={jSla.cls}>{jSla.text}</dd>
                      </div>
                    )}
                  </dl>
                </article>
              );
            })}
          </div>
          <p id="schedule-no-results" class="hidden py-3 text-sm text-white/50">No dispatches match your filter.</p>
          {scheduleTotalPages > 1 && (
            <nav class="mt-5 flex items-center justify-between border-t border-kharon-purple/10 pt-4">
              {schedulePage > 1 ? (
                <a href={`?schedulePage=${schedulePage - 1}&lifecyclePage=${lifecyclePage}`} class="rounded border border-kharon-purple/30 bg-kharon-charcoal/60 px-4 py-2 text-sm font-semibold text-white hover:bg-kharon-purple/20 hover:border-kharon-purple transition-all">Previous</a>
              ) : (
                <span class="rounded border border-kharon-purple/10 bg-kharon-charcoal/30 px-4 py-2 text-sm font-semibold text-white/30 cursor-not-allowed">Previous</span>
              )}
              <span class="text-sm text-white/60">Dispatch page {schedulePage} of {scheduleTotalPages}</span>
              {schedulePage < scheduleTotalPages ? (
                <a href={`?schedulePage=${schedulePage + 1}&lifecyclePage=${lifecyclePage}`} class="rounded border border-kharon-purple/30 bg-kharon-charcoal/60 px-4 py-2 text-sm font-semibold text-white hover:bg-kharon-purple/20 hover:border-kharon-purple transition-all">Next</a>
              ) : (
                <span class="rounded border border-kharon-purple/10 bg-kharon-charcoal/30 px-4 py-2 text-sm font-semibold text-white/30 cursor-not-allowed">Next</span>
              )}
            </nav>
          )}
        </article>

        <article class="rounded-xl border border-kharon-purple/20 bg-kharon-surface-elevated p-4 sm:p-5 backdrop-blur-sm text-white">
          <p class="text-xs font-bold uppercase text-kharon-cyan">Technician load</p>
          <h2 class="mt-2 text-xl font-bold text-white">Capacity snapshot</h2>
          <div class="mt-5 grid gap-3">
            {technicianLoad.length === 0 && <p class="text-white/50 italic py-2 text-sm">No active technicians found.</p>}
            {technicianLoad.map((tech) => (
              <article class="border border-kharon-purple/10 bg-kharon-black/35 p-4 rounded-lg text-white">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <p class="font-semibold text-white">{tech.name}</p>
                  <span class="rounded-md border border-kharon-purple/20 bg-kharon-charcoal/60 px-3 py-1 text-xs font-bold uppercase text-white/70">
                    Next {tech.next_dispatch_date || "none"}
                  </span>
                </div>
                <dl class="mt-4 grid grid-cols-2 gap-3 text-sm">
                  <div><dt class="font-bold uppercase text-white/40">Scheduled</dt><dd class="text-white/80">{tech.scheduled_count || 0}</dd></div>
                  <div><dt class="font-bold uppercase text-white/40">In progress</dt><dd class="text-white/80">{tech.in_progress_count || 0}</dd></div>
                </dl>
              </article>
            ))}
          </div>
        </article>
      </section>

      <section class="grid gap-6 xl:grid-cols-2">
        <article class="rounded-xl border border-kharon-purple/20 bg-kharon-surface-elevated p-4 sm:p-5 backdrop-blur-sm text-white">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <p class="text-xs font-bold uppercase text-kharon-red">Lifecycle due calendar</p>
              <h2 class="mt-2 text-xl font-bold text-white">Due and overdue systems through {ninetyDaysFromNow}</h2>
            </div>
            <span class="rounded-md border border-kharon-purple/20 bg-kharon-charcoal/60 px-3 py-2 text-xs font-bold uppercase text-white/70">Today {todayIso}</span>
          </div>

          <div class="mt-5 mb-3">
            <input
              id="lifecycle-search"
              type="search"
              class="kharon-field text-sm"
              placeholder="Search site, system or area…"
              size="28"
            />
          </div>
          <div id="lifecycle-list" class="grid gap-3">
            {lifecycle.length === 0 && <p class="text-white/50 italic py-2 text-sm">No systems are due in the next 90 days.</p>}
            {lifecycle.map((system) => {
              const risk = riskForDueDate(system.next_due_date);
              return (
                <article
                  class="grid gap-3 border border-kharon-purple/10 bg-kharon-black/35 p-4 rounded-lg lg:grid-cols-2 text-white"
                  data-search={`${system.owner_company_name} ${system.system_type} ${system.coverage_area} ${system.manufacturer || ""} ${system.model_reference || ""}`}
                >
                  <div class="min-w-0">
                    <p class="font-semibold text-white">{system.owner_company_name}</p>
                    <p class="mt-1 text-sm text-white/60">{system.system_type} / {system.coverage_area}</p>
                    <p class="mt-1 text-xs uppercase text-white/40">{system.manufacturer || "Manufacturer not recorded"} / {system.model_reference || "Model not recorded"}</p>
                  </div>
                  <div class="grid gap-2 text-sm">
                    <span class={`rounded-md border px-3 py-2 text-xs font-bold uppercase ${risk.className}`}>{risk.label}</span>
                    <p><span class="font-bold uppercase text-white/40">Next due:</span> <span class="text-white/90">{system.next_due_date}</span></p>
                    <p><span class="font-bold uppercase text-white/40">Last service:</span> <span class="text-white/90">{system.last_service_date || "Not recorded"}</span></p>
                  </div>
                </article>
              );
            })}
          </div>
          <p id="lifecycle-no-results" class="hidden py-3 text-sm text-white/50">No systems match your search.</p>
          {lifecycleTotalPages > 1 && (
            <nav class="mt-5 flex items-center justify-between border-t border-kharon-purple/10 pt-4">
              {lifecyclePage > 1 ? (
                <a href={`?schedulePage=${schedulePage}&lifecyclePage=${lifecyclePage - 1}`} class="rounded border border-kharon-purple/30 bg-kharon-charcoal/60 px-4 py-2 text-sm font-semibold text-white hover:bg-kharon-purple/20 hover:border-kharon-purple transition-all">Previous</a>
              ) : (
                <span class="rounded border border-kharon-purple/10 bg-kharon-charcoal/30 px-4 py-2 text-sm font-semibold text-white/30 cursor-not-allowed">Previous</span>
              )}
              <span class="text-sm text-white/60">Lifecycle page {lifecyclePage} of {lifecycleTotalPages}</span>
              {lifecyclePage < lifecycleTotalPages ? (
                <a href={`?schedulePage=${schedulePage}&lifecyclePage=${lifecyclePage + 1}`} class="rounded border border-kharon-purple/30 bg-kharon-charcoal/60 px-4 py-2 text-sm font-semibold text-white hover:bg-kharon-purple/20 hover:border-kharon-purple transition-all">Next</a>
              ) : (
                <span class="rounded border border-kharon-purple/10 bg-kharon-charcoal/30 px-4 py-2 text-sm font-semibold text-white/30 cursor-not-allowed">Next</span>
              )}
            </nav>
          )}
        </article>

        <article class="rounded-xl border border-kharon-purple/20 bg-kharon-surface-elevated p-4 sm:p-5 backdrop-blur-sm text-white">
          <p class="text-xs font-bold uppercase text-kharon-purple">Open client requests</p>
          <h2 class="mt-2 text-xl font-bold text-white">Review queue</h2>
          <div class="mt-5 grid gap-3">
            {openRequests.length === 0 && <p class="text-white/50 italic py-2 text-sm">No open client requests need planning review.</p>}
            {openRequests.map((request) => (
              <article class="border-l-4 border-kharon-purple bg-kharon-black/35 border border-kharon-purple/10 p-4 rounded-lg text-white">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div class="min-w-0">
                    <p class="font-semibold text-white">{request.owner_company_name}</p>
                    <p class="mt-1 text-sm text-white/70">{request.subject}</p>
                    <p class="mt-1 text-xs uppercase text-white/40">{request.request_type} / {request.coverage_area || "General site request"}</p>
                  </div>
                  <span class="rounded-md border border-kharon-purple/20 bg-kharon-charcoal/60 px-3 py-2 text-xs font-bold uppercase text-white/70">
                    {request.priority}
                  </span>
                </div>
                <p class="mt-3 text-xs uppercase text-white/40">{request.status} / {request.created_at}</p>
              </article>
            ))}
          </div>
        </article>
      </section>
    </div>
  </section>
  <script>
    // ── Active schedule filter ──────────────────────────────────────────────
    const scheduleSearch       = document.getElementById("schedule-search") as HTMLInputElement | null;
    const scheduleStatusFilter = document.getElementById("schedule-status-filter") as HTMLSelectElement | null;
    const scheduleList         = document.getElementById("schedule-list");
    const scheduleNoResults    = document.getElementById("schedule-no-results");

    function applyScheduleFilter() {
      if (!scheduleList) return;
      const q  = (scheduleSearch?.value || "").toLowerCase().trim();
      const sv = scheduleStatusFilter?.value || "";
      const cards = scheduleList.querySelectorAll<HTMLElement>("[data-search]");
      let visible = 0;
      for (const card of cards) {
        const text = (card.dataset.search ?? "").toLowerCase();
        const show =
          (!q  || text.includes(q)) &&
          (!sv || (card.dataset.status ?? "") === sv);
        card.style.display = show ? "" : "none";
        if (show) visible++;
      }
      if (scheduleNoResults) scheduleNoResults.style.display = visible === 0 ? "" : "none";
    }
    scheduleSearch?.addEventListener("input",  applyScheduleFilter);
    scheduleStatusFilter?.addEventListener("change", applyScheduleFilter);

    // ── Lifecycle calendar filter ───────────────────────────────────────────
    const lifecycleSearch    = document.getElementById("lifecycle-search") as HTMLInputElement | null;
    const lifecycleList      = document.getElementById("lifecycle-list");
    const lifecycleNoResults = document.getElementById("lifecycle-no-results");

    function applyLifecycleFilter() {
      if (!lifecycleList) return;
      const q = (lifecycleSearch?.value || "").toLowerCase().trim();
      const cards = lifecycleList.querySelectorAll<HTMLElement>("[data-search]");
      let visible = 0;
      for (const card of cards) {
        const text = (card.dataset.search ?? "").toLowerCase();
        const show = !q || text.includes(q);
        card.style.display = show ? "" : "none";
        if (show) visible++;
      }
      if (lifecycleNoResults) lifecycleNoResults.style.display = visible === 0 ? "" : "none";
    }
    lifecycleSearch?.addEventListener("input", applyLifecycleFilter);
  </script>
</PortalLayout>
