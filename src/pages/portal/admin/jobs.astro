---
import { SITE_CONFIG } from "../../../config/site-config";
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings";
import { requireAdmin } from "../../../lib/server/admin";

export async function getStaticPaths() {
  return [{ params: {} }];
}

const { user } = Astro.locals;

// Verify admin access
const adminError = requireAdmin(user);
if (adminError) {
  return {
    redirect: {
      destination: '/portal/login',
      permanent: false,
    },
  };
}

// Fetch jobs with pagination
const db = getDatabase();
const jobs = await db.prepare(
  `SELECT j.id, j.scheduled_date, j.status, j.priority, j.job_type, 
          s.coverage_area, si.owner_company_name, u.name as technician_name
   FROM jobs j
   LEFT JOIN systems s ON s.id = j.system_id
   LEFT JOIN sites si ON si.id = s.site_id
   LEFT JOIN users u ON u.id = j.assigned_technician_id
   ORDER BY j.scheduled_date DESC
   LIMIT 50`
).all();
---

<PortalLayout user={user}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="sm:flex sm:items-center sm:justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Job Management</h1>
        <p class="mt-1 text-sm text-gray-500">View and manage all jobs</p>
      </div>
    </div>

    <div class="bg-white shadow overflow-hidden sm:rounded-md">
      <ul class="divide-y divide-gray-200">
        {jobs.results?.map((job) => (
          <li key={job.id}>
            <div class="px-4 py-4 sm:px-6">
              <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-kharon-blue truncate">{job.id}</p>
                <div class="ml-2 flex-shrink-0 flex">
                  <span class={`px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${
                    job.status === 'Completed' ? 'bg-green-100 text-green-800' :
                    job.status === 'In Progress' ? 'bg-yellow-100 text-yellow-800' :
                    job.status === 'Scheduled' ? 'bg-blue-100 text-blue-800' :
                    'bg-gray-100 text-gray-800'
                  }`}>
                    {job.status}
                  </span>
                </div>
              </div>
              <div class="mt-2 sm:flex sm:justify-between">
                <div class="sm:flex">
                  <p class="flex items-center text-sm text-gray-500">
                    <span class="font-medium">{job.job_type}</span> • {job.coverage_area}
                  </p>
                </div>
                <div class="mt-2 flex items-center text-sm text-gray-500 sm:mt-0">
                  <p>{new Date(job.scheduled_date).toLocaleDateString()}</p>
                </div>
              </div>
              <div class="mt-2 text-sm text-gray-700">
                <p>
                  <span class="font-medium">{job.owner_company_name}</span> • 
                  {job.technician_name ? ` Assigned: ${job.technician_name}` : ' Unassigned'}
                </p>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</PortalLayout>