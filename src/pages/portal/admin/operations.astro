---
import { auditError } from "../../../lib/server/audit.js";
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import type {
  DbUser,
  DbSite,
  DbSystem,
  DbJob,
  DbContactEnquiry,
  DbDefect,
  DbCertificate,
  DbClientSiteAccess,
} from "@sentinel/types";
import EnquiriesPanel   from "../../../components/portal/admin/EnquiriesPanel.astro";
import JobsPanel        from "../../../components/portal/admin/JobsPanel.astro";
import UsersPanel       from "../../../components/portal/admin/UsersPanel.astro";
import SiteSystemsPanel from "../../../components/portal/admin/SiteSystemsPanel.astro";
import DataPanel        from "../../../components/portal/admin/DataPanel.astro";
import DefectsPanel     from "../../../components/portal/admin/DefectsPanel.astro";
import CertificatesPanel from "../../../components/portal/admin/CertificatesPanel.astro";

export const prerender = false;

const user = Astro.locals.user;
const today    = new Date().toISOString().slice(0, 10);
const soonDate = new Date(Date.now() + 30 * 86400000).toISOString().slice(0, 10);

const params  = Astro.url.searchParams;
const page    = Math.max(1, Math.min(999, parseInt(params.get("page") || "1", 10) || 1));
const perPage = 50;
const offset  = (page - 1) * perPage;

let users:           DbUser[]           = [];
let sites:           DbSite[]           = [];
let systems:         DbSystem[]         = [];
let jobs:            DbJob[]            = [];
let technicians:     DbUser[]           = [];
let clientUsers:     DbUser[]           = [];
let clientSiteAccess: DbClientSiteAccess[] = [];
let contactEnquiries: DbContactEnquiry[] = [];
let defects:         DbDefect[]         = [];
let certificates:    DbCertificate[]    = [];
let jobsTotal    = 0;
let contactsTotal = 0;
let loadError    = "";

try {
  const db = getDatabase();

  jobsTotal     = ((await db.prepare(`SELECT COUNT(*) as total FROM jobs WHERE deleted_at IS NULL`).first()) as { total: number } | null)?.total ?? 0;
  contactsTotal = ((await db.prepare(`SELECT COUNT(*) as total FROM contact_submissions`).first()) as { total: number } | null)?.total ?? 0;

  // LIMIT 1000 prevents unbounded edge-memory growth if datasets grow unexpectedly.
  users = ((await db.prepare(
    `SELECT id, name, email, role, site_id, is_active, force_password_change,
            mfa_required, mfa_enabled, last_login_at
     FROM users
     ORDER BY role, name
     LIMIT 1000`
  ).all()).results ?? []) as DbUser[];

  sites = ((await db.prepare(
    `SELECT id, owner_company_name, physical_address, site_contact_person,
            site_contact_email, site_contact_phone, billing_emails
     FROM sites
     ORDER BY owner_company_name
     LIMIT 1000`
  ).all()).results ?? []) as DbSite[];

  systems = ((await db.prepare(
    `SELECT systems.id, systems.site_id, systems.system_type, systems.coverage_area,
            systems.manufacturer, systems.model_reference, systems.next_due_date,
            systems.service_interval_months, sites.owner_company_name
     FROM systems
     INNER JOIN sites ON sites.id = systems.site_id
     WHERE systems.deleted_at IS NULL
     ORDER BY sites.owner_company_name, systems.coverage_area
     LIMIT 1000`
  ).all()).results ?? []) as DbSystem[];

  jobs = ((await db.prepare(
    `SELECT jobs.id, jobs.system_id, jobs.assigned_technician_id, jobs.scheduled_date,
            jobs.status, jobs.job_type, jobs.site_notes, jobs.priority, jobs.is_emergency,
            jobs.required_by_date, jobs.estimated_duration_minutes,
            systems.coverage_area, sites.owner_company_name
     FROM jobs
     INNER JOIN systems ON systems.id = jobs.system_id
     INNER JOIN sites   ON sites.id   = systems.site_id
     WHERE jobs.deleted_at IS NULL AND systems.deleted_at IS NULL
     ORDER BY jobs.scheduled_date DESC
     LIMIT ? OFFSET ?`
  ).bind(perPage, offset).all()).results ?? []) as DbJob[];

  technicians = users.filter((u) => u.role === "tech"   && u.is_active);
  clientUsers = users.filter((u) => u.role === "client" && u.is_active);

  clientSiteAccess = ((await db.prepare(
    `SELECT client_site_access.user_id, client_site_access.site_id, client_site_access.granted_at,
            users.name AS user_name, users.email AS user_email, sites.owner_company_name
     FROM client_site_access
     INNER JOIN users ON users.id = client_site_access.user_id
     INNER JOIN sites ON sites.id = client_site_access.site_id
     ORDER BY users.name, sites.owner_company_name
     LIMIT 1000`
  ).all()).results ?? []) as DbClientSiteAccess[];

  contactEnquiries = ((await db.prepare(
    `SELECT id, name, email, request_type, message, submitted_at
     FROM contact_submissions
     ORDER BY submitted_at DESC
     LIMIT ? OFFSET ?`
  ).bind(perPage, offset).all()).results ?? []) as DbContactEnquiry[];

  defects = ((await db.prepare(
    `SELECT defects.id, defects.severity, defects.sans_clause_ref, defects.description,
            defects.certificate_blocking, defects.status, defects.created_at,
            systems.id AS system_id, systems.system_type, systems.coverage_area,
            sites.id AS site_id, sites.owner_company_name,
            jobs.id AS job_id
     FROM defects
     INNER JOIN systems ON systems.id = defects.system_id
     INNER JOIN sites   ON sites.id   = systems.site_id
     LEFT  JOIN jobs    ON jobs.id    = defects.job_id AND jobs.deleted_at IS NULL
     WHERE defects.deleted_at IS NULL AND systems.deleted_at IS NULL
     ORDER BY
       CASE defects.severity WHEN 'Critical' THEN 1 WHEN 'Major' THEN 2 WHEN 'Minor' THEN 3 ELSE 4 END,
       defects.created_at DESC
     LIMIT 200`
  ).all()).results ?? []) as DbDefect[];

  certificates = ((await db.prepare(
    `SELECT certificates.id, certificates.certificate_type, certificates.issued_date,
            certificates.expiry_date, certificates.status, certificates.created_at,
            systems.id AS system_id, systems.system_type, systems.coverage_area,
            sites.id AS site_id, sites.owner_company_name,
            jobs.id AS job_id,
            blocking_defect.severity AS blocking_severity,
            blocking_defect.description AS blocking_description
     FROM certificates
     INNER JOIN systems  ON systems.id  = certificates.system_id
     INNER JOIN sites    ON sites.id    = systems.site_id
     LEFT  JOIN jobs     ON jobs.id     = certificates.job_id AND jobs.deleted_at IS NULL
     LEFT  JOIN defects  AS blocking_defect ON blocking_defect.id = certificates.blocked_by_defect_id AND blocking_defect.deleted_at IS NULL
     WHERE certificates.deleted_at IS NULL AND systems.deleted_at IS NULL
     ORDER BY
       CASE certificates.status WHEN 'Blocked' THEN 1 WHEN 'Expired' THEN 2 WHEN 'Revoked' THEN 3 ELSE 4 END,
       certificates.expiry_date ASC
     LIMIT 200`
  ).all()).results ?? []) as DbCertificate[];

} catch (error) {
  await auditError(typeof db !== "undefined" ? db : Astro.locals.db, Astro.request, error, { user: typeof user !== "undefined" ? user : Astro.locals.user, metadata: { message: "admin operations failed" } });
  loadError = "Administration data could not be loaded.";
}

const jobsTotalPages      = Math.max(1, Math.ceil(jobsTotal / perPage));
const contactsTotalPages  = Math.max(1, Math.ceil(contactsTotal / perPage));
---

<PortalLayout title="Admin Operations | Kharon Portal" active="operations" user={user}>
  <section class="bg-kharon-black px-4 py-8 text-white sm:px-6 sm:py-10">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-bold uppercase text-kharon-cyan">Administration</p>
      <h1 class="mt-3 text-2xl font-bold sm:text-3xl">Portal operations control</h1>
      <p class="mt-4 max-w-3xl text-white/65">
        Manage users, client sites, protected systems and scheduled jobs without direct D1 editing.
      </p>
    </div>
  </section>

  <div class="border-b border-kharon-border bg-white">
    <div class="mx-auto flex max-w-7xl flex-wrap gap-1 px-4 py-3 sm:px-6">
      <button data-tab="enquiries"    class="ops-tab rounded-md px-4 py-2 text-sm font-semibold bg-kharon-purple text-white">Enquiries</button>
      <button data-tab="jobs"         class="ops-tab rounded-md px-4 py-2 text-sm font-semibold text-kharon-grey">Jobs</button>
      <button data-tab="users"        class="ops-tab rounded-md px-4 py-2 text-sm font-semibold text-kharon-grey">Users</button>
      <button data-tab="sites"        class="ops-tab rounded-md px-4 py-2 text-sm font-semibold text-kharon-grey">Sites &amp; Systems</button>
      <button data-tab="data"         class="ops-tab rounded-md px-4 py-2 text-sm font-semibold text-kharon-grey">Data</button>
      <button data-tab="defects"      class="ops-tab rounded-md px-4 py-2 text-sm font-semibold text-kharon-grey">Defects</button>
      <button data-tab="certificates" class="ops-tab rounded-md px-4 py-2 text-sm font-semibold text-kharon-grey">Certificates</button>
    </div>
  </div>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    {loadError && (
      <p class="mx-auto mb-6 max-w-7xl border border-red-300 bg-red-50 p-4 text-red-800">{loadError}</p>
    )}

    <EnquiriesPanel   contactEnquiries={contactEnquiries} page={page} totalPages={contactsTotalPages} />
    <JobsPanel        jobs={jobs} systems={systems} technicians={technicians} page={page} totalPages={jobsTotalPages} today={today} />
    <UsersPanel       users={users} sites={sites} />
    <SiteSystemsPanel sites={sites} systems={systems} clientUsers={clientUsers} clientSiteAccess={clientSiteAccess} today={today} soonDate={soonDate} />
    <DataPanel />
    <DefectsPanel     defects={defects} systems={systems} />
    <CertificatesPanel certificates={certificates} systems={systems} today={today} />
  </section>

  <!-- Consolidated typed script: tab switching, filters, form handlers, quick actions -->
  <script>
    import { portalPost, extractFormPayload, setResult, bindAdminForms } from "../../../lib/client/portalApi.ts";

    // ── Tab switching ─────────────────────────────────────────────────────────
    const VALID_TABS = ["enquiries", "jobs", "users", "sites", "data", "defects", "certificates"] as const;
    type TabId = typeof VALID_TABS[number];
    const CLS_ACTIVE   = "ops-tab rounded-md px-4 py-2 text-sm font-semibold bg-kharon-purple text-white";
    const CLS_INACTIVE = "ops-tab rounded-md px-4 py-2 text-sm font-semibold text-kharon-grey";

    function switchTab(tabId: string) {
      const id: TabId = (VALID_TABS as readonly string[]).includes(tabId) ? (tabId as TabId) : "enquiries";
      for (const panel of document.querySelectorAll<HTMLElement>(".ops-panel")) {
        panel.style.display = panel.id === `ops-panel-${id}` ? "grid" : "none";
      }
      for (const btn of document.querySelectorAll<HTMLButtonElement>(".ops-tab")) {
        btn.className = btn.dataset.tab === id ? CLS_ACTIVE : CLS_INACTIVE;
      }
      const url = new URL(location.href);
      url.searchParams.set("tab", id);
      url.searchParams.delete("page");
      url.hash = id;
      history.replaceState(null, "", url.pathname + url.search + url.hash);
    }

    const urlTab  = new URLSearchParams(location.search).get("tab");
    const hashTab = location.hash.slice(1);
    const initialTab = urlTab && (VALID_TABS as readonly string[]).includes(urlTab) ? urlTab :
                       hashTab && (VALID_TABS as readonly string[]).includes(hashTab) ? hashTab : "enquiries";
    switchTab(initialTab);

    for (const btn of document.querySelectorAll<HTMLButtonElement>(".ops-tab")) {
      btn.addEventListener("click", () => switchTab(btn.dataset.tab ?? "enquiries"));
    }

    // ── Panel search / filter ─────────────────────────────────────────────────
    interface FilterSelect { id: string; attr: string; }

    function initFilter(opts: {
      listId: string;
      searchId: string;
      noResultsId: string;
      filterSelects?: FilterSelect[];
    }) {
      const list      = document.getElementById(opts.listId);
      const search    = document.getElementById(opts.searchId) as HTMLInputElement | null;
      const noResults = document.getElementById(opts.noResultsId);
      if (!list || !search) return;
      const selects = (opts.filterSelects ?? []).map((f) => ({
        el: document.getElementById(f.id) as HTMLSelectElement | null,
        attr: f.attr,
      }));
      function apply() {
        const q    = search!.value.toLowerCase().trim();
        const rows = list!.querySelectorAll<HTMLElement>("[data-search]");
        let visible = 0;
        for (const row of rows) {
          const text = (row.dataset.search ?? "").toLowerCase();
          const matchSearch   = !q || text.includes(q);
          const matchSelects  = selects.every((f) => !f.el?.value || (row.dataset[f.attr] ?? "") === f.el.value);
          const show = matchSearch && matchSelects;
          row.style.display = show ? "" : "none";
          if (show) visible++;
        }
        if (noResults) noResults.style.display = visible === 0 ? "" : "none";
      }
      search.addEventListener("input", apply);
      for (const f of selects) f.el?.addEventListener("change", apply);
    }

    initFilter({ listId: "jobs-list",         searchId: "jobs-search",         noResultsId: "jobs-no-results",         filterSelects: [{ id: "jobs-status-filter",         attr: "status"   }] });
    initFilter({ listId: "users-list",        searchId: "users-search",        noResultsId: "users-no-results",        filterSelects: [{ id: "users-role-filter",          attr: "role"     }] });
    initFilter({ listId: "sites-list",        searchId: "sites-search",        noResultsId: "sites-no-results"                                                                                  });
    initFilter({ listId: "systems-list",      searchId: "systems-search",      noResultsId: "systems-no-results",      filterSelects: [{ id: "systems-type-filter",        attr: "systype"  }] });
    initFilter({ listId: "defects-list",      searchId: "defects-search",      noResultsId: "defects-no-results",      filterSelects: [{ id: "defects-severity-filter",    attr: "severity" }, { id: "defects-status-filter", attr: "status" }] });
    initFilter({ listId: "certificates-list", searchId: "certificates-search", noResultsId: "certificates-no-results", filterSelects: [{ id: "certificates-status-filter", attr: "status"   }] });

    // ── Admin CRUD forms (generic) ────────────────────────────────────────────
    bindAdminForms();

    // ── Client site access forms ──────────────────────────────────────────────
    for (const form of document.querySelectorAll<HTMLFormElement>(".client-site-access-form")) {
      form.addEventListener("submit", async (event: Event) => {
        event.preventDefault();
        const result = form.querySelector<HTMLElement>(".client-site-access-result");
        if (result) result.classList.add("hidden");
        const { response, body } = await portalPost(form.dataset.endpoint ?? "", extractFormPayload(form));
        if (!response.ok || !body.ok) {
          setResult(result, body.message ?? "Client site access update failed.", "error");
          return;
        }
        setResult(result, body.action === "grant" ? "Client site access granted." : "Client site access revoked.", "success");
        setTimeout(() => window.location.reload(), 700);
      });
    }

    // ── CSV import forms ──────────────────────────────────────────────────────
    for (const form of document.querySelectorAll<HTMLFormElement>(".import-form")) {
      form.addEventListener("submit", async (event: Event) => {
        event.preventDefault();
        const result = form.querySelector<HTMLElement>(".import-result");
        if (result) result.classList.add("hidden");
        const csv = (form.querySelector<HTMLTextAreaElement>("[name='csv']")?.value ?? "").trim();
        const { response, body } = await portalPost("/portal/api/admin/import", { type: form.dataset.type ?? "", csv });
        if (!response.ok) {
          setResult(result, body.message ?? "Import failed.", "error");
          return;
        }
        const failures = (body.failures as unknown[])?.length ?? 0;
        if (failures) {
          const list = document.createElement("ul");
          list.className = "mt-2 list-disc pl-5 text-xs font-normal";
          for (const f of (body.failures as { rowNumber?: number; message?: string }[])) {
            const li = document.createElement("li");
            li.textContent = `Row ${f.rowNumber ?? "?"}: ${f.message ?? "Unknown error"}`;
            list.append(li);
          }
          setResult(result, `Import completed with ${failures} failed row(s):`, "warning");
          result?.append(list);
        } else {
          setResult(result, `Imported ${(body.results as unknown[])?.length ?? 0} row(s) successfully.`, "success");
        }
      });
    }

    // ── Issue reset link ──────────────────────────────────────────────────────
    for (const btn of document.querySelectorAll<HTMLButtonElement>(".generate-reset-link")) {
      btn.addEventListener("click", async () => {
        const form   = btn.closest<HTMLFormElement>("form");
        const result = form?.querySelector<HTMLElement>(".admin-result");
        if (result) result.classList.add("hidden");
        const { response, body } = await portalPost("/portal/api/admin/users", { action: "reset-link", id: btn.dataset.userId });
        if (!response.ok || !body.ok) {
          setResult(result, body.message ?? "Reset link could not be issued.", "error", "lg:col-span-6");
          return;
        }
        const resetUrl = String(body.resetUrl ?? "");
        setResult(result, `Reset link issued — valid until ${body.expiresAt}. `, "success", "lg:col-span-6");
        const copyBtn = document.createElement("button");
        copyBtn.type = "button";
        copyBtn.textContent = "Copy link";
        copyBtn.className = "ml-1 inline-flex items-center rounded-md border border-emerald-600 px-2 py-0.5 text-xs font-bold text-emerald-800 hover:bg-emerald-100";
        copyBtn.addEventListener("click", async () => {
          await navigator.clipboard.writeText(resetUrl).catch(() => null);
          copyBtn.textContent = "Copied!";
          setTimeout(() => { copyBtn.textContent = "Copy link"; }, 2500);
        });
        result?.append(copyBtn);
      });
    }

    // ── Reset MFA ─────────────────────────────────────────────────────────────
    for (const btn of document.querySelectorAll<HTMLButtonElement>(".reset-mfa")) {
      btn.addEventListener("click", async () => {
        const form   = btn.closest<HTMLFormElement>("form");
        const result = form?.querySelector<HTMLElement>(".admin-result");
        if (result) result.classList.add("hidden");
        const { response, body } = await portalPost("/portal/api/admin/users", { action: "reset-mfa", id: btn.dataset.userId });
        if (!response.ok || !body.ok) {
          setResult(result, body.message ?? "MFA could not be reset.", "error", "lg:col-span-6");
          return;
        }
        setResult(result, "MFA reset. The user must enrol again if MFA is required.", "success", "lg:col-span-6");
      });
    }

    // ── Defect quick actions ──────────────────────────────────────────────────
    async function defectAction(action: string, id: string) {
      const { response, body } = await portalPost("/portal/api/admin/defects", { action, id });
      if (!response.ok || !body.ok) throw new Error((body.message as string) ?? "Action failed.");
      return body;
    }

    for (const btn of document.querySelectorAll<HTMLButtonElement>(".resolve-defect")) {
      btn.addEventListener("click", async () => {
        try { await defectAction("resolve", btn.dataset.id ?? ""); window.location.reload(); }
        catch (err) { alert((err as Error).message ?? "Could not resolve defect."); }
      });
    }
    for (const btn of document.querySelectorAll<HTMLButtonElement>(".close-defect")) {
      btn.addEventListener("click", async () => {
        try { await defectAction("close", btn.dataset.id ?? ""); window.location.reload(); }
        catch (err) { alert((err as Error).message ?? "Could not close defect."); }
      });
    }
    for (const btn of document.querySelectorAll<HTMLButtonElement>(".quote-defect")) {
      btn.addEventListener("click", async () => {
        try { await defectAction("quoteRequired", btn.dataset.id ?? ""); window.location.reload(); }
        catch (err) { alert((err as Error).message ?? "Could not set quote required."); }
      });
    }

    // ── Certificate quick actions ─────────────────────────────────────────────
    async function certAction(action: string, id: string) {
      const { response, body } = await portalPost("/portal/api/admin/certificates", { action, id });
      if (!response.ok || !body.ok) throw new Error((body.message as string) ?? "Action failed.");
      return body;
    }

    for (const btn of document.querySelectorAll<HTMLButtonElement>(".revoke-cert")) {
      btn.addEventListener("click", async () => {
        if (!window.confirm("Confirm revoking this certificate.")) return;
        try { await certAction("revoke", btn.dataset.id ?? ""); window.location.reload(); }
        catch (err) { alert((err as Error).message ?? "Could not revoke certificate."); }
      });
    }
    for (const btn of document.querySelectorAll<HTMLButtonElement>(".expire-cert")) {
      btn.addEventListener("click", async () => {
        if (!window.confirm("Confirm expiring this certificate.")) return;
        try { await certAction("expire", btn.dataset.id ?? ""); window.location.reload(); }
        catch (err) { alert((err as Error).message ?? "Could not expire certificate."); }
      });
    }

    // ── Record relationship navigation ────────────────────────────────────────
    for (const btn of document.querySelectorAll<HTMLButtonElement>(".link-to-section")) {
      btn.addEventListener("click", () => {
        const searchEl = document.getElementById(btn.dataset.targetSearch ?? "") as HTMLInputElement | null;
        if (!searchEl) return;
        searchEl.value = btn.dataset.targetValue ?? "";
        searchEl.dispatchEvent(new Event("input"));
        searchEl.scrollIntoView({ behavior: "smooth", block: "center" });
        searchEl.focus();
      });
    }

    for (const btn of document.querySelectorAll<HTMLButtonElement>(".link-to-tab")) {
      btn.addEventListener("click", () => {
        switchTab(btn.dataset.targetTab ?? "enquiries");
        const searchEl = document.getElementById(btn.dataset.targetSearch ?? "") as HTMLInputElement | null;
        if (!searchEl) return;
        searchEl.value = btn.dataset.targetValue ?? "";
        searchEl.dispatchEvent(new Event("input"));
        requestAnimationFrame(() => {
          searchEl.scrollIntoView({ behavior: "smooth", block: "center" });
          searchEl.focus();
        });
      });
    }
  </script>

  <datalist id="sans-clauses">
    <!-- SANS 10139: Fire detection and alarm systems -->
    <option value="SANS 10139" /><option value="SANS 10139-4.1" /><option value="SANS 10139-4.2" />
    <option value="SANS 10139-4.3" /><option value="SANS 10139-5.1" /><option value="SANS 10139-5.2" />
    <option value="SANS 10139-6.1" /><option value="SANS 10139-6.2" /><option value="SANS 10139-7.1" />
    <option value="SANS 10139-7.2" /><option value="SANS 10139-8.1" /><option value="SANS 10139-8.3" />
    <option value="SANS 10139-9.1" /><option value="SANS 10139-10.1" /><option value="SANS 10139-11.1" />
    <option value="SANS 10139-11.2" />
    <!-- SANS 14520: Gaseous fire-extinguishing systems -->
    <option value="SANS 14520" /><option value="SANS 14520-1" /><option value="SANS 14520-5" />
    <option value="SANS 14520-6" /><option value="SANS 14520-7" /><option value="SANS 14520-9" />
  </datalist>
</PortalLayout>
