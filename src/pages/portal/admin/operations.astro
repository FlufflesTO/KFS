---
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";

export const prerender = false;

const user = Astro.locals.user;
const today    = new Date().toISOString().slice(0, 10);
const soonDate = new Date(Date.now() + 30 * 86400000).toISOString().slice(0, 10);

const params = Astro.url.searchParams;
const activeTab = params.get('tab') || 'enquiries';
const page = Math.max(1, Math.min(999, parseInt(params.get('page') || '1', 10) || 1));
const perPage = 50;
const offset = (page - 1) * perPage;

let users = [];
let sites = [];
let systems = [];
let jobs = [];
let technicians = [];
let clientUsers = [];
let clientSiteAccess = [];
let contactEnquiries = [];
let jobsTotal = 0;
let contactsTotal = 0;
let loadError = "";

try {
  const db = getDatabase();
  jobsTotal = (await db.prepare(`SELECT COUNT(*) as total FROM jobs`).first()).total ?? 0;
  contactsTotal = (await db.prepare(`SELECT COUNT(*) as total FROM contact_submissions`).first()).total ?? 0;
  users = (await db.prepare(
    `SELECT id, name, email, role, site_id, is_active, force_password_change, mfa_required, mfa_enabled, last_login_at
     FROM users
     ORDER BY role, name`
  ).all()).results || [];

  sites = (await db.prepare(
    `SELECT id, owner_company_name, physical_address, site_contact_person, site_contact_email, site_contact_phone, billing_emails
     FROM sites
     ORDER BY owner_company_name`
  ).all()).results || [];

  systems = (await db.prepare(
    `SELECT systems.id, systems.site_id, systems.system_type, systems.coverage_area, systems.manufacturer,
            systems.model_reference, systems.next_due_date, systems.service_interval_months,
            sites.owner_company_name
     FROM systems
     INNER JOIN sites ON sites.id = systems.site_id
     ORDER BY sites.owner_company_name, systems.coverage_area`
  ).all()).results || [];

  jobs = (await db.prepare(
    `SELECT jobs.id, jobs.system_id, jobs.assigned_technician_id, jobs.scheduled_date, jobs.status,
            jobs.job_type, jobs.site_notes, systems.coverage_area, sites.owner_company_name
     FROM jobs
     INNER JOIN systems ON systems.id = jobs.system_id
     INNER JOIN sites ON sites.id = systems.site_id
     ORDER BY jobs.scheduled_date DESC
     LIMIT ? OFFSET ?`
  ).bind(perPage, offset).all()).results || [];

  technicians = users.filter((item) => item.role === "tech" && item.is_active);
  clientUsers = users.filter((item) => item.role === "client" && item.is_active);

  clientSiteAccess = (await db.prepare(
    `SELECT client_site_access.user_id, client_site_access.site_id, client_site_access.granted_at,
            users.name AS user_name, users.email AS user_email, sites.owner_company_name
     FROM client_site_access
     INNER JOIN users ON users.id = client_site_access.user_id
     INNER JOIN sites ON sites.id = client_site_access.site_id
     ORDER BY users.name, sites.owner_company_name`
  ).all()).results || [];

  contactEnquiries = (await db.prepare(
    `SELECT id, name, email, request_type, message, submitted_at
     FROM contact_submissions
     ORDER BY submitted_at DESC
     LIMIT ? OFFSET ?`
  ).bind(perPage, offset).all()).results || [];
} catch (error) {
  console.error("admin operations failed", error);
  loadError = "Administration data could not be loaded.";
}

const jobsTotalPages = Math.max(1, Math.ceil(jobsTotal / perPage));
const contactsTotalPages = Math.max(1, Math.ceil(contactsTotal / perPage));
---

<PortalLayout title="Admin Operations | Kharon Portal" active="operations" user={user}>
  <section class="bg-kharon-black px-4 py-8 text-white sm:px-6 sm:py-10">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-bold uppercase text-kharon-cyan">Administration</p>
      <h1 class="mt-3 text-2xl font-bold sm:text-3xl">Portal operations control</h1>
      <p class="mt-4 max-w-3xl text-white/65">
        Manage users, client sites, protected systems and scheduled jobs without direct D1 editing.
      </p>
    </div>
  </section>

  <!-- Tab navigation -->
  <div class="border-b border-kharon-border bg-white">
    <div class="mx-auto flex max-w-7xl flex-wrap gap-1 px-4 py-3 sm:px-6">
      <button data-tab="enquiries" class="ops-tab rounded-md px-4 py-2 text-sm font-semibold bg-kharon-purple text-white">Enquiries</button>
      <button data-tab="jobs" class="ops-tab rounded-md px-4 py-2 text-sm font-semibold text-kharon-grey">Jobs</button>
      <button data-tab="users" class="ops-tab rounded-md px-4 py-2 text-sm font-semibold text-kharon-grey">Users</button>
      <button data-tab="sites" class="ops-tab rounded-md px-4 py-2 text-sm font-semibold text-kharon-grey">Sites & Systems</button>
      <button data-tab="data" class="ops-tab rounded-md px-4 py-2 text-sm font-semibold text-kharon-grey">Data</button>
    </div>
  </div>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    {loadError && <p class="mx-auto mb-6 max-w-7xl border border-red-300 bg-red-50 p-4 text-red-800">{loadError}</p>}

    <!-- ─── Enquiries panel ─────────────────────────────────────────── -->
    <div id="ops-panel-enquiries" class="ops-panel mx-auto grid max-w-7xl gap-8">
      <article class="border border-kharon-border bg-white p-4 sm:p-5">
        <details class="ops-section" open>
          <summary class="flex cursor-pointer items-center justify-between">
            <div>
              <p class="text-xs font-bold uppercase text-kharon-purple">Public contact form</p>
              <h2 class="mt-1 text-xl font-bold">Website enquiries <span class="ml-2 text-sm font-normal text-kharon-grey">({contactEnquiries.length})</span></h2>
            </div>
            <span class="text-sm text-kharon-purple">Toggle</span>
          </summary>
          <div class="mt-5 grid gap-3">
            {contactEnquiries.length === 0 && (
              <p class="text-kharon-grey">No contact enquiries have been received yet.</p>
            )}
            {contactEnquiries.map((item) => (
              <article class="grid gap-2 border-l-4 border-kharon-blue bg-kharon-light p-4 lg:grid-cols-2">
                <div class="min-w-0">
                  <p class="font-semibold">{item.name}</p>
                  <p class="text-sm text-kharon-purple">
                    <a href={`mailto:${item.email}`} class="hover:underline">{item.email}</a>
                  </p>
                  <p class="mt-1 text-xs font-bold uppercase text-kharon-grey">{item.request_type}</p>
                  <p class="mt-2 text-sm leading-6 text-kharon-black">{item.message}</p>
                </div>
                <div class="text-xs text-kharon-grey">
                  <p>{item.submitted_at?.slice(0, 16).replace("T", " ")} UTC</p>
                </div>
              </article>
            ))}
          </div>
        </details>
      </article>
      <nav class="flex items-center justify-between mt-6 pt-4 border-t border-kharon-border">
        {page > 1 ? (
          <a href={`?tab=enquiries&page=${page - 1}`} class="px-4 py-2 text-sm font-medium rounded border border-kharon-border hover:bg-kharon-light text-kharon-black">Previous</a>
        ) : (
          <span class="px-4 py-2 text-sm font-medium rounded border border-kharon-border text-kharon-grey/50 cursor-not-allowed">Previous</span>
        )}
        <span class="text-sm text-kharon-grey">Page {page} of {contactsTotalPages}</span>
        {page < contactsTotalPages ? (
          <a href={`?tab=enquiries&page=${page + 1}`} class="px-4 py-2 text-sm font-medium rounded border border-kharon-border hover:bg-kharon-light text-kharon-black">Next</a>
        ) : (
          <span class="px-4 py-2 text-sm font-medium rounded border border-kharon-border text-kharon-grey/50 cursor-not-allowed">Next</span>
        )}
      </nav>
    </div>

    <!-- ─── Jobs panel ─────────────────────────────────────────────── -->
    <div id="ops-panel-jobs" class="ops-panel mx-auto grid max-w-7xl gap-8">
      <article class="border border-kharon-border bg-white p-4 sm:p-5">
        <div class="sticky top-0 z-10 mb-4 bg-white flex flex-wrap items-center justify-between gap-3">
          <h2 class="text-xl font-bold">Jobs <span class="ml-2 text-sm font-normal text-kharon-grey">({jobs.length})</span></h2>
          <div class="flex flex-wrap gap-3">
            <input
              id="jobs-search"
              type="search"
              class="rounded-md border border-kharon-border px-3 py-2 text-sm"
              placeholder="Search site or area…"
              size="24"
            />
            <select id="jobs-status-filter" class="rounded-md border border-kharon-border px-3 py-2 text-sm">
              <option value="">All statuses</option>
              {["Scheduled", "In Progress", "Completed", "Invoiced"].map((s) => (
                <option value={s}>{s}</option>
              ))}
            </select>
          </div>
        </div>
        <div id="jobs-list" class="grid gap-4">
          {jobs.map((record) => (
            <form
              class="admin-form grid gap-3 border border-kharon-border bg-kharon-light p-4 lg:grid-cols-7"
              data-endpoint="/portal/api/admin/jobs"
              data-search={`${record.owner_company_name} ${record.coverage_area || ""} ${record.job_type || ""} ${record.site_notes || ""}`}
              data-status={record.status}
            >
              <input type="hidden" name="action" value="update" />
              <input type="hidden" name="id" value={record.id} />
              <select class="rounded-md border border-kharon-border px-3 py-2" name="systemId">
                {systems.map((system) => <option value={system.id} selected={record.system_id === system.id}>{system.owner_company_name} / {system.coverage_area}</option>)}
              </select>
              <select class="rounded-md border border-kharon-border px-3 py-2" name="assignedTechnicianId">
                <option value="">Unassigned</option>
                {technicians.map((tech) => <option value={tech.id} selected={record.assigned_technician_id === tech.id}>{tech.name}</option>)}
              </select>
              <input class="rounded-md border border-kharon-border px-3 py-2" name="scheduledDate" type="date" value={record.scheduled_date} />
              <select class="rounded-md border border-kharon-border px-3 py-2" name="status">
                {["Scheduled", "In Progress", "Completed", "Invoiced"].map((status) => <option value={status} selected={record.status === status}>{status}</option>)}
              </select>
              <input class="rounded-md border border-kharon-border px-3 py-2" name="jobType" value={record.job_type} />
              <input class="rounded-md border border-kharon-border px-3 py-2" name="siteNotes" value={record.site_notes || ""} />
              <button class="rounded-md bg-kharon-blue px-4 py-2 font-semibold text-white">Save</button>
              <p class="admin-result hidden rounded-md border px-4 py-3 text-sm font-semibold lg:col-span-7"></p>
            </form>
          ))}
        </div>
        <p id="jobs-no-results" class="hidden py-4 text-sm text-kharon-grey">No jobs match your filter.</p>
      </article>
      <nav class="flex items-center justify-between mt-6 pt-4 border-t border-kharon-border">
        {page > 1 ? (
          <a href={`?tab=jobs&page=${page - 1}`} class="px-4 py-2 text-sm font-medium rounded border border-kharon-border hover:bg-kharon-light text-kharon-black">Previous</a>
        ) : (
          <span class="px-4 py-2 text-sm font-medium rounded border border-kharon-border text-kharon-grey/50 cursor-not-allowed">Previous</span>
        )}
        <span class="text-sm text-kharon-grey">Page {page} of {jobsTotalPages}</span>
        {page < jobsTotalPages ? (
          <a href={`?tab=jobs&page=${page + 1}`} class="px-4 py-2 text-sm font-medium rounded border border-kharon-border hover:bg-kharon-light text-kharon-black">Next</a>
        ) : (
          <span class="px-4 py-2 text-sm font-medium rounded border border-kharon-border text-kharon-grey/50 cursor-not-allowed">Next</span>
        )}
      </nav>

      <article class="border border-kharon-border bg-white p-4 sm:p-5">
        <h2 class="text-xl font-bold">Create job</h2>
        <form class="admin-form mt-5 grid gap-3" data-endpoint="/portal/api/admin/jobs">
          <input type="hidden" name="action" value="create" />
          <select class="rounded-md border border-kharon-border px-4 py-3" name="systemId" required>
            <option value="">Select system</option>
            {systems.map((system) => <option value={system.id}>{system.owner_company_name} / {system.coverage_area}</option>)}
          </select>
          <select class="rounded-md border border-kharon-border px-4 py-3" name="assignedTechnicianId">
            <option value="">Unassigned</option>
            {technicians.map((tech) => <option value={tech.id}>{tech.name}</option>)}
          </select>
          <input class="rounded-md border border-kharon-border px-4 py-3" name="scheduledDate" type="date" value={today} required />
          <select class="rounded-md border border-kharon-border px-4 py-3" name="status">
            <option value="Scheduled">Scheduled</option>
            <option value="In Progress">In Progress</option>
          </select>
          <input class="rounded-md border border-kharon-border px-4 py-3" name="jobType" value="Maintenance" required />
          <textarea class="min-h-20 rounded-md border border-kharon-border px-4 py-3" name="siteNotes" placeholder="Site notes"></textarea>
          <button class="rounded-md bg-kharon-purple px-5 py-3 font-semibold text-white">Create job</button>
          <p class="admin-result hidden rounded-md border px-4 py-3 text-sm font-semibold"></p>
        </form>
      </article>
    </div>

    <!-- ─── Users panel ────────────────────────────────────────────── -->
    <div id="ops-panel-users" class="ops-panel mx-auto grid max-w-7xl gap-8">
      <article class="border border-kharon-border bg-white p-4 sm:p-5">
        <div class="sticky top-0 z-10 mb-4 bg-white flex flex-wrap items-center justify-between gap-3">
          <h2 class="text-xl font-bold">Users <span class="ml-2 text-sm font-normal text-kharon-grey">({users.length})</span></h2>
          <div class="flex flex-wrap gap-3">
            <input
              id="users-search"
              type="search"
              class="rounded-md border border-kharon-border px-3 py-2 text-sm"
              placeholder="Search name or email…"
              size="24"
            />
            <select id="users-role-filter" class="rounded-md border border-kharon-border px-3 py-2 text-sm">
              <option value="">All roles</option>
              <option value="tech">Technician</option>
              <option value="admin">Admin</option>
              <option value="client">Client</option>
              <option value="finance">Finance</option>
            </select>
          </div>
        </div>
        <div id="users-list" class="grid gap-4">
          {users.map((record) => (
            <form
              class="admin-form grid gap-3 border border-kharon-border bg-kharon-light p-4 lg:grid-cols-6"
              data-endpoint="/portal/api/admin/users"
              data-search={`${record.name} ${record.email} ${record.role}`}
              data-role={record.role}
            >
              <input type="hidden" name="action" value="update" />
              <input type="hidden" name="id" value={record.id} />
              <input class="rounded-md border border-kharon-border px-3 py-2" name="name" value={record.name} />
              <input class="rounded-md border border-kharon-border px-3 py-2" value={record.email} disabled />
              <select class="rounded-md border border-kharon-border px-3 py-2" name="role">
                {["tech", "admin", "client", "finance"].map((role) => <option value={role} selected={record.role === role}>{role}</option>)}
              </select>
              <select class="rounded-md border border-kharon-border px-3 py-2" name="siteId">
                <option value="">No site</option>
                {sites.map((site) => <option value={site.id} selected={record.site_id === site.id}>{site.owner_company_name}</option>)}
              </select>
              <div class="grid gap-2 text-sm">
                <label><input type="checkbox" name="isActive" checked={Boolean(record.is_active)} /> Active</label>
                <label><input type="checkbox" name="forcePasswordChange" checked={Boolean(record.force_password_change)} /> Rotate password</label>
                {["admin", "finance"].includes(record.role) && (
                  <label><input type="checkbox" name="mfaRequired" checked={Boolean(record.mfa_required)} /> Require MFA</label>
                )}
                {record.mfa_enabled && <span class="text-xs font-bold uppercase text-emerald-700">MFA enabled</span>}
              </div>
              <div class="grid gap-2">
                <input class="rounded-md border border-kharon-border px-3 py-2" name="password" type="password" placeholder="Optional reset password" />
                <button class="rounded-md bg-kharon-blue px-4 py-2 font-semibold text-white">Save</button>
                <button class="generate-reset-link rounded-md border border-kharon-purple px-4 py-2 text-sm font-semibold text-kharon-purple" type="button" data-user-id={record.id}>
                  Issue reset link
                </button>
                {record.mfa_enabled && (
                  <button class="reset-mfa rounded-md border border-red-300 bg-red-50 px-4 py-2 text-sm font-semibold text-red-900" type="button" data-user-id={record.id}>
                    Reset MFA
                  </button>
                )}
              </div>
              <p class="admin-result hidden rounded-md border px-4 py-3 text-sm font-semibold lg:col-span-6"></p>
            </form>
          ))}
        </div>
        <p id="users-no-results" class="hidden py-4 text-sm text-kharon-grey">No users match your filter.</p>
      </article>

      <article class="border border-kharon-border bg-white p-4 sm:p-5">
        <h2 class="text-xl font-bold">Create user</h2>
        <form class="admin-form mt-5 grid gap-3" data-endpoint="/portal/api/admin/users">
          <input type="hidden" name="action" value="create" />
          <input class="rounded-md border border-kharon-border px-4 py-3" name="name" placeholder="Full name" required />
          <input class="rounded-md border border-kharon-border px-4 py-3" name="email" type="email" placeholder="email@domain.co.za" required />
          <select class="rounded-md border border-kharon-border px-4 py-3" name="role" required>
            <option value="tech">Technician</option>
            <option value="admin">Admin</option>
            <option value="client">Client</option>
            <option value="finance">Finance</option>
          </select>
          <select class="rounded-md border border-kharon-border px-4 py-3" name="siteId">
            <option value="">No site mapping</option>
            {sites.map((site) => <option value={site.id}>{site.owner_company_name}</option>)}
          </select>
          <input class="rounded-md border border-kharon-border px-4 py-3" name="password" type="password" minlength="14" placeholder="Temporary password" required />
          <label class="flex items-center gap-2 text-sm font-semibold"><input type="checkbox" name="forcePasswordChange" checked /> Force password change</label>
          <label class="flex items-center gap-2 text-sm font-semibold"><input type="checkbox" name="mfaRequired" /> Require MFA for admin/finance roles</label>
          <button class="rounded-md bg-kharon-purple px-5 py-3 font-semibold text-white">Create user</button>
          <p class="admin-result hidden rounded-md border px-4 py-3 text-sm font-semibold"></p>
        </form>
      </article>
    </div>

    <!-- ─── Sites & Systems panel ──────────────────────────────────── -->
    <div id="ops-panel-sites" class="ops-panel mx-auto grid max-w-7xl gap-8">
      <article class="border border-kharon-border bg-white p-4 sm:p-5">
        <div class="sticky top-0 z-10 mb-4 bg-white flex flex-wrap items-center justify-between gap-3">
          <h2 class="text-xl font-bold">Sites <span class="ml-2 text-sm font-normal text-kharon-grey">({sites.length})</span></h2>
          <input
            id="sites-search"
            type="search"
            class="rounded-md border border-kharon-border px-3 py-2 text-sm"
            placeholder="Search company…"
            size="24"
          />
        </div>
        <div id="sites-list" class="grid gap-4">
          {sites.map((record) => (
            <form
              class="admin-form grid gap-3 border border-kharon-border bg-kharon-light p-4 lg:grid-cols-6"
              data-endpoint="/portal/api/admin/sites"
              data-search={`${record.owner_company_name} ${record.site_contact_person || ""} ${record.site_contact_email || ""}`}
            >
              <input type="hidden" name="action" value="update" />
              <input type="hidden" name="id" value={record.id} />
              <input class="rounded-md border border-kharon-border px-3 py-2" name="ownerCompanyName" value={record.owner_company_name} />
              <input class="rounded-md border border-kharon-border px-3 py-2" name="siteContactPerson" value={record.site_contact_person} />
              <input class="rounded-md border border-kharon-border px-3 py-2" name="siteContactEmail" type="email" value={record.site_contact_email || ""} />
              <input class="rounded-md border border-kharon-border px-3 py-2" name="siteContactPhone" value={record.site_contact_phone || ""} />
              <input class="rounded-md border border-kharon-border px-3 py-2" name="billingEmails" value={record.billing_emails} />
              <button class="rounded-md bg-kharon-blue px-4 py-2 font-semibold text-white">Save</button>
              <textarea class="min-h-20 rounded-md border border-kharon-border px-3 py-2 lg:col-span-6" name="physicalAddress">{record.physical_address}</textarea>
              <button type="button" class="link-to-section text-left text-xs font-semibold text-kharon-purple hover:underline lg:col-span-6" data-target-search="systems-search" data-target-value={record.owner_company_name}>-> Systems for {record.owner_company_name}</button>
              <p class="admin-result hidden rounded-md border px-4 py-3 text-sm font-semibold lg:col-span-6"></p>
            </form>
          ))}
        </div>
        <p id="sites-no-results" class="hidden py-4 text-sm text-kharon-grey">No sites match your search.</p>
      </article>

      <article class="border border-kharon-border bg-white p-4 sm:p-5">
        <div class="sticky top-0 z-10 mb-4 bg-white flex flex-wrap items-center justify-between gap-3">
          <h2 class="text-xl font-bold">Systems <span class="ml-2 text-sm font-normal text-kharon-grey">({systems.length})</span></h2>
          <div class="flex flex-wrap gap-3">
            <input
              id="systems-search"
              type="search"
              class="rounded-md border border-kharon-border px-3 py-2 text-sm"
              placeholder="Search site or area…"
              size="24"
            />
            <select id="systems-type-filter" class="rounded-md border border-kharon-border px-3 py-2 text-sm">
              <option value="">All types</option>
              <option value="Gas Suppression">Gas Suppression</option>
              <option value="Fire Detection">Fire Detection</option>
            </select>
          </div>
        </div>
        <div id="systems-list" class="grid gap-4">
          {systems.map((record) => (
            <form
              class="admin-form grid gap-3 border border-kharon-border bg-kharon-light p-4 lg:grid-cols-7"
              data-endpoint="/portal/api/admin/systems"
              data-search={`${record.owner_company_name} ${record.coverage_area} ${record.manufacturer || ""} ${record.model_reference || ""}`}
              data-systype={record.system_type}
            >
              <input type="hidden" name="action" value="update" />
              <input type="hidden" name="id" value={record.id} />
              <select class="rounded-md border border-kharon-border px-3 py-2" name="siteId">
                {sites.map((site) => <option value={site.id} selected={record.site_id === site.id}>{site.owner_company_name}</option>)}
              </select>
              <select class="rounded-md border border-kharon-border px-3 py-2" name="systemType">
                {["Gas Suppression", "Fire Detection"].map((type) => <option value={type} selected={record.system_type === type}>{type}</option>)}
              </select>
              <input class="rounded-md border border-kharon-border px-3 py-2" name="coverageArea" value={record.coverage_area} />
              <input class="rounded-md border border-kharon-border px-3 py-2" name="manufacturer" value={record.manufacturer || ""} />
              <input class="rounded-md border border-kharon-border px-3 py-2" name="modelReference" value={record.model_reference || ""} />
              <input class="rounded-md border border-kharon-border px-3 py-2" name="nextDueDate" type="date" value={record.next_due_date} />
              <div class="flex items-center gap-2">
                <label class="text-xs font-semibold whitespace-nowrap">Interval (mo.)</label>
                <input class="w-16 rounded-md border border-kharon-border px-2 py-2 text-sm" name="serviceIntervalMonths" type="number" min="1" max="36" value={record.service_interval_months ?? 6} />
              </div>
              <button class="rounded-md bg-kharon-blue px-4 py-2 font-semibold text-white">Save</button>
              {record.next_due_date && record.next_due_date < today && (
                <p class="rounded border border-red-300 bg-red-50 px-3 py-2 text-xs font-bold uppercase text-red-900 lg:col-span-7">
                  Warning: Service overdue  -  due {record.next_due_date}. Update after the next completed visit.
                </p>
              )}
              {record.next_due_date && record.next_due_date >= today && record.next_due_date <= soonDate && (
                <p class="rounded border border-amber-300 bg-amber-50 px-3 py-2 text-xs font-bold uppercase text-amber-900 lg:col-span-7">
                  Service due {record.next_due_date}  -  within 30 days.
                </p>
              )}
              <button type="button" class="link-to-tab text-left text-xs font-semibold text-kharon-purple hover:underline lg:col-span-7" data-target-tab="jobs" data-target-search="jobs-search" data-target-value={`${record.owner_company_name} ${record.coverage_area}`}>-> Jobs for {record.coverage_area}</button>
              <p class="admin-result hidden rounded-md border px-4 py-3 text-sm font-semibold lg:col-span-7"></p>
            </form>
          ))}
        </div>
        <p id="systems-no-results" class="hidden py-4 text-sm text-kharon-grey">No systems match your filter.</p>
      </article>

      <article class="border border-kharon-border bg-white p-4 sm:p-5">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="text-xs font-bold uppercase text-kharon-purple">Client account access</p>
            <h2 class="mt-2 text-xl font-bold">Multi-site record mapping</h2>
            <p class="mt-2 max-w-3xl text-sm leading-6 text-kharon-muted">
              Grant additional client site access without changing the user's primary `site_id`. Existing single-site client mapping remains supported.
            </p>
          </div>
          <a class="rounded-md border border-kharon-purple px-4 py-2 text-sm font-semibold text-kharon-purple" href="/portal/client/quotes">
            Client quote view
          </a>
        </div>

        <form class="client-site-access-form mt-5 grid gap-3 lg:grid-cols-3" data-endpoint="/portal/api/admin/client-site-access">
          <select class="portal-field rounded-md border border-kharon-border px-4 py-3" name="userId" required>
            <option value="">Select client user</option>
            {clientUsers.map((client) => <option value={client.id}>{client.name} / {client.email}</option>)}
          </select>
          <select class="portal-field rounded-md border border-kharon-border px-4 py-3" name="siteId" required>
            <option value="">Select site</option>
            {sites.map((site) => <option value={site.id}>{site.owner_company_name}</option>)}
          </select>
          <button class="rounded-md bg-kharon-purple px-5 py-3 font-semibold text-white">Grant access</button>
          <input type="hidden" name="action" value="grant" />
          <p class="client-site-access-result hidden rounded-md border px-4 py-3 text-sm font-semibold lg:col-span-3"></p>
        </form>

        <div class="mt-5 grid gap-3">
          {clientSiteAccess.length === 0 && <p class="text-kharon-grey">No additional client site access mappings have been granted.</p>}
          {clientSiteAccess.map((mapping) => (
            <form class="client-site-access-form flex flex-wrap items-center justify-between gap-3 border border-kharon-border bg-kharon-light p-4" data-endpoint="/portal/api/admin/client-site-access">
              <div>
                <p class="font-semibold">{mapping.user_name} / {mapping.owner_company_name}</p>
                <p class="text-sm text-kharon-grey">{mapping.user_email} / granted {mapping.granted_at}</p>
              </div>
              <input type="hidden" name="action" value="revoke" />
              <input type="hidden" name="userId" value={mapping.user_id} />
              <input type="hidden" name="siteId" value={mapping.site_id} />
              <button class="rounded-md border border-red-300 bg-red-50 px-4 py-2 text-sm font-semibold text-red-900">Revoke</button>
              <p class="client-site-access-result hidden w-full rounded-md border px-4 py-3 text-sm font-semibold"></p>
            </form>
          ))}
        </div>
      </article>

      <div class="grid gap-6 xl:grid-cols-2">
        <article class="border border-kharon-border bg-white p-4 sm:p-5">
          <h2 class="text-xl font-bold">Create site</h2>
          <form class="admin-form mt-5 grid gap-3" data-endpoint="/portal/api/admin/sites">
            <input type="hidden" name="action" value="create" />
            <input class="rounded-md border border-kharon-border px-4 py-3" name="ownerCompanyName" placeholder="Owner company" required />
            <textarea class="min-h-20 rounded-md border border-kharon-border px-4 py-3" name="physicalAddress" placeholder="Physical address" required></textarea>
            <input class="rounded-md border border-kharon-border px-4 py-3" name="siteContactPerson" placeholder="Site contact person" required />
            <input class="rounded-md border border-kharon-border px-4 py-3" name="siteContactEmail" type="email" placeholder="site.contact@example.com" />
            <input class="rounded-md border border-kharon-border px-4 py-3" name="siteContactPhone" placeholder="Site phone" />
            <input class="rounded-md border border-kharon-border px-4 py-3" name="billingEmails" placeholder="billing@example.com" required />
            <button class="rounded-md bg-kharon-purple px-5 py-3 font-semibold text-white">Create site</button>
            <p class="admin-result hidden rounded-md border px-4 py-3 text-sm font-semibold"></p>
          </form>
        </article>

        <article class="border border-kharon-border bg-white p-4 sm:p-5">
          <h2 class="text-xl font-bold">Create system</h2>
          <form class="admin-form mt-5 grid gap-3" data-endpoint="/portal/api/admin/systems">
            <input type="hidden" name="action" value="create" />
            <select class="rounded-md border border-kharon-border px-4 py-3" name="siteId" required>
              <option value="">Select site</option>
              {sites.map((site) => <option value={site.id}>{site.owner_company_name}</option>)}
            </select>
            <select class="rounded-md border border-kharon-border px-4 py-3" name="systemType" required>
              <option value="Gas Suppression">Gas Suppression</option>
              <option value="Fire Detection">Fire Detection</option>
            </select>
            <input class="rounded-md border border-kharon-border px-4 py-3" name="coverageArea" placeholder="Server Room 01" required />
            <input class="rounded-md border border-kharon-border px-4 py-3" name="manufacturer" placeholder="Manufacturer" />
            <input class="rounded-md border border-kharon-border px-4 py-3" name="modelReference" placeholder="Model/reference" />
            <input class="rounded-md border border-kharon-border px-4 py-3" name="nextDueDate" type="date" value={today} required />
            <div class="flex items-center gap-3">
              <label class="whitespace-nowrap text-sm font-semibold">Service interval (months)</label>
              <input class="w-24 rounded-md border border-kharon-border px-3 py-2" name="serviceIntervalMonths" type="number" min="1" max="36" value="6" required />
            </div>
            <button class="rounded-md bg-kharon-purple px-5 py-3 font-semibold text-white">Create system</button>
            <p class="admin-result hidden rounded-md border px-4 py-3 text-sm font-semibold"></p>
          </form>
        </article>
      </div>
    </div>

    <!-- ─── Data panel ──────────────────────────────────────────────── -->
    <div id="ops-panel-data" class="ops-panel mx-auto grid max-w-7xl gap-8">
      <article class="border border-kharon-border bg-white p-4 sm:p-5">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="text-xs font-bold uppercase text-kharon-purple">Bulk administration</p>
            <h2 class="mt-2 text-xl font-bold">CSV import and export</h2>
            <p class="mt-2 max-w-3xl text-sm leading-6 text-kharon-muted">
              Export operational records for review, then import controlled site or system updates using the exact CSV headers shown below.
              User export is read-only; user bulk import remains blocked until password and reset-link delivery controls are approved.
            </p>
          </div>
          <div class="flex flex-wrap gap-2">
            <a class="rounded-md border border-kharon-border px-4 py-2 text-sm font-semibold text-kharon-black" href="/portal/api/admin/export?type=users">Export users</a>
            <a class="rounded-md border border-kharon-border px-4 py-2 text-sm font-semibold text-kharon-black" href="/portal/api/admin/export?type=sites">Export sites</a>
            <a class="rounded-md border border-kharon-border px-4 py-2 text-sm font-semibold text-kharon-black" href="/portal/api/admin/export?type=systems">Export systems</a>
          </div>
        </div>

        <div class="mt-5 grid gap-5 lg:grid-cols-2">
          <form class="import-form grid gap-3" data-type="sites">
            <h3 class="font-bold">Import sites</h3>
            <p class="portal-scroll-x rounded-md bg-kharon-light px-3 py-2 font-mono text-xs whitespace-nowrap">id,owner_company_name,physical_address,site_contact_person,site_contact_email,site_contact_phone,billing_emails</p>
            <textarea class="portal-field min-h-40 rounded-md border border-kharon-border px-4 py-3 font-mono text-xs" name="csv" placeholder="Paste sites CSV here"></textarea>
            <button class="rounded-md bg-kharon-blue px-5 py-3 font-semibold text-white">Import sites</button>
            <p class="import-result hidden rounded-md border px-4 py-3 text-sm font-semibold"></p>
          </form>

          <form class="import-form grid gap-3" data-type="systems">
            <h3 class="font-bold">Import systems</h3>
            <p class="portal-scroll-x rounded-md bg-kharon-light px-3 py-2 font-mono text-xs whitespace-nowrap">id,site_id,system_type,coverage_area,manufacturer,model_reference,next_due_date</p>
            <textarea class="portal-field min-h-40 rounded-md border border-kharon-border px-4 py-3 font-mono text-xs" name="csv" placeholder="Paste systems CSV here"></textarea>
            <button class="rounded-md bg-kharon-blue px-5 py-3 font-semibold text-white">Import systems</button>
            <p class="import-result hidden rounded-md border px-4 py-3 text-sm font-semibold"></p>
          </form>
        </div>
      </article>
    </div>
  </section>

  <script>
    // ─── Tab switching ────────────────────────────────────────────────
    const VALID_TABS = ["enquiries", "jobs", "users", "sites", "data"];
    const CLS_ACTIVE = "ops-tab rounded-md px-4 py-2 text-sm font-semibold bg-kharon-purple text-white";
    const CLS_INACTIVE = "ops-tab rounded-md px-4 py-2 text-sm font-semibold text-kharon-grey";

    function switchTab(tabId: string) {
      const id = VALID_TABS.includes(tabId) ? tabId : "enquiries";
      for (const panel of document.querySelectorAll<HTMLElement>(".ops-panel")) {
        panel.style.display = panel.id === `ops-panel-${id}` ? "grid" : "none";
      }
      for (const btn of document.querySelectorAll<HTMLElement>(".ops-tab")) {
        btn.className = (btn as HTMLButtonElement).dataset.tab === id ? CLS_ACTIVE : CLS_INACTIVE;
      }
      const url = new URL(location.href);
      url.searchParams.set('tab', id);
      url.searchParams.delete('page');
      url.hash = id;
      history.replaceState(null, "", url.pathname + url.search + url.hash);
    }

    const urlTab = new URLSearchParams(location.search).get('tab');
    const hashTab = location.hash.slice(1);
    const initialTab = (urlTab && VALID_TABS.includes(urlTab)) ? urlTab :
                       (hashTab && VALID_TABS.includes(hashTab)) ? hashTab : "enquiries";
    switchTab(initialTab);

    for (const btn of document.querySelectorAll<HTMLButtonElement>(".ops-tab")) {
      btn.addEventListener("click", () => switchTab(btn.dataset.tab ?? "enquiries"));
    }

    // ─── Panel search / filter ────────────────────────────────────────
    interface FilterSelect {
      id: string;
      attr: string;
    }

    function initFilter(opts: {
      listId: string;
      searchId: string;
      noResultsId: string;
      filterSelects?: FilterSelect[];
    }) {
      const list = document.getElementById(opts.listId);
      const search = document.getElementById(opts.searchId) as HTMLInputElement | null;
      const noResults = document.getElementById(opts.noResultsId);
      if (!list || !search) return;

      const selects = (opts.filterSelects ?? []).map((f) => ({
        el: document.getElementById(f.id) as HTMLSelectElement | null,
        attr: f.attr,
      }));

      function apply() {
        const q = search.value.toLowerCase().trim();
        const rows = list!.querySelectorAll<HTMLElement>("[data-search]");
        let visible = 0;
        for (const row of rows) {
          const text = (row.dataset.search ?? "").toLowerCase();
          const matchSearch = !q || text.includes(q);
          const matchSelects = selects.every((f) => {
            if (!f.el?.value) return true;
            return (row.dataset[f.attr] ?? "") === f.el.value;
          });
          const show = matchSearch && matchSelects;
          row.style.display = show ? "" : "none";
          if (show) visible++;
        }
        if (noResults) noResults.style.display = visible === 0 ? "" : "none";
      }

      search.addEventListener("input", apply);
      for (const f of selects) {
        f.el?.addEventListener("change", apply);
      }
    }

    initFilter({
      listId: "jobs-list",
      searchId: "jobs-search",
      noResultsId: "jobs-no-results",
      filterSelects: [{ id: "jobs-status-filter", attr: "status" }],
    });

    initFilter({
      listId: "users-list",
      searchId: "users-search",
      noResultsId: "users-no-results",
      filterSelects: [{ id: "users-role-filter", attr: "role" }],
    });

    initFilter({
      listId: "sites-list",
      searchId: "sites-search",
      noResultsId: "sites-no-results",
    });

    initFilter({
      listId: "systems-list",
      searchId: "systems-search",
      noResultsId: "systems-no-results",
      filterSelects: [{ id: "systems-type-filter", attr: "systype" }],
    });

    // ─── Record relationship navigation ──────────────────────────────
    // link-to-section: pre-fill a search input within the same panel and scroll to it
    for (const btn of document.querySelectorAll<HTMLButtonElement>(".link-to-section")) {
      btn.addEventListener("click", () => {
        const searchEl = document.getElementById(btn.dataset.targetSearch ?? "") as HTMLInputElement | null;
        if (!searchEl) return;
        searchEl.value = btn.dataset.targetValue ?? "";
        searchEl.dispatchEvent(new Event("input"));
        searchEl.scrollIntoView({ behavior: "smooth", block: "center" });
        searchEl.focus();
      });
    }

    // link-to-tab: switch to another tab, then pre-fill its search input
    for (const btn of document.querySelectorAll<HTMLButtonElement>(".link-to-tab")) {
      btn.addEventListener("click", () => {
        const tab = btn.dataset.targetTab ?? "enquiries";
        switchTab(tab);
        const searchEl = document.getElementById(btn.dataset.targetSearch ?? "") as HTMLInputElement | null;
        if (!searchEl) return;
        searchEl.value = btn.dataset.targetValue ?? "";
        searchEl.dispatchEvent(new Event("input"));
        // Allow the tab panel to become visible before scrolling
        requestAnimationFrame(() => {
          searchEl.scrollIntoView({ behavior: "smooth", block: "center" });
          searchEl.focus();
        });
      });
    }
  </script>

  <script is:inline>
    function formPayload(form) {
      const data = {};
      for (const element of form.elements) {
        if (!element.name || element.disabled) continue;
        if (element.type === "checkbox") {
          data[element.name] = element.checked ? "1" : "0";
        } else {
          data[element.name] = element.value;
        }
      }
      return data;
    }

    for (const form of document.querySelectorAll(".admin-form")) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const result = form.querySelector(".admin-result");
        result.classList.add("hidden");

        const response = await window.kharonPortalFetch(form.dataset.endpoint, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(formPayload(form))
        });
        const body = await response.json();
        if (!response.ok || !body.ok) {
          result.textContent = body.message || "Operation failed.";
          result.className = "admin-result rounded-md border border-red-300 bg-red-50 px-4 py-3 text-sm font-semibold text-red-900";
          return;
        }

        result.textContent = `Saved ${body.id || ""}`.trim();
        result.className = "admin-result rounded-md border border-emerald-300 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-900";
        const action = form.querySelector('[name="action"]')?.value || "";
        if (action === "create") {
          result.textContent = "Saved. Refreshing related lists...";
          setTimeout(() => window.location.replace(`${window.location.pathname}${window.location.hash}`), 350);
        }
      });
    }

    for (const form of document.querySelectorAll(".client-site-access-form")) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const result = form.querySelector(".client-site-access-result");
        result.classList.add("hidden");

        const response = await window.kharonPortalFetch(form.dataset.endpoint, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(formPayload(form))
        });
        const body = await response.json().catch(() => ({ ok: false, message: "Client site access update failed." }));
        if (!response.ok || !body.ok) {
          result.textContent = body.message || "Client site access update failed.";
          result.className = "client-site-access-result rounded-md border border-red-300 bg-red-50 px-4 py-3 text-sm font-semibold text-red-900";
          return;
        }

        result.textContent = body.action === "grant" ? "Client site access granted." : "Client site access revoked.";
        result.className = "client-site-access-result rounded-md border border-emerald-300 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-900";
        setTimeout(() => window.location.reload(), 700);
      });
    }

    for (const form of document.querySelectorAll(".import-form")) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const result = form.querySelector(".import-result");
        result.classList.add("hidden");
        const formData = new FormData(form);
        const response = await window.kharonPortalFetch("/portal/api/admin/import", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ type: form.dataset.type, csv: formData.get("csv") })
        });
        const body = await response.json().catch(() => ({ ok: false, message: "Import failed." }));
        if (!response.ok) {
          result.textContent = body.message || "Import failed.";
          result.className = "import-result rounded-md border border-red-300 bg-red-50 px-4 py-3 text-sm font-semibold text-red-900";
          result.classList.remove("hidden");
          return;
        }
        const failures = body.failures?.length || 0;
        if (failures) {
          const list = document.createElement("ul");
          list.className = "mt-2 list-disc pl-5 text-xs font-normal";
          for (const f of body.failures) {
            const li = document.createElement("li");
            li.textContent = `Row ${f.rowNumber ?? "?"}: ${f.message || "Unknown error"}`;
            list.append(li);
          }
          result.textContent = `Import completed with ${failures} failed row(s):`;
          result.className = "import-result rounded-md border border-amber-300 bg-amber-50 px-4 py-3 text-sm font-semibold text-amber-900";
          result.append(list);
        } else {
          result.textContent = `Imported ${body.results?.length || 0} row(s) successfully.`;
          result.className = "import-result rounded-md border border-emerald-300 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-900";
        }
      });
    }

    for (const button of document.querySelectorAll(".generate-reset-link")) {
      button.addEventListener("click", async () => {
        const form = button.closest("form");
        const result = form.querySelector(".admin-result");
        result.classList.add("hidden");
        const response = await window.kharonPortalFetch("/portal/api/admin/users", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ action: "reset-link", id: button.dataset.userId })
        });
        const body = await response.json().catch(() => ({ ok: false, message: "Reset link could not be issued." }));
        if (!response.ok || !body.ok) {
          result.textContent = body.message || "Reset link could not be issued.";
          result.className = "admin-result rounded-md border border-red-300 bg-red-50 px-4 py-3 text-sm font-semibold text-red-900 lg:col-span-6";
          return;
        }
        const resetUrl = String(body.resetUrl || "");
        result.textContent = `Reset link issued  -  valid until ${body.expiresAt}. `;
        result.className = "admin-result rounded-md border border-emerald-300 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-900 lg:col-span-6";
        const copyBtn = document.createElement("button");
        copyBtn.type = "button";
        copyBtn.textContent = "Copy link";
        copyBtn.className = "ml-1 inline-flex items-center rounded-md border border-emerald-600 px-2 py-0.5 text-xs font-bold text-emerald-800 hover:bg-emerald-100";
        copyBtn.addEventListener("click", async () => {
          await navigator.clipboard.writeText(resetUrl).catch(() => null);
          copyBtn.textContent = "Copied!";
          setTimeout(() => { copyBtn.textContent = "Copy link"; }, 2500);
        });
        result.append(copyBtn);
      });
    }

    for (const button of document.querySelectorAll(".reset-mfa")) {
      button.addEventListener("click", async () => {
        const form = button.closest("form");
        const result = form.querySelector(".admin-result");
        result.classList.add("hidden");
        const response = await window.kharonPortalFetch("/portal/api/admin/users", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ action: "reset-mfa", id: button.dataset.userId })
        });
        const body = await response.json().catch(() => ({ ok: false, message: "MFA could not be reset." }));
        if (!response.ok || !body.ok) {
          result.textContent = body.message || "MFA could not be reset.";
          result.className = "admin-result rounded-md border border-red-300 bg-red-50 px-4 py-3 text-sm font-semibold text-red-900 lg:col-span-6";
          return;
        }
        result.textContent = "MFA reset. The user must enrol again if MFA is required.";
        result.className = "admin-result rounded-md border border-emerald-300 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-900 lg:col-span-6";
      });
    }
  </script>
</PortalLayout>
