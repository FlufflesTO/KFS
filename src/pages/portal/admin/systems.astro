---
/**
 * Project Sentinel - Admin Systems
 * Purpose: Admin interface for fire & security systems
 * Dependencies: PortalLayout, getDatabase, requireAdmin
 * Structural Role: Administrative UI for system lifecycle management
 */
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings";
import { requireAdmin } from "../../../lib/server/access";
import type { DbSystem, DbSite } from "@sentinel/types";

export const prerender = false;

const { user } = Astro.locals;
const adminError = requireAdmin(user);
if (adminError) {
  return adminError;
}

const params = Astro.url.searchParams;
const page = Math.max(1, Math.min(999, parseInt(params.get("page") || "1", 10) || 1));
const searchQuery = params.get("q") || "";
const typeFilter = params.get("type") || "";
const perPage = 50;
const offset = (page - 1) * perPage;

let systems: DbSystem[] = [];
let sites: DbSite[] = [];
let systemsTotal = 0;
let loadError = "";

const today = new Date().toISOString().slice(0, 10);
const soonDate = new Date(Date.now() + 30 * 86400000).toISOString().slice(0, 10);

try {
  const db = getDatabase();

  let searchCondition = "";
  const bindParams: string[] = [];

  if (searchQuery) {
    searchCondition += ` AND (sites.owner_company_name LIKE ? OR systems.coverage_area LIKE ? OR systems.manufacturer LIKE ? OR systems.model_reference LIKE ?)`;
    const q = `%${searchQuery}%`;
    bindParams.push(q, q, q, q);
  }

  if (typeFilter) {
    searchCondition += ` AND systems.system_type = ?`;
    bindParams.push(typeFilter);
  }

  const countQuery = `
    SELECT COUNT(*) as total 
    FROM systems 
    INNER JOIN sites ON sites.id = systems.site_id
    WHERE systems.deleted_at IS NULL ${searchCondition}
  `;
  systemsTotal = ((await db.prepare(countQuery).bind(...bindParams).first()) as { total: number } | null)?.total ?? 0;

  const dataQuery = `
    SELECT systems.id, systems.site_id, systems.system_type, systems.coverage_area,
           systems.manufacturer, systems.model_reference, systems.next_due_date,
           systems.service_interval_months, sites.owner_company_name
    FROM systems
    INNER JOIN sites ON sites.id = systems.site_id
    WHERE systems.deleted_at IS NULL ${searchCondition}
    ORDER BY sites.owner_company_name, systems.coverage_area
    LIMIT ? OFFSET ?
  `;

  systems = ((await db.prepare(dataQuery).bind(...bindParams, perPage, offset).all()).results ?? []) as unknown as DbSystem[];

  sites = ((await db.prepare(
    `SELECT id, owner_company_name
     FROM sites
     WHERE deleted_at IS NULL
     ORDER BY owner_company_name
     LIMIT 1000`
  ).all()).results ?? []) as unknown as DbSite[];

} catch (error) {
  loadError = "Systems data could not be loaded.";
}

const totalPages = Math.max(1, Math.ceil(systemsTotal / perPage));
---

<PortalLayout title="System Management | Kharon Portal" active="systems" user={user}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="sm:flex sm:items-center sm:justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-white tracking-tight font-heading">System Management</h1>
        <p class="mt-1 text-sm text-white/60">Manage protected systems and lifecycle service dates</p>
      </div>
    </div>

    {loadError && (
      <p class="mx-auto mb-6 max-w-7xl border border-kharon-red bg-kharon-red/10 p-4 text-red-200 font-semibold">{loadError}</p>
    )}

    <article class="kharon-surface p-4 sm:p-5">
      <div class="mb-4 flex flex-wrap items-end justify-between gap-4 border-b border-line-cyan-soft pb-4">
        <h2 class="text-xl font-bold text-white font-heading">
          Systems <span class="ml-2 text-sm font-normal text-white/60">({systemsTotal})</span>
        </h2>
        <form class="flex flex-wrap items-end gap-3" method="get">
          <div class="grid gap-1">
            <label for="systems-q" class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple">Search</label>
            <input
              id="systems-q"
              name="q"
              type="search"
              class="kharon-field min-w-[200px]"
              placeholder="Search site or area…"
              value={searchQuery}
            />
          </div>
          <div class="grid gap-1">
            <label for="systems-type" class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple">Type</label>
            <select id="systems-type" name="type" class="kharon-field">
              <option value="">All types</option>
              <option value="Gas Suppression" selected={typeFilter === "Gas Suppression"}>Gas Suppression</option>
              <option value="Fire Detection" selected={typeFilter === "Fire Detection"}>Fire Detection</option>
            </select>
          </div>
          <button type="submit" class="kharon-command-button text-xs py-2 px-4 h-[38px] self-end">Filter</button>
          {(searchQuery || typeFilter) && (
            <a href="/portal/admin/systems" class="kharon-secondary-button text-xs py-2 px-4 h-[38px] flex items-center justify-center">Clear</a>
          )}
        </form>
      </div>

      <div class="grid gap-4">
        {systems.length === 0 && <p class="py-4 text-sm text-white/50 italic">No systems match your filter.</p>}
        {systems.map((record) => (
          <form
            class="admin-form grid gap-4 bg-surface-charcoal/40 border border-line-cyan-soft/50 p-4 lg:grid-cols-7 rounded-md"
            data-endpoint="/portal/api/admin/systems"
          >
            <input type="hidden" name="action" value="update" />
            <input type="hidden" name="id" value={record.id} />
            
            <div class="grid gap-1">
              <label for={`site-${record.id}`} class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple">Site</label>
              <select id={`site-${record.id}`} class="kharon-field" name="siteId">
                {sites.map((site) => (
                  <option value={site.id} selected={record.site_id === site.id}>{site.owner_company_name}</option>
                ))}
              </select>
            </div>

            <div class="grid gap-1">
              <label for={`type-${record.id}`} class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple">System Type</label>
              <select id={`type-${record.id}`} class="kharon-field" name="systemType">
                {["Gas Suppression", "Fire Detection"].map((type) => (
                  <option value={type} selected={record.system_type === type}>{type}</option>
                ))}
              </select>
            </div>

            <div class="grid gap-1">
              <label for={`area-${record.id}`} class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple">Coverage Area</label>
              <input id={`area-${record.id}`} class="kharon-field" name="coverageArea" value={record.coverage_area} required />
            </div>

            <div class="grid gap-1">
              <label for={`mfr-${record.id}`} class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple">Manufacturer</label>
              <input id={`mfr-${record.id}`} class="kharon-field" name="manufacturer" value={record.manufacturer || ""} />
            </div>

            <div class="grid gap-1">
              <label for={`model-${record.id}`} class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple">Model Ref</label>
              <input id={`model-${record.id}`} class="kharon-field" name="modelReference" value={record.model_reference || ""} />
            </div>

            <div class="grid gap-1">
              <label for={`due-${record.id}`} class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple">Next Due Date</label>
              <input id={`due-${record.id}`} class="kharon-field" name="nextDueDate" type="date" value={record.next_due_date} />
            </div>

            <div class="grid gap-1">
              <label for={`interval-${record.id}`} class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple">Interval (Mo.)</label>
              <div class="flex gap-2">
                <input id={`interval-${record.id}`} class="kharon-field" name="serviceIntervalMonths" type="number" min="1" max="36" value={record.service_interval_months ?? 6} required />
                <button class="kharon-command-button px-4 py-2 text-xs">Save</button>
              </div>
            </div>

            {record.next_due_date && record.next_due_date < today && (
              <p class="rounded border border-kharon-red bg-kharon-red/10 px-3 py-2 text-xs font-bold uppercase text-red-200 lg:col-span-7">
                Warning: Service overdue — due {record.next_due_date}. Update after the next completed visit.
              </p>
            )}
            {record.next_due_date && record.next_due_date >= today && record.next_due_date <= soonDate && (
              <p class="rounded border border-kharon-amber bg-kharon-amber/10 px-3 py-2 text-xs font-bold uppercase text-amber-200 lg:col-span-7">
                Service due {record.next_due_date} — within 30 days.
              </p>
            )}
            <a href={`/portal/admin/jobs?q=${encodeURIComponent(record.owner_company_name + " " + record.coverage_area)}`} class="text-left text-xs font-semibold text-kharon-purple hover:underline lg:col-span-7">
              &rarr; View Jobs for {record.coverage_area}
            </a>
            <p class="admin-result hidden rounded border px-4 py-3 text-sm font-semibold lg:col-span-7"></p>
          </form>
        ))}
      </div>
    </article>

    <nav class="mt-6 mb-8 flex items-center justify-between border-t border-line-cyan-soft pt-4">
      {page > 1 ? (
        <a href={`?page=${page - 1}&q=${encodeURIComponent(searchQuery)}&type=${encodeURIComponent(typeFilter)}`} class="kharon-secondary-button py-2 text-xs">Previous</a>
      ) : (
        <span class="cursor-not-allowed rounded border border-line-cyan-soft/40 px-4 py-2 text-xs font-semibold text-white/30">Previous</span>
      )}
      <span class="text-sm text-white/60">Page {page} of {totalPages}</span>
      {page < totalPages ? (
        <a href={`?page=${page + 1}&q=${encodeURIComponent(searchQuery)}&type=${encodeURIComponent(typeFilter)}`} class="kharon-secondary-button py-2 text-xs">Next</a>
      ) : (
        <span class="cursor-not-allowed rounded border border-line-cyan-soft/40 px-4 py-2 text-xs font-semibold text-white/30">Next</span>
      )}
    </nav>

    <article class="kharon-surface p-6 sm:p-8">
      <h2 class="text-xl font-bold text-white font-heading">Create system</h2>
      <form class="admin-form mt-5 grid gap-4 md:grid-cols-2 lg:grid-cols-3" data-endpoint="/portal/api/admin/systems">
        <input type="hidden" name="action" value="create" />
        
        <div class="grid gap-1">
          <label for="create-siteId" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Mapped Site *</label>
          <select id="create-siteId" class="kharon-field" name="siteId" required>
            <option value="">Select site</option>
            {sites.map((site) => <option value={site.id}>{site.owner_company_name}</option>)}
          </select>
        </div>

        <div class="grid gap-1">
          <label for="create-systemType" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">System Type *</label>
          <select id="create-systemType" class="kharon-field" name="systemType" required>
            <option value="Gas Suppression">Gas Suppression</option>
            <option value="Fire Detection">Fire Detection</option>
          </select>
        </div>

        <div class="grid gap-1">
          <label for="create-coverageArea" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Coverage Area *</label>
          <input id="create-coverageArea" class="kharon-field" name="coverageArea" placeholder="Server Room 01" required />
        </div>

        <div class="grid gap-1">
          <label for="create-manufacturer" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Manufacturer</label>
          <input id="create-manufacturer" class="kharon-field" name="manufacturer" placeholder="e.g. Inergen" />
        </div>

        <div class="grid gap-1">
          <label for="create-modelReference" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Model/Reference</label>
          <input id="create-modelReference" class="kharon-field" name="modelReference" placeholder="e.g. V-100" />
        </div>

        <div class="grid gap-1">
          <label for="create-nextDueDate" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Next Service Due *</label>
          <input id="create-nextDueDate" class="kharon-field" name="nextDueDate" type="date" value={today} required />
        </div>

        <div class="grid gap-1">
          <label for="create-serviceIntervalMonths" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Service Interval (months) *</label>
          <input id="create-serviceIntervalMonths" class="kharon-field" name="serviceIntervalMonths" type="number" min="1" max="36" value="6" required />
        </div>

        <div class="md:col-span-2 lg:col-span-3 mt-2">
          <button class="w-full kharon-command-button py-3">Create System Record</button>
        </div>
        <p class="admin-result hidden rounded border px-4 py-3 text-sm font-semibold md:col-span-2 lg:col-span-3"></p>
      </form>
    </article>
  </div>
  
  <script>
    import { bindAdminForms } from "../../../lib/client/portalApi";
    bindAdminForms();
  </script>
</PortalLayout>
