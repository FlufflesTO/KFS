---
/**
 * Project Sentinel - Admin Systems
 * Purpose: Admin interface for fire & security systems with elite command aesthetic.
 * Dependencies: PortalLayout, getDatabase, requireAdmin
 * Structural Role: Administrative UI for system lifecycle management
 */
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings";
import { requireAdminOrManager } from "../../../lib/server/access";
import type { DbSystem, DbSite } from "@sentinel/types";

export const prerender = false;

const { user } = Astro.locals;
const adminError = requireAdminOrManager(user);
if (adminError) {
  return adminError;
}

const params = Astro.url.searchParams;
const page = Math.max(1, Math.min(999, parseInt(params.get("page") || "1", 10) || 1));
const searchQuery = params.get("q") || "";
const typeFilter = params.get("type") || "";
const perPage = 50;
const offset = (page - 1) * perPage;

let systems: DbSystem[] = [];
let sites: DbSite[] = [];
let systemsTotal = 0;
let loadError = "";

const today = new Date().toISOString().slice(0, 10);
const soonDate = new Date(Date.now() + 30 * 86400000).toISOString().slice(0, 10);

try {
  const db = getDatabase();

  let searchCondition = "";
  const bindParams: string[] = [];

  if (searchQuery) {
    searchCondition += ` AND (sites.owner_company_name LIKE ? OR systems.coverage_area LIKE ? OR systems.manufacturer LIKE ? OR systems.model_reference LIKE ?)`;
    const q = `%${searchQuery}%`;
    bindParams.push(q, q, q, q);
  }

  if (typeFilter) {
    searchCondition += ` AND systems.system_type = ?`;
    bindParams.push(typeFilter);
  }

  const countQuery = `
    SELECT COUNT(*) as total 
    FROM systems 
    INNER JOIN sites ON sites.id = systems.site_id
    WHERE systems.deleted_at IS NULL ${searchCondition}
  `;
  systemsTotal = ((await db.prepare(countQuery).bind(...bindParams).first()) as { total: number } | null)?.total ?? 0;

  const dataQuery = `
    SELECT systems.id, systems.site_id, systems.system_type, systems.coverage_area,
           systems.manufacturer, systems.model_reference, systems.next_due_date,
           systems.service_interval_months, sites.owner_company_name
    FROM systems
    INNER JOIN sites ON sites.id = systems.site_id
    WHERE systems.deleted_at IS NULL ${searchCondition}
    ORDER BY sites.owner_company_name, systems.coverage_area
    LIMIT ? OFFSET ?
  `;

  systems = ((await db.prepare(dataQuery).bind(...bindParams, perPage, offset).all()).results ?? []) as unknown as DbSystem[];

  sites = ((await db.prepare(
    `SELECT id, owner_company_name
     FROM sites
     WHERE deleted_at IS NULL
     ORDER BY owner_company_name
     LIMIT 1000`
  ).all()).results ?? []) as unknown as DbSite[];

} catch (error) {
  loadError = "Systems data could not be loaded.";
}

// Pre-calculate alerts to avoid '<' in JSX template
const systemsWithAlerts = systems.map(s => ({
  ...s,
  isOverdue: !!(s.next_due_date && s.next_due_date < today),
  isDueSoon: !!(s.next_due_date && s.next_due_date >= today && s.next_due_date <= soonDate)
}));

const totalPages = Math.max(1, Math.ceil(systemsTotal / perPage));
import CsrfInput from "../../../components/ui/CsrfInput.astro";
---

<PortalLayout title="System Management | Kharon Portal" active="systems" user={user}>
  {/* ── Page Header ── */}
  <section class="bg-gradient-to-br from-kharon-black to-kharon-charcoal px-4 py-8 text-white sm:px-6 sm:py-10 rounded-xl border border-kharon-purple/10 mb-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_90%_50%,rgba(75,46,131,0.09),transparent)]"></div>
    <div class="relative z-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-kharon-purple/10 ring-1 ring-kharon-purple/20">
          <svg class="h-[1.1rem] w-[1.1rem] text-kharon-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18" />
          </svg>
        </div>
        <p class="text-xs font-black uppercase tracking-[0.2em] text-kharon-cyan">Infrastructure Console</p>
      </div>
      <h1 class="text-2xl font-black sm:text-3xl tracking-tight text-white">Protection System Registry</h1>
      <p class="mt-2 max-w-3xl text-sm text-kharon-light/60">Manage protected systems, technical specifications, and mission-critical lifecycle cadence.</p>
    </div>
  </section>

  <div class="grid gap-8">
    {loadError && (
      <p class="rounded-lg border border-kharon-red/40 bg-kharon-red/10 px-4 py-3 text-sm font-semibold text-kharon-red">{loadError}</p>
    )}

    {/* ── Search & Filter ── */}
    <div class="flex flex-wrap items-end justify-between gap-6 bg-kharon-charcoal/40 p-5 rounded-xl border border-kharon-purple/10">
      <form class="flex flex-wrap items-end gap-3 flex-1" method="get">
        <div class="grid gap-1 flex-1 min-w-[200px]">
          <label for="systems-q" class="text-[10px] font-black uppercase tracking-widest text-kharon-purple px-1">Global Registry Search</label>
          <input
            id="systems-q"
            name="q"
            type="search"
            class="kharon-field"
            placeholder="Site, area, manufacturer…"
            value={searchQuery}
          />
        </div>
        <div class="grid gap-1 min-w-[160px]">
          <label for="systems-type" class="text-[10px] font-black uppercase tracking-widest text-kharon-purple px-1">System Topology</label>
          <select id="systems-type" name="type" class="kharon-field">
            <option value="">All Architectures</option>
            <option value="Gas Suppression" selected={typeFilter === "Gas Suppression"}>Gas Suppression</option>
            <option value="Fire Detection" selected={typeFilter === "Fire Detection"}>Fire Detection</option>
          </select>
        </div>
        <button type="submit" class="kharon-command-button py-2 px-6 h-[42px] text-[10px]">Filter Matrix</button>
        {(searchQuery || typeFilter) && (
          <a href="/portal/admin/systems" class="kharon-secondary-button py-2 px-4 h-[42px] text-[10px] flex items-center justify-center">Reset</a>
        )}
      </form>
      
      <div class="flex items-center gap-6 px-4 py-2 border-l border-kharon-purple/10">
        <div>
          <p class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">Registered Systems</p>
          <p class="text-2xl font-black text-white leading-none mt-1">{systemsTotal}</p>
        </div>
      </div>
    </div>

    {/* ── Systems Grid ── */}
    <div class="grid gap-6">
      {systemsWithAlerts.length === 0 && (
        <div class="py-20 text-center border border-dashed border-kharon-purple/20 rounded-2xl">
          <p class="text-white/40 font-bold uppercase tracking-widest">No matching architectures in registry</p>
        </div>
      )}
      <div class="grid gap-6">
        {systemsWithAlerts.map((record) => (
          <form
            class={`admin-form group relative grid gap-6 bg-kharon-charcoal/60 border p-6 lg:grid-cols-7 rounded-xl hover:border-kharon-purple/40 transition-all backdrop-blur-md shadow-xl ${record.isOverdue ? 'border-kharon-red/40 bg-kharon-red/5' : 'border-kharon-purple/20'}`}
            data-endpoint="/portal/api/admin/systems"
          >
            <CsrfInput />
            <input type="hidden" name="action" value="update" />
            <input type="hidden" name="id" value={record.id} />
            
            <div class="lg:col-span-2 grid gap-1.5">
              <label for={`site-${record.id}`} class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">Mapped Entity</label>
              <select id={`site-${record.id}`} class="kharon-field text-xs font-bold" name="siteId">
                {sites.map((site) => (
                  <option value={site.id} selected={record.site_id === site.id}>{site.owner_company_name}</option>
                ))}
              </select>
            </div>

            <div class="grid gap-1.5">
              <label for={`type-${record.id}`} class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">Architecture</label>
              <select id={`type-${record.id}`} class="kharon-field text-xs" name="systemType">
                {["Gas Suppression", "Fire Detection"].map((type) => (
                  <option value={type} selected={record.system_type === type}>{type}</option>
                ))}
              </select>
            </div>

            <div class="grid gap-1.5">
              <label for={`area-${record.id}`} class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">Coverage Perimeter</label>
              <input id={`area-${record.id}`} class="kharon-field text-xs" name="coverageArea" value={record.coverage_area} required />
            </div>

            <div class="grid gap-1.5">
              <label for={`mfr-${record.id}`} class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">OEM Manufacturer</label>
              <input id={`mfr-${record.id}`} class="kharon-field text-xs" name="manufacturer" value={record.manufacturer || ""} />
            </div>

            <div class="grid gap-1.5">
              <label for={`model-${record.id}`} class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">Model Signature</label>
              <input id={`model-${record.id}`} class="kharon-field text-xs" name="modelReference" value={record.model_reference || ""} />
            </div>

            <div class="grid gap-1.5 self-end">
              <button class="kharon-command-button w-full py-2.5 text-[10px] h-[40px]">Commit Spec</button>
            </div>

            <div class="lg:col-span-2 grid gap-1.5">
              <label for={`due-${record.id}`} class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">Next Mission-Critical Due Date</label>
              <input id={`due-${record.id}`} class={`kharon-field text-xs font-bold ${record.isOverdue ? 'text-kharon-red' : record.isDueSoon ? 'text-kharon-amber' : 'text-kharon-cyan'}`} type="date" value={record.next_due_date} name="nextDueDate" />
            </div>

            <div class="grid gap-1.5">
              <label for={`interval-${record.id}`} class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">SLA Interval (Mo.)</label>
              <input id={`interval-${record.id}`} class="kharon-field text-xs" name="serviceIntervalMonths" type="number" min="1" max="36" value={record.service_interval_months ?? 6} required />
            </div>

            <div class="lg:col-span-4 flex items-center justify-between gap-6 border-t border-kharon-purple/10 pt-4 mt-2">
              <div class="flex gap-4">
                <a href={`/portal/admin/jobs?q=${encodeURIComponent(record.owner_company_name + " " + record.coverage_area)}`} class="text-[10px] font-black uppercase tracking-widest text-kharon-purple hover:text-kharon-cyan transition-colors">
                  Deployment History &rarr;
                </a>
                <a href={`/portal/admin/compliance?q=${encodeURIComponent(record.id)}`} class="text-[10px] font-black uppercase tracking-widest text-kharon-purple hover:text-kharon-cyan transition-colors">
                  SANS Audit Log &rarr;
                </a>
              </div>
              <span class="text-[10px] font-mono text-white/20 uppercase tracking-tighter">REF: {record.id.slice(0, 8)}</span>
            </div>
            
            {record.isOverdue && (
              <div class="lg:col-span-7 mt-2 p-3 rounded bg-kharon-red/10 border border-kharon-red/30 flex items-center gap-3">
                <span class="h-1.5 w-1.5 rounded-full bg-kharon-red animate-ping"></span>
                <p class="text-[10px] font-black uppercase tracking-widest text-kharon-red">Critical Alert: Hardware maintenance is overdue since {record.next_due_date}.</p>
              </div>
            )}
            
            <p class="admin-result hidden rounded border px-4 py-3 text-[10px] font-bold uppercase tracking-widest lg:col-span-7"></p>
          </form>
        ))}
      </div>
    </div>

    {/* ── Pagination ── */}
    {totalPages > 1 && (
      <nav class="flex items-center justify-between border-t border-kharon-purple/10 pt-6">
        {page > 1 ? (
          <a href={`?page=${page - 1}&q=${encodeURIComponent(searchQuery)}&type=${encodeURIComponent(typeFilter)}`} class="kharon-secondary-button py-2.5 px-6 text-[10px]">Previous Batch</a>
        ) : (
          <span class="opacity-30 rounded border border-kharon-purple/20 px-6 py-2.5 text-[10px] font-black uppercase text-white">Previous</span>
        )}
        <span class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">Sequence {page} of {totalPages}</span>
        {page < totalPages ? (
          <a href={`?page=${page + 1}&q=${encodeURIComponent(searchQuery)}&type=${encodeURIComponent(typeFilter)}`} class="kharon-secondary-button py-2.5 px-6 text-[10px]">Next Batch</a>
        ) : (
          <span class="opacity-30 rounded border border-kharon-purple/20 px-6 py-2.5 text-[10px] font-black uppercase text-white">Next</span>
        )}
      </nav>
    )}

    {/* ── System Creation ── */}
    <article class="bg-kharon-charcoal/60 border border-kharon-purple/20 p-8 rounded-xl backdrop-blur-md shadow-2xl">
      <div class="mb-8">
        <p class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">Registry Entry</p>
        <h2 class="mt-1 text-xl font-black text-white uppercase tracking-widest">Initialize New Architecture</h2>
      </div>

      <form class="admin-form grid gap-6 md:grid-cols-2 lg:grid-cols-3" data-endpoint="/portal/api/admin/systems">
        <CsrfInput />
        <input type="hidden" name="action" value="create" />
        
        <div class="grid gap-1.5">
          <label for="create-siteId" class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">Host Site Registry *</label>
          <select id="create-siteId" class="kharon-field text-xs py-2" name="siteId" required>
            <option value="">— Select Host Site —</option>
            {sites.map((site) => <option value={site.id}>{site.owner_company_name}</option>)}
          </select>
        </div>

        <div class="grid gap-1.5">
          <label for="create-systemType" class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">System Topology *</label>
          <select id="create-systemType" class="kharon-field text-xs py-2" name="systemType" required>
            <option value="Gas Suppression">Gas Suppression Architecture</option>
            <option value="Fire Detection">Fire Detection Architecture</option>
          </select>
        </div>

        <div class="grid gap-1.5">
          <label for="create-coverageArea" class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">Operational Perimeter *</label>
          <input id="create-coverageArea" class="kharon-field text-xs" name="coverageArea" placeholder="e.g. Server Room A / Level 04" required />
        </div>

        <div class="grid gap-1.5">
          <label for="create-manufacturer" class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">OEM Manufacturer</label>
          <input id="create-manufacturer" class="kharon-field text-xs" name="manufacturer" placeholder="e.g. Technoswitch / Kentec" />
        </div>

        <div class="grid gap-1.5">
          <label for="create-modelReference" class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">Reference / Version</label>
          <input id="create-modelReference" class="kharon-field text-xs" name="modelReference" placeholder="e.g. V-1000-AD" />
        </div>

        <div class="grid gap-1.5">
          <label for="create-nextDueDate" class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">Initial Compliance Due *</label>
          <input id="create-nextDueDate" class="kharon-field text-xs" name="nextDueDate" type="date" value={today} required />
        </div>

        <div class="grid gap-1.5">
          <label for="create-serviceIntervalMonths" class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">Regulatory Interval (Months) *</label>
          <input id="create-serviceIntervalMonths" class="kharon-field text-xs" name="serviceIntervalMonths" type="number" min="1" max="36" value="6" required />
        </div>

        <div class="md:col-span-2 lg:col-span-3 mt-4">
          <button class="w-full kharon-command-button py-4 text-[11px]">Deploy Architecture to Registry</button>
        </div>
        <p class="admin-result hidden rounded border px-4 py-3 text-[10px] font-bold uppercase tracking-widest md:col-span-2 lg:col-span-3"></p>
      </form>
    </article>
  </div>
  
  <script>
    import { bindAdminForms } from "../../../lib/client/portalApi";
    bindAdminForms();
  </script>
</PortalLayout>
