---
import { SITE_CONFIG } from "../../../config/site-config";
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings";
import { requireAdmin } from "../../../lib/server/admin";

export async function getStaticPaths() {
  return [{ params: {} }];
}

const { user } = Astro.locals;

// Verify admin access
const adminError = requireAdmin(user);
if (adminError) {
  return {
    redirect: {
      destination: '/portal/login',
      permanent: false,
    },
  };
}

// Fetch contact enquiries
const db = getDatabase();
const enquiries = await db.prepare(
  `SELECT id, name, email, request_type, message, submitted_at 
   FROM contact_submissions 
   ORDER BY submitted_at DESC 
   LIMIT 50`
).all();
---

<PortalLayout user={user}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="sm:flex sm:items-center sm:justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Contact Enquiries</h1>
        <p class="mt-1 text-sm text-gray-500">Manage incoming contact submissions</p>
      </div>
    </div>

    <div class="bg-white shadow overflow-hidden sm:rounded-md">
      <ul class="divide-y divide-gray-200">
        {enquiries.results?.map((enquiry) => (
          <li key={enquiry.id}>
            <div class="px-4 py-4 sm:px-6">
              <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-kharon-blue truncate">{enquiry.name}</p>
                <div class="ml-2 flex-shrink-0 flex">
                  <p class="text-xs font-medium text-gray-500">{enquiry.email}</p>
                </div>
              </div>
              <div class="mt-2 sm:flex sm:justify-between">
                <div class="sm:flex">
                  <p class="flex items-center text-sm text-gray-500">
                    {enquiry.request_type}
                  </p>
                </div>
                <div class="mt-2 flex items-center text-sm text-gray-500 sm:mt-0">
                  <p>{new Date(enquiry.submitted_at).toLocaleString()}</p>
                </div>
              </div>
              <div class="mt-2 text-sm text-gray-700">
                <p class="truncate">{enquiry.message.substring(0, 100)}{enquiry.message.length > 100 ? '...' : ''}</p>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</PortalLayout>