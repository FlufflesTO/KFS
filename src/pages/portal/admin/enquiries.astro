---
/**
 * Project Sentinel - Admin Enquiries
 * Purpose: Admin interface for incoming service requests
 * Dependencies: PortalLayout, getDatabase, requireAdmin
 * Structural Role: Administrative UI for lead/inquiry management
 */
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings";
import { requireAdmin } from "../../../lib/server/admin";
import type { DbContactEnquiry } from "@sentinel/types";

export const prerender = false;

const { user } = Astro.locals;
const adminError = requireAdmin(user);
if (adminError) {
  return adminError;
}

const params = Astro.url.searchParams;
const page = Math.max(1, Math.min(999, parseInt(params.get("page") || "1", 10) || 1));
const searchQuery = params.get("q") || "";
const perPage = 50;
const offset = (page - 1) * perPage;

let contactEnquiries: DbContactEnquiry[] = [];
let total = 0;
let loadError = "";

try {
  const db = getDatabase();

  let searchCondition = "";
  const bindParams: string[] = [];

  if (searchQuery) {
    searchCondition += ` WHERE name LIKE ? OR email LIKE ? OR message LIKE ?`;
    const q = `%${searchQuery}%`;
    bindParams.push(q, q, q);
  }

  const countQuery = `SELECT COUNT(*) as total FROM contact_enquiries ${searchCondition}`;
  total = ((await db.prepare(countQuery).bind(...bindParams).first()) as { total: number } | null)?.total ?? 0;

  const dataQuery = `
    SELECT *
    FROM contact_enquiries
    ${searchCondition}
    ORDER BY submitted_at DESC
    LIMIT ? OFFSET ?
  `;

  contactEnquiries = ((await db.prepare(dataQuery).bind(...bindParams, perPage, offset).all()).results ?? []) as DbContactEnquiry[];

} catch (error) {
  loadError = "Enquiries could not be loaded.";
}

const totalPages = Math.max(1, Math.ceil(total / perPage));
---

<PortalLayout title="Website Enquiries | Kharon Portal" active="enquiries" user={user}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="sm:flex sm:items-center sm:justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Website Enquiries</h1>
        <p class="mt-1 text-sm text-gray-500">View contact form submissions from the public website</p>
      </div>
    </div>

    {loadError && (
      <p class="mx-auto mb-6 max-w-7xl border border-red-300 bg-red-50 p-4 text-red-800">{loadError}</p>
    )}

    <article class="border border-kharon-border bg-white p-4 sm:p-5">
      <div class="sticky top-0 z-10 mb-4 flex flex-wrap items-center justify-between gap-3 bg-white">
        <h2 class="text-xl font-bold">
          Enquiries <span class="ml-2 text-sm font-normal text-kharon-grey">({total})</span>
        </h2>
        <form class="flex flex-wrap gap-3" method="get">
          <input
            name="q"
            type="search"
            class="rounded-md border border-kharon-border px-3 py-2 text-sm"
            placeholder="Search name, email, message…"
            value={searchQuery}
            size="24"
          />
          <button type="submit" class="rounded-md bg-kharon-blue px-4 py-2 font-semibold text-white text-sm">Search</button>
          {searchQuery && (
            <a href="/portal/admin/enquiries" class="rounded-md border border-kharon-border px-4 py-2 font-semibold text-kharon-grey text-sm">Clear</a>
          )}
        </form>
      </div>

      <div class="mt-5 grid gap-3">
        {contactEnquiries.length === 0 && (
          <p class="text-kharon-grey py-4">No contact enquiries found.</p>
        )}
        {contactEnquiries.map((item) => (
          <article class="grid gap-2 border-l-4 border-kharon-blue bg-kharon-light p-4 lg:grid-cols-2">
            <div class="min-w-0">
              <p class="font-semibold">{item.name}</p>
              <p class="text-sm text-kharon-purple">
                <a href={`mailto:${item.email}`} class="hover:underline">{item.email}</a>
              </p>
              <p class="mt-1 text-xs font-bold uppercase text-kharon-grey">{item.request_type}</p>
              <p class="mt-2 text-sm leading-6 text-kharon-black">{item.message}</p>
            </div>
            <div class="text-xs text-kharon-grey flex justify-between flex-col lg:items-end">
              <p>{item.submitted_at?.slice(0, 16).replace("T", " ")} UTC</p>
            </div>
          </article>
        ))}
      </div>
    </article>

    <nav class="mt-6 mb-8 flex items-center justify-between border-t border-kharon-border pt-4">
      {page > 1 ? (
        <a href={`?page=${page - 1}&q=${encodeURIComponent(searchQuery)}`} class="rounded border border-kharon-border px-4 py-2 text-sm font-medium text-kharon-black hover:bg-kharon-light">Previous</a>
      ) : (
        <span class="cursor-not-allowed rounded border border-kharon-border px-4 py-2 text-sm font-medium text-kharon-grey/50">Previous</span>
      )}
      <span class="text-sm text-kharon-grey">Page {page} of {totalPages}</span>
      {page < totalPages ? (
        <a href={`?page=${page + 1}&q=${encodeURIComponent(searchQuery)}`} class="rounded border border-kharon-border px-4 py-2 text-sm font-medium text-kharon-black hover:bg-kharon-light">Next</a>
      ) : (
        <span class="cursor-not-allowed rounded border border-kharon-border px-4 py-2 text-sm font-medium text-kharon-grey/50">Next</span>
      )}
    </nav>
  </div>
</PortalLayout>