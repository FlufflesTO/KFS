---
import { auditError } from "../../../lib/server/audit.js";
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";

export const prerender = false;

const user = Astro.locals.user;

let stats = {
  openCriticalDefects: 0,
  openDefects: 0,
  blockedCertificates: 0,
  overdueRemediation: 0,
  dueSoonCertificates: 0,
  systemsAtRisk: 0
};
let criticalDefects: Array<any> = [];
let blockedCertificates: Array<any> = [];
let dueSoonCertificates: Array<any> = [];
let systemsAtRisk: Array<any> = [];
let loadError = "";
let db: any = null;

try {
  db = getDatabase();

  const [cntCritical, cntOpen, cntBlocked, cntOverdue, cntDueSoon, cntAtRisk] = await db.batch([
    db.prepare(`SELECT COUNT(*) AS n FROM defects WHERE deleted_at IS NULL AND status = 'Open' AND severity = 'Critical'`),
    db.prepare(`SELECT COUNT(*) AS n FROM defects WHERE deleted_at IS NULL AND status IN ('Open', 'In Progress')`),
    db.prepare(`SELECT COUNT(*) AS n FROM certificates WHERE deleted_at IS NULL AND status = 'Blocked'`),
    db.prepare(`SELECT COUNT(*) AS n FROM defects WHERE deleted_at IS NULL AND status IN ('Open', 'In Progress') AND updated_at < date('now', '-30 days')`),
    db.prepare(`SELECT COUNT(*) AS n FROM certificates WHERE deleted_at IS NULL AND status = 'Valid' AND expiry_date IS NOT NULL AND expiry_date <= date('now', '+30 days')`),
    db.prepare(`SELECT COUNT(DISTINCT system_id) AS n FROM defects WHERE deleted_at IS NULL AND status IN ('Open', 'In Progress') AND severity = 'Critical'`)
  ]);

  interface CountResult {
    n: number;
  }
  stats = {
    openCriticalDefects: (cntCritical.results[0] as CountResult | undefined)?.n ?? 0,
    openDefects: (cntOpen.results[0] as CountResult | undefined)?.n ?? 0,
    blockedCertificates: (cntBlocked.results[0] as CountResult | undefined)?.n ?? 0,
    overdueRemediation: (cntOverdue.results[0] as CountResult | undefined)?.n ?? 0,
    dueSoonCertificates: (cntDueSoon.results[0] as CountResult | undefined)?.n ?? 0,
    systemsAtRisk: (cntAtRisk.results[0] as CountResult | undefined)?.n ?? 0
  };

  criticalDefects = (await db.prepare(
    `SELECT defects.id, defects.severity, defects.sans_clause_ref, defects.description,
            defects.status, defects.created_at,
            systems.id AS system_id, systems.system_type, systems.coverage_area,
            sites.owner_company_name
     FROM defects
     INNER JOIN systems ON systems.id = defects.system_id
     INNER JOIN sites ON sites.id = systems.site_id
     WHERE defects.deleted_at IS NULL AND systems.deleted_at IS NULL
       AND defects.status IN ('Open', 'In Progress') AND defects.severity = 'Critical'
     ORDER BY defects.created_at ASC
     LIMIT 20`
  ).all()).results || [];

  blockedCertificates = (await db.prepare(
    `SELECT certificates.id, certificates.certificate_type, certificates.issued_date,
            certificates.expiry_date,
            systems.id AS system_id, systems.system_type, systems.coverage_area,
            sites.owner_company_name,
            blocking_defect.id AS blocking_defect_id,
            blocking_defect.severity AS blocking_severity,
            blocking_defect.description AS blocking_description
     FROM certificates
     INNER JOIN systems ON systems.id = certificates.system_id
     INNER JOIN sites ON sites.id = systems.site_id
     LEFT JOIN defects AS blocking_defect ON blocking_defect.id = certificates.blocked_by_defect_id AND blocking_defect.deleted_at IS NULL
     WHERE certificates.deleted_at IS NULL AND systems.deleted_at IS NULL
       AND certificates.status = 'Blocked'
     ORDER BY certificates.created_at DESC
     LIMIT 20`
  ).all()).results || [];

  dueSoonCertificates = (await db.prepare(
    `SELECT certificates.id, certificates.certificate_type, certificates.issued_date,
            certificates.expiry_date,
            systems.id AS system_id, systems.system_type, systems.coverage_area,
            sites.owner_company_name
     FROM certificates
     INNER JOIN systems ON systems.id = certificates.system_id
     INNER JOIN sites ON sites.id = systems.site_id
     WHERE certificates.deleted_at IS NULL AND systems.deleted_at IS NULL
       AND certificates.status = 'Valid' AND certificates.expiry_date IS NOT NULL
       AND certificates.expiry_date <= date('now', '+30 days')
     ORDER BY certificates.expiry_date ASC
     LIMIT 20`
  ).all()).results || [];

  systemsAtRisk = (await db.prepare(
    `SELECT systems.id, systems.system_type, systems.coverage_area,
            sites.owner_company_name,
            COUNT(defects.id) AS critical_count
     FROM defects
     INNER JOIN systems ON systems.id = defects.system_id
     INNER JOIN sites ON sites.id = systems.site_id
     WHERE defects.deleted_at IS NULL AND systems.deleted_at IS NULL
       AND defects.status IN ('Open', 'In Progress') AND defects.severity = 'Critical'
     GROUP BY systems.id
     ORDER BY critical_count DESC
     LIMIT 20`
  ).all()).results || [];
} catch (error) {
  await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "compliance_dashboard" });
  loadError = "Compliance data could not be loaded.";
}
---

<PortalLayout title="Compliance Control | Kharon Portal" active="compliance" user={user}>
  <section class="bg-gradient-to-br from-kharon-black to-kharon-charcoal px-4 py-8 text-white sm:px-6 sm:py-10 kharon-environment rounded-xl border border-kharon-purple/10 mb-6 shadow-inner relative overflow-hidden">
    <div class="mx-auto max-w-7xl relative z-10">
      <p class="text-[0.625rem] font-bold uppercase tracking-[0.2em] text-kharon-purple">Compliance chain</p>
      <h1 class="mt-2 text-2xl font-bold sm:text-3xl tracking-tight">Defects, certificates and remediation</h1>
      <p class="mt-3 max-w-3xl text-sm text-white/50">
        Open findings that block certification, expired or soon-expiring certificates and systems with unresolved critical defects.
      </p>
    </div>
  </section>

  <section class="mt-2">
    <div class="mx-auto grid max-w-7xl gap-6">
      {loadError && <p class="rounded border border-kharon-red/40 bg-kharon-red/10 px-4 py-3 text-sm font-semibold text-kharon-red mb-6">{loadError}</p>}

      <!-- Stat cards -->
      <div class="grid gap-4 sm:grid-cols-3 xl:grid-cols-6">
        <article class={`rounded-lg border p-4 backdrop-blur-sm ${stats.openCriticalDefects > 0 ? "border-kharon-red/30 bg-kharon-surface-elevated text-white" : "border-kharon-purple/20 bg-kharon-surface-elevated text-white"}`}>
          <p class={`text-xs font-bold uppercase tracking-wider ${stats.openCriticalDefects > 0 ? "text-kharon-red" : "text-kharon-purple"}`}>Critical defects</p>
          <p class="mt-2 text-2xl font-bold text-white">{stats.openCriticalDefects}</p>
          <a href="#critical-defects" class="mt-2 block text-xs font-semibold text-kharon-cyan hover:underline">View -></a>
        </article>
        <article class={`rounded-lg border p-4 backdrop-blur-sm ${stats.openDefects > 0 ? "border-kharon-amber/30 bg-kharon-surface-elevated text-white" : "border-kharon-purple/20 bg-kharon-surface-elevated text-white"}`}>
          <p class={`text-xs font-bold uppercase tracking-wider ${stats.openDefects > 0 ? "text-kharon-amber" : "text-kharon-purple"}`}>Open defects</p>
          <p class="mt-2 text-2xl font-bold text-white">{stats.openDefects}</p>
          <a href="/portal/admin/operations#defects" class="mt-2 block text-xs font-semibold text-kharon-cyan hover:underline">Manage -></a>
        </article>
        <article class={`rounded-lg border p-4 backdrop-blur-sm ${stats.blockedCertificates > 0 ? "border-kharon-amber/30 bg-kharon-surface-elevated text-white" : "border-kharon-purple/20 bg-kharon-surface-elevated text-white"}`}>
          <p class={`text-xs font-bold uppercase tracking-wider ${stats.blockedCertificates > 0 ? "text-kharon-amber" : "text-kharon-purple"}`}>Blocked certs</p>
          <p class="mt-2 text-2xl font-bold text-white">{stats.blockedCertificates}</p>
          <a href="#blocked-certs" class="mt-2 block text-xs font-semibold text-kharon-cyan hover:underline">View -></a>
        </article>
        <article class={`rounded-lg border p-4 backdrop-blur-sm ${stats.overdueRemediation > 0 ? "border-kharon-red/30 bg-kharon-surface-elevated text-white" : "border-kharon-purple/20 bg-kharon-surface-elevated text-white"}`}>
          <p class={`text-xs font-bold uppercase tracking-wider ${stats.overdueRemediation > 0 ? "text-kharon-red" : "text-kharon-purple"}`}>Overdue remediation</p>
          <p class="mt-2 text-2xl font-bold text-white">{stats.overdueRemediation}</p>
          <p class="mt-1 text-xs text-white/50">>30 days open</p>
        </article>
        <article class={`rounded-lg border p-4 backdrop-blur-sm ${stats.dueSoonCertificates > 0 ? "border-kharon-blue/20 bg-kharon-surface-elevated text-white" : "border-kharon-purple/20 bg-kharon-surface-elevated text-white"}`}>
          <p class={`text-xs font-bold uppercase tracking-wider ${stats.dueSoonCertificates > 0 ? "text-kharon-cyan" : "text-kharon-purple"}`}>Certs expiring</p>
          <p class="mt-2 text-2xl font-bold text-white">{stats.dueSoonCertificates}</p>
          <p class="mt-1 text-xs text-white/50">within 30 days</p>
        </article>
        <article class={`rounded-lg border p-4 backdrop-blur-sm ${stats.systemsAtRisk > 0 ? "border-kharon-red/30 bg-kharon-surface-elevated text-white" : "border-kharon-purple/20 bg-kharon-surface-elevated text-white"}`}>
          <p class={`text-xs font-bold uppercase tracking-wider ${stats.systemsAtRisk > 0 ? "text-kharon-red" : "text-kharon-purple"}`}>Systems at risk</p>
          <p class="mt-2 text-2xl font-bold text-white">{stats.systemsAtRisk}</p>
          <a href="#systems-risk" class="mt-2 block text-xs font-semibold text-kharon-cyan hover:underline">View -></a>
        </article>
      </div>

      <!-- Critical defects -->
      <article id="critical-defects" class="rounded-xl border border-kharon-purple/20 bg-kharon-surface-elevated p-4 sm:p-5 backdrop-blur-sm">
        <h2 class="text-xl font-bold text-white">Critical defects</h2>
        <div class="mt-4 grid gap-3">
          {criticalDefects.length === 0 && <p class="text-sm text-white/50 italic">No critical defects require attention.</p>}
          {criticalDefects.map((item) => (
            <a href="/portal/admin/operations#defects" class="block border-l-4 border-kharon-red bg-kharon-black/35 hover:bg-kharon-black/60 border border-kharon-purple/10 p-4 transition-all rounded-lg">
              <div class="flex flex-wrap items-center gap-2">
                <span class="rounded bg-kharon-red/20 px-2 py-0.5 text-xs font-bold text-kharon-red border border-kharon-red/30">Critical</span>
                <span class="font-semibold text-white">{item.owner_company_name}</span>
                <span class="text-sm text-white/60">{item.system_type} / {item.coverage_area}</span>
              </div>
              <p class="mt-2 text-sm text-kharon-light/80 leading-relaxed">{item.description}</p>
              {item.sans_clause_ref && <p class="mt-2 text-xs text-white/40 font-mono">SANS clause: {item.sans_clause_ref}</p>}
              <p class="mt-1 text-xs text-white/40">Reported {item.created_at?.slice(0, 10)}</p>
            </a>
          ))}
        </div>
      </article>

      <!-- Blocked certificates -->
      <article id="blocked-certs" class="rounded-xl border border-kharon-purple/20 bg-kharon-surface-elevated p-4 sm:p-5 backdrop-blur-sm">
        <h2 class="text-xl font-bold text-white">Blocked certificates</h2>
        <div class="mt-4 grid gap-3">
          {blockedCertificates.length === 0 && <p class="text-sm text-white/50 italic">No certificates are blocked by open defects.</p>}
          {blockedCertificates.map((item) => (
            <article class="border-l-4 border-kharon-amber bg-kharon-black/35 border border-kharon-purple/10 p-4 rounded-lg">
              <div class="flex flex-wrap items-center gap-2">
                <span class="rounded bg-kharon-amber/20 px-2 py-0.5 text-xs font-bold text-kharon-amber border border-kharon-amber/35">Blocked</span>
                <span class="font-semibold text-white">{item.owner_company_name}</span>
                <span class="text-sm text-white/60">{item.certificate_type}</span>
                <span class="text-sm text-white/60">{item.system_type} / {item.coverage_area}</span>
              </div>
              {item.blocking_severity && (
                <p class="mt-2 text-sm text-kharon-amber">
                  Blocked by <span class="font-bold">{item.blocking_severity}</span> defect: {item.blocking_description}
                </p>
              )}
            </article>
          ))}
        </div>
      </article>

      <!-- Due soon certificates -->
      <article class="rounded-xl border border-kharon-purple/20 bg-kharon-surface-elevated p-4 sm:p-5 backdrop-blur-sm">
        <h2 class="text-xl font-bold text-white">Certificates expiring within 30 days</h2>
        <div class="mt-4 grid gap-3">
          {dueSoonCertificates.length === 0 && <p class="text-sm text-white/50 italic">No certificates are expiring soon.</p>}
          {dueSoonCertificates.map((item) => (
            <article class="border-l-4 border-kharon-blue bg-kharon-black/35 border border-kharon-purple/10 p-4 rounded-lg">
              <div class="flex flex-wrap items-center gap-2">
                <span class="rounded bg-kharon-blue/20 px-2 py-0.5 text-xs font-bold text-kharon-cyan border border-kharon-blue/40">Expiring</span>
                <span class="font-semibold text-white">{item.owner_company_name}</span>
                <span class="text-sm text-white/60">{item.certificate_type}</span>
                <span class="text-sm text-white/60">{item.system_type} / {item.coverage_area}</span>
              </div>
              <p class="mt-2 text-xs text-white/40">Expires {item.expiry_date}</p>
            </article>
          ))}
        </div>
      </article>

      <!-- Systems at risk -->
      <article id="systems-risk" class="rounded-xl border border-kharon-purple/20 bg-kharon-surface-elevated p-4 sm:p-5 backdrop-blur-sm">
        <h2 class="text-xl font-bold text-white">Systems with open critical defects</h2>
        <div class="mt-4 grid gap-3">
          {systemsAtRisk.length === 0 && <p class="text-sm text-white/50 italic">No systems have unresolved critical defects.</p>}
          {systemsAtRisk.map((item) => (
            <article class="border-l-4 border-kharon-red bg-kharon-black/35 border border-kharon-purple/10 p-4 rounded-lg">
              <div class="flex flex-wrap items-center gap-2">
                <span class="rounded bg-kharon-red/20 px-2 py-0.5 text-xs font-bold text-kharon-red border border-kharon-red/30">{item.critical_count} critical</span>
                <span class="font-semibold text-white">{item.owner_company_name}</span>
                <span class="text-sm text-white/60">{item.system_type} / {item.coverage_area}</span>
              </div>
            </article>
          ))}
        </div>
      </article>
    </div>
  </section>
</PortalLayout>
