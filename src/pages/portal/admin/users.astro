---
/**
 * Project Sentinel - Admin Users
 * Purpose: Admin interface for user and role management
 * Dependencies: PortalLayout, getDatabase, requireAdmin
 * Structural Role: Administrative UI for identity and access management
 */
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings";
import { requireAdmin } from "../../../lib/server/access";
import type { DbUser, DbSite } from "@sentinel/types";

export const prerender = false;

const { user } = Astro.locals;
const adminError = requireAdmin(user);
if (adminError) {
  return adminError;
}

const params = Astro.url.searchParams;
const page = Math.max(1, Math.min(999, parseInt(params.get("page") || "1", 10) || 1));
const searchQuery = params.get("q") || "";
const roleFilter = params.get("role") || "";
const perPage = 50;
const offset = (page - 1) * perPage;

let users: DbUser[] = [];
let sites: DbSite[] = [];
let usersTotal = 0;
let loadError = "";

try {
  const db = getDatabase();

  let searchCondition = "";
  const bindParams: string[] = [];

  if (searchQuery) {
    searchCondition += ` AND (name LIKE ? OR email LIKE ?)`;
    const q = `%${searchQuery}%`;
    bindParams.push(q, q);
  }

  if (roleFilter) {
    searchCondition += ` AND role = ?`;
    bindParams.push(roleFilter);
  }

  const countQuery = `
    SELECT COUNT(*) as total 
    FROM users 
    WHERE 1=1 ${searchCondition}
  `;
  
  usersTotal = ((await db.prepare(countQuery).bind(...bindParams).first()) as { total: number } | null)?.total ?? 0;

  const dataQuery = `
    SELECT id, name, email, role, site_id, is_active, force_password_change, mfa_required, mfa_enabled, last_login_at
    FROM users
    WHERE 1=1 ${searchCondition}
    ORDER BY role, name
    LIMIT ? OFFSET ?
  `;

  users = ((await db.prepare(dataQuery).bind(...bindParams, perPage, offset).all()).results ?? []) as DbUser[];

  sites = ((await db.prepare(
    `SELECT id, owner_company_name, physical_address, site_contact_person, site_contact_email, site_contact_phone, billing_emails
     FROM sites
     ORDER BY owner_company_name
     LIMIT 1000`
  ).all()).results ?? []) as DbSite[];

} catch (error) {
  loadError = "Users data could not be loaded.";
}

const totalPages = Math.max(1, Math.ceil(usersTotal / perPage));
---

<PortalLayout title="User Management | Kharon Portal" active="users" user={user}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="sm:flex sm:items-center sm:justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-white tracking-tight font-heading">User Management</h1>
        <p class="mt-1 text-sm text-white/60">Manage system users, roles, and access control</p>
      </div>
    </div>

    {loadError && (
      <p class="mx-auto mb-6 max-w-7xl border border-kharon-red bg-kharon-red/10 p-4 text-red-200 font-semibold">{loadError}</p>
    )}

    <article class="kharon-surface p-4 sm:p-5">
      <div class="mb-4 flex flex-wrap items-end justify-between gap-4 border-b border-line-cyan-soft pb-4">
        <h2 class="text-xl font-bold text-white font-heading">
          Users <span class="ml-2 text-sm font-normal text-white/60">({usersTotal})</span>
        </h2>
        <form class="flex flex-wrap items-end gap-3" method="get">
          <div class="grid gap-1">
            <label for="users-q" class="text-[10px] font-bold uppercase tracking-widest text-kharon-cyan">Search Name/Email</label>
            <input
              id="users-q"
              name="q"
              type="search"
              class="kharon-field min-w-[200px]"
              placeholder="Search name or email…"
              value={searchQuery}
            />
          </div>
          <div class="grid gap-1">
            <label for="users-role" class="text-[10px] font-bold uppercase tracking-widest text-kharon-cyan">Role</label>
            <select id="users-role" name="role" class="kharon-field">
              <option value="">All roles</option>
              {["tech", "admin", "client", "finance"].map((r) => (
                <option value={r} selected={roleFilter === r}>{r}</option>
              ))}
            </select>
          </div>
          <button type="submit" class="kharon-command-button text-xs py-2 px-4 h-[38px] self-end">Filter</button>
          {(searchQuery || roleFilter) && (
            <a href="/portal/admin/users" class="kharon-secondary-button text-xs py-2 px-4 h-[38px] flex items-center justify-center">Clear</a>
          )}
        </form>
      </div>

      <div class="grid gap-4">
        {users.length === 0 && <p class="py-4 text-sm text-white/50 italic">No users match your filter.</p>}
        {users.map((record) => (
          <form
            class="admin-form grid gap-4 bg-surface-charcoal/40 border border-line-cyan-soft/50 p-4 lg:grid-cols-6 rounded-md"
            data-endpoint="/portal/api/admin/users"
          >
            <input type="hidden" name="action" value="update" />
            <input type="hidden" name="id" value={record.id} />
            
            <div class="grid gap-1">
              <label for={`name-${record.id}`} class="text-[10px] font-bold uppercase tracking-widest text-kharon-cyan">Full Name</label>
              <input id={`name-${record.id}`} class="kharon-field" name="name" value={record.name} required />
            </div>
            
            <div class="grid gap-1">
              <label for={`email-${record.id}`} class="text-[10px] font-bold uppercase tracking-widest text-kharon-cyan">Email Address</label>
              <input id={`email-${record.id}`} class="kharon-field opacity-60 cursor-not-allowed" value={record.email} disabled />
            </div>
            
            <div class="grid gap-1">
              <label for={`role-${record.id}`} class="text-[10px] font-bold uppercase tracking-widest text-kharon-cyan">System Role</label>
              <select id={`role-${record.id}`} class="kharon-field" name="role">
                {(["tech", "admin", "client", "finance"] as const).map((role) => (
                  <option value={role} selected={record.role === role}>{role}</option>
                ))}
              </select>
            </div>
            
            <div class="grid gap-1">
              <label for={`site-${record.id}`} class="text-[10px] font-bold uppercase tracking-widest text-kharon-cyan">Site Mapping</label>
              <select id={`site-${record.id}`} class="kharon-field" name="siteId">
                <option value="">No site</option>
                {sites.map((site) => (
                  <option value={site.id} selected={record.site_id === site.id}>{site.owner_company_name}</option>
                ))}
              </select>
            </div>
            
            <div class="grid gap-2 text-xs self-center">
              <label class="flex items-center gap-2 cursor-pointer text-white/80"><input type="checkbox" name="isActive" checked={Boolean(record.is_active)} /> Active</label>
              <label class="flex items-center gap-2 cursor-pointer text-white/80"><input type="checkbox" name="forcePasswordChange" checked={Boolean(record.force_password_change)} /> Rotate password</label>
              {(["admin", "finance"] as const).includes(record.role) && (
                <label class="flex items-center gap-2 cursor-pointer text-white/80"><input type="checkbox" name="mfaRequired" checked={Boolean(record.mfa_required)} /> Require MFA</label>
              )}
              {record.mfa_enabled ? <span class="text-[10px] font-bold uppercase text-kharon-cyan">MFA enabled</span> : null}
            </div>
            
            <div class="grid gap-2">
              <div class="grid gap-1">
                <label for={`password-${record.id}`} class="text-[10px] font-bold uppercase tracking-widest text-kharon-cyan">Reset Password</label>
                <input id={`password-${record.id}`} class="kharon-field py-1" name="password" type="password" placeholder="Optional reset password" />
              </div>
              <div class="flex gap-2">
                <button class="flex-1 kharon-command-button py-1.5 text-xs">Save</button>
                <button
                  class="generate-reset-link kharon-secondary-button py-1.5 text-xs"
                  type="button"
                  data-user-id={record.id}
                  data-user-email={record.email}
                >
                  Link
                </button>
              </div>
              {record.mfa_enabled ? (
                <button
                  class="reset-mfa kharon-danger-button py-1.5 text-xs"
                  type="button"
                  data-user-id={record.id}
                  data-user-email={record.email}
                >
                  Reset MFA
                </button>
              ) : null}
            </div>
            <p class="admin-result hidden rounded border px-4 py-3 text-sm font-semibold lg:col-span-6"></p>
          </form>
        ))}
      </div>
    </article>

    <nav class="mt-6 mb-8 flex items-center justify-between border-t border-line-cyan-soft pt-4">
      {page > 1 ? (
        <a href={`?page=${page - 1}&q=${encodeURIComponent(searchQuery)}&role=${encodeURIComponent(roleFilter)}`} class="kharon-secondary-button py-2 text-xs">Previous</a>
      ) : (
        <span class="cursor-not-allowed rounded border border-line-cyan-soft/40 px-4 py-2 text-xs font-semibold text-white/30">Previous</span>
      )}
      <span class="text-sm text-white/60">Page {page} of {totalPages}</span>
      {page < totalPages ? (
        <a href={`?page=${page + 1}&q=${encodeURIComponent(searchQuery)}&role=${encodeURIComponent(roleFilter)}`} class="kharon-secondary-button py-2 text-xs">Next</a>
      ) : (
        <span class="cursor-not-allowed rounded border border-line-cyan-soft/40 px-4 py-2 text-xs font-semibold text-white/30">Next</span>
      )}
    </nav>

    <article class="kharon-surface p-6 sm:p-8">
      <h2 class="text-xl font-bold text-white font-heading">Create new user</h2>
      <form class="admin-form mt-5 grid gap-4 md:grid-cols-2 lg:grid-cols-3" data-endpoint="/portal/api/admin/users">
        <input type="hidden" name="action" value="create" />
        
        <div class="grid gap-1">
          <label for="create-name" class="text-xs font-bold uppercase tracking-widest text-kharon-cyan">Full Name *</label>
          <input id="create-name" class="kharon-field" name="name" placeholder="John Doe" required />
        </div>

        <div class="grid gap-1">
          <label for="create-email" class="text-xs font-bold uppercase tracking-widest text-kharon-cyan">Email Address *</label>
          <input id="create-email" class="kharon-field" name="email" type="email" placeholder="email@domain.co.za" required />
        </div>

        <div class="grid gap-1">
          <label for="create-role" class="text-xs font-bold uppercase tracking-widest text-kharon-cyan">System Role *</label>
          <select id="create-role" class="kharon-field" name="role" required>
            <option value="tech">Technician</option>
            <option value="admin">Admin</option>
            <option value="client">Client</option>
            <option value="finance">Finance</option>
          </select>
        </div>

        <div class="grid gap-1">
          <label for="create-siteId" class="text-xs font-bold uppercase tracking-widest text-kharon-cyan">Site Mapping (Optional)</label>
          <select id="create-siteId" class="kharon-field" name="siteId">
            <option value="">No site mapping</option>
            {sites.map((site) => <option value={site.id}>{site.owner_company_name}</option>)}
          </select>
        </div>

        <div class="grid gap-1">
          <label for="create-password" class="text-xs font-bold uppercase tracking-widest text-kharon-cyan">Temporary Password *</label>
          <input id="create-password" class="kharon-field" name="password" type="password" minlength="14" placeholder="Temporary password" required />
        </div>

        <div class="flex flex-col gap-2 justify-end text-xs pb-1">
          <label class="flex items-center gap-2 cursor-pointer font-semibold text-white/80">
            <input type="checkbox" name="forcePasswordChange" checked /> Force password change
          </label>
          <label class="flex items-center gap-2 cursor-pointer font-semibold text-white/80">
            <input type="checkbox" name="mfaRequired" /> Require MFA for admin/finance
          </label>
        </div>

        <div class="md:col-span-2 lg:col-span-3 mt-2">
          <button class="w-full kharon-command-button py-3">Create User Account</button>
        </div>
        <p class="admin-result hidden rounded border px-4 py-3 text-sm font-semibold md:col-span-2 lg:col-span-3"></p>
      </form>
    </article>
  </div>
  
  <script>
    import { bindAdminForms, portalPost, setResult } from "../../../lib/client/portalApi";
    bindAdminForms();

    // ── Issue reset link ──────────────────────────────────────────────────────
    for (const btn of document.querySelectorAll<HTMLButtonElement>(".generate-reset-link")) {
      btn.addEventListener("click", async () => {
        const email = btn.dataset.userEmail;
        if (!window.confirm(`Are you sure you want to generate a password reset link for user: ${email}?`)) {
          return;
        }

        const form   = btn.closest<HTMLFormElement>("form");
        const result = form?.querySelector<HTMLElement>(".admin-result");
        if (result) result.classList.add("hidden");
        const { response, body } = await portalPost("/portal/api/admin/users", { action: "reset-link", id: btn.dataset.userId });
        if (!response.ok || !body.ok) {
          setResult(result, body.message ?? "Reset link could not be issued.", "error", "lg:col-span-6");
          return;
        }
        const resetUrl = String(body.resetUrl ?? "");
        setResult(result, `Reset link issued — valid until ${body.expiresAt}. `, "success", "lg:col-span-6");
        const copyBtn = document.createElement("button");
        copyBtn.type = "button";
        copyBtn.textContent = "Copy link";
        copyBtn.className = "ml-1 inline-flex items-center rounded border border-green-600 px-2 py-0.5 text-xs font-bold text-green-200 hover:bg-green-700 bg-green-800";
        copyBtn.addEventListener("click", async () => {
          await navigator.clipboard.writeText(resetUrl).catch(() => null);
          copyBtn.textContent = "Copied!";
          setTimeout(() => { copyBtn.textContent = "Copy link"; }, 2500);
        });
        result?.append(copyBtn);
      });
    }

    // ── Reset MFA ─────────────────────────────────────────────────────────────
    for (const btn of document.querySelectorAll<HTMLButtonElement>(".reset-mfa")) {
      btn.addEventListener("click", async () => {
        const email = btn.dataset.userEmail;
        if (!window.confirm(`Are you sure you want to deactivate and reset Multi-Factor Authentication (MFA) for user: ${email}?`)) {
          return;
        }

        const form   = btn.closest<HTMLFormElement>("form");
        const result = form?.querySelector<HTMLElement>(".admin-result");
        if (result) result.classList.add("hidden");
        const { response, body } = await portalPost("/portal/api/admin/users", { action: "reset-mfa", id: btn.dataset.userId });
        if (!response.ok || !body.ok) {
          setResult(result, body.message ?? "MFA could not be reset.", "error", "lg:col-span-6");
          return;
        }
        setResult(result, "MFA reset. The user must enrol again if MFA is required.", "success", "lg:col-span-6");
      });
    }
  </script>
</PortalLayout>