---
/**
 * Project Sentinel - Admin Users
 * Purpose: Admin interface for user and role management
 * Dependencies: PortalLayout, getDatabase, requireAdmin
 * Structural Role: Administrative UI for identity and access management
 */
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings";
import { requireAdmin } from "../../../lib/server/admin";
import type { DbUser, DbSite } from "@sentinel/types";

export const prerender = false;

const { user } = Astro.locals;
const adminError = requireAdmin(user);
if (adminError) {
  return adminError;
}

const params = Astro.url.searchParams;
const page = Math.max(1, Math.min(999, parseInt(params.get("page") || "1", 10) || 1));
const searchQuery = params.get("q") || "";
const roleFilter = params.get("role") || "";
const perPage = 50;
const offset = (page - 1) * perPage;

let users: DbUser[] = [];
let sites: DbSite[] = [];
let usersTotal = 0;
let loadError = "";

try {
  const db = getDatabase();

  let searchCondition = "";
  const bindParams: string[] = [];

  if (searchQuery) {
    searchCondition += ` AND (name LIKE ? OR email LIKE ?)`;
    const q = `%${searchQuery}%`;
    bindParams.push(q, q);
  }

  if (roleFilter) {
    searchCondition += ` AND role = ?`;
    bindParams.push(roleFilter);
  }

  const countQuery = `
    SELECT COUNT(*) as total 
    FROM users 
    WHERE 1=1 ${searchCondition}
  `;
  
  usersTotal = ((await db.prepare(countQuery).bind(...bindParams).first()) as { total: number } | null)?.total ?? 0;

  const dataQuery = `
    SELECT id, name, email, role, site_id, is_active, force_password_change, mfa_required, mfa_enabled, last_login_at
    FROM users
    WHERE 1=1 ${searchCondition}
    ORDER BY role, name
    LIMIT ? OFFSET ?
  `;

  users = ((await db.prepare(dataQuery).bind(...bindParams, perPage, offset).all()).results ?? []) as DbUser[];

  sites = ((await db.prepare(
    `SELECT id, owner_company_name, physical_address, site_contact_person, site_contact_email, site_contact_phone, billing_emails
     FROM sites
     ORDER BY owner_company_name
     LIMIT 1000`
  ).all()).results ?? []) as DbSite[];

} catch (error) {
  loadError = "Users data could not be loaded.";
}

const totalPages = Math.max(1, Math.ceil(usersTotal / perPage));
---

<PortalLayout title="User Management | Kharon Portal" active="users" user={user}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="sm:flex sm:items-center sm:justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">User Management</h1>
        <p class="mt-1 text-sm text-gray-500">Manage system users, roles, and access control</p>
      </div>
    </div>

    {loadError && (
      <p class="mx-auto mb-6 max-w-7xl border border-red-300 bg-red-50 p-4 text-red-800">{loadError}</p>
    )}

    <article class="border border-kharon-border bg-white p-4 sm:p-5">
      <div class="sticky top-0 z-10 mb-4 flex flex-wrap items-center justify-between gap-3 bg-white">
        <h2 class="text-xl font-bold">
          Users <span class="ml-2 text-sm font-normal text-kharon-grey">({usersTotal})</span>
        </h2>
        <form class="flex flex-wrap gap-3" method="get">
          <input
            name="q"
            type="search"
            class="rounded-md border border-kharon-border px-3 py-2 text-sm"
            placeholder="Search name or email…"
            value={searchQuery}
            size="24"
          />
          <select name="role" class="rounded-md border border-kharon-border px-3 py-2 text-sm">
            <option value="">All roles</option>
            {["tech", "admin", "client", "finance"].map((r) => (
              <option value={r} selected={roleFilter === r}>{r}</option>
            ))}
          </select>
          <button type="submit" class="rounded-md bg-kharon-blue px-4 py-2 font-semibold text-white text-sm">Filter</button>
          {(searchQuery || roleFilter) && (
            <a href="/portal/admin/users" class="rounded-md border border-kharon-border px-4 py-2 font-semibold text-kharon-grey text-sm">Clear</a>
          )}
        </form>
      </div>

      <div class="grid gap-4">
        {users.length === 0 && <p class="py-4 text-sm text-kharon-grey">No users match your filter.</p>}
        {users.map((record) => (
          <form
            class="admin-form grid gap-3 border border-kharon-border bg-kharon-light p-4 lg:grid-cols-6"
            data-endpoint="/portal/api/admin/users"
          >
            <input type="hidden" name="action" value="update" />
            <input type="hidden" name="id" value={record.id} />
            <input class="rounded-md border border-kharon-border px-3 py-2" name="name" value={record.name} />
            <input class="rounded-md border border-kharon-border px-3 py-2" value={record.email} disabled />
            <select class="rounded-md border border-kharon-border px-3 py-2" name="role">
              {(["tech", "admin", "client", "finance"] as const).map((role) => (
                <option value={role} selected={record.role === role}>{role}</option>
              ))}
            </select>
            <select class="rounded-md border border-kharon-border px-3 py-2" name="siteId">
              <option value="">No site</option>
              {sites.map((site) => (
                <option value={site.id} selected={record.site_id === site.id}>{site.owner_company_name}</option>
              ))}
            </select>
            <div class="grid gap-2 text-sm">
              <label><input type="checkbox" name="isActive" checked={Boolean(record.is_active)} /> Active</label>
              <label><input type="checkbox" name="forcePasswordChange" checked={Boolean(record.force_password_change)} /> Rotate password</label>
              {(["admin", "finance"] as const).includes(record.role) && (
                <label><input type="checkbox" name="mfaRequired" checked={Boolean(record.mfa_required)} /> Require MFA</label>
              )}
              {record.mfa_enabled ? <span class="text-xs font-bold uppercase text-emerald-700">MFA enabled</span> : null}
            </div>
            <div class="grid gap-2">
              <input class="rounded-md border border-kharon-border px-3 py-2" name="password" type="password" placeholder="Optional reset password" />
              <button class="rounded-md bg-kharon-blue px-4 py-2 font-semibold text-white">Save</button>
              <button
                class="generate-reset-link rounded-md border border-kharon-purple px-4 py-2 text-sm font-semibold text-kharon-purple"
                type="button"
                data-user-id={record.id}
              >
                Issue reset link
              </button>
              {record.mfa_enabled ? (
                <button
                  class="reset-mfa rounded-md border border-red-300 bg-red-50 px-4 py-2 text-sm font-semibold text-red-900"
                  type="button"
                  data-user-id={record.id}
                >
                  Reset MFA
                </button>
              ) : null}
            </div>
            <p class="admin-result hidden rounded-md border px-4 py-3 text-sm font-semibold lg:col-span-6"></p>
          </form>
        ))}
      </div>
    </article>

    <nav class="mt-6 mb-8 flex items-center justify-between border-t border-kharon-border pt-4">
      {page > 1 ? (
        <a href={`?page=${page - 1}&q=${encodeURIComponent(searchQuery)}&role=${encodeURIComponent(roleFilter)}`} class="rounded border border-kharon-border px-4 py-2 text-sm font-medium text-kharon-black hover:bg-kharon-light">Previous</a>
      ) : (
        <span class="cursor-not-allowed rounded border border-kharon-border px-4 py-2 text-sm font-medium text-kharon-grey/50">Previous</span>
      )}
      <span class="text-sm text-kharon-grey">Page {page} of {totalPages}</span>
      {page < totalPages ? (
        <a href={`?page=${page + 1}&q=${encodeURIComponent(searchQuery)}&role=${encodeURIComponent(roleFilter)}`} class="rounded border border-kharon-border px-4 py-2 text-sm font-medium text-kharon-black hover:bg-kharon-light">Next</a>
      ) : (
        <span class="cursor-not-allowed rounded border border-kharon-border px-4 py-2 text-sm font-medium text-kharon-grey/50">Next</span>
      )}
    </nav>

    <article class="border border-kharon-border bg-white p-4 sm:p-5">
      <h2 class="text-xl font-bold">Create user</h2>
      <form class="admin-form mt-5 grid gap-3" data-endpoint="/portal/api/admin/users">
        <input type="hidden" name="action" value="create" />
        <input class="rounded-md border border-kharon-border px-4 py-3" name="name" placeholder="Full name" required />
        <input class="rounded-md border border-kharon-border px-4 py-3" name="email" type="email" placeholder="email@domain.co.za" required />
        <select class="rounded-md border border-kharon-border px-4 py-3" name="role" required>
          <option value="tech">Technician</option>
          <option value="admin">Admin</option>
          <option value="client">Client</option>
          <option value="finance">Finance</option>
        </select>
        <select class="rounded-md border border-kharon-border px-4 py-3" name="siteId">
          <option value="">No site mapping</option>
          {sites.map((site) => <option value={site.id}>{site.owner_company_name}</option>)}
        </select>
        <input class="rounded-md border border-kharon-border px-4 py-3" name="password" type="password" minlength="14" placeholder="Temporary password" required />
        <label class="flex items-center gap-2 text-sm font-semibold">
          <input type="checkbox" name="forcePasswordChange" checked /> Force password change
        </label>
        <label class="flex items-center gap-2 text-sm font-semibold">
          <input type="checkbox" name="mfaRequired" /> Require MFA for admin/finance roles
        </label>
        <button class="rounded-md bg-kharon-purple px-5 py-3 font-semibold text-white">Create user</button>
        <p class="admin-result hidden rounded-md border px-4 py-3 text-sm font-semibold"></p>
      </form>
    </article>
  </div>
  
  <script>
    import { bindAdminForms, portalPost, setResult } from "../../../lib/client/portalApi";
    bindAdminForms();

    // ── Issue reset link ──────────────────────────────────────────────────────
    for (const btn of document.querySelectorAll<HTMLButtonElement>(".generate-reset-link")) {
      btn.addEventListener("click", async () => {
        const form   = btn.closest<HTMLFormElement>("form");
        const result = form?.querySelector<HTMLElement>(".admin-result");
        if (result) result.classList.add("hidden");
        const { response, body } = await portalPost("/portal/api/admin/users", { action: "reset-link", id: btn.dataset.userId });
        if (!response.ok || !body.ok) {
          setResult(result, body.message ?? "Reset link could not be issued.", "error", "lg:col-span-6");
          return;
        }
        const resetUrl = String(body.resetUrl ?? "");
        setResult(result, `Reset link issued — valid until ${body.expiresAt}. `, "success", "lg:col-span-6");
        const copyBtn = document.createElement("button");
        copyBtn.type = "button";
        copyBtn.textContent = "Copy link";
        copyBtn.className = "ml-1 inline-flex items-center rounded-md border border-emerald-600 px-2 py-0.5 text-xs font-bold text-emerald-800 hover:bg-emerald-100";
        copyBtn.addEventListener("click", async () => {
          await navigator.clipboard.writeText(resetUrl).catch(() => null);
          copyBtn.textContent = "Copied!";
          setTimeout(() => { copyBtn.textContent = "Copy link"; }, 2500);
        });
        result?.append(copyBtn);
      });
    }

    // ── Reset MFA ─────────────────────────────────────────────────────────────
    for (const btn of document.querySelectorAll<HTMLButtonElement>(".reset-mfa")) {
      btn.addEventListener("click", async () => {
        const form   = btn.closest<HTMLFormElement>("form");
        const result = form?.querySelector<HTMLElement>(".admin-result");
        if (result) result.classList.add("hidden");
        const { response, body } = await portalPost("/portal/api/admin/users", { action: "reset-mfa", id: btn.dataset.userId });
        if (!response.ok || !body.ok) {
          setResult(result, body.message ?? "MFA could not be reset.", "error", "lg:col-span-6");
          return;
        }
        setResult(result, "MFA reset. The user must enrol again if MFA is required.", "success", "lg:col-span-6");
      });
    }
  </script>
</PortalLayout>