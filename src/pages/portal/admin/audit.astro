---
/**
 * Project Sentinel - Audit Trail Console
 * Purpose: Allows administrators to search and filter audit ledger logs and security events
 * Dependencies: PortalLayout, getDatabase
 * Structural Role: Portal administrative audit review console
 */
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";

export const prerender = false;

const user = Astro.locals.user;

// ─── URL filter parameters ─────────────────────────────────────────────────
const url = new URL(Astro.request.url);
const filterCategory = url.searchParams.get("category") || "";
const filterOutcome  = url.searchParams.get("outcome")  || "";
const filterFrom     = url.searchParams.get("from")     || "";
const filterTo       = url.searchParams.get("to")       || "";

const CATEGORY_PATTERNS: Record<string, string> = {
  auth:     "auth.%",
  admin:    "admin.%",
  finance:  "finance.%",
  job:      "job%",
  security: "security.%",
  document: "document.%",
};

// ─── Helpers ──────────────────────────────────────────────────────────────
function formatEventType(et: string): string {
  return et
    .split(".")
    .map((s) => s.replace(/_/g, " ").replace(/\b\w/g, (c) => c.toUpperCase()))
    .join(" · ");
}

function outcomeClasses(outcome: string): string {
  if (outcome === "success")
    return "rounded border border-kharon-green bg-kharon-green/10 px-2 py-1 text-xs font-bold text-green-200";
  if (outcome === "failure")
    return "rounded border border-kharon-red bg-kharon-red/10 px-2 py-1 text-xs font-bold text-red-200";
  return "rounded border border-kharon-amber bg-kharon-amber/10 px-2 py-1 text-xs font-bold text-amber-200";
}

function isHighRisk(et: string, outcome: string): boolean {
  if (et.startsWith("security.")) return true;
  if (et.startsWith("auth.") && (outcome === "failure" || outcome === "blocked")) return true;
  if (et.startsWith("admin.") && (outcome === "failure" || outcome === "blocked")) return true;
  return false;
}

function dateOffset(days: number): string {
  const d = new Date();
  d.setUTCDate(d.getUTCDate() - days);
  return d.toISOString().slice(0, 10);
}
const last7  = dateOffset(7);
const last30 = dateOffset(30);

// ─── Database query ────────────────────────────────────────────────────────
let events: Array<Record<string, unknown>> = [];
let loadError = "";
const isFiltered = !!(filterCategory || filterOutcome || filterFrom || filterTo);
let db: any = null;

try {
  db = getDatabase();

  const conditions: string[] = [];
  const params: string[] = [];

  if (filterCategory && CATEGORY_PATTERNS[filterCategory]) {
    conditions.push("ae.event_type LIKE ?");
    params.push(CATEGORY_PATTERNS[filterCategory]);
  }
  if (filterOutcome && ["success", "failure", "blocked"].includes(filterOutcome)) {
    conditions.push("ae.outcome = ?");
    params.push(filterOutcome);
  }
  if (filterFrom) {
    conditions.push("date(ae.created_at) >= ?");
    params.push(filterFrom);
  }
  if (filterTo) {
    conditions.push("date(ae.created_at) <= ?");
    params.push(filterTo);
  }

  const whereClause = conditions.length > 0 ? "WHERE " + conditions.join(" AND ") : "";

  const sql = `
    SELECT ae.id, ae.actor_role, ae.event_type, ae.entity_type, ae.entity_id,
           ae.outcome, ae.metadata_json, ae.created_at,
           u.name AS actor_name, u.email AS actor_email
    FROM audit_events ae
    LEFT JOIN users u ON u.id = ae.actor_user_id
    ${whereClause}
    ORDER BY ae.created_at DESC
    LIMIT 100`;

  const stmt = db.prepare(sql);
  events = ((await (params.length > 0 ? stmt.bind(...params) : stmt).all()).results || []) as Array<Record<string, unknown>>;
} catch (error) {
  loadError = "Audit data could not be loaded.";
}
---

<PortalLayout title="Audit Console | Kharon Portal" active="audit" user={user}>
  <section class="bg-kharon-black px-4 py-8 text-white sm:px-6 sm:py-10">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-bold uppercase tracking-wider text-kharon-cyan">Administration Console</p>
      <h1 class="mt-3 text-2xl font-bold sm:text-3xl font-heading tracking-tight">System Audit Log</h1>
      <p class="mt-4 max-w-3xl text-white/60">
        Read-only ledger of portal security operations and system state modifications. Showing the 100 most recent events.
      </p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto max-w-7xl">
      {loadError && (
        <p class="mb-6 border border-kharon-red bg-kharon-red/10 p-4 text-red-200 font-semibold">{loadError}</p>
      )}

      <!-- ─── Filter form ─────────────────────────────────────────────── -->
      <form method="GET" action="/portal/admin/audit" class="mb-6 kharon-surface p-4 sm:p-5">
        <p class="mb-4 text-xs font-bold uppercase tracking-widest text-kharon-cyan">Filter telemetry events</p>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <label class="grid gap-1.5 text-xs font-bold uppercase tracking-wider text-white/85">
            Category
            <select name="category" class="kharon-field">
              <option value="">All categories</option>
              <option value="auth"     selected={filterCategory === "auth"}>Auth</option>
              <option value="admin"    selected={filterCategory === "admin"}>Admin</option>
              <option value="finance"  selected={filterCategory === "finance"}>Finance</option>
              <option value="job"      selected={filterCategory === "job"}>Jobs</option>
              <option value="security" selected={filterCategory === "security"}>Security</option>
              <option value="document" selected={filterCategory === "document"}>Documents</option>
            </select>
          </label>

          <label class="grid gap-1.5 text-xs font-bold uppercase tracking-wider text-white/85">
            Outcome
            <select name="outcome" class="kharon-field">
              <option value="">All outcomes</option>
              <option value="success" selected={filterOutcome === "success"}>Success</option>
              <option value="failure" selected={filterOutcome === "failure"}>Failure</option>
              <option value="blocked" selected={filterOutcome === "blocked"}>Blocked</option>
            </select>
          </label>

          <label class="grid gap-1.5 text-xs font-bold uppercase tracking-wider text-white/85">
            From date
            <input
              type="date"
              name="from"
              value={filterFrom}
              class="kharon-field"
            />
          </label>

          <label class="grid gap-1.5 text-xs font-bold uppercase tracking-wider text-white/85">
            To date
            <input
              type="date"
              name="to"
              value={filterTo}
              class="kharon-field"
            />
          </label>
        </div>

        <div class="mt-4 flex flex-wrap gap-3">
          <button type="submit" class="kharon-command-button text-xs py-2 px-4 h-[38px]">
            Apply filter
          </button>
          <a href="/portal/admin/audit" class="kharon-secondary-button text-xs py-2 px-4 h-[38px] flex items-center justify-center">
            Clear
          </a>
          <a href={`/portal/admin/audit?from=${last7}`} class="kharon-secondary-button text-xs py-2 px-4 h-[38px] flex items-center justify-center">
            Last 7 days
          </a>
          <a href={`/portal/admin/audit?from=${last30}`} class="kharon-secondary-button text-xs py-2 px-4 h-[38px] flex items-center justify-center">
            Last 30 days
          </a>
        </div>
      </form>

      <!-- ─── Result summary + export ───────────────────────────────────── -->
      <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
        <p class="text-sm text-white/60">
          {events.length} event{events.length === 1 ? "" : "s"}
          {isFiltered ? " matching filter" : ""}
          {events.length === 100 ? " — showing 100 most recent" : ""}
        </p>
        {(() => {
          const exportParams = new URLSearchParams();
          if (filterCategory) exportParams.set("category", filterCategory);
          if (filterOutcome)  exportParams.set("outcome",  filterOutcome);
          if (filterFrom)     exportParams.set("from",     filterFrom);
          if (filterTo)       exportParams.set("to",       filterTo);
          const exportHref = `/portal/api/admin/audit-export${exportParams.size ? "?" + exportParams.toString() : ""}`;
          return (
            <a href={exportHref} class="kharon-secondary-button text-xs py-2 px-4 flex items-center justify-center h-[36px]">
              Export CSV
            </a>
          );
        })()}
      </div>

      <!-- ─── Event list ─────────────────────────────────────────────── -->
      <div class="grid gap-3">
        {events.length === 0 && !loadError && (
          <p class="kharon-surface p-8 text-center text-white/50 italic">
            No events match the current filter.
          </p>
        )}
        {events.map((ev) => {
          const et = String(ev.event_type ?? "");
          const oc = String(ev.outcome ?? "");
          const highRisk = isHighRisk(et, oc);
          return (
          <article class={`border p-4 rounded-md transition-colors ${highRisk ? "border-kharon-red bg-kharon-red/5" : "border-line-cyan-soft/30 bg-surface-charcoal/40 hover:bg-surface-charcoal/60"}`}>
            <div class="flex flex-wrap items-start justify-between gap-3">
              <!-- Left: event detail -->
              <div class="min-w-0">
                <p class="text-xs text-white/50">
                  {String(ev.created_at ?? "").slice(0, 19).replace("T", " ")} UTC
                </p>
                <p class="mt-1 font-semibold text-white">
                  {formatEventType(et)}
                </p>
                <p class="mt-1 text-sm text-white/60">
                  {String(ev.entity_type ?? "")}
                  {ev.entity_id && (
                    <span class="font-mono text-xs">
                      {" · "}
                      {String(ev.entity_id).length > 26
                        ? String(ev.entity_id).slice(0, 26) + "…"
                        : String(ev.entity_id)}
                    </span>
                  )}
                </p>
              </div>
              <!-- Right: actor + outcome -->
              <div class="flex flex-col items-end gap-2 text-right">
                {highRisk && (
                  <span class="rounded border border-kharon-red bg-kharon-red/10 px-2 py-0.5 text-[10px] font-bold uppercase text-red-200">
                    High risk
                  </span>
                )}
                <span class={outcomeClasses(oc)}>{oc}</span>
                <p class="text-xs font-semibold text-white/95">
                  {ev.actor_name ? String(ev.actor_name) : "System / Unauthenticated"}
                </p>
                {ev.actor_email && (
                  <p class="text-xs text-white/65 font-mono">{String(ev.actor_email)}</p>
                )}
                {ev.actor_role && (
                  <p class="text-[10px] font-bold uppercase tracking-wider text-kharon-cyan">{String(ev.actor_role)}</p>
                )}
              </div>
            </div>
            <!-- Metadata preview -->
            {ev.metadata_json && String(ev.metadata_json) !== "null" && (
              <p
                class="mt-3 overflow-hidden rounded bg-surface-obsidian border border-line-cyan-soft/20 px-3 py-2 font-mono text-xs text-white/70"
                title={String(ev.metadata_json)}
              >
                {String(ev.metadata_json).length > 200
                  ? String(ev.metadata_json).slice(0, 200) + "…"
                  : String(ev.metadata_json)}
              </p>
            )}
          </article>
          );
        })}
      </div>
    </div>
  </section>
</PortalLayout>
