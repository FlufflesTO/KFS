---
/**
 * Project Sentinel - Audit Trail Console
 * Purpose: Allows administrators to search and filter audit ledger logs and security events
 * Dependencies: PortalLayout, getDatabase, AuditService
 * Structural Role: Portal administrative audit review console
 */
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import { AuditService, type AuditEvent } from "../../../lib/server/services/audit-service";

export const prerender = false;

const user = Astro.locals.user;

// ─── URL filter parameters ─────────────────────────────────────────────────
const url = new URL(Astro.request.url);
const filterCategory = url.searchParams.get("category") || "";
const filterOutcome  = url.searchParams.get("outcome")  || "";
const filterFrom     = url.searchParams.get("from")     || "";
const filterTo       = url.searchParams.get("to")       || "";

// ─── Helpers ──────────────────────────────────────────────────────────────
function formatEventType(et: string): string {
  return et
    .split(".")
    .map((s) => s.replace(/_/g, " ").replace(/\b\w/g, (c) => c.toUpperCase()))
    .join(" · ");
}

function outcomeClasses(outcome: string): string {
  if (outcome === "success")
    return "rounded border border-kharon-green bg-kharon-green/10 px-2 py-1 text-xs font-bold text-green-200";
  if (outcome === "failure")
    return "rounded border border-kharon-red bg-kharon-red/10 px-2 py-1 text-xs font-bold text-red-200";
  return "rounded border border-kharon-amber bg-kharon-amber/10 px-2 py-1 text-xs font-bold text-amber-200";
}

function isHighRisk(et: string, outcome: string): boolean {
  if (et.startsWith("security.")) return true;
  if (et.startsWith("auth.") && (outcome === "failure" || outcome === "blocked")) return true;
  if (et.startsWith("admin.") && (outcome === "failure" || outcome === "blocked")) return true;
  return false;
}

function dateOffset(days: number): string {
  const d = new Date();
  d.setUTCDate(d.getUTCDate() - days);
  return d.toISOString().slice(0, 10);
}
const last7  = dateOffset(7);
const last30 = dateOffset(30);

// ─── Database query ────────────────────────────────────────────────────────
let events: AuditEvent[] = [];
let loadError = "";
const isFiltered = !!(filterCategory || filterOutcome || filterFrom || filterTo);

try {
  const db = getDatabase();
  const service = new AuditService(db);
  events = await service.getEvents({
    category: filterCategory,
    outcome: filterOutcome,
    from: filterFrom,
    to: filterTo
  });
} catch (error) {
  loadError = "Audit data could not be loaded.";
}
---

<PortalLayout title="Audit Console | Kharon Portal" active="audit" user={user}>
  <section class="bg-kharon-black px-4 py-8 text-white sm:px-6 sm:py-10">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-bold uppercase tracking-wider text-kharon-purple">Administration Console</p>
      <h1 class="mt-3 text-2xl font-bold sm:text-3xl font-heading tracking-tight">System Audit Log</h1>
      <p class="mt-4 max-w-3xl text-white/60">
        Read-only ledger of portal security operations and system state modifications. Showing the 100 most recent events.
      </p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto max-w-7xl">
      {loadError && (
        <p class="mb-6 border border-kharon-red bg-kharon-red/10 p-4 text-red-200 font-semibold">{loadError}</p>
      )}

      <!-- ─── Filter form ─────────────────────────────────────────────── -->
      <form method="GET" action="/portal/admin/audit" class="mb-6 kharon-surface p-4 sm:p-5">
        <p class="mb-4 text-xs font-bold uppercase tracking-widest text-kharon-purple">Filter telemetry events</p>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <label class="grid gap-1.5 text-xs font-bold uppercase tracking-wider text-white/85">
            Category
            <select name="category" class="kharon-field">
              <option value="">All categories</option>
              <option value="auth"     selected={filterCategory === "auth"}>Auth</option>
              <option value="admin"    selected={filterCategory === "admin"}>Admin</option>
              <option value="finance"  selected={filterCategory === "finance"}>Finance</option>
              <option value="job"      selected={filterCategory === "job"}>Jobs</option>
              <option value="security" selected={filterCategory === "security"}>Security</option>
              <option value="document" selected={filterCategory === "document"}>Documents</option>
            </select>
          </label>

          <label class="grid gap-1.5 text-xs font-bold uppercase tracking-wider text-white/85">
            Outcome
            <select name="outcome" class="kharon-field">
              <option value="">All outcomes</option>
              <option value="success" selected={filterOutcome === "success"}>Success</option>
              <option value="failure" selected={filterOutcome === "failure"}>Failure</option>
              <option value="blocked" selected={filterOutcome === "blocked"}>Blocked</option>
            </select>
          </label>

          <label class="grid gap-1.5 text-xs font-bold uppercase tracking-wider text-white/85">
            From
            <input type="date" name="from" value={filterFrom} class="kharon-field" />
          </label>

          <label class="grid gap-1.5 text-xs font-bold uppercase tracking-wider text-white/85">
            To
            <input type="date" name="to" value={filterTo} class="kharon-field" />
          </label>
        </div>

        <div class="mt-5 flex flex-wrap items-center justify-between gap-4 border-t border-kharon-purple/10 pt-5">
          <div class="flex flex-wrap gap-2">
            <a href="?category=auth&outcome=failure" class="rounded border border-kharon-purple/30 bg-kharon-purple/5 px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest text-kharon-purple hover:bg-kharon-purple/10 transition-colors">
              Failed logins
            </a>
            <a href={`?from=${last7}`} class="rounded border border-kharon-purple/30 bg-kharon-purple/5 px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest text-kharon-purple hover:bg-kharon-purple/10 transition-colors">
              Last 7 days
            </a>
            <a href={`?from=${last30}`} class="rounded border border-kharon-purple/30 bg-kharon-purple/5 px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest text-kharon-purple hover:bg-kharon-purple/10 transition-colors">
              Last 30 days
            </a>
            {isFiltered && (
              <a href="/portal/admin/audit" class="rounded border border-kharon-red/30 bg-kharon-red/5 px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest text-kharon-red hover:bg-kharon-red/10 transition-colors">
                Clear all
              </a>
            )}
          </div>
          <button type="submit" class="kharon-command-button px-8 py-2.5 text-xs font-black tracking-widest">
            Execute Filter
          </button>
        </div>
      </form>

      <!-- ─── Audit table ────────────────────────────────────────────── -->
      <div class="portal-scroll-x rounded-xl border border-kharon-purple/20 bg-kharon-black shadow-2xl overflow-hidden">
        <table class="w-full min-w-[1000px] border-collapse text-left text-sm">
          <thead>
            <tr class="border-b border-kharon-purple/20 bg-kharon-charcoal text-white uppercase tracking-widest text-[10px] font-black">
              <th scope="col" class="p-4">Timestamp</th>
              <th scope="col" class="p-4">Actor</th>
              <th scope="col" class="p-4">Event Context</th>
              <th scope="col" class="p-4">Entity</th>
              <th scope="col" class="p-4">Outcome</th>
              <th scope="col" class="p-4">Metadata</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-kharon-purple/10">
            {events.length === 0 && (
              <tr>
                <td colspan="6" class="p-8 text-center text-white/40 italic">No matching security events found in the ledger.</td>
              </tr>
            )}
            {events.map((ev) => (
              <tr class={`transition-colors hover:bg-kharon-purple/5 ${isHighRisk(ev.event_type, ev.outcome) ? 'bg-kharon-red/5' : ''}`}>
                <td class="p-4 font-mono text-[11px] text-white/50">{new Date(ev.created_at).toLocaleString()}</td>
                <td class="p-4">
                  <div class="flex flex-col">
                    <span class="font-bold text-white/90">{ev.actor_name || "System"}</span>
                    <span class="text-[10px] font-black uppercase tracking-tighter text-kharon-purple">{ev.actor_role}</span>
                  </div>
                </td>
                <td class="p-4">
                  <span class="text-xs font-bold text-kharon-cyan">{formatEventType(ev.event_type)}</span>
                </td>
                <td class="p-4">
                  <div class="flex flex-col">
                    <span class="text-[10px] font-black uppercase text-white/40">{ev.entity_type}</span>
                    <span class="font-mono text-[10px] text-white/60 truncate max-w-[120px]">{ev.entity_id || "—"}</span>
                  </div>
                </td>
                <td class="p-4">
                  <span class={outcomeClasses(ev.outcome)}>{ev.outcome.toUpperCase()}</span>
                </td>
                <td class="p-4">
                  {ev.metadata_json && (
                    <details class="group cursor-pointer">
                      <summary class="text-[10px] font-bold text-kharon-purple hover:text-white transition-colors uppercase tracking-widest list-none">View payload</summary>
                      <pre class="mt-2 rounded bg-kharon-black/80 p-3 text-[10px] text-kharon-cyan font-mono border border-kharon-purple/20 overflow-x-auto max-w-xs">{JSON.stringify(JSON.parse(ev.metadata_json), null, 2)}</pre>
                    </details>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>
</PortalLayout>
