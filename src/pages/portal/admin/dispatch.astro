---
/**
 * Project Sentinel - Dispatch Command Board
 * Purpose: Assign technicians, track SLA deadlines and manage the active job queue.
 */
import { auditError } from "../../../lib/server/audit.js";
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import { JobService, type TechJob } from "../../../lib/server/services/job-service";
import CsrfInput from "../../../components/ui/CsrfInput.astro";

export const prerender = false;

const user = Astro.locals.user;

// ── Helpers ────────────────────────────────────────────────────────────────
function slaInfo(requiredByDate: string | null): { text: string; cls: string } {
  if (!requiredByDate) return { text: "—", cls: "text-white/70" };
  const ms = new Date(requiredByDate + "T00:00:00Z").getTime() - Date.now();
  const days = Math.ceil(ms / 86400000);
  if (days < 0) return { text: `${-days}d overdue`, cls: "text-kharon-red font-bold" };
  if (days <= 3) return { text: `${days}d`, cls: "text-kharon-amber font-semibold" };
  return { text: `${days}d`, cls: "text-kharon-green font-medium" };
}

function priorityBadgeCls(p: string): string {
  if (p === "Critical") return "bg-kharon-red/20 text-kharon-red border border-kharon-red/30";
  if (p === "High") return "border border-kharon-amber/30 bg-kharon-amber/20 text-kharon-amber";
  if (p === "Low") return "border border-kharon-purple/20 bg-kharon-charcoal text-white/50";
  return "bg-kharon-purple/10 text-white/70 border border-kharon-purple/20"; // Normal
}

interface DispatchJob extends TechJob {
  sla: { text: string; cls: string };
  priorityCls: string;
  isEmergency: boolean;
  searchText: string;
}

let unassigned: DispatchJob[] = [];
let dispatched: DispatchJob[] = [];
let techs: { id: string; name: string }[] = [];
let stats = { unassigned: 0, inProgress: 0, emergency: 0, slaWarning: 0 };
let loadError = "";



try {
  const db = getDatabase();
  const service = new JobService(db);
  const allJobs = await service.getTechDashboardJobs("", "admin"); // Admin sees all

  const mapJob = (raw: TechJob): DispatchJob => ({
    ...raw,
    sla: slaInfo(raw.required_by_date),
    priorityCls: priorityBadgeCls(raw.priority || "Normal"),
    isEmergency: raw.is_emergency === 1,
    searchText: `${raw.owner_company_name} ${raw.coverage_area} ${raw.system_type} ${raw.id}`.toLowerCase()
  });

  const jobs = allJobs.map(mapJob);
  unassigned = jobs.filter(j => !j.assigned_technician_id && j.status === 'Scheduled');
  dispatched = jobs.filter(j => j.assigned_technician_id && (j.status === 'Scheduled' || j.status === 'In Progress'));
  
  const techResult = await db.prepare(`SELECT id, name FROM users WHERE role = 'tech' AND is_active = 1 ORDER BY name ASC`).all();
  techs = (techResult.results || []) as { id: string; name: string }[];

  stats = {
    unassigned: unassigned.length,
    inProgress: jobs.filter(j => j.status === 'In Progress').length,
    emergency: jobs.filter(j => j.is_emergency === 1).length,
    slaWarning: jobs.filter(j => j.required_by_date && new Date(j.required_by_date).getTime() < Date.now() + 3 * 86400000).length
  };
} catch (error) {
  await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "dispatch_board" });
  loadError = "Dispatch data could not be loaded.";
}

// Group dispatched jobs by technician for workload view
interface TechGroup { techId: string; techName: string; jobs: DispatchJob[] }
const techGroupMap = new Map<string, TechGroup>();
for (const job of dispatched) {
  const key = job.assigned_technician_id || "__unknown";
  const techName = techs.find(t => t.id === key)?.name || "Unknown";
  if (!techGroupMap.has(key)) {
    techGroupMap.set(key, { techId: key, techName, jobs: [] });
  }
  techGroupMap.get(key)!.jobs.push(job);
}
const techGroups: TechGroup[] = Array.from(techGroupMap.values()).sort((a, b) => a.techName.localeCompare(b.techName));
---

<PortalLayout title="Dispatch Board | Kharon Portal" active="dispatch" user={user}>
  <section class="bg-gradient-to-br from-kharon-black to-kharon-charcoal px-4 py-8 text-white sm:px-6 sm:py-10 rounded-xl border border-kharon-purple/10 mb-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_50%,rgba(124,93,194,0.09),transparent)]"></div>
    <div class="relative z-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-kharon-purple/10 ring-1 ring-kharon-purple/20">
          <svg class="h-[1.1rem] w-[1.1rem] text-kharon-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
          </svg>
        </div>
        <p class="text-xs font-black uppercase tracking-[0.2em] text-kharon-cyan">Operations Console</p>
      </div>
      <h1 class="text-2xl font-black sm:text-3xl tracking-tight text-white">Dispatch Command Board</h1>
      <p class="mt-2 max-w-3xl text-sm text-kharon-light/60">Assign technicians, set priorities, and track active fieldwork.</p>
    </div>
  </section>

  <div class="mx-auto max-w-7xl grid gap-8 px-4 sm:px-6 pb-10">
    {loadError && <p class="rounded-lg border border-kharon-red/40 bg-kharon-red/10 px-4 py-3 text-sm font-semibold text-kharon-red">{loadError}</p>}

    <div class="grid gap-4 grid-cols-2 lg:grid-cols-4">
      <div class="kharon-surface p-5 text-center">
        <p class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">Unassigned</p>
        <p class="text-3xl font-black text-white mt-2">{stats.unassigned}</p>
      </div>
      <div class="kharon-surface p-5 text-center">
        <p class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">In Progress</p>
        <p class="text-3xl font-black text-kharon-cyan mt-2">{stats.inProgress}</p>
      </div>
      <div class="kharon-surface p-5 text-center">
        <p class="text-[10px] font-black uppercase tracking-widest text-kharon-red">Emergency</p>
        <p class="text-3xl font-black text-white mt-2">{stats.emergency}</p>
      </div>
      <div class="kharon-surface p-5 text-center">
        <p class="text-[10px] font-black uppercase tracking-widest text-kharon-amber">SLA Danger</p>
        <p class="text-3xl font-black text-white mt-2">{stats.slaWarning}</p>
      </div>
    </div>

    <div class="grid gap-8 lg:grid-cols-[1fr_1.5fr]">
      <div class="space-y-6">
        <h2 class="text-sm font-black uppercase tracking-[0.2em] text-kharon-cyan">Unassigned Queue</h2>
        {unassigned.map(job => (
          <div class="rounded-xl border border-kharon-purple/20 bg-kharon-charcoal/80 p-5 shadow-lg relative overflow-hidden group hover:border-kharon-purple/40 transition-all">
            <div class="flex justify-between items-start mb-4">
              <span class={`rounded-full px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-widest ${job.priorityCls}`}>{job.priority}</span>
              <span class="text-[10px] font-mono text-white/30 uppercase tracking-tighter">#{job.id.slice(0, 8)}</span>
            </div>
            <h3 class="text-lg font-black text-white leading-tight">{job.owner_company_name}</h3>
            <p class="text-[11px] font-bold text-kharon-cyan uppercase tracking-wider mt-1">{job.system_type} | {job.coverage_area}</p>
            
            <form class="dispatch-form mt-5 pt-5 border-t border-kharon-purple/10 flex flex-col gap-3" data-action="assign">
              <CsrfInput />
              <input type="hidden" name="jobId" value={job.id} />
              <div class="flex gap-2">
                <select name="technicianId" class="kharon-field text-xs py-2 flex-1" required>
                  <option value="">— Assign Technician —</option>
                  {techs.map(t => <option value={t.id}>{t.name}</option>)}
                </select>
                <button type="submit" class="kharon-command-button px-6 py-2 text-[10px]">Dispatch</button>
              </div>
            </form>
          </div>
        ))}
      </div>

      <div class="space-y-6">
        <h2 class="text-sm font-black uppercase tracking-[0.2em] text-kharon-cyan">Technician Workload</h2>
        {techGroups.map(group => (
          <div class="rounded-xl border border-kharon-purple/20 bg-kharon-black/40 overflow-hidden shadow-xl">
            <div class="flex items-center justify-between bg-kharon-charcoal/80 px-5 py-3 border-b border-kharon-purple/20">
              <span class="text-sm font-black uppercase tracking-widest text-white">{group.techName}</span>
              <span class="rounded-full bg-kharon-purple/10 px-2 py-0.5 text-[10px] font-black uppercase text-kharon-cyan">{group.jobs.length} Active</span>
            </div>
            <div class="divide-y divide-kharon-purple/10">
              {group.jobs.map(job => (
                <div class="px-5 py-5 hover:bg-kharon-purple/5 transition-colors">
                   <div class="flex justify-between items-center mb-2">
                      <span class="font-bold text-white tracking-tight">{job.owner_company_name}</span>
                      <a href={`/portal/tech/jobs/${job.id}`} class="text-[10px] font-black uppercase text-kharon-purple hover:text-kharon-cyan transition-colors">Details &rarr;</a>
                   </div>
                   <p class="text-[10px] font-bold text-white/40 uppercase tracking-widest">{job.system_type} | {job.coverage_area}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</PortalLayout>

<script>
  import { portalPost } from "../../../lib/client/portalApi.ts";

  document.querySelectorAll(".dispatch-form").forEach(form => {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const formEl = e.target as HTMLFormElement;
      const formData = new FormData(formEl);
      const payload = Object.fromEntries(formData);
      
      const btn = formEl.querySelector("button");
      if (btn) btn.disabled = true;

      try {
        const { response, body } = await portalPost("/portal/api/admin/dispatch", {
          ...payload,
          action: formEl.dataset.action
        });
        if (response.ok && body.ok) {
          window.location.reload();
        } else {
          alert(body.message || "Dispatch failed.");
          if (btn) btn.disabled = false;
        }
      } catch (err) {
        alert("Network error.");
        if (btn) btn.disabled = false;
      }
    });
  });
</script>
