---
/**
 * Project Sentinel - Multi-Client Management
 * Purpose: Create, read, update, and delete client company entities
 * Dependencies: PortalLayout, getDatabase, requireAdmin
 * Structural Role: Administrative client records management
 */
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings";
import { requireAdmin } from "../../../lib/server/access";
import CsrfInput from "../../../components/ui/CsrfInput.astro";

export const prerender = false;

const { user } = Astro.locals;
const adminError = requireAdmin(user);
if (adminError) return adminError;

interface ClientRecord {
  id: string;
  company_name: string;
  contact_person: string | null;
  contact_email: string | null;
  contact_phone: string | null;
  billing_address: string | null;
  created_at: string;
  site_count: number;
  system_count: number;
  job_count: number;
  finance_record_count: number;
}

let clientRecords: ClientRecord[] = [];
let loadError = "";

try {
  const db = getDatabase();
  const rawClients = await db.prepare(`
    SELECT
      c.id, c.company_name, c.contact_person, c.contact_email, c.contact_phone,
      c.billing_address, c.created_at,
      COUNT(DISTINCT si.id) AS site_count,
      COUNT(DISTINCT s.id)  AS system_count,
      COUNT(DISTINCT j.id)  AS job_count,
      COUNT(DISTINCT fr.id) AS finance_record_count
    FROM clients c
    LEFT JOIN sites si ON si.owner_company_name = c.company_name AND si.deleted_at IS NULL
    LEFT JOIN systems s  ON s.site_id = si.id AND s.deleted_at IS NULL
    LEFT JOIN jobs j     ON j.system_id = s.id AND j.deleted_at IS NULL
    LEFT JOIN financial_records fr ON fr.site_id = si.id
    WHERE c.deleted_at IS NULL
    GROUP BY c.id, c.company_name
    ORDER BY c.company_name ASC
  `).all();
  clientRecords = (rawClients.results ?? []) as unknown as ClientRecord[];
} catch (_err) {
  loadError = "Client records could not be loaded.";
}
---

<PortalLayout title="Multi-Client Management | Kharon Portal" active="clients" user={user}>

  <section class="bg-gradient-to-br from-kharon-black to-kharon-charcoal px-4 py-8 text-white sm:px-6 sm:py-10 kharon-environment rounded-xl border border-kharon-purple/10 mb-6 shadow-inner relative overflow-hidden">
    <div class="mx-auto max-w-7xl flex items-end justify-between gap-4 flex-wrap relative z-10">
      <div>
        <p class="text-[0.625rem] font-bold uppercase tracking-[0.2em] text-kharon-purple">Admin Operations</p>
        <h1 class="mt-2 text-2xl font-bold sm:text-3xl tracking-tight">Multi-Client Management</h1>
        <p class="mt-3 max-w-3xl text-sm text-white/50">Create and manage client company records linked to portal sites and users.</p>
      </div>
      <button id="add-client-btn" type="button"
        class="kharon-command-button min-h-[44px] px-5 py-3 text-sm font-semibold">
        + Add Client
      </button>
    </div>
  </section>

  <section class="min-h-[40vh]">
    <div class="mx-auto max-w-7xl">

      {loadError && (
        <p class="mb-6 rounded border border-kharon-red/40 bg-kharon-red/10 px-4 py-3 text-sm font-semibold text-kharon-red">{loadError}</p>
      )}

      <div id="page-result" class="mb-4 hidden rounded border px-4 py-3 text-sm font-semibold"></div>

      {clientRecords.length === 0 && !loadError && (
        <div class="rounded-lg border border-kharon-purple/20 bg-kharon-charcoal px-8 py-12 text-center">
          <p class="text-white/40 text-sm mb-4">No client companies registered yet.</p>
          <button id="empty-add-btn" type="button"
            class="kharon-command-button px-5 py-3 text-sm font-semibold">
            Add First Client
          </button>
        </div>
      )}

      {clientRecords.length > 0 && (
        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
          {clientRecords.map((client) => (
            <article class="rounded-lg border border-kharon-purple/20 bg-kharon-charcoal p-5 flex flex-col gap-4">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <h2 class="text-base font-semibold text-white truncate">{client.company_name}</h2>
                  {client.contact_person && (
                    <p class="text-xs text-white/50 mt-0.5">{client.contact_person}</p>
                  )}
                  {client.contact_email && (
                    <a href={`mailto:${client.contact_email}`} class="text-xs text-kharon-cyan hover:underline">{client.contact_email}</a>
                  )}
                </div>
                <div class="flex gap-2 shrink-0">
                  <button
                    class="edit-client kharon-secondary-button px-3 py-2 text-xs"
                    type="button"
                    data-client={JSON.stringify(client)}
                  >Edit</button>
                  <button
                    class="delete-client rounded border border-kharon-red/40 bg-kharon-red/10 px-3 py-2 text-xs font-semibold text-kharon-red hover:bg-kharon-red/20 transition-colors min-h-[44px]"
                    type="button"
                    data-client-id={client.id}
                    data-client-name={client.company_name}
                  >Delete</button>
                </div>
              </div>

              <div class="grid grid-cols-4 gap-2 border-t border-kharon-purple/10 pt-3">
                {[
                  { label: "Sites",    value: client.site_count },
                  { label: "Systems",  value: client.system_count },
                  { label: "Jobs",     value: client.job_count },
                  { label: "Finance",  value: client.finance_record_count },
                ].map(stat => (
                  <div class="text-center">
                    <p class="text-lg font-bold text-kharon-cyan">{stat.value}</p>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-white/40">{stat.label}</p>
                  </div>
                ))}
              </div>

              <p class="text-[10px] text-white/30">
                Added {new Date(client.created_at).toLocaleDateString("en-ZA")}
              </p>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Add/Edit Modal -->
  <div id="client-modal" class="fixed inset-0 z-[100] hidden overflow-y-auto" role="dialog" aria-modal="true" aria-labelledby="modal-title">
    <div class="flex min-h-screen items-center justify-center p-4">
      <div class="fixed inset-0 bg-kharon-black/80 backdrop-blur-sm" id="modal-backdrop"></div>
      <div class="relative w-full max-w-lg rounded-xl border border-kharon-purple/30 bg-kharon-charcoal p-6 shadow-2xl">
        <div class="mb-5">
          <h2 id="modal-title" class="text-lg font-bold text-white">
            <span id="modal-action">Add</span> Client
          </h2>
          <p class="mt-1 text-xs text-white/50">All client records link to portal sites by company name.</p>
        </div>
        <form id="client-form" class="grid gap-4">
          <CsrfInput />
          <input type="hidden" id="client-id" name="id" />

          <div class="grid gap-1">
            <label for="company-name" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Company Name *</label>
            <input type="text" id="company-name" name="companyName" required class="kharon-field" placeholder="e.g. Acme Industries (Pty) Ltd" />
          </div>
          <div class="grid gap-1">
            <label for="contact-person" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Contact Person</label>
            <input type="text" id="contact-person" name="contactPerson" class="kharon-field" placeholder="Full name" />
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div class="grid gap-1">
              <label for="contact-email" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Email</label>
              <input type="email" id="contact-email" name="contactEmail" class="kharon-field" placeholder="contact@company.co.za" />
            </div>
            <div class="grid gap-1">
              <label for="contact-phone" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Phone</label>
              <input type="tel" id="contact-phone" name="contactPhone" class="kharon-field" placeholder="0xx xxx xxxx" />
            </div>
          </div>
          <div class="grid gap-1">
            <label for="billing-address" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Billing Address</label>
            <textarea id="billing-address" name="billingAddress" rows="2" class="kharon-field" placeholder="Street, Suburb, City, Code"></textarea>
          </div>

          <div id="modal-result" class="hidden rounded border px-4 py-3 text-sm font-semibold"></div>

          <div class="flex justify-end gap-3 pt-2">
            <button type="button" id="cancel-client-btn" class="kharon-secondary-button px-5 py-3 text-sm">Cancel</button>
            <button type="button" id="save-client-btn" class="kharon-command-button px-5 py-3 text-sm">Save Client</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="delete-modal" class="fixed inset-0 z-[110] hidden overflow-y-auto" role="dialog" aria-modal="true">
    <div class="flex min-h-screen items-center justify-center p-4">
      <div class="fixed inset-0 bg-kharon-black/80 backdrop-blur-sm" id="delete-backdrop"></div>
      <div class="relative w-full max-w-md rounded-xl border border-kharon-red/30 bg-kharon-charcoal p-6 shadow-2xl">
        <h2 class="text-lg font-bold text-white mb-2">Deactivate Client?</h2>
        <p class="text-sm text-white/60 mb-6">
          This will soft-delete <strong id="delete-client-name" class="text-white"></strong> and preserve all associated records.
        </p>
        <div id="delete-result" class="hidden rounded border px-4 py-3 text-sm font-semibold mb-4"></div>
        <div class="flex justify-end gap-3">
          <button type="button" id="cancel-delete-btn" class="kharon-secondary-button px-5 py-3 text-sm">Cancel</button>
          <button type="button" id="confirm-delete-btn"
            class="rounded border border-kharon-red/40 bg-kharon-red/20 px-5 py-3 text-sm font-semibold text-kharon-red hover:bg-kharon-red/30 transition-colors min-h-[44px]">
            Deactivate
          </button>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { portalPost } from "../../../lib/client/portalApi";

    interface ClientPayload {
      id?: string;
      company_name?: string;
      contact_person?: string | null;
      contact_email?: string | null;
      contact_phone?: string | null;
      billing_address?: string | null;
    }

    let currentClientId: string | null = null;

    function setResult(el: HTMLElement | null, text: string, variant: "success" | "error") {
      if (!el) return;
      el.textContent = text;
      el.className = variant === "success"
        ? "rounded border border-kharon-green/40 bg-kharon-green/10 px-4 py-3 text-sm font-semibold text-kharon-green"
        : "rounded border border-kharon-red/40 bg-kharon-red/10 px-4 py-3 text-sm font-semibold text-kharon-red";
      el.classList.remove("hidden");
    }

    function openModal(client?: ClientPayload) {
      const isEdit = !!client?.id;
      document.getElementById("modal-action")!.textContent = isEdit ? "Edit" : "Add";
      (document.getElementById("client-id") as HTMLInputElement).value = client?.id ?? "";
      (document.getElementById("company-name") as HTMLInputElement).value = client?.company_name ?? "";
      (document.getElementById("contact-person") as HTMLInputElement).value = client?.contact_person ?? "";
      (document.getElementById("contact-email") as HTMLInputElement).value = client?.contact_email ?? "";
      (document.getElementById("contact-phone") as HTMLInputElement).value = client?.contact_phone ?? "";
      (document.getElementById("billing-address") as HTMLTextAreaElement).value = client?.billing_address ?? "";
      document.getElementById("modal-result")?.classList.add("hidden");
      document.getElementById("client-modal")!.classList.remove("hidden");
    }

    function closeModal() {
      document.getElementById("client-modal")!.classList.add("hidden");
    }

    function openDeleteModal(id: string, name: string) {
      currentClientId = id;
      document.getElementById("delete-client-name")!.textContent = name;
      document.getElementById("delete-result")?.classList.add("hidden");
      document.getElementById("delete-modal")!.classList.remove("hidden");
    }

    function closeDeleteModal() {
      document.getElementById("delete-modal")!.classList.add("hidden");
      currentClientId = null;
    }

    async function saveClient() {
      const clientId = (document.getElementById("client-id") as HTMLInputElement).value;
      const payload: Record<string, unknown> = {
        action: clientId ? "update" : "create",
        id: clientId || undefined,
        companyName: (document.getElementById("company-name") as HTMLInputElement).value,
        contactPerson: (document.getElementById("contact-person") as HTMLInputElement).value,
        contactEmail: (document.getElementById("contact-email") as HTMLInputElement).value,
        contactPhone: (document.getElementById("contact-phone") as HTMLInputElement).value,
        billingAddress: (document.getElementById("billing-address") as HTMLTextAreaElement).value,
      };
      const result = document.getElementById("modal-result");
      const { body } = await portalPost("/portal/admin/api/multi-client", payload);
      if (body.ok) {
        setResult(result, body.message as string || "Client saved.", "success");
        setTimeout(() => { closeModal(); window.location.reload(); }, 900);
      } else {
        setResult(result, body.message as string || "Failed to save client.", "error");
      }
    }

    async function deleteClient() {
      if (!currentClientId) return;
      const result = document.getElementById("delete-result");
      const { body } = await portalPost("/portal/admin/api/multi-client", { action: "delete", id: currentClientId });
      if (body.ok) {
        setResult(result, "Client deactivated.", "success");
        setTimeout(() => { closeDeleteModal(); window.location.reload(); }, 900);
      } else {
        setResult(result, body.message as string || "Failed to deactivate client.", "error");
      }
    }

    // Wire up buttons
    document.getElementById("add-client-btn")?.addEventListener("click", () => openModal());
    document.getElementById("empty-add-btn")?.addEventListener("click", () => openModal());
    document.getElementById("save-client-btn")?.addEventListener("click", saveClient);
    document.getElementById("cancel-client-btn")?.addEventListener("click", closeModal);
    document.getElementById("modal-backdrop")?.addEventListener("click", closeModal);
    document.getElementById("confirm-delete-btn")?.addEventListener("click", deleteClient);
    document.getElementById("cancel-delete-btn")?.addEventListener("click", closeDeleteModal);
    document.getElementById("delete-backdrop")?.addEventListener("click", closeDeleteModal);

    document.querySelectorAll<HTMLButtonElement>(".edit-client").forEach(btn => {
      btn.addEventListener("click", () => {
        const client = JSON.parse(btn.dataset.client ?? "{}") as ClientPayload;
        openModal(client);
      });
    });

    document.querySelectorAll<HTMLButtonElement>(".delete-client").forEach(btn => {
      btn.addEventListener("click", () => {
        openDeleteModal(btn.dataset.clientId ?? "", btn.dataset.clientName ?? "");
      });
    });
  </script>

</PortalLayout>
