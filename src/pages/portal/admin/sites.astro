---
/**
 * Project Sentinel - Admin Sites
 * Purpose: Admin interface for client site management with elite command aesthetic.
 * Dependencies: PortalLayout, getDatabase, requireAdmin
 * Structural Role: Administrative UI for facility tracking
 */
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings";
import { requireAdmin } from "../../../lib/server/access";
import type { DbSite, DbUser } from "@sentinel/types";

interface ClientSiteAccessJoin {
  user_id: string;
  site_id: string;
  granted_at: string;
  user_name: string;
  user_email: string;
  owner_company_name: string;
}

export const prerender = false;

const { user } = Astro.locals;
const adminError = requireAdmin(user);
if (adminError) {
  return adminError;
}

const params = Astro.url.searchParams;
const page = Math.max(1, Math.min(999, parseInt(params.get("page") || "1", 10) || 1));
const searchQuery = params.get("q") || "";
const perPage = 50;
const offset = (page - 1) * perPage;

let sites: DbSite[] = [];
let clientUsers: DbUser[] = [];
let clientSiteAccess: ClientSiteAccessJoin[] = [];
let sitesTotal = 0;
let loadError = "";

try {
  const db = getDatabase();

  let searchCondition = "";
  const bindParams: string[] = [];

  if (searchQuery) {
    searchCondition += ` AND (owner_company_name LIKE ? OR site_contact_person LIKE ? OR site_contact_email LIKE ?)`;
    const q = `%${searchQuery}%`;
    bindParams.push(q, q, q);
  }

  const countQuery = `SELECT COUNT(*) as total FROM sites WHERE deleted_at IS NULL ${searchCondition}`;
  sitesTotal = ((await db.prepare(countQuery).bind(...bindParams).first()) as { total: number } | null)?.total ?? 0;

  const dataQuery = `
    SELECT id, owner_company_name, physical_address, site_contact_person, site_contact_email, site_contact_phone, billing_emails
    FROM sites
    WHERE deleted_at IS NULL ${searchCondition}
    ORDER BY owner_company_name
    LIMIT ? OFFSET ?
  `;

  sites = ((await db.prepare(dataQuery).bind(...bindParams, perPage, offset).all()).results ?? []) as unknown as DbSite[];

  clientUsers = ((await db.prepare(`SELECT id, name, email FROM users WHERE role = 'client' AND is_active = 1`).all()).results ?? []) as unknown as DbUser[];

  clientSiteAccess = ((await db.prepare(
    `SELECT client_site_access.user_id, client_site_access.site_id, client_site_access.granted_at,
            users.name AS user_name, users.email AS user_email, sites.owner_company_name
     FROM client_site_access
     INNER JOIN users ON users.id = client_site_access.user_id
     INNER JOIN sites ON sites.id = client_site_access.site_id
     ORDER BY users.name, sites.owner_company_name
     LIMIT 1000`
  ).all()).results ?? []) as unknown as ClientSiteAccessJoin[];

} catch (error) {
  loadError = "Sites data could not be loaded.";
}

const totalPages = Math.max(1, Math.ceil(sitesTotal / perPage));
import CsrfInput from "../../../components/ui/CsrfInput.astro";
---

<PortalLayout title="Site Management | Kharon Portal" active="sites" user={user}>
  {/* ── Page Header ── */}
  <section class="bg-gradient-to-br from-kharon-black to-kharon-charcoal px-4 py-8 text-white sm:px-6 sm:py-10 rounded-xl border border-kharon-purple/10 mb-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_10%_50%,rgba(124,93,194,0.09),transparent)]"></div>
    <div class="relative z-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-kharon-purple/10 ring-1 ring-kharon-purple/20">
          <svg class="h-[1.1rem] w-[1.1rem] text-kharon-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </div>
        <p class="text-xs font-black uppercase tracking-[0.2em] text-kharon-cyan">Asset Console</p>
      </div>
      <h1 class="text-2xl font-black sm:text-3xl tracking-tight text-white">Client Site Management</h1>
      <p class="mt-2 max-w-3xl text-sm text-kharon-light/60">Manage client locations, contact infrastructure, and secure access mappings across the portfolio.</p>
    </div>
  </section>

  <div class="grid gap-8">
    {loadError && (
      <p class="rounded-lg border border-kharon-red/40 bg-kharon-red/10 px-4 py-3 text-sm font-semibold text-kharon-red">{loadError}</p>
    )}

    {/* ── Search & Metrics ── */}
    <div class="flex flex-wrap items-end justify-between gap-6 bg-kharon-charcoal/40 p-5 rounded-xl border border-kharon-purple/10">
      <div class="flex flex-wrap items-end gap-4 flex-1">
        <form class="flex flex-wrap items-end gap-3 flex-1 min-w-[300px]" method="get">
          <CsrfInput />
          <div class="grid gap-1 flex-1">
            <label for="sites-q" class="text-[10px] font-black uppercase tracking-widest text-kharon-purple px-1">Search Registry</label>
            <input
              id="sites-q"
              name="q"
              type="search"
              class="kharon-field"
              placeholder="Company, contact, or email…"
              value={searchQuery}
            />
          </div>
          <button type="submit" class="kharon-command-button py-2 px-6 h-[42px] text-[10px]">Execute Search</button>
          {searchQuery && (
            <a href="/portal/admin/sites" class="kharon-secondary-button py-2 px-4 h-[42px] text-[10px] flex items-center justify-center">Reset</a>
          )}
        </form>
      </div>
      
      <div class="flex items-center gap-6 px-4 py-2 border-l border-kharon-purple/10">
        <div>
          <p class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">Total Sites</p>
          <p class="text-2xl font-black text-white leading-none mt-1">{sitesTotal}</p>
        </div>
      </div>
    </div>

    {/* ── Sites Grid ── */}
    <div class="grid gap-6">
      {sites.length === 0 && (
        <div class="py-20 text-center border border-dashed border-kharon-purple/20 rounded-2xl">
          <p class="text-white/40 font-bold uppercase tracking-widest">No site records found</p>
        </div>
      )}
      <div class="grid gap-6">
        {sites.map((record) => (
          <form
            class="admin-form group relative grid gap-6 bg-kharon-charcoal/60 border border-kharon-purple/20 p-6 lg:grid-cols-6 rounded-xl hover:border-kharon-purple/40 transition-all backdrop-blur-md shadow-xl"
            data-endpoint="/portal/api/admin/sites"
          >
            <CsrfInput />
            <input type="hidden" name="action" value="update" />
            <input type="hidden" name="id" value={record.id} />
            
            <div class="lg:col-span-2 grid gap-1.5">
              <label for={`comp-${record.id}`} class="text-[9px] font-black uppercase tracking-widest text-kharon-purple">Registered Entity</label>
              <input id={`comp-${record.id}`} class="kharon-field text-sm font-bold" name="ownerCompanyName" value={record.owner_company_name} required />
            </div>
            
            <div class="grid gap-1.5">
              <label for={`contact-${record.id}`} class="text-[9px] font-black uppercase tracking-widest text-kharon-purple">Lead Contact</label>
              <input id={`contact-${record.id}`} class="kharon-field text-xs" name="siteContactPerson" value={record.site_contact_person ?? ""} required />
            </div>
            
            <div class="grid gap-1.5">
              <label for={`email-${record.id}`} class="text-[9px] font-black uppercase tracking-widest text-kharon-purple">Contact Email</label>
              <input id={`email-${record.id}`} class="kharon-field text-xs" name="siteContactEmail" type="email" value={record.site_contact_email || ""} />
            </div>
            
            <div class="grid gap-1.5">
              <label for={`phone-${record.id}`} class="text-[9px] font-black uppercase tracking-widest text-kharon-purple">Phone Infrastructure</label>
              <input id={`phone-${record.id}`} class="kharon-field text-xs" name="siteContactPhone" value={record.site_contact_phone || ""} />
            </div>

            <div class="grid gap-1.5 self-end">
              <button class="kharon-command-button w-full py-2.5 text-[10px] h-[40px]">Update Site</button>
            </div>
            
            <div class="lg:col-span-4 grid gap-1.5">
              <label for={`address-${record.id}`} class="text-[9px] font-black uppercase tracking-widest text-kharon-purple">Physical Site Address</label>
              <textarea id={`address-${record.id}`} class="min-h-[80px] kharon-field text-xs leading-relaxed" name="physicalAddress" required>{record.physical_address}</textarea>
            </div>

            <div class="lg:col-span-2 grid gap-1.5">
              <label for={`billing-${record.id}`} class="text-[9px] font-black uppercase tracking-widest text-kharon-purple">Finance Emails (Comma separated)</label>
              <input id={`billing-${record.id}`} class="kharon-field text-xs" name="billingEmails" value={record.billing_emails} required />
              <div class="mt-4 flex items-center justify-between gap-4 border-t border-kharon-purple/10 pt-4">
                <a href={`/portal/admin/systems?q=${encodeURIComponent(record.owner_company_name)}`} class="text-[10px] font-black uppercase tracking-widest text-kharon-purple hover:text-kharon-cyan transition-colors">
                  System Registry &rarr;
                </a>
                <span class="text-[10px] font-mono text-white/20 uppercase tracking-tighter">ID: {record.id.slice(0, 8)}</span>
              </div>
            </div>
            
            <p class="admin-result hidden rounded border px-4 py-3 text-xs font-bold uppercase tracking-widest lg:col-span-6"></p>
          </form>
        ))}
      </div>
    </div>

    {/* ── Pagination ── */}
    {totalPages > 1 && (
      <nav class="flex items-center justify-between border-t border-kharon-purple/10 pt-6">
        {page > 1 ? (
          <a href={`?page=${page - 1}&q=${encodeURIComponent(searchQuery)}`} class="kharon-secondary-button py-2.5 px-6 text-[10px]">Previous Payload</a>
        ) : (
          <span class="opacity-30 rounded border border-kharon-purple/20 px-6 py-2.5 text-[10px] font-black uppercase text-white">Previous</span>
        )}
        <span class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">Segment {page} of {totalPages}</span>
        {page < totalPages ? (
          <a href={`?page=${page + 1}&q=${encodeURIComponent(searchQuery)}`} class="kharon-secondary-button py-2.5 px-6 text-[10px]">Next Payload</a>
        ) : (
          <span class="opacity-30 rounded border border-kharon-purple/20 px-6 py-2.5 text-[10px] font-black uppercase text-white">Next</span>
        )}
      </nav>
    )}

    {/* ── Operational Grid (Create & Mapping) ── */}
    <div class="grid gap-8 xl:grid-cols-2">
      <article class="bg-kharon-charcoal/60 border border-kharon-purple/20 p-6 rounded-xl backdrop-blur-md shadow-2xl">
        <h2 class="text-lg font-black text-white uppercase tracking-widest mb-6">Initialize New Site</h2>
        <form class="admin-form grid gap-5" data-endpoint="/portal/api/admin/sites">
          <CsrfInput />
          <input type="hidden" name="action" value="create" />
          
          <div class="grid gap-1.5">
            <label for="create-company" class="text-[9px] font-black uppercase tracking-widest text-kharon-purple">Entity Name *</label>
            <input id="create-company" class="kharon-field" name="ownerCompanyName" placeholder="e.g. Acme Industrial" required />
          </div>

          <div class="grid gap-1.5">
            <label for="create-address" class="text-[9px] font-black uppercase tracking-widest text-kharon-purple">Physical Location *</label>
            <textarea id="create-address" class="min-h-[80px] kharon-field text-xs" name="physicalAddress" placeholder="Street address, suburb, code" required></textarea>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="grid gap-1.5">
              <label for="create-contact" class="text-[9px] font-black uppercase tracking-widest text-kharon-purple">Lead Liaison *</label>
              <input id="create-contact" class="kharon-field text-xs" name="siteContactPerson" placeholder="Full name" required />
            </div>

            <div class="grid gap-1.5">
              <label for="create-phone" class="text-[9px] font-black uppercase tracking-widest text-kharon-purple">Contact Phone</label>
              <input id="create-phone" class="kharon-field text-xs" name="siteContactPhone" placeholder="+27..." />
            </div>
          </div>

          <div class="grid gap-1.5">
            <label for="create-email" class="text-[9px] font-black uppercase tracking-widest text-kharon-purple">Liaison Email</label>
            <input id="create-email" class="kharon-field text-xs" name="siteContactEmail" type="email" placeholder="contact@company.com" />
          </div>

          <div class="grid gap-1.5">
            <label for="create-billing" class="text-[9px] font-black uppercase tracking-widest text-kharon-purple">Sage Billing Targets *</label>
            <input id="create-billing" class="kharon-field text-xs" name="billingEmails" placeholder="accounts@company.com" required />
          </div>

          <button class="kharon-command-button w-full py-4 mt-2 text-[10px]">Create Site Registry Record</button>
          <p class="admin-result hidden mt-4 rounded border px-4 py-3 text-[10px] font-bold uppercase tracking-widest"></p>
        </form>
      </article>

      <article class="bg-kharon-charcoal/60 border border-kharon-purple/20 p-6 rounded-xl backdrop-blur-md shadow-2xl">
        <div class="mb-6">
          <p class="text-[10px] font-black uppercase tracking-widest text-kharon-purple">Security Protocol</p>
          <h2 class="mt-1 text-lg font-black text-white uppercase tracking-widest">Multi-Site Authorization</h2>
        </div>

        <form class="client-site-access-form grid gap-5" data-endpoint="/portal/api/admin/client-site-access">
          <CsrfInput />
          <input type="hidden" name="action" value="grant" />
          
          <div class="grid grid-cols-2 gap-4">
            <div class="grid gap-1.5">
              <label for="grant-user" class="text-[9px] font-black uppercase tracking-widest text-kharon-purple">Target Client Account *</label>
              <select id="grant-user" class="kharon-field text-xs py-2" name="userId" required>
                <option value="">— Select Account —</option>
                {clientUsers.map((client) => (
                  <option value={client.id}>{client.name} ({client.email})</option>
                ))}
              </select>
            </div>
            
            <div class="grid gap-1.5">
              <label for="grant-site" class="text-[9px] font-black uppercase tracking-widest text-kharon-purple">Authorize Site Access *</label>
              <select id="grant-site" class="kharon-field text-xs py-2" name="siteId" required>
                <option value="">— Select Site —</option>
                {sites.map((site) => <option value={site.id}>{site.owner_company_name}</option>)}
              </select>
            </div>
          </div>
          
          <button class="kharon-command-button py-3 text-[10px]">Authorize Mapped Access</button>
          <p class="client-site-access-result hidden rounded border px-4 py-3 text-[10px] font-bold uppercase tracking-widest"></p>
        </form>

        <div class="mt-8 space-y-3">
          <p class="text-[10px] font-black uppercase tracking-widest text-white/30 mb-4 px-1">Active Mapping Registry</p>
          {clientSiteAccess.length === 0 && (
            <p class="text-white/20 text-xs italic p-4 border border-dashed border-kharon-purple/10 rounded-lg text-center">No authorized multi-site mappings found.</p>
          )}
          <div class="grid gap-3 max-h-[400px] overflow-y-auto pr-2 custom-scrollbar">
            {clientSiteAccess.map((mapping) => (
              <form
                class="client-site-access-form flex items-center justify-between gap-4 bg-kharon-black/40 border border-kharon-purple/10 p-4 rounded-lg hover:border-kharon-purple/30 transition-colors"
                data-endpoint="/portal/api/admin/client-site-access"
                data-user-name={mapping.user_name}
                data-site-name={mapping.owner_company_name}
              >
                <CsrfInput />
                <div class="min-w-0">
                  <p class="font-bold text-white text-xs truncate">{mapping.user_name}</p>
                  <p class="text-[10px] font-bold text-kharon-cyan uppercase tracking-tighter truncate mt-0.5">{mapping.owner_company_name}</p>
                </div>
                <input type="hidden" name="action" value="revoke" />
                <input type="hidden" name="userId" value={mapping.user_id} />
                <input type="hidden" name="siteId" value={mapping.site_id} />
                <button class="kharon-danger-button py-1.5 px-3 text-[8px] h-fit">Revoke</button>
                <p class="client-site-access-result hidden w-full rounded border px-4 py-3 text-[10px] font-bold uppercase"></p>
              </form>
            ))}
          </div>
        </div>
      </article>
    </div>
  </div>
  
  <script>
    import { bindAdminForms, portalPost, extractFormPayload, setResult } from "../../../lib/client/portalApi";
    bindAdminForms();

    for (const form of document.querySelectorAll<HTMLFormElement>(".client-site-access-form")) {
      form.addEventListener("submit", async (event: Event) => {
        event.preventDefault();
        
        const actionInput = form.querySelector<HTMLInputElement>('input[name="action"]');
        if (actionInput?.value === "revoke") {
          const userName = form.getAttribute("data-user-name") || "this user";
          const siteName = form.getAttribute("data-site-name") || "this site";
          if (!window.confirm(`REVOKE ACCESS COMMAND: Are you sure you want to terminate site access for "${userName}" at "${siteName}"?`)) {
            return;
          }
        }

        const result = form.querySelector<HTMLElement>(".client-site-access-result");
        if (result) {
          result.classList.add("hidden");
          result.textContent = "Processing...";
        }
        
        const { response, body } = await portalPost(form.dataset.endpoint ?? "", extractFormPayload(form));
        if (!response.ok || !body.ok) {
          setResult(result, body.message ?? "Operational command failed.", "error");
          return;
        }
        setResult(result, body.action === "grant" ? "ACCESS AUTHORIZED." : "ACCESS REVOKED.", "success");
        setTimeout(() => window.location.reload(), 800);
      });
    }
  </script>
</PortalLayout>
