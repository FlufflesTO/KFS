---
/**
 * Project Sentinel - Admin Sites
 * Purpose: Admin interface for client site management
 * Dependencies: PortalLayout, getDatabase, requireAdmin
 * Structural Role: Administrative UI for facility tracking
 */
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings";
import { requireAdmin } from "../../../lib/server/access";
import type { DbSite, DbUser } from "@sentinel/types";

interface ClientSiteAccessJoin {
  user_id: string;
  site_id: string;
  granted_at: string;
  user_name: string;
  user_email: string;
  owner_company_name: string;
}

export const prerender = false;

const { user } = Astro.locals;
const adminError = requireAdmin(user);
if (adminError) {
  return adminError;
}

const params = Astro.url.searchParams;
const page = Math.max(1, Math.min(999, parseInt(params.get("page") || "1", 10) || 1));
const searchQuery = params.get("q") || "";
const perPage = 50;
const offset = (page - 1) * perPage;

let sites: DbSite[] = [];
let clientUsers: DbUser[] = [];
let clientSiteAccess: ClientSiteAccessJoin[] = [];
let sitesTotal = 0;
let loadError = "";

try {
  const db = getDatabase();

  let searchCondition = "";
  const bindParams: string[] = [];

  if (searchQuery) {
    searchCondition += ` AND (owner_company_name LIKE ? OR site_contact_person LIKE ? OR site_contact_email LIKE ?)`;
    const q = `%${searchQuery}%`;
    bindParams.push(q, q, q);
  }

  const countQuery = `SELECT COUNT(*) as total FROM sites WHERE deleted_at IS NULL ${searchCondition}`;
  sitesTotal = ((await db.prepare(countQuery).bind(...bindParams).first()) as { total: number } | null)?.total ?? 0;

  const dataQuery = `
    SELECT id, owner_company_name, physical_address, site_contact_person, site_contact_email, site_contact_phone, billing_emails
    FROM sites
    WHERE deleted_at IS NULL ${searchCondition}
    ORDER BY owner_company_name
    LIMIT ? OFFSET ?
  `;

  sites = ((await db.prepare(dataQuery).bind(...bindParams, perPage, offset).all()).results ?? []) as unknown as DbSite[];

  clientUsers = ((await db.prepare(`SELECT id, name, email FROM users WHERE role = 'client' AND is_active = 1`).all()).results ?? []) as unknown as DbUser[];

  clientSiteAccess = ((await db.prepare(
    `SELECT client_site_access.user_id, client_site_access.site_id, client_site_access.granted_at,
            users.name AS user_name, users.email AS user_email, sites.owner_company_name
     FROM client_site_access
     INNER JOIN users ON users.id = client_site_access.user_id
     INNER JOIN sites ON sites.id = client_site_access.site_id
     ORDER BY users.name, sites.owner_company_name
     LIMIT 1000`
  ).all()).results ?? []) as unknown as ClientSiteAccessJoin[];

} catch (error) {
  loadError = "Sites data could not be loaded.";
}

const totalPages = Math.max(1, Math.ceil(sitesTotal / perPage));
import CsrfInput from "../../../components/ui/CsrfInput.astro";
---

<PortalLayout title="Site Management | Kharon Portal" active="sites" user={user}>
  <div class="py-2">
    <div class="sm:flex sm:items-center sm:justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-white tracking-tight font-heading">Site Management</h1>
        <p class="mt-1 text-sm text-white/60">Manage client locations and access mappings</p>
      </div>
    </div>

    {loadError && (
      <p class="mx-auto mb-6 max-w-7xl border border-kharon-red bg-kharon-red/10 p-4 text-red-200 font-semibold">{loadError}</p>
    )}

    <article class="kharon-surface p-4 sm:p-5">
      <div class="mb-4 flex flex-wrap items-end justify-between gap-4 border-b border-line-cyan-soft pb-4">
        <h2 class="text-xl font-bold text-white font-heading">
          Sites <span class="ml-2 text-sm font-normal text-white/60">({sitesTotal})</span>
        </h2>
        <form class="flex flex-wrap items-end gap-3" method="get">
          <CsrfInput />
          <div class="grid gap-1">
            <label for="sites-q" class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple">Search Company</label>
            <input
              id="sites-q"
              name="q"
              type="search"
              class="kharon-field min-w-[200px]"
              placeholder="Search company…"
              value={searchQuery}
            />
          </div>
          <button type="submit" class="kharon-command-button text-xs py-2 px-4 h-[38px] self-end">Search</button>
          {searchQuery && (
            <a href="/portal/admin/sites" class="kharon-secondary-button text-xs py-2 px-4 h-[38px] flex items-center justify-center">Clear</a>
          )}
        </form>
      </div>

      <div class="grid gap-4">
        {sites.length === 0 && <p class="py-4 text-sm text-white/50 italic">No sites match your search.</p>}
        {sites.map((record) => (
          <form
            class="admin-form grid gap-4 bg-surface-charcoal/40 border border-line-cyan-soft/50 p-4 lg:grid-cols-6 rounded-md"
            data-endpoint="/portal/api/admin/sites"
          >
          <CsrfInput />
            <input type="hidden" name="action" value="update" />
            <input type="hidden" name="id" value={record.id} />
            
            <div class="grid gap-1">
              <label for={`comp-${record.id}`} class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple">Company Name</label>
              <input id={`comp-${record.id}`} class="kharon-field" name="ownerCompanyName" value={record.owner_company_name} required />
            </div>
            
            <div class="grid gap-1">
              <label for={`contact-${record.id}`} class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple">Contact Person</label>
              <input id={`contact-${record.id}`} class="kharon-field" name="siteContactPerson" value={record.site_contact_person ?? ""} required />
            </div>
            
            <div class="grid gap-1">
              <label for={`email-${record.id}`} class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple">Contact Email</label>
              <input id={`email-${record.id}`} class="kharon-field" name="siteContactEmail" type="email" value={record.site_contact_email || ""} />
            </div>
            
            <div class="grid gap-1">
              <label for={`phone-${record.id}`} class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple">Contact Phone</label>
              <input id={`phone-${record.id}`} class="kharon-field" name="siteContactPhone" value={record.site_contact_phone || ""} />
            </div>
            
            <div class="grid gap-1">
              <label for={`billing-${record.id}`} class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple">Billing Email(s)</label>
              <input id={`billing-${record.id}`} class="kharon-field" name="billingEmails" value={record.billing_emails} required />
            </div>
            
            <div class="grid gap-1 self-end">
              <button class="kharon-command-button w-full py-2 text-xs">Save</button>
            </div>
            
            <div class="grid gap-1 lg:col-span-6">
              <label for={`address-${record.id}`} class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple">Physical Address</label>
              <textarea id={`address-${record.id}`} class="min-h-20 kharon-field" name="physicalAddress" required>{record.physical_address}</textarea>
            </div>
            
            <a href={`/portal/admin/systems?q=${encodeURIComponent(record.owner_company_name)}`} class="text-left text-xs font-semibold text-kharon-purple hover:underline lg:col-span-6">
              &rarr; View Systems for {record.owner_company_name}
            </a>
            <p class="admin-result hidden rounded border px-4 py-3 text-sm font-semibold lg:col-span-6"></p>
          </form>
        ))}
      </div>
    </article>

    <nav class="mt-6 mb-8 flex items-center justify-between border-t border-line-cyan-soft pt-4">
      {page > 1 ? (
        <a href={`?page=${page - 1}&q=${encodeURIComponent(searchQuery)}`} class="kharon-secondary-button py-2 text-xs">Previous</a>
      ) : (
        <span class="cursor-not-allowed rounded border border-line-cyan-soft/40 px-4 py-2 text-xs font-semibold text-white/30">Previous</span>
      )}
      <span class="text-sm text-white/60">Page {page} of {totalPages}</span>
      {page < totalPages ? (
        <a href={`?page=${page + 1}&q=${encodeURIComponent(searchQuery)}`} class="kharon-secondary-button py-2 text-xs">Next</a>
      ) : (
        <span class="cursor-not-allowed rounded border border-line-cyan-soft/40 px-4 py-2 text-xs font-semibold text-white/30">Next</span>
      )}
    </nav>

    <div class="grid gap-6 xl:grid-cols-2">
      <article class="kharon-surface p-5">
        <h2 class="text-xl font-bold text-white font-heading">Create site</h2>
        <form class="admin-form mt-5 grid gap-4" data-endpoint="/portal/api/admin/sites">
          <CsrfInput />
          <input type="hidden" name="action" value="create" />
          
          <div class="grid gap-1">
            <label for="create-company" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Company Name *</label>
            <input id="create-company" class="kharon-field" name="ownerCompanyName" placeholder="Owner company" required />
          </div>

          <div class="grid gap-1">
            <label for="create-address" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Physical Address *</label>
            <textarea id="create-address" class="min-h-20 kharon-field" name="physicalAddress" placeholder="Physical address" required></textarea>
          </div>

          <div class="grid gap-1">
            <label for="create-contact" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Contact Person *</label>
            <input id="create-contact" class="kharon-field" name="siteContactPerson" placeholder="Site contact person" required />
          </div>

          <div class="grid gap-1">
            <label for="create-email" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Contact Email</label>
            <input id="create-email" class="kharon-field" name="siteContactEmail" type="email" placeholder="site.contact@example.com" />
          </div>

          <div class="grid gap-1">
            <label for="create-phone" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Contact Phone</label>
            <input id="create-phone" class="kharon-field" name="siteContactPhone" placeholder="Site phone" />
          </div>

          <div class="grid gap-1">
            <label for="create-billing" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Billing Email(s) *</label>
            <input id="create-billing" class="kharon-field" name="billingEmails" placeholder="billing@example.com" required />
          </div>

          <button class="kharon-command-button w-full py-3 mt-2">Create Site Record</button>
          <p class="admin-result hidden rounded border px-4 py-3 text-sm font-semibold"></p>
        </form>
      </article>

      <article class="kharon-surface p-5">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="text-xs font-bold uppercase tracking-wider text-kharon-purple">Client account access</p>
            <h2 class="mt-2 text-xl font-bold text-white font-heading">Multi-site record mapping</h2>
          </div>
        </div>

        <form class="client-site-access-form mt-5 grid gap-4 lg:grid-cols-3" data-endpoint="/portal/api/admin/client-site-access">
          <CsrfInput />
          <input type="hidden" name="action" value="grant" />
          
          <div class="grid gap-1">
            <label for="grant-user" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Client User *</label>
            <select id="grant-user" class="kharon-field" name="userId" required>
              <option value="">Select client user</option>
              {clientUsers.map((client) => (
                <option value={client.id}>{client.name} ({client.email})</option>
              ))}
            </select>
          </div>
          
          <div class="grid gap-1">
            <label for="grant-site" class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Site *</label>
            <select id="grant-site" class="kharon-field" name="siteId" required>
              <option value="">Select site</option>
              {sites.map((site) => <option value={site.id}>{site.owner_company_name}</option>)}
            </select>
          </div>
          
          <div class="grid gap-1 justify-end self-end">
            <button class="kharon-command-button py-3 px-6 h-[40px] text-xs">Grant Access</button>
          </div>
          <p class="client-site-access-result hidden rounded border px-4 py-3 text-sm font-semibold lg:col-span-3"></p>
        </form>

        <div class="mt-5 grid gap-3">
          {clientSiteAccess.length === 0 && (
            <p class="text-white/50 italic">No additional client site access mappings have been granted.</p>
          )}
          {clientSiteAccess.map((mapping) => (
            <form
              class="client-site-access-form flex flex-wrap items-center justify-between gap-3 bg-surface-charcoal/40 border border-line-cyan-soft/50 p-4 rounded"
              data-endpoint="/portal/api/admin/client-site-access"
              data-user-name={mapping.user_name}
              data-site-name={mapping.owner_company_name}
            >
          <CsrfInput />
              <div>
                <p class="font-semibold text-white">{mapping.user_name} / {mapping.owner_company_name}</p>
                <p class="text-xs text-white/60">{mapping.user_email} / granted {mapping.granted_at}</p>
              </div>
              <input type="hidden" name="action" value="revoke" />
              <input type="hidden" name="userId" value={mapping.user_id} />
              <input type="hidden" name="siteId" value={mapping.site_id} />
              <button class="kharon-danger-button py-2 px-3 text-xs">Revoke</button>
              <p class="client-site-access-result hidden w-full rounded border px-4 py-3 text-sm font-semibold"></p>
            </form>
          ))}
        </div>
      </article>
    </div>
  </div>
  
  <script>
    import { bindAdminForms, portalPost, extractFormPayload, setResult } from "../../../lib/client/portalApi";
    bindAdminForms();

    for (const form of document.querySelectorAll<HTMLFormElement>(".client-site-access-form")) {
      form.addEventListener("submit", async (event: Event) => {
        event.preventDefault();
        
        const actionInput = form.querySelector<HTMLInputElement>('input[name="action"]');
        if (actionInput?.value === "revoke") {
          const userName = form.getAttribute("data-user-name") || "this user";
          const siteName = form.getAttribute("data-site-name") || "this site";
          if (!window.confirm(`Are you sure you want to revoke access to site: "${siteName}" for client user: "${userName}"?`)) {
            return;
          }
        }

        const result = form.querySelector<HTMLElement>(".client-site-access-result");
        if (result) result.classList.add("hidden");
        const { response, body } = await portalPost(form.dataset.endpoint ?? "", extractFormPayload(form));
        if (!response.ok || !body.ok) {
          setResult(result, body.message ?? "Client site access update failed.", "error");
          return;
        }
        setResult(result, body.action === "grant" ? "Client site access granted." : "Client site access revoked.", "success");
        setTimeout(() => window.location.reload(), 700);
      });
    }
  </script>
</PortalLayout>
