---
import { auditError } from "../../../lib/server/audit.js";
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import { DashboardService, type DashboardStats } from "../../../lib/server/services/dashboard-service";
import DashboardFeatureCard from "../../../components/portal/DashboardFeatureCard.astro";
import PortalQuickActions from "../../../components/portal/PortalQuickActions.astro";

export const prerender = false;

const adminActions = [
  { label: "Dispatch Job",  href: "/portal/admin/dispatch",     icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />`,                                                                                                                                                                                                        accent: "cyan"   as const },
  { label: "Add Site",      href: "/portal/admin/sites",        icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />`,                                                                         accent: "purple" as const },
  { label: "Sage Ledger",   href: "/portal/finance/dashboard",  icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,                                    accent: "green"  as const },
  { label: "SANS Audit",    href: "/portal/admin/compliance",   icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />`,  accent: "amber"  as const }
];

const user = Astro.locals.user;
let stats: DashboardStats = {
  activeJobs: 0, unassignedJobs: 0, overdueSystems: 0, openRequests: 0,
  missingDocuments: 0, openDefects: 0, criticalDefects: 0,
  blockedCertificates: 0, validCertificates: 0
};
let loadError = "";

try {
  const db = getDatabase();
  const service = new DashboardService(db);
  stats = await service.getAdminStats();
} catch (error) {
  await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "admin_dashboard" });
  loadError = "Admin matrix data could not be loaded.";
}

const exceptions = [
  { condition: stats.unassignedJobs > 0,     count: stats.unassignedJobs,    label: "job(s) unassigned — technician allocation required",   href: "/portal/admin/dispatch",  severity: "red"   },
  { condition: stats.criticalDefects > 0,    count: stats.criticalDefects,   label: "critical defect(s) open — immediate remediation needed", href: "/portal/admin/systems",  severity: "red"   },
  { condition: stats.overdueSystems > 0,     count: stats.overdueSystems,    label: "system(s) overdue for scheduled service",               href: "/portal/admin/systems",  severity: "amber" },
  { condition: stats.missingDocuments > 0,   count: stats.missingDocuments,  label: "completed job(s) missing sign-off documentation",       href: "/portal/admin/jobs",     severity: "amber" },
  { condition: stats.openRequests > 0,       count: stats.openRequests,      label: "client request(s) awaiting review and scheduling",      href: "/portal/admin/dispatch", severity: "amber" },
  { condition: stats.blockedCertificates > 0,count: stats.blockedCertificates,"label": "certificate(s) blocked — compliance action needed",  href: "/portal/admin/compliance",severity: "amber"},
].filter(e => e.condition);
---

<PortalLayout title="Admin Control Panel | Kharon Portal" active="admin" user={user}>

  <section class="bg-gradient-to-br from-kharon-black to-kharon-charcoal px-4 py-8 text-white sm:px-6 sm:py-10 rounded-xl border border-kharon-purple/10 mb-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(75,46,131,0.1),transparent)]"></div>
    <div class="mx-auto max-w-7xl relative z-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-kharon-purple/10 ring-1 ring-kharon-purple/20">
          <svg class="h-[1.1rem] w-[1.1rem] text-kharon-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2H6a2 2 0 01-2-2v-4zM14 16a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2h-2a2 2 0 01-2-2v-4z" />
          </svg>
        </div>
        <p class="text-xs font-black uppercase tracking-[0.2em] text-kharon-cyan">Admin Control Panel</p>
      </div>
      <h1 class="text-2xl font-black sm:text-3xl tracking-tight text-white">Operations Matrix</h1>
      <p class="mt-2 max-w-2xl text-sm text-white/60">
        Portfolio health at a glance — exceptions, dispatch status, and compliance standing across all client sites.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 space-y-6 pb-10">

    {loadError && (
      <p class="rounded border border-kharon-red/40 bg-kharon-red/10 px-4 py-3 text-sm font-semibold text-kharon-red">{loadError}</p>
    )}

    <section>
      <h2 class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple/80 mb-3">Quick Actions</h2>
      <PortalQuickActions actions={adminActions} />
    </section>

    {exceptions.length > 0 ? (
      <section class="rounded-xl border border-kharon-red/20 bg-kharon-red/5 p-4 sm:p-5">
        <p class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-red mb-3">Exceptions Requiring Attention</p>
        <ul class="space-y-2">
          {exceptions.map(ex => (
            <li>
              <a href={ex.href} class={`flex items-center gap-3 rounded-lg border px-4 py-3 text-sm font-semibold transition-colors ${ex.severity === 'red' ? 'border-kharon-red/30 bg-kharon-red/10 text-red-200 hover:bg-kharon-red/15' : 'border-kharon-amber/30 bg-kharon-amber/10 text-kharon-amber hover:bg-kharon-amber/15'}`}>
                <span class={`text-xl font-black tabular-nums ${ex.severity === 'red' ? 'text-kharon-red' : 'text-kharon-amber'}`}>{ex.count}</span>
                <span class="flex-1">{ex.label}</span>
                <svg class="h-4 w-4 shrink-0 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ) : !loadError ? (
      <section class="rounded-xl border border-kharon-green/20 bg-kharon-green/5 px-5 py-4">
        <div class="flex items-center gap-3">
          <svg class="h-5 w-5 shrink-0 text-kharon-green" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          <p class="text-sm font-bold text-kharon-green">All clear — no exceptions detected across the portfolio.</p>
        </div>
      </section>
    ) : null}

    <section>
      <p class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple/80 mb-3">Portfolio Health</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
        <a href="/portal/admin/dispatch" class="kharon-surface p-4 text-center hover:border-kharon-purple/40 transition-colors">
          <p class="text-[10px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Active Jobs</p>
          <p class="text-2xl font-black text-white">{stats.activeJobs}</p>
        </a>
        <a href="/portal/admin/dispatch" class={`kharon-surface p-4 text-center transition-colors ${stats.unassignedJobs > 0 ? 'border-kharon-red/40 hover:border-kharon-red/60' : 'hover:border-kharon-purple/40'}`}>
          <p class="text-[10px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Unassigned</p>
          <p class={`text-2xl font-black ${stats.unassignedJobs > 0 ? 'text-kharon-red' : 'text-white'}`}>{stats.unassignedJobs}</p>
        </a>
        <a href="/portal/admin/systems" class={`kharon-surface p-4 text-center transition-colors ${stats.overdueSystems > 0 ? 'border-kharon-amber/40 hover:border-kharon-amber/60' : 'hover:border-kharon-purple/40'}`}>
          <p class="text-[10px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Overdue Systems</p>
          <p class={`text-2xl font-black ${stats.overdueSystems > 0 ? 'text-kharon-amber' : 'text-white'}`}>{stats.overdueSystems}</p>
        </a>
        <a href="/portal/admin/dispatch" class={`kharon-surface p-4 text-center transition-colors ${stats.openRequests > 0 ? 'border-kharon-amber/40 hover:border-kharon-amber/60' : 'hover:border-kharon-purple/40'}`}>
          <p class="text-[10px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Client Requests</p>
          <p class={`text-2xl font-black ${stats.openRequests > 0 ? 'text-kharon-amber' : 'text-white'}`}>{stats.openRequests}</p>
        </a>
        <a href="/portal/admin/jobs" class={`kharon-surface p-4 text-center transition-colors ${stats.missingDocuments > 0 ? 'border-kharon-amber/40 hover:border-kharon-amber/60' : 'hover:border-kharon-purple/40'}`}>
          <p class="text-[10px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Missing Docs</p>
          <p class={`text-2xl font-black ${stats.missingDocuments > 0 ? 'text-kharon-amber' : 'text-white'}`}>{stats.missingDocuments}</p>
        </a>
        <a href="/portal/admin/systems" class={`kharon-surface p-4 text-center transition-colors ${stats.openDefects > 0 ? 'border-kharon-amber/30 hover:border-kharon-amber/50' : 'hover:border-kharon-purple/40'}`}>
          <p class="text-[10px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Open Defects</p>
          <p class={`text-2xl font-black ${stats.openDefects > 0 ? 'text-kharon-amber' : 'text-white'}`}>{stats.openDefects}</p>
        </a>
        <a href="/portal/admin/systems" class={`kharon-surface p-4 text-center transition-colors ${stats.criticalDefects > 0 ? 'border-kharon-red/40 hover:border-kharon-red/60' : 'hover:border-kharon-purple/40'}`}>
          <p class="text-[10px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Critical Defects</p>
          <p class={`text-2xl font-black ${stats.criticalDefects > 0 ? 'text-kharon-red' : 'text-white'}`}>{stats.criticalDefects}</p>
        </a>
        <a href="/portal/admin/compliance" class={`kharon-surface p-4 text-center transition-colors ${stats.blockedCertificates > 0 ? 'border-kharon-amber/30 hover:border-kharon-amber/50' : 'hover:border-kharon-purple/40'}`}>
          <p class="text-[10px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Blocked Certs</p>
          <p class={`text-2xl font-black ${stats.blockedCertificates > 0 ? 'text-kharon-amber' : 'text-white'}`}>{stats.blockedCertificates}</p>
        </a>
        <div class="kharon-surface p-4 text-center">
          <p class="text-[10px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Valid Certs</p>
          <p class="text-2xl font-black text-white">{stats.validCertificates}</p>
        </div>
      </div>
    </section>

    <div class="grid gap-6 lg:grid-cols-2">
      <DashboardFeatureCard
        title="Planning Calendar"
        description="Schedule maintenance, view job board and capacity."
        href="/portal/admin/planning"
        iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />`}
      />
      <DashboardFeatureCard
        title="Dispatch Board"
        description="Assign and track active field technician dispatches."
        href="/portal/admin/dispatch"
        iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />`}
        badge={stats.unassignedJobs > 0 ? stats.unassignedJobs : undefined}
        badgeVariant="warning"
      />
      <DashboardFeatureCard
        title="Client Sites"
        description="Manage all registered client sites and their metadata."
        href="/portal/admin/sites"
        iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />`}
      />
      <DashboardFeatureCard
        title="Protection Systems"
        description="All installed fire and security systems by site."
        href="/portal/admin/systems"
        iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18" />`}
        badge={stats.overdueSystems > 0 ? stats.overdueSystems : undefined}
        badgeVariant="danger"
      />
    </div>
  </div>
</PortalLayout>
