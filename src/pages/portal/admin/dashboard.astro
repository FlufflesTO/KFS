---
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import { formatCurrency } from "../../../lib/utils/financial-utils.ts";

export const prerender = false;

const user = Astro.locals.user;
let completed = [];
let active = [];
let due = [];
let clientRequests = [];
let overdue = [];
let missingDocs = [];
let openDefects = [];
let financeFollowup = [];
let technicians = [];
let requestSystems = [];
let stats = {
  activeJobs: 0,
  unassignedJobs: 0,
  overdueSystems: 0,
  openRequests: 0,
  missingDocuments: 0,
  openDefects: 0,
  criticalDefects: 0,
  blockedCertificates: 0,
  validCertificates: 0
};
let loadError = "";
const today    = new Date().toISOString().slice(0, 10);
const soonDate = new Date(Date.now() + 30 * 86400000).toISOString().slice(0, 10);

function dueDateCls(nd: string | null | undefined): string {
  if (!nd || nd > soonDate) return "border-l-4 border-kharon-blue bg-kharon-light";
  if (nd > today) return "border-l-4 border-amber-300 bg-amber-50";
  return "border-l-4 border-kharon-red bg-kharon-light";
}
function dueDateLabel(nd: string | null | undefined): string {
  if (!nd) return "Not scheduled";
  if (nd > soonDate) return "Scheduled";
  if (nd > today) return "Due soon";
  return "Overdue";
}

try {
  const db = getDatabase();

  const [cntActive, cntUnassigned, cntOverdue, cntRequests, cntMissingDocs,
         cntOpenDefects, cntCriticalDefects, cntBlockedCerts, cntValidCerts] = await db.batch([
    db.prepare(`SELECT COUNT(*) AS n FROM jobs WHERE status IN ('Scheduled', 'In Progress')`),
    db.prepare(`SELECT COUNT(*) AS n FROM jobs WHERE status IN ('Scheduled', 'In Progress') AND assigned_technician_id IS NULL`),
    db.prepare(`SELECT COUNT(*) AS n FROM systems WHERE date(next_due_date) < date('now')`),
    db.prepare(`SELECT COUNT(*) AS n FROM maintenance_requests WHERE status IN ('New', 'Reviewing')`),
    db.prepare(`SELECT COUNT(*) AS n FROM jobs WHERE status IN ('Completed', 'Invoiced') AND documentation_path IS NULL`),
    db.prepare(`SELECT COUNT(*) AS n FROM defects WHERE status = 'Open'`),
    db.prepare(`SELECT COUNT(*) AS n FROM defects WHERE status = 'Open' AND severity = 'Critical'`),
    db.prepare(`SELECT COUNT(*) AS n FROM certificates WHERE status = 'Blocked'`),
    db.prepare(`SELECT COUNT(*) AS n FROM certificates WHERE status = 'Valid'`)
  ]);
  interface CountResult {
    n: number;
  }
  stats = {
    activeJobs:        (cntActive.results[0] as CountResult | undefined)?.n        ?? 0,
    unassignedJobs:    (cntUnassigned.results[0] as CountResult | undefined)?.n    ?? 0,
    overdueSystems:    (cntOverdue.results[0] as CountResult | undefined)?.n       ?? 0,
    openRequests:      (cntRequests.results[0] as CountResult | undefined)?.n      ?? 0,
    missingDocuments:  (cntMissingDocs.results[0] as CountResult | undefined)?.n   ?? 0,
    openDefects:       (cntOpenDefects.results[0] as CountResult | undefined)?.n   ?? 0,
    criticalDefects:   (cntCriticalDefects.results[0] as CountResult | undefined)?.n ?? 0,
    blockedCertificates: (cntBlockedCerts.results[0] as CountResult | undefined)?.n ?? 0,
    validCertificates: (cntValidCerts.results[0] as CountResult | undefined)?.n    ?? 0
  };

  completed = (await db.prepare(
    `SELECT jobs.id, jobs.completed_at, jobs.status, systems.system_type, systems.coverage_area, sites.owner_company_name
     FROM jobs
     INNER JOIN systems ON systems.id = jobs.system_id
     INNER JOIN sites ON sites.id = systems.site_id
     WHERE jobs.status IN ('Completed', 'Invoiced')
     ORDER BY jobs.completed_at DESC
     LIMIT 12`
  ).all()).results || [];

  active = (await db.prepare(
    `SELECT jobs.id, jobs.status, jobs.scheduled_date, users.name AS technician_name, sites.owner_company_name
     FROM jobs
     LEFT JOIN users ON users.id = jobs.assigned_technician_id
     INNER JOIN systems ON systems.id = jobs.system_id
     INNER JOIN sites ON sites.id = systems.site_id
     WHERE jobs.status IN ('Scheduled', 'In Progress')
     ORDER BY jobs.scheduled_date ASC
     LIMIT 12`
  ).all()).results || [];

  due = (await db.prepare(
    `SELECT systems.id, systems.system_type, systems.coverage_area, systems.next_due_date, sites.owner_company_name
     FROM systems
     INNER JOIN sites ON sites.id = systems.site_id
     ORDER BY systems.next_due_date ASC
     LIMIT 12`
  ).all()).results || [];

  clientRequests = (await db.prepare(
    `SELECT maintenance_requests.id, maintenance_requests.site_id, maintenance_requests.system_id,
            maintenance_requests.request_type, maintenance_requests.priority,
            maintenance_requests.status, maintenance_requests.subject, maintenance_requests.message,
            maintenance_requests.created_at, maintenance_requests.linked_job_id,
            sites.owner_company_name, systems.coverage_area
     FROM maintenance_requests
     INNER JOIN sites ON sites.id = maintenance_requests.site_id
     LEFT JOIN systems ON systems.id = maintenance_requests.system_id
     WHERE maintenance_requests.status IN ('New', 'Reviewing', 'Scheduled')
     ORDER BY
       CASE maintenance_requests.priority WHEN 'Critical' THEN 1 WHEN 'Urgent' THEN 2 ELSE 3 END,
       maintenance_requests.created_at ASC
     LIMIT 12`
  ).all()).results || [];

  technicians = (await db.prepare(
    `SELECT id, name FROM users WHERE role = 'tech' AND is_active = 1 ORDER BY name`
  ).all()).results || [];

  requestSystems = (await db.prepare(
    `SELECT id, site_id, system_type, coverage_area FROM systems ORDER BY coverage_area`
  ).all()).results || [];

  overdue = (await db.prepare(
    `SELECT systems.id, systems.system_type, systems.coverage_area, systems.next_due_date, sites.owner_company_name
     FROM systems
     INNER JOIN sites ON sites.id = systems.site_id
     WHERE date(systems.next_due_date) < date('now')
     ORDER BY systems.next_due_date ASC
     LIMIT 12`
  ).all()).results || [];

  missingDocs = (await db.prepare(
    `SELECT jobs.id, jobs.completed_at, systems.system_type, systems.coverage_area, sites.owner_company_name
     FROM jobs
     INNER JOIN systems ON systems.id = jobs.system_id
     INNER JOIN sites ON sites.id = systems.site_id
     WHERE jobs.status IN ('Completed', 'Invoiced') AND jobs.documentation_path IS NULL
     ORDER BY jobs.completed_at DESC
     LIMIT 12`
  ).all()).results || [];

  openDefects = (await db.prepare(
    `SELECT defects.id, defects.severity, defects.sans_clause_ref, defects.status,
            systems.id AS system_id, systems.system_type, systems.coverage_area,
            sites.owner_company_name
     FROM defects
     INNER JOIN systems ON systems.id = defects.system_id
     INNER JOIN sites ON sites.id = systems.site_id
     WHERE defects.status = 'Open'
     ORDER BY CASE defects.severity WHEN 'Critical' THEN 1 WHEN 'Major' THEN 2 ELSE 3 END,
              defects.created_at ASC
     LIMIT 12`
  ).all()).results || [];

  financeFollowup = (await db.prepare(
    `SELECT sites.owner_company_name, COUNT(financial_records.id) AS record_count, SUM(financial_records.amount) AS amount
     FROM financial_records
     INNER JOIN sites ON sites.id = financial_records.site_id
     WHERE financial_records.payment_status IN ('Pending Approval', 'Unpaid')
     GROUP BY sites.id
     ORDER BY amount DESC
     LIMIT 8`
  ).all()).results || [];
} catch (error) {
  console.error("admin dashboard failed", error);
  loadError = "Admin matrix data could not be loaded.";
}

---

<PortalLayout title="Admin Control Panel | Kharon Portal" active="admin" user={user}>
  <section class="bg-kharon-black px-4 py-8 text-white sm:px-6 sm:py-10">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-bold uppercase text-kharon-cyan">Office control panel</p>
      <h1 class="mt-3 text-2xl font-bold sm:text-3xl">Operational dispatch and lifecycle matrix</h1>
      <p class="mt-4 max-w-3xl text-white/65">Completed works, active jobs and upcoming maintenance exposure across client infrastructure.</p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto grid max-w-7xl gap-6">
      {loadError && <p class="border border-red-300 bg-red-50 p-4 text-red-800">{loadError}</p>}

      <!-- ─── Quick-stats row ──────────────────────────────────────── -->
      <div class="grid gap-4 sm:grid-cols-3 xl:grid-cols-7">
        <article class="border border-kharon-border bg-white p-4">
          <p class="text-xs font-bold uppercase text-kharon-purple">Active jobs</p>
          <p class="mt-2 text-2xl font-bold">{stats.activeJobs}</p>
          <a href="/portal/admin/planning" class="mt-2 block text-xs font-semibold text-kharon-purple hover:underline">Planning -></a>
        </article>
        <article class={`border p-4 ${stats.unassignedJobs > 0 ? "border-red-300 bg-red-50" : "border-kharon-border bg-white"}`}>
          <p class={`text-xs font-bold uppercase ${stats.unassignedJobs > 0 ? "text-kharon-red" : "text-kharon-grey"}`}>Unassigned</p>
          <p class="mt-2 text-2xl font-bold">{stats.unassignedJobs}</p>
          <a href="/portal/admin/operations#jobs" class="mt-2 block text-xs font-semibold text-kharon-purple hover:underline">Assign -></a>
        </article>
        <article class={`border p-4 ${stats.overdueSystems > 0 ? "border-red-300 bg-red-50" : "border-kharon-border bg-white"}`}>
          <p class={`text-xs font-bold uppercase ${stats.overdueSystems > 0 ? "text-kharon-red" : "text-kharon-grey"}`}>Overdue systems</p>
          <p class="mt-2 text-2xl font-bold">{stats.overdueSystems}</p>
          <a href="/portal/admin/planning" class="mt-2 block text-xs font-semibold text-kharon-purple hover:underline">View lifecycle -></a>
        </article>
        <article class={`border p-4 ${stats.openDefects > 0 ? "border-red-300 bg-red-50" : "border-kharon-border bg-white"}`}>
          <p class={`text-xs font-bold uppercase ${stats.openDefects > 0 ? "text-kharon-red" : "text-kharon-grey"}`}>Open defects</p>
          <p class="mt-2 text-2xl font-bold">{stats.openDefects}</p>
          {stats.criticalDefects > 0 && <p class="mt-1 text-xs font-bold text-kharon-red">{stats.criticalDefects} critical</p>}
        </article>
        <article class={`border p-4 ${stats.blockedCertificates > 0 ? "border-amber-300 bg-amber-50" : "border-kharon-border bg-white"}`}>
          <p class={`text-xs font-bold uppercase ${stats.blockedCertificates > 0 ? "text-amber-600" : "text-kharon-grey"}`}>Blocked certs</p>
          <p class="mt-2 text-2xl font-bold">{stats.blockedCertificates}</p>
          <p class="mt-1 text-xs text-kharon-grey">{stats.validCertificates} valid</p>
        </article>
        <article class="border border-kharon-border bg-white p-4">
          <p class="text-xs font-bold uppercase text-kharon-purple">Open requests</p>
          <p class="mt-2 text-2xl font-bold">{stats.openRequests}</p>
          <a href="/portal/admin/dashboard#requests" class="mt-2 block text-xs font-semibold text-kharon-purple hover:underline">Review below -></a>
        </article>
        <article class={`border p-4 ${stats.missingDocuments > 0 ? "border-kharon-purple bg-kharon-light" : "border-kharon-border bg-white"}`}>
          <p class={`text-xs font-bold uppercase ${stats.missingDocuments > 0 ? "text-kharon-purple" : "text-kharon-grey"}`}>Missing docs</p>
          <p class="mt-2 text-2xl font-bold">{stats.missingDocuments}</p>
          <a href="/portal/admin/operations#jobs" class="mt-2 block text-xs font-semibold text-kharon-purple hover:underline">Review jobs -></a>
        </article>
      </div>

      <div class="grid gap-5 xl:grid-cols-3 xl:gap-6">
      <div class="border border-kharon-border bg-white p-4 sm:p-5">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-xl font-bold">Completed works</h2>
          <a href="/portal/tech/history" class="text-xs font-semibold text-kharon-purple hover:underline">View all</a>
        </div>
        <div class="mt-5 grid gap-3">
          {completed.map((item) => (
            <article class="border-l-4 border-kharon-blue bg-kharon-light p-4">
              <p class="font-semibold">{item.owner_company_name}</p>
              <p class="text-sm text-kharon-grey">{item.system_type} / {item.coverage_area}</p>
              <p class="mt-2 text-xs uppercase text-kharon-grey/70">{item.completed_at || "Completion pending timestamp"}</p>
              {item.status === "Completed" && (
                <button class="mark-invoiced-btn mt-3 rounded-md border border-kharon-blue px-3 py-2 text-xs font-semibold text-kharon-blue hover:bg-kharon-blue hover:text-white" data-job-id={item.id}>
                  Sage invoice raised
                </button>
              )}
              {item.status === "Invoiced" && (
                <span class="mt-3 block text-xs font-bold uppercase text-kharon-grey/60">Sage invoice raised</span>
              )}
            </article>
          ))}
        </div>
      </div>

      <div class="border border-kharon-border bg-white p-4 sm:p-5">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-xl font-bold">Active dispatches</h2>
          <a href="/portal/admin/planning" class="text-xs font-semibold text-kharon-purple hover:underline">View all in Planning</a>
        </div>
        <div class="mt-5 grid gap-3">
          {active.map((item) => (
            <article class="border-l-4 border-kharon-purple bg-kharon-light p-4">
              <p class="font-semibold">{item.owner_company_name}</p>
              <p class="text-sm text-kharon-grey">{item.status} / {item.technician_name || "Unassigned"}</p>
              <p class="mt-2 text-xs uppercase text-kharon-grey/70">{item.scheduled_date}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="border border-kharon-border bg-white p-4 sm:p-5">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-xl font-bold">Lifecycle due dates</h2>
          <a href="/portal/admin/planning" class="text-xs font-semibold text-kharon-purple hover:underline">View all in Planning</a>
        </div>
        <div class="mt-5 grid gap-3">
          {due.map((item) => (
            <article class={`${dueDateCls(item.next_due_date)} p-4`}>
              <p class="font-semibold">{item.owner_company_name}</p>
              <p class="text-sm text-kharon-grey">{item.system_type} / {item.coverage_area}</p>
              <p class="mt-2 text-xs uppercase text-kharon-grey/70">{dueDateLabel(item.next_due_date)}  -  {item.next_due_date}</p>
            </article>
          ))}
        </div>
      </div>
      </div>

      <section class="grid gap-6 xl:grid-cols-2">
        <article class="border border-kharon-border bg-white p-4 sm:p-5">
          <h2 class="text-xl font-bold">Client request queue</h2>
          <div class="mt-5 grid gap-3">
            {clientRequests.length === 0 && <p class="text-kharon-grey">No new client requests require review.</p>}
            {clientRequests.map((item) => (
              <article class="request-card border-l-4 border-kharon-purple bg-kharon-light p-4" data-request-id={item.id}>
                <div class="flex flex-wrap justify-between gap-3">
                  <div>
                    <p class="font-semibold">{item.owner_company_name}</p>
                    <p class="text-sm text-kharon-grey">{item.subject}</p>
                    <p class="mt-1 text-xs uppercase text-kharon-grey/70">{item.request_type} / {item.coverage_area || "General site request"}</p>
                    <p class="mt-2 text-sm text-kharon-grey">{item.message}</p>
                    {item.linked_job_id && <p class="mt-2 text-xs font-bold uppercase text-kharon-blue">Dispatch: {item.linked_job_id}</p>}
                  </div>
                  <span class="h-fit rounded-md border border-kharon-border px-3 py-2 text-xs font-bold uppercase text-kharon-grey">{item.priority} / {item.status}</span>
                </div>
                <div class="mt-4 grid gap-3">
                  <form class="request-status-form flex flex-wrap gap-2" data-request-id={item.id}>
                    <input type="hidden" name="requestId" value={item.id} />
                    <select class="portal-field sm:w-auto rounded-md border border-kharon-border px-3 py-2 text-sm" name="status">
                      {["New", "Reviewing", "Closed"].map((status) => <option value={status} selected={item.status === status}>{status}</option>)}
                    </select>
                    <button class="w-full rounded-md border border-kharon-blue px-4 py-2 text-sm font-semibold text-kharon-blue sm:w-auto">Update status</button>
                    <p class="request-result hidden text-sm font-semibold"></p>
                  </form>
                  {!item.linked_job_id && (
                    <form class="request-schedule-form grid gap-2 lg:grid-cols-5" data-request-id={item.id}>
                      <input type="hidden" name="requestId" value={item.id} />
                      <select class="portal-field rounded-md border border-kharon-border px-3 py-2 text-sm lg:col-span-2" name="systemId" required>
                        <option value="">Select system</option>
                        {requestSystems.filter((system) => system.site_id === item.site_id).map((system) => (
                          <option value={system.id} selected={system.id === item.system_id}>{system.system_type} / {system.coverage_area}</option>
                        ))}
                      </select>
                      <select class="portal-field rounded-md border border-kharon-border px-3 py-2 text-sm" name="assignedTechnicianId">
                        <option value="">Unassigned</option>
                        {technicians.map((tech) => <option value={tech.id}>{tech.name}</option>)}
                      </select>
                      <input class="portal-field rounded-md border border-kharon-border px-3 py-2 text-sm" name="scheduledDate" type="date" required />
                      <button class="rounded-md bg-kharon-purple px-4 py-2 text-sm font-semibold text-white">Schedule dispatch</button>
                      <input class="portal-field rounded-md border border-kharon-border px-3 py-2 text-sm lg:col-span-2" name="jobType" value={item.request_type} />
                      <input class="portal-field rounded-md border border-kharon-border px-3 py-2 text-sm lg:col-span-3" name="siteNotes" value={`${item.subject}: ${item.message}`.slice(0, 900)} />
                    </form>
                  )}
                </div>
              </article>
            ))}
          </div>
        </article>

        <article class="border border-kharon-border bg-white p-4 sm:p-5">
          <h2 class="text-xl font-bold">Exception queue</h2>
          <div class="mt-5 grid gap-5">
            <div>
              <p class="text-sm font-bold uppercase text-kharon-red">Overdue systems</p>
              <div class="mt-3 grid gap-2">
                {overdue.length === 0 && <p class="text-sm text-kharon-grey">No overdue lifecycle items.</p>}
                {overdue.map((item) => (
                  <p class="border-l-4 border-kharon-red bg-kharon-light p-3 text-sm">
                    <span class="font-semibold">{item.owner_company_name}</span> / {item.system_type} / {item.coverage_area} / due {item.next_due_date}
                  </p>
                ))}
              </div>
            </div>

            <div>
              <p class="text-sm font-bold uppercase text-kharon-purple">Missing documentation</p>
              <div class="mt-3 grid gap-2">
                {missingDocs.length === 0 && <p class="text-sm text-kharon-grey">No completed jobs are missing documentation.</p>}
                {missingDocs.map((item) => (
                  <p class="border-l-4 border-kharon-purple bg-kharon-light p-3 text-sm">
                    <span class="font-semibold">{item.owner_company_name}</span> / {item.id} / {item.completed_at || "completed"}
                  </p>
                ))}
              </div>
            </div>

            <div>
              <p class="text-sm font-bold uppercase text-kharon-blue">Finance follow-up</p>
              <div class="mt-3 grid gap-2">
                {financeFollowup.length === 0 && <p class="text-sm text-kharon-grey">No pending finance follow-up.</p>}
                {financeFollowup.map((item) => (
                  <p class="border-l-4 border-kharon-blue bg-kharon-light p-3 text-sm">
                    <span class="font-semibold">{item.owner_company_name}</span> / {item.record_count} open records / {formatCurrency(item.amount || 0)}
                  </p>
                ))}
              </div>
            </div>

            <div>
              <p class="text-sm font-bold uppercase text-kharon-red">Open defects</p>
              <div class="mt-3 grid gap-2">
                {openDefects.length === 0 && <p class="text-sm text-kharon-grey">No open defects require attention.</p>}
                {openDefects.map((item) => (
                  <a href={`/portal/admin/operations?system_id=${item.system_id}`} class="block border-l-4 bg-kharon-light p-3 text-sm hover:bg-white" class:list={[
                    item.severity === "Critical" ? "border-kharon-red" : item.severity === "Major" ? "border-amber-500" : "border-kharon-grey"
                  ]}>
                    <span class="font-semibold">{item.owner_company_name}</span> / {item.system_type} / {item.coverage_area}
                    <span class={`ml-2 rounded px-1.5 py-0.5 text-xs font-bold ${
                      item.severity === "Critical" ? "bg-kharon-red text-white" :
                      item.severity === "Major" ? "bg-amber-200 text-amber-800" :
                      "bg-kharon-grey/20 text-kharon-grey"
                    }`}>{item.severity}</span>
                    {item.sans_clause_ref && <p class="mt-1 text-xs text-kharon-grey">Clause: {item.sans_clause_ref}</p>}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </article>
      </section>
    </div>
  </section>
  <script>
    async function postJson(url, payload) {
      const response = await window.kharonPortalFetch(url, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload)
      });
      const body = await response.json();
      if (!response.ok || !body.ok) throw new Error(body.message || "Request failed.");
      return body;
    }

    for (const form of document.querySelectorAll(".request-status-form")) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const result = form.querySelector(".request-result");
        const data = new FormData(form);
        try {
          const body = await postJson("/portal/api/admin/maintenance-requests", {
            action: "updateStatus",
            requestId: data.get("requestId"),
            status: data.get("status")
          });
          result.textContent = `Status: ${body.status}`;
          result.className = "request-result text-sm font-semibold text-kharon-blue";
        } catch (error) {
          result.textContent = error.message;
          result.className = "request-result text-sm font-semibold text-red-700";
        }
      });
    }

    for (const form of document.querySelectorAll(".request-schedule-form")) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const card = form.closest(".request-card");
        const result = card.querySelector(".request-result");
        const data = new FormData(form);
        try {
          const body = await postJson("/portal/api/admin/maintenance-requests", {
            action: "scheduleDispatch",
            requestId: data.get("requestId"),
            systemId: data.get("systemId"),
            assignedTechnicianId: data.get("assignedTechnicianId"),
            scheduledDate: data.get("scheduledDate"),
            jobType: data.get("jobType"),
            siteNotes: data.get("siteNotes")
          });
          result.textContent = `Scheduled dispatch: ${body.jobId}`;
          result.className = "request-result text-sm font-semibold text-kharon-blue";
          form.remove();
        } catch (error) {
          result.textContent = error.message;
          result.className = "request-result text-sm font-semibold text-red-700";
        }
      });
    }

    for (const btn of document.querySelectorAll(".mark-invoiced-btn")) {
      btn.addEventListener("click", async () => {
        if (!window.confirm("Confirm that a Sage invoice has been raised for this job.")) return;
        const jobId = btn.dataset.jobId;
        btn.disabled = true;
        btn.textContent = "Updating…";
        try {
          await postJson("/portal/api/admin/jobs", { action: "markInvoiced", id: jobId });
          const confirmed = document.createElement("span");
          confirmed.className = "mt-3 block text-xs font-bold uppercase text-kharon-grey/60";
          confirmed.textContent = "Sage invoice raised";
          btn.replaceWith(confirmed);
        } catch (error) {
          btn.disabled = false;
          btn.textContent = "Sage invoice raised";
          alert(error.message || "Could not update job status.");
        }
      });
    }
  </script>
</PortalLayout>
