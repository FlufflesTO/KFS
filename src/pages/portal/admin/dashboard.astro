---
import { auditError } from "../../../lib/server/audit.js";
/**
 * Project Sentinel - Portal Admin Dashboard
 * Purpose: Provides admin office control panel for completed works, active dispatches, lifecycle exposure, and exception queue
 * Dependencies: PortalLayout, bindings, financial-utils, KharonCard, KharonButton
 * Structural Role: Office/Admin main control view
 */
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import { formatCurrency } from "../../../lib/utils/financial-utils.ts";
import KharonCard from "../../../components/ui/KharonCard.astro";
import KharonButton from "../../../components/ui/KharonButton.astro";

export const prerender = false;

const user = Astro.locals.user;
let completed = [];
let active = [];
let due = [];
let clientRequests = [];
let overdue = [];
let missingDocs = [];
let openDefects = [];
let financeFollowup = [];
let technicians = [];
let requestSystems = [];
let stats = {
  activeJobs: 0,
  unassignedJobs: 0,
  overdueSystems: 0,
  openRequests: 0,
  missingDocuments: 0,
  openDefects: 0,
  criticalDefects: 0,
  blockedCertificates: 0,
  validCertificates: 0
};
let loadError = "";
const today    = new Date().toISOString().slice(0, 10);
const soonDate = new Date(Date.now() + 30 * 86400000).toISOString().slice(0, 10);

function dueDateCls(nd: string | null | undefined): string {
  if (!nd || nd > soonDate) return "border-l-4 border-kharon-blue bg-kharon-light";
  if (nd > today) return "border-l-4 border-amber-300 bg-amber-50";
  return "border-l-4 border-kharon-red bg-kharon-light";
}
function dueDateLabel(nd: string | null | undefined): string {
  if (!nd) return "Not scheduled";
  if (nd > soonDate) return "Scheduled";
  if (nd > today) return "Due soon";
  return "Overdue";
}

try {
  const db = getDatabase();

  const [cntActive, cntUnassigned, cntOverdue, cntRequests, cntMissingDocs,
         cntOpenDefects, cntCriticalDefects, cntBlockedCerts, cntValidCerts] = await db.batch([
    db.prepare(`SELECT COUNT(*) AS n FROM jobs WHERE deleted_at IS NULL AND status IN ('Scheduled', 'In Progress')`),
    db.prepare(`SELECT COUNT(*) AS n FROM jobs WHERE deleted_at IS NULL AND status IN ('Scheduled', 'In Progress') AND assigned_technician_id IS NULL`),
    db.prepare(`SELECT COUNT(*) AS n FROM systems WHERE deleted_at IS NULL AND date(next_due_date) < date('now')`),
    db.prepare(`SELECT COUNT(*) AS n FROM maintenance_requests WHERE status IN ('New', 'Reviewing')`),
    db.prepare(`SELECT COUNT(*) AS n FROM jobs WHERE deleted_at IS NULL AND status IN ('Completed', 'Invoiced') AND documentation_path IS NULL`),
    db.prepare(`SELECT COUNT(*) AS n FROM defects WHERE deleted_at IS NULL AND status = 'Open'`),
    db.prepare(`SELECT COUNT(*) AS n FROM defects WHERE deleted_at IS NULL AND status = 'Open' AND severity = 'Critical'`),
    db.prepare(`SELECT COUNT(*) AS n FROM certificates WHERE deleted_at IS NULL AND status = 'Blocked'`),
    db.prepare(`SELECT COUNT(*) AS n FROM certificates WHERE deleted_at IS NULL AND status = 'Valid'`)
  ]);
  interface CountResult {
    n: number;
  }
  stats = {
    activeJobs:        (cntActive.results[0] as CountResult | undefined)?.n        ?? 0,
    unassignedJobs:    (cntUnassigned.results[0] as CountResult | undefined)?.n    ?? 0,
    overdueSystems:    (cntOverdue.results[0] as CountResult | undefined)?.n       ?? 0,
    openRequests:      (cntRequests.results[0] as CountResult | undefined)?.n      ?? 0,
    missingDocuments:  (cntMissingDocs.results[0] as CountResult | undefined)?.n   ?? 0,
    openDefects:       (cntOpenDefects.results[0] as CountResult | undefined)?.n   ?? 0,
    criticalDefects:   (cntCriticalDefects.results[0] as CountResult | undefined)?.n ?? 0,
    blockedCertificates: (cntBlockedCerts.results[0] as CountResult | undefined)?.n ?? 0,
    validCertificates: (cntValidCerts.results[0] as CountResult | undefined)?.n    ?? 0
  };

  completed = (await db.prepare(
    `SELECT jobs.id, jobs.completed_at, jobs.status, systems.system_type, systems.coverage_area, sites.owner_company_name
     FROM jobs
     INNER JOIN systems ON systems.id = jobs.system_id
     INNER JOIN sites ON sites.id = systems.site_id
     WHERE jobs.deleted_at IS NULL AND systems.deleted_at IS NULL AND jobs.status IN ('Completed', 'Invoiced')
     ORDER BY jobs.completed_at DESC
     LIMIT 12`
  ).all()).results || [];

  active = (await db.prepare(
    `SELECT jobs.id, jobs.status, jobs.scheduled_date, users.name AS technician_name, sites.owner_company_name
     FROM jobs
     LEFT JOIN users ON users.id = jobs.assigned_technician_id
     INNER JOIN systems ON systems.id = jobs.system_id
     INNER JOIN sites ON sites.id = systems.site_id
     WHERE jobs.deleted_at IS NULL AND systems.deleted_at IS NULL AND jobs.status IN ('Scheduled', 'In Progress')
     ORDER BY jobs.scheduled_date ASC
     LIMIT 12`
  ).all()).results || [];

  due = (await db.prepare(
    `SELECT systems.id, systems.system_type, systems.coverage_area, systems.next_due_date, sites.owner_company_name
     FROM systems
     INNER JOIN sites ON sites.id = systems.site_id
     WHERE systems.deleted_at IS NULL
     ORDER BY systems.next_due_date ASC
     LIMIT 12`
  ).all()).results || [];

  clientRequests = (await db.prepare(
    `SELECT maintenance_requests.id, maintenance_requests.site_id, maintenance_requests.system_id,
            maintenance_requests.request_type, maintenance_requests.priority,
            maintenance_requests.status, maintenance_requests.subject, maintenance_requests.message,
            maintenance_requests.created_at, maintenance_requests.linked_job_id,
            sites.owner_company_name, systems.coverage_area
     FROM maintenance_requests
     INNER JOIN sites ON sites.id = maintenance_requests.site_id
     LEFT JOIN systems ON systems.id = maintenance_requests.system_id AND systems.deleted_at IS NULL
     WHERE maintenance_requests.status IN ('New', 'Reviewing', 'Scheduled')
     ORDER BY
       CASE maintenance_requests.priority WHEN 'Critical' THEN 1 WHEN 'Urgent' THEN 2 ELSE 3 END,
       maintenance_requests.created_at ASC
     LIMIT 12`
  ).all()).results || [];

  technicians = (await db.prepare(
    `SELECT id, name FROM users WHERE role = 'tech' AND is_active = 1 ORDER BY name LIMIT 100`
  ).all()).results || [];

  requestSystems = (await db.prepare(
    `SELECT id, site_id, system_type, coverage_area FROM systems WHERE deleted_at IS NULL ORDER BY coverage_area LIMIT 200`
  ).all()).results || [];

  overdue = (await db.prepare(
    `SELECT systems.id, systems.system_type, systems.coverage_area, systems.next_due_date, sites.owner_company_name
     FROM systems
     INNER JOIN sites ON sites.id = systems.site_id
     WHERE systems.deleted_at IS NULL AND date(systems.next_due_date) < date('now')
     ORDER BY systems.next_due_date ASC
     LIMIT 12`
  ).all()).results || [];

  missingDocs = (await db.prepare(
    `SELECT jobs.id, jobs.completed_at, systems.system_type, systems.coverage_area, sites.owner_company_name
     FROM jobs
     INNER JOIN systems ON systems.id = jobs.system_id
     INNER JOIN sites ON sites.id = systems.site_id
     WHERE jobs.deleted_at IS NULL AND systems.deleted_at IS NULL
       AND jobs.status IN ('Completed', 'Invoiced') AND jobs.documentation_path IS NULL
     ORDER BY jobs.completed_at DESC
     LIMIT 12`
  ).all()).results || [];

  openDefects = (await db.prepare(
    `SELECT defects.id, defects.severity, defects.sans_clause_ref, defects.status,
            systems.id AS system_id, systems.system_type, systems.coverage_area,
            sites.owner_company_name
     FROM defects
     INNER JOIN systems ON systems.id = defects.system_id
     INNER JOIN sites ON sites.id = systems.site_id
     WHERE defects.deleted_at IS NULL AND systems.deleted_at IS NULL AND defects.status = 'Open'
     ORDER BY CASE defects.severity WHEN 'Critical' THEN 1 WHEN 'Major' THEN 2 ELSE 3 END,
              defects.created_at ASC
     LIMIT 12`
  ).all()).results || [];

  financeFollowup = (await db.prepare(
    `SELECT sites.owner_company_name, COUNT(financial_records.id) AS record_count, SUM(financial_records.amount) AS amount
     FROM financial_records
     INNER JOIN sites ON sites.id = financial_records.site_id
     WHERE financial_records.payment_status IN ('Pending Approval', 'Unpaid')
     GROUP BY sites.id
     ORDER BY amount DESC
     LIMIT 8`
  ).all()).results || [];
} catch (error) {
  await auditError(typeof db !== "undefined" ? db : Astro.locals.db, Astro.request, error, { user: typeof user !== "undefined" ? user : Astro.locals.user, metadata: { message: "admin dashboard failed" } });
  loadError = "Admin matrix data could not be loaded.";
}

---

<PortalLayout title="Admin Control Panel | Kharon Portal" active="admin" user={user}>
  <section class="bg-gradient-to-r from-[#0B0D0F] to-[#1A1F26] px-4 py-10 text-white sm:px-6 sm:py-12 shadow-inner">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-bold uppercase tracking-wider text-kharon-cyan">Office control panel</p>
      <h1 class="mt-2 text-2xl font-bold sm:text-3xl tracking-tight">Operational dispatch and lifecycle matrix</h1>
      <p class="mt-3 max-w-3xl text-sm text-white/60">Completed works, active jobs and upcoming maintenance exposure across client infrastructure.</p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto max-w-7xl">
      {loadError && <p class="border border-red-300 bg-red-50 p-4 text-red-800 mb-6">{loadError}</p>}

      {/* Quick-stats row */}
      <div class="grid gap-4 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-7 mb-6">
        <KharonCard variant={stats.activeJobs > 0 ? 'primary' : 'default'}>
          <div class="flex flex-col justify-between h-full">
            <div>
              <p class="text-xs font-bold uppercase text-kharon-purple">Active jobs</p>
              <p class="mt-2 text-2xl font-bold text-kharon-black">{stats.activeJobs}</p>
            </div>
            <KharonButton href="/portal/admin/planning" variant="ghost" size="sm">Planning →</KharonButton>
          </div>
        </KharonCard>
        
        <KharonCard variant={stats.unassignedJobs > 0 ? 'danger' : 'default'}>
          <div class="flex flex-col justify-between h-full">
            <div>
              <p class={`text-xs font-bold uppercase ${stats.unassignedJobs > 0 ? "text-kharon-red" : "text-kharon-grey"}`}>Unassigned</p>
              <p class="mt-2 text-2xl font-bold text-kharon-black">{stats.unassignedJobs}</p>
            </div>
            <KharonButton href="/portal/admin/jobs" variant="ghost" size="sm">Assign →</KharonButton>
          </div>
        </KharonCard>
        
        <KharonCard variant={stats.overdueSystems > 0 ? 'danger' : 'default'}>
          <div class="flex flex-col justify-between h-full">
            <div>
              <p class={`text-xs font-bold uppercase ${stats.overdueSystems > 0 ? "text-kharon-red" : "text-kharon-grey"}`}>Overdue systems</p>
              <p class="mt-2 text-2xl font-bold text-kharon-black">{stats.overdueSystems}</p>
            </div>
            <KharonButton href="/portal/admin/planning" variant="ghost" size="sm">View lifecycle →</KharonButton>
          </div>
        </KharonCard>
        
        <KharonCard variant={stats.openDefects > 0 ? 'danger' : 'default'}>
          <div class="flex flex-col justify-between h-full">
            <div>
              <p class={`text-xs font-bold uppercase ${stats.openDefects > 0 ? "text-kharon-red" : "text-kharon-grey"}`}>Open defects</p>
              <p class="mt-2 text-2xl font-bold text-kharon-black">{stats.openDefects}</p>
              {stats.criticalDefects > 0 && <p class="mt-1 text-xs font-bold text-kharon-red">{stats.criticalDefects} critical</p>}
            </div>
            <KharonButton href="/portal/admin/compliance" variant="ghost" size="sm">Audits →</KharonButton>
          </div>
        </KharonCard>
        
        <KharonCard variant={stats.blockedCertificates > 0 ? 'warning' : 'default'}>
          <div class="flex flex-col justify-between h-full">
            <div>
              <p class={`text-xs font-bold uppercase ${stats.blockedCertificates > 0 ? "text-amber-600" : "text-kharon-grey"}`}>Blocked certs</p>
              <p class="mt-2 text-2xl font-bold text-kharon-black">{stats.blockedCertificates}</p>
              <p class="mt-1 text-xs text-kharon-grey">{stats.validCertificates} valid</p>
            </div>
            <span class="mt-3 block text-xs text-kharon-grey/50">—</span>
          </div>
        </KharonCard>
        
        <KharonCard variant="default">
          <div class="flex flex-col justify-between h-full">
            <div>
              <p class="text-xs font-bold uppercase text-kharon-purple">Open requests</p>
              <p class="mt-2 text-2xl font-bold text-kharon-black">{stats.openRequests}</p>
            </div>
            <KharonButton href="/portal/admin/dashboard#requests" variant="ghost" size="sm">Review below →</KharonButton>
          </div>
        </KharonCard>
        
        <KharonCard variant={stats.missingDocuments > 0 ? 'primary' : 'default'}>
          <div class="flex flex-col justify-between h-full">
            <div>
              <p class={`text-xs font-bold uppercase ${stats.missingDocuments > 0 ? "text-kharon-purple" : "text-kharon-grey"}`}>Missing docs</p>
              <p class="mt-2 text-2xl font-bold text-kharon-black">{stats.missingDocuments}</p>
            </div>
            <KharonButton href="/portal/admin/jobs" variant="ghost" size="sm">Review jobs →</KharonButton>
          </div>
        </KharonCard>
      </div>

      <div class="grid gap-5 lg:grid-cols-2 xl:grid-cols-3 xl:gap-6">
        <KharonCard title="Completed works" subtitle="Asset Lifecycle">
          <KharonButton href="/portal/tech/history" variant="ghost" size="sm">View all</KharonButton>
          <div class="mt-4 grid gap-3">
            {completed.map((item) => (
              <article class="border border-kharon-border border-l-4 border-l-kharon-blue bg-kharon-light/30 p-4 rounded-lg">
                <p class="font-semibold text-kharon-black">{item.owner_company_name}</p>
                <p class="text-sm text-kharon-grey mt-0.5">{item.system_type} / {item.coverage_area}</p>
                <p class="mt-2.5 text-xs text-kharon-grey/70 uppercase font-medium">{item.completed_at || "Completion pending timestamp"}</p>
                {item.status === "Completed" && (
                  <button class="mark-invoiced-btn mt-3 w-full rounded bg-white border border-kharon-blue px-3 py-2 text-xs font-semibold text-kharon-blue hover:bg-kharon-blue hover:text-white transition-all" data-job-id={item.id}>
                    Sage invoice raised
                  </button>
                )}
                {item.status === "Invoiced" && (
                  <span class="mt-3 block text-xs font-bold uppercase text-kharon-grey/50 border border-dashed border-kharon-border bg-white text-center py-1.5 rounded">Sage invoice raised</span>
                )}
              </article>
            ))}
          </div>
        </KharonCard>

        <KharonCard title="Active dispatches" subtitle="Operations">
          <KharonButton href="/portal/admin/planning" variant="ghost" size="sm">View planning</KharonButton>
          <div class="mt-4 grid gap-3">
            {active.map((item) => (
              <article class="border border-kharon-border border-l-4 border-l-kharon-purple bg-kharon-light/30 p-4 rounded-lg">
                <p class="font-semibold text-kharon-black">{item.owner_company_name}</p>
                <p class="text-sm text-kharon-grey mt-0.5">{item.status} / {item.technician_name || "Unassigned"}</p>
                <p class="mt-2.5 text-xs text-kharon-grey/70 uppercase font-medium">{item.scheduled_date}</p>
              </article>
            ))}
          </div>
        </KharonCard>

        <KharonCard title="Lifecycle due dates" subtitle="Compliance">
          <KharonButton href="/portal/admin/planning" variant="ghost" size="sm">View planning</KharonButton>
          <div class="mt-4 grid gap-3">
            {due.map((item) => (
              <article class={`border border-kharon-border p-4 rounded-lg ${dueDateCls(item.next_due_date)}`}>
                <p class="font-semibold text-kharon-black">{item.owner_company_name}</p>
                <p class="text-sm text-kharon-grey mt-0.5">{item.system_type} / {item.coverage_area}</p>
                <p class="mt-2.5 text-xs uppercase font-medium">{dueDateLabel(item.next_due_date)}  -  {item.next_due_date}</p>
              </article>
            ))}
          </div>
        </KharonCard>
      </div>

      <section class="grid gap-6 lg:grid-cols-2 mt-6">
        <KharonCard title="Client request queue" subtitle="Customer Support">
          <div class="mt-4 grid gap-3">
            {clientRequests.length === 0 && <p class="text-sm text-kharon-grey italic py-2">No new client requests require review.</p>}
            {clientRequests.map((item) => (
              <article class="request-card border border-kharon-border border-l-4 border-l-kharon-purple bg-kharon-light/30 p-4 rounded-lg shadow-sm" data-request-id={item.id}>
                <div class="flex flex-wrap justify-between gap-3">
                  <div class="min-w-0 flex-1">
                    <p class="font-semibold text-kharon-black">{item.owner_company_name}</p>
                    <p class="text-xs font-bold text-kharon-purple mt-0.5">{item.subject}</p>
                    <p class="mt-1 text-[10px] uppercase font-bold text-kharon-grey/65">{item.request_type} / {item.coverage_area || "General site request"}</p>
                    <p class="mt-2.5 text-xs text-kharon-grey leading-relaxed bg-white border border-kharon-border/60 p-2.5 rounded">{item.message}</p>
                    {item.linked_job_id && <p class="mt-2.5 text-xs font-bold uppercase text-kharon-blue bg-blue-50 border border-blue-200 px-2 py-0.5 rounded w-fit">Scheduled Dispatch: {item.linked_job_id}</p>}
                  </div>
                  <span class="h-fit rounded border border-kharon-border bg-white px-2 py-1 text-[10px] font-bold uppercase text-kharon-grey">{item.priority} / {item.status}</span>
                </div>
                <div class="mt-4 pt-3 border-t border-kharon-border/60 grid gap-3">
                  <form class="request-status-form flex flex-wrap gap-2" data-request-id={item.id}>
                    <input type="hidden" name="requestId" value={item.id} />
                    <select class="portal-field sm:w-auto rounded border border-kharon-border bg-white px-3 py-1.5 text-xs focus:outline-none" name="status">
                      {["New", "Reviewing", "Closed"].map((status) => <option value={status} selected={item.status === status}>{status}</option>)}
                    </select>
                    <KharonButton type="submit" size="sm">Update status</KharonButton>
                    <p class="request-result hidden text-sm font-semibold"></p>
                  </form>
                  {!item.linked_job_id && (
                    <form class="request-schedule-form grid gap-3 border-t border-kharon-border/40 pt-3" data-request-id={item.id}>
                      <input type="hidden" name="requestId" value={item.id} />
                      <div class="grid gap-2 sm:grid-cols-2">
                        <div class="grid gap-1">
                          <label class="text-[10px] font-bold uppercase text-kharon-grey/70">System</label>
                          <select class="portal-field rounded border border-kharon-border bg-white px-3 py-1.5 text-xs focus:outline-none" name="systemId" required>
                            <option value="">Select system</option>
                            {requestSystems.filter((system) => system.site_id === item.site_id).map((system) => (
                              <option value={system.id} selected={system.id === item.system_id}>{system.system_type} / {system.coverage_area}</option>
                            ))}
                          </select>
                        </div>
                        <div class="grid gap-1">
                          <label class="text-[10px] font-bold uppercase text-kharon-grey/70">Technician</label>
                          <select class="portal-field rounded border border-kharon-border bg-white px-3 py-1.5 text-xs focus:outline-none" name="assignedTechnicianId">
                            <option value="">Unassigned</option>
                            {technicians.map((tech) => <option value={tech.id}>{tech.name}</option>)}
                          </select>
                        </div>
                      </div>
                      <div class="grid gap-2 sm:grid-cols-2">
                        <div class="grid gap-1">
                          <label class="text-[10px] font-bold uppercase text-kharon-grey/70">Scheduled Date</label>
                          <input class="portal-field rounded border border-kharon-border bg-white px-3 py-1.5 text-xs focus:outline-none" name="scheduledDate" type="date" required />
                        </div>
                        <div class="grid gap-1">
                          <label class="text-[10px] font-bold uppercase text-kharon-grey/70">Job Type</label>
                          <input class="portal-field rounded border border-kharon-border bg-white px-3 py-1.5 text-xs focus:outline-none" name="jobType" value={item.request_type} />
                        </div>
                      </div>
                      <div class="grid gap-1">
                        <label class="text-[10px] font-bold uppercase text-kharon-grey/70">Site Notes</label>
                        <input class="portal-field rounded border border-kharon-border bg-white px-3 py-1.5 text-xs focus:outline-none" name="siteNotes" value={`${item.subject}: ${item.message}`.slice(0, 900)} />
                      </div>
                      <KharonButton type="submit" variant="primary">Schedule dispatch</KharonButton>
                    </form>
                  )}
                </div>
              </article>
            ))}
          </div>
        </KharonCard>

        <KharonCard title="Exception queue" subtitle="Risk Management">
          <div class="mt-4 grid gap-5">
            <div>
              <p class="text-xs font-bold uppercase text-kharon-red tracking-wider">Overdue systems</p>
              <div class="mt-3 grid gap-2">
                {overdue.length === 0 && <p class="text-sm text-kharon-grey italic py-1">No overdue lifecycle items.</p>}
                {overdue.map((item) => (
                  <div class="border border-kharon-border border-l-4 border-l-kharon-red bg-kharon-light/30 p-3 text-xs rounded-lg flex items-center justify-between">
                    <span class="font-semibold text-kharon-black">{item.owner_company_name}</span>
                    <span class="text-kharon-grey">{item.system_type} / {item.coverage_area} / due {item.next_due_date}</span>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <p class="text-xs font-bold uppercase text-kharon-purple tracking-wider">Missing documentation</p>
              <div class="mt-3 grid gap-2">
                {missingDocs.length === 0 && <p class="text-sm text-kharon-grey italic py-1">No completed jobs are missing documentation.</p>}
                {missingDocs.map((item) => (
                  <div class="border border-kharon-border border-l-4 border-l-kharon-purple bg-kharon-light/30 p-3 text-xs rounded-lg flex items-center justify-between">
                    <span class="font-semibold text-kharon-black">{item.owner_company_name}</span>
                    <span class="text-kharon-grey font-mono">{item.id.slice(0, 8)}... / {item.completed_at || "completed"}</span>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <p class="text-xs font-bold uppercase text-kharon-blue tracking-wider">Finance follow-up</p>
              <div class="mt-3 grid gap-2">
                {financeFollowup.length === 0 && <p class="text-sm text-kharon-grey italic py-1">No pending finance follow-up.</p>}
                {financeFollowup.map((item) => (
                  <div class="border border-kharon-border border-l-4 border-l-kharon-blue bg-kharon-light/30 p-3 text-xs rounded-lg flex items-center justify-between">
                    <span class="font-semibold text-kharon-black">{item.owner_company_name}</span>
                    <span class="text-kharon-grey font-medium">{item.record_count} open / {formatCurrency(item.amount || 0)}</span>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <p class="text-xs font-bold uppercase text-kharon-red tracking-wider">Open defects</p>
              <div class="mt-3 grid gap-2">
                {openDefects.length === 0 && <p class="text-sm text-kharon-grey italic py-1">No open defects require attention.</p>}
                {openDefects.map((item) => (
                  <a href={`/portal/admin/systems?q=${encodeURIComponent(item.system_id)}`} class="block border border-kharon-border border-l-4 p-3 text-xs rounded-lg hover:bg-kharon-light/50 transition-colors" class:list={[
                    item.severity === "Critical" ? "border-l-kharon-red bg-red-50/20" : item.severity === "Major" ? "border-l-kharon-amber bg-amber-50/20" : "border-l-kharon-grey bg-kharon-light/20"
                  ]}>
                    <div class="flex items-center justify-between">
                      <span class="font-semibold text-kharon-black">{item.owner_company_name}</span>
                      <span class={`rounded px-1.5 py-0.5 text-[9px] font-bold uppercase border ${
                        item.severity === "Critical" ? "border-red-200 bg-red-50 text-kharon-red" :
                        item.severity === "Major" ? "border-amber-200 bg-amber-50 text-amber-700" :
                        "border-kharon-border bg-white text-kharon-grey"
                      }`}>{item.severity}</span>
                    </div>
                    <p class="text-kharon-grey mt-1">{item.system_type} / {item.coverage_area}</p>
                    {item.sans_clause_ref && <p class="mt-1 font-mono text-[10px] text-kharon-grey/70">SANS Clause: {item.sans_clause_ref}</p>}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </KharonCard>
      </section>
    </div>
  </section>
  <script>
    async function postJson(url, payload) {
      const response = await window.kharonPortalFetch(url, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload)
      });
      const body = await response.json();
      if (!response.ok || !body.ok) throw new Error(body.message || "Request failed.");
      return body;
    }

    for (const form of document.querySelectorAll(".request-status-form")) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const result = form.querySelector(".request-result");
        const data = new FormData(form);
        try {
          const body = await postJson("/portal/api/admin/maintenance-requests", {
            action: "updateStatus",
            requestId: data.get("requestId"),
            status: data.get("status")
          });
          result.textContent = `Status: ${body.status}`;
          result.className = "request-result text-sm font-semibold text-kharon-blue";
        } catch (error) {
          result.textContent = error.message;
          result.className = "request-result text-sm font-semibold text-red-700";
        }
      });
    }

    for (const form of document.querySelectorAll(".request-schedule-form")) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const card = form.closest(".request-card");
        const result = card.querySelector(".request-result");
        const data = new FormData(form);
        try {
          const body = await postJson("/portal/api/admin/maintenance-requests", {
            action: "scheduleDispatch",
            requestId: data.get("requestId"),
            systemId: data.get("systemId"),
            assignedTechnicianId: data.get("assignedTechnicianId"),
            scheduledDate: data.get("scheduledDate"),
            jobType: data.get("jobType"),
            siteNotes: data.get("siteNotes")
          });
          result.textContent = `Scheduled dispatch: ${body.jobId}`;
          result.className = "request-result text-sm font-semibold text-kharon-blue";
          form.remove();
        } catch (error) {
          result.textContent = error.message;
          result.className = "request-result text-sm font-semibold text-red-700";
        }
      });
    }

    for (const btn of document.querySelectorAll(".mark-invoiced-btn")) {
      btn.addEventListener("click", async () => {
        if (!window.confirm("Confirm that a Sage invoice has been raised for this job.")) return;
        const jobId = btn.dataset.jobId;
        btn.disabled = true;
        btn.textContent = "Updating…";
        try {
          await postJson("/portal/api/admin/jobs", { action: "markInvoiced", id: jobId });
          const confirmed = document.createElement("span");
          confirmed.className = "mt-3 block text-xs font-bold uppercase text-kharon-grey/60";
          confirmed.textContent = "Sage invoice raised";
          btn.replaceWith(confirmed);
        } catch (error) {
          btn.disabled = false;
          btn.textContent = "Sage invoice raised";
          alert(error.message || "Could not update job status.");
        }
      });
    }
  </script>
</PortalLayout>
