---
/**
 * Project Sentinel - Advanced Reporting Dashboard
 * Purpose: Aggregates system metrics, finance, and technician performance statistics
 * Dependencies: PortalLayout, getDatabase, requireAdmin
 * Structural Role: Administrative reporting portal UI
 */
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings";
import { requireAdmin } from "../../../lib/server/access";

export const prerender = false;

const { user } = Astro.locals;

// Verify admin access
const adminError = requireAdmin(user);
if (adminError) {
  return {
    redirect: {
      destination: '/portal/login',
      permanent: false,
    },
  };
}

// Fetch reporting data
const db = getDatabase();

interface AdvancedStats {
  completed_jobs: number;
  scheduled_jobs: number;
  in_progress_jobs: number;
  overdue_systems: number;
  open_defects: number;
  unpaid_invoices: number;
  unpaid_amount: number;
  active_users: number;
}

// Overall stats
const stats = (await db.prepare(`
  SELECT 
    (SELECT COUNT(*) FROM jobs WHERE status = 'Completed') as completed_jobs,
    (SELECT COUNT(*) FROM jobs WHERE status = 'Scheduled') as scheduled_jobs,
    (SELECT COUNT(*) FROM jobs WHERE status = 'In Progress') as in_progress_jobs,
    (SELECT COUNT(*) FROM systems WHERE next_due_date < date('now')) as overdue_systems,
    (SELECT COUNT(*) FROM defects WHERE status = 'Open') as open_defects,
    (SELECT COUNT(*) FROM financial_records WHERE payment_status = 'Unpaid') as unpaid_invoices,
    (SELECT SUM(amount)/100.0 FROM financial_records WHERE payment_status = 'Unpaid') as unpaid_amount,
    (SELECT COUNT(*) FROM users WHERE is_active = 1) as active_users
`).first()) as unknown as AdvancedStats | null;

// Monthly trends
const monthlyTrends = await db.prepare(`
  SELECT 
    strftime('%Y-%m', created_at) as month,
    COUNT(CASE WHEN status = 'Completed' THEN 1 END) as completed,
    COUNT(CASE WHEN status = 'Scheduled' THEN 1 END) as scheduled,
    COUNT(CASE WHEN status = 'In Progress' THEN 1 END) as in_progress
  FROM jobs 
  WHERE created_at >= date('now', '-6 months')
  GROUP BY strftime('%Y-%m', created_at)
  ORDER BY month
`).all();

// Top technicians by completed jobs
const topTechs = await db.prepare(`
  SELECT 
    u.name,
    COUNT(j.id) as completed_jobs
  FROM users u
  LEFT JOIN jobs j ON u.id = j.assigned_technician_id
  WHERE u.role = 'tech' AND j.status = 'Completed'
  GROUP BY u.id, u.name
  ORDER BY completed_jobs DESC
  LIMIT 5
`).all();

// System types breakdown
const systemTypes = await db.prepare(`
  SELECT 
    system_type,
    COUNT(*) as count
  FROM systems
  GROUP BY system_type
`).all();

// Outstanding finance
const outstandingFinance = await db.prepare(`
  SELECT 
    fr.reference,
    fr.amount/100.0 as amount,
    si.owner_company_name,
    fr.distribution_date,
    fr.payment_status
  FROM financial_records fr
  JOIN sites si ON si.id = fr.site_id
  WHERE fr.payment_status = 'Unpaid'
  ORDER BY fr.distribution_date DESC
  LIMIT 10
`).all();
---

<PortalLayout title="Advanced Reporting | Kharon Portal" active="advanced-reporting" user={user}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="sm:flex sm:items-center sm:justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Advanced Reporting Dashboard</h1>
        <p class="mt-1 text-sm text-gray-500">Comprehensive business intelligence and analytics</p>
      </div>
      <div class="mt-3 sm:mt-0 sm:ml-4">
        <button 
          id="export-report-btn"
          type="button"
          class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-kharon-blue hover:bg-kharon-purple focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-kharon-blue"
        >
          Export Report
        </button>
      </div>
    </div>

    <!-- Stats Overview -->
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4 mb-8">
      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0 bg-kharon-blue rounded-md p-3">
              <svg class="h-6 w-6 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Completed Jobs</dt>
                <dd class="flex items-baseline">
                  <div class="text-2xl font-semibold text-gray-900">{stats?.completed_jobs || 0}</div>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0 bg-kharon-purple rounded-md p-3">
              <svg class="h-6 w-6 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Scheduled Jobs</dt>
                <dd class="flex items-baseline">
                  <div class="text-2xl font-semibold text-gray-900">{stats?.scheduled_jobs || 0}</div>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0 bg-kharon-amber rounded-md p-3">
              <svg class="h-6 w-6 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Overdue Systems</dt>
                <dd class="flex items-baseline">
                  <div class="text-2xl font-semibold text-gray-900">{stats?.overdue_systems || 0}</div>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0 bg-kharon-red rounded-md p-3">
              <svg class="h-6 w-6 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Unpaid Amount</dt>
                <dd class="flex items-baseline">
                  <div class="text-2xl font-semibold text-gray-900">R{(stats?.unpaid_amount || 0).toFixed(2)}</div>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-10">
      <!-- Monthly Trends Chart -->
      <div class="bg-white shadow overflow-hidden sm:rounded-md">
        <div class="px-4 py-5 sm:px-6">
          <h3 class="text-lg leading-6 font-medium text-gray-900">Monthly Job Trends</h3>
          <p class="mt-1 max-w-2xl text-sm text-gray-500">Job status distribution over the last 6 months</p>
        </div>
        <div class="border-t border-gray-200 px-4 py-5 sm:p-6">
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Month</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Completed</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Scheduled</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">In Progress</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                {monthlyTrends.results?.map((month: any) => (
                  <tr>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">{month.month}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{month.completed}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{month.scheduled}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{month.in_progress}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Top Technicians -->
      <div class="bg-white shadow overflow-hidden sm:rounded-md">
        <div class="px-4 py-5 sm:px-6">
          <h3 class="text-lg leading-6 font-medium text-gray-900">Top Technicians</h3>
          <p class="mt-1 max-w-2xl text-sm text-gray-500">Based on completed jobs in the last period</p>
        </div>
        <div class="border-t border-gray-200 px-4 py-5 sm:p-6">
          <ul class="divide-y divide-gray-200">
            {topTechs.results?.map((tech: any, index: number) => (
              <li class="py-4 flex items-center justify-between">
                <div class="flex items-center">
                  <div class="flex-shrink-0 h-10 w-10 rounded-full bg-kharon-blue flex items-center justify-center text-white font-bold">
                    {index + 1}
                  </div>
                  <div class="ml-4">
                    <div class="text-sm font-medium text-gray-900">{tech.name}</div>
                  </div>
                </div>
                <div class="text-sm text-gray-500">{tech.completed_jobs} jobs</div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-10 mt-8">
      <!-- System Types Breakdown -->
      <div class="bg-white shadow overflow-hidden sm:rounded-md">
        <div class="px-4 py-5 sm:px-6">
          <h3 class="text-lg leading-6 font-medium text-gray-900">System Types Breakdown</h3>
          <p class="mt-1 max-w-2xl text-sm text-gray-500">Distribution of installed system types</p>
        </div>
        <div class="border-t border-gray-200 px-4 py-5 sm:p-6">
          <div class="flex items-center justify-center">
            <div class="w-full max-w-xs">
              <ul class="space-y-4">
                {systemTypes.results?.map((type: any) => (
                  <li class="flex justify-between items-center">
                    <span class="text-sm font-medium text-gray-900">{type.system_type}</span>
                    <span class="text-sm font-semibold text-gray-700">{type.count}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>

      <!-- Outstanding Finance -->
      <div class="bg-white shadow overflow-hidden sm:rounded-md">
        <div class="px-4 py-5 sm:px-6">
          <h3 class="text-lg leading-6 font-medium text-gray-900">Outstanding Finance</h3>
          <p class="mt-1 max-w-2xl text-sm text-gray-500">Unpaid invoices and their details</p>
        </div>
        <div class="border-t border-gray-200 px-4 py-5 sm:p-6">
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Reference</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Client</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                {outstandingFinance.results?.map((record: any) => (
                  <tr>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">{record.reference}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">R{record.amount.toFixed(2)}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{record.owner_company_name}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{new Date(record.distribution_date).toLocaleDateString()}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    document.querySelector("#export-report-btn")?.addEventListener("click", () => {
      // This would trigger a more detailed report export
      alert('Generating detailed report. This would export a comprehensive report with all metrics.');
    });
  </script>
</PortalLayout>
