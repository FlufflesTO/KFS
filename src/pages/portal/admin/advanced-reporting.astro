---
/**
 * Project Sentinel - Advanced Reporting Dashboard
 * Purpose: Aggregates operational, compliance, finance, and technician performance signals.
 */
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings";
import { requireAdminOrManager } from "../../../lib/server/access";

export const prerender = false;

const { user } = Astro.locals;
const adminError = requireAdminOrManager(user);
if (adminError) {
  return adminError;
}

const db = getDatabase();
const generatedAt = new Date();

interface AdvancedStats {
  completed_jobs: number;
  scheduled_jobs: number;
  in_progress_jobs: number;
  overdue_systems: number;
  open_defects: number;
  critical_defects: number;
  unpaid_invoices: number;
  unpaid_amount: number | null;
  active_users: number;
}

interface TrendRow {
  month: string;
  completed: number;
  scheduled: number;
  in_progress: number;
}

interface TechnicianRow {
  name: string;
  completed_jobs: number;
}

interface SystemTypeRow {
  system_type: string;
  count: number;
}

interface FinanceRow {
  reference: string;
  amount: number;
  owner_company_name: string;
  distribution_date: string;
  payment_status: string;
}

const stats = (await db.prepare(`
  SELECT
    (SELECT COUNT(*) FROM jobs WHERE deleted_at IS NULL AND status = 'Completed') AS completed_jobs,
    (SELECT COUNT(*) FROM jobs WHERE deleted_at IS NULL AND status = 'Scheduled') AS scheduled_jobs,
    (SELECT COUNT(*) FROM jobs WHERE deleted_at IS NULL AND status = 'In Progress') AS in_progress_jobs,
    (SELECT COUNT(*) FROM systems WHERE deleted_at IS NULL AND date(next_due_date) < date('now')) AS overdue_systems,
    (SELECT COUNT(*) FROM defects WHERE deleted_at IS NULL AND status = 'Open') AS open_defects,
    (SELECT COUNT(*) FROM defects WHERE deleted_at IS NULL AND status = 'Open' AND severity = 'Critical') AS critical_defects,
    (SELECT COUNT(*) FROM financial_records WHERE payment_status = 'Unpaid') AS unpaid_invoices,
    (SELECT COALESCE(SUM(amount), 0) / 100.0 FROM financial_records WHERE payment_status = 'Unpaid') AS unpaid_amount,
    (SELECT COUNT(*) FROM users WHERE is_active = 1 AND deleted_at IS NULL) AS active_users
`).first()) as unknown as AdvancedStats | null;

const monthlyTrends = ((await db.prepare(`
  SELECT
    strftime('%Y-%m', created_at) AS month,
    COUNT(CASE WHEN status = 'Completed' THEN 1 END) AS completed,
    COUNT(CASE WHEN status = 'Scheduled' THEN 1 END) AS scheduled,
    COUNT(CASE WHEN status = 'In Progress' THEN 1 END) AS in_progress
  FROM jobs
  WHERE deleted_at IS NULL AND created_at >= date('now', '-6 months')
  GROUP BY strftime('%Y-%m', created_at)
  ORDER BY month
`).all()).results || []) as unknown as TrendRow[];

const topTechs = ((await db.prepare(`
  SELECT
    users.name,
    COUNT(jobs.id) AS completed_jobs
  FROM users
  LEFT JOIN jobs
    ON users.id = jobs.assigned_technician_id
   AND jobs.deleted_at IS NULL
   AND jobs.status = 'Completed'
  WHERE users.role = 'tech'
    AND users.is_active = 1
    AND users.deleted_at IS NULL
  GROUP BY users.id, users.name
  ORDER BY completed_jobs DESC, users.name ASC
  LIMIT 5
`).all()).results || []) as unknown as TechnicianRow[];

const systemTypes = ((await db.prepare(`
  SELECT
    system_type,
    COUNT(*) AS count
  FROM systems
  WHERE deleted_at IS NULL
  GROUP BY system_type
  ORDER BY count DESC, system_type ASC
  LIMIT 8
`).all()).results || []) as unknown as SystemTypeRow[];

const outstandingFinance = ((await db.prepare(`
  SELECT
    financial_records.reference,
    financial_records.amount / 100.0 AS amount,
    sites.owner_company_name,
    financial_records.distribution_date,
    financial_records.payment_status
  FROM financial_records
  INNER JOIN sites ON sites.id = financial_records.site_id
  WHERE financial_records.payment_status = 'Unpaid'
  ORDER BY financial_records.distribution_date DESC
  LIMIT 10
`).all()).results || []) as unknown as FinanceRow[];

const maxTrend = Math.max(1, ...monthlyTrends.flatMap((row) => [row.completed, row.scheduled, row.in_progress]));
const maxTech = Math.max(1, ...topTechs.map((row) => row.completed_jobs));
const maxSystem = Math.max(1, ...systemTypes.map((row) => row.count));

const currency = new Intl.NumberFormat("en-ZA", { style: "currency", currency: "ZAR" });
const dateFormat = new Intl.DateTimeFormat("en-ZA", { dateStyle: "medium" });

const kpis = [
  { label: "Completed jobs", value: stats?.completed_jobs ?? 0, tone: "text-emerald-200", note: "Closed work orders" },
  { label: "Active dispatches", value: (stats?.scheduled_jobs ?? 0) + (stats?.in_progress_jobs ?? 0), tone: "text-cyan-200", note: "Scheduled and in progress" },
  { label: "Overdue systems", value: stats?.overdue_systems ?? 0, tone: "text-amber-200", note: "Past next service date" },
  { label: "Critical defects", value: stats?.critical_defects ?? 0, tone: "text-rose-200", note: "Open critical findings" },
  { label: "Unpaid invoices", value: stats?.unpaid_invoices ?? 0, tone: "text-purple-100", note: currency.format(stats?.unpaid_amount ?? 0) },
  { label: "Active users", value: stats?.active_users ?? 0, tone: "text-white", note: "Enabled portal accounts" }
];
---

<PortalLayout title="Advanced Reporting | Kharon Portal" active="advanced-reporting" user={user}>
  <section class="bg-gradient-to-br from-kharon-black to-kharon-charcoal px-4 py-8 text-white sm:px-6 sm:py-10 kharon-environment rounded-xl border border-kharon-purple/10 mb-6 shadow-inner relative overflow-hidden">
    <div class="mx-auto max-w-7xl flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between relative z-10">
      <div>
        <p class="text-[0.625rem] font-bold uppercase tracking-[0.2em] text-kharon-purple">Operational intelligence</p>
        <h1 class="mt-2 text-2xl font-bold sm:text-3xl tracking-tight">Advanced Reporting</h1>
        <p class="mt-3 max-w-3xl text-sm text-white/50">
          Six-month operational view across dispatch throughput, compliance exposure, technician load, system estate mix, and unpaid finance.
        </p>
      </div>
      <div class="rounded-md border border-kharon-purple/20 bg-kharon-charcoal/70 px-4 py-3 text-sm text-white/70 backdrop-blur-sm">
        <p class="font-semibold text-white">Generated {dateFormat.format(generatedAt)}</p>
        <p class="mt-1 text-xs text-white/50">Live D1 snapshot. Amounts are displayed in ZAR.</p>
      </div>
    </div>
  </section>

  <div class="space-y-6">

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 xl:grid-cols-6">
      {kpis.map((item) => (
        <article class="rounded-md border border-white/10 bg-kharon-charcoal/70 p-4">
          <p class="text-xs font-semibold uppercase tracking-wide text-white/40">{item.label}</p>
          <p class={`mt-3 text-3xl font-bold ${item.tone}`}>{item.value}</p>
          <p class="mt-2 text-xs text-white/60">{item.note}</p>
        </article>
      ))}
    </div>

    <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">
      <article class="rounded-md border border-white/10 bg-kharon-charcoal/70 p-5">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <h2 class="text-lg font-semibold text-white">Monthly Job Flow</h2>
            <p class="mt-1 text-sm text-white/60">Completed, scheduled, and in-progress work by creation month.</p>
          </div>
          <p class="text-xs font-semibold uppercase tracking-wide text-white/40">Direct labels, no hover required</p>
        </div>
        <div class="mt-5 space-y-4">
          {monthlyTrends.length === 0 ? (
            <p class="rounded-md border border-white/10 bg-black/20 p-4 text-sm text-white/60">No job trend rows found for the last six months.</p>
          ) : monthlyTrends.map((row) => (
            <div class="grid gap-2 sm:grid-cols-6 sm:items-center">
              <p class="text-sm font-semibold text-white/70">{row.month}</p>
              <div class="space-y-2 sm:col-span-5">
                {[
                  { label: "Completed", value: row.completed, className: "bg-emerald-400" },
                  { label: "Scheduled", value: row.scheduled, className: "bg-cyan-400" },
                  { label: "In progress", value: row.in_progress, className: "bg-amber-400" }
                ].map((series) => (
                  <div class="grid grid-cols-6 items-center gap-2 text-xs">
                    <span class="text-white/60">{series.label}</span>
                    <span class="col-span-4 h-2 overflow-hidden rounded-full bg-white/10">
                      <span class={`block h-full rounded-full ${series.className}`} style={`width: ${Math.max(4, (series.value / maxTrend) * 100)}%`}></span>
                    </span>
                    <span class="text-right font-semibold text-white/70">{series.value}</span>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </article>

      <article class="rounded-md border border-white/10 bg-kharon-charcoal/70 p-5">
        <h2 class="text-lg font-semibold text-white">Technician Throughput</h2>
        <p class="mt-1 text-sm text-white/60">Completed jobs by active technician.</p>
        <div class="mt-5 space-y-3">
          {topTechs.length === 0 ? (
            <p class="rounded-md border border-white/10 bg-black/20 p-4 text-sm text-white/60">No technician completions found.</p>
          ) : topTechs.map((tech, index) => (
            <div>
              <div class="mb-1 flex items-center justify-between gap-3 text-sm">
                <span class="truncate text-white/80">{index + 1}. {tech.name}</span>
                <span class="font-semibold text-white">{tech.completed_jobs}</span>
              </div>
              <div class="h-2 rounded-full bg-white/10">
                <div class="h-full rounded-full bg-kharon-purple" style={`width: ${Math.max(4, (tech.completed_jobs / maxTech) * 100)}%`}></div>
              </div>
            </div>
          ))}
        </div>
      </article>
    </div>

    <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">
      <article class="rounded-md border border-white/10 bg-kharon-charcoal/70 p-5">
        <h2 class="text-lg font-semibold text-white">System Estate Mix</h2>
        <p class="mt-1 text-sm text-white/60">Installed active systems by type.</p>
        <div class="mt-5 space-y-3">
          {systemTypes.map((type) => (
            <div>
              <div class="mb-1 flex items-center justify-between gap-3 text-sm">
                <span class="truncate text-white/80">{type.system_type || "Unclassified"}</span>
                <span class="font-semibold text-white">{type.count}</span>
              </div>
              <div class="h-2 rounded-full bg-white/10">
                <div class="h-full rounded-full bg-cyan-400" style={`width: ${Math.max(4, (type.count / maxSystem) * 100)}%`}></div>
              </div>
            </div>
          ))}
        </div>
      </article>

      <article class="rounded-md border border-white/10 bg-kharon-charcoal/70 p-5">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <h2 class="text-lg font-semibold text-white">Outstanding Finance</h2>
            <p class="mt-1 text-sm text-white/60">Newest unpaid records requiring finance follow-up.</p>
          </div>
          <a href="/portal/api/finance/export" class="rounded-md border border-kharon-purple/30 px-3 py-2 text-xs font-bold uppercase tracking-wide text-white/70 hover:bg-kharon-purple/20">Export CSV</a>
        </div>
        <div class="mt-5 overflow-x-auto">
          <table class="min-w-full text-left text-sm">
            <thead class="border-b border-white/10 text-xs uppercase tracking-wide text-white/40">
              <tr>
                <th scope="col" class="py-2 pr-4">Reference</th>
                <th scope="col" class="py-2 pr-4">Client</th>
                <th scope="col" class="py-2 pr-4">Date</th>
                <th scope="col" class="py-2 text-right">Amount</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/10 text-white/70">
              {outstandingFinance.length === 0 ? (
                <tr><td colspan="4" class="py-4 text-white/60">No unpaid finance records found.</td></tr>
              ) : outstandingFinance.map((record) => (
                <tr>
                  <td class="py-3 pr-4 font-semibold text-white/80">{record.reference}</td>
                  <td class="py-3 pr-4">{record.owner_company_name}</td>
                  <td class="py-3 pr-4">{record.distribution_date ? dateFormat.format(new Date(record.distribution_date)) : "Not dated"}</td>
                  <td class="py-3 text-right font-semibold text-white">{currency.format(record.amount || 0)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </article>
    </div>

    <p class="rounded-md border border-white/10 bg-black/20 p-4 text-xs leading-5 text-white/50">
      Caveat: this view summarizes operational records already present in D1. It does not infer missing field reports, external Sage settlement status, or certificate validity beyond stored portal records.
    </p>
  </div>
</PortalLayout>
