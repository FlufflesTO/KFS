---
import { auditError } from "../../../lib/server/audit";
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";

export const prerender = false;

const user = Astro.locals.user;
let mfa = { required: Boolean(user?.mfaRequired), enabled: Boolean(user?.mfaEnabled), eligible: ["admin", "finance", "tech"].includes(user?.role || "") };
let loadError = "";

try {
  const db = getDatabase();
  const record = await db
    .prepare(`SELECT mfa_required, mfa_enabled FROM users WHERE id = ?1 AND is_active = 1 LIMIT 1`)
    .bind(user?.id || "")
    .first();
  if (record) {
    mfa = {
      required: Boolean(record.mfa_required),
      enabled: Boolean(record.mfa_enabled),
      eligible: ["admin", "finance", "tech"].includes(user?.role || "")
    };
  }
} catch (error) {
  await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "mfa_page" });
  loadError = "MFA status could not be loaded.";
}
---

<PortalLayout title="MFA Control | Kharon Portal" active="mfa" user={user}>
  <section class="bg-kharon-black px-4 py-8 text-white sm:px-6 sm:py-10">
    <div class="mx-auto max-w-4xl">
      <p class="text-xs font-bold uppercase text-kharon-cyan">Account control</p>
      <h1 class="mt-3 text-2xl font-bold sm:text-3xl">Multi-factor authentication</h1>
      <p class="mt-4 max-w-2xl text-white/65">
        Admin, finance and technician accounts can enrol an authenticator app before accessing sensitive operational, ledger and field workflows.
      </p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto grid max-w-3xl gap-6">
      {loadError && <p class="rounded-md border border-red-300 bg-red-50 px-4 py-3 text-sm font-semibold text-red-900">{loadError}</p>}

      {!mfa.eligible && (
        <article class="kharon-surface p-6 sm:p-8">
          <h2 class="text-xl font-bold text-white">Not required for this role</h2>
          <p class="mt-3 leading-relaxed text-kharon-light/70">
            MFA enrolment is currently limited to staff accounts. Client account controls remain password, session and RBAC protected.
          </p>
        </article>
      )}

      {mfa.eligible && (
        <article class="kharon-surface p-6 sm:p-8">
          <div class="flex flex-wrap items-center justify-between gap-3 border-b border-kharon-cyan/10 pb-5 mb-5">
            <div>
              <p class="text-xs font-bold uppercase tracking-widest text-kharon-cyan">Current Status</p>
              <h2 class="mt-2 text-xl font-bold text-white">{mfa.enabled ? "MFA Enabled" : mfa.required ? "MFA Required" : "MFA Available"}</h2>
            </div>
            <span class={`rounded px-3 py-1 text-xs font-bold uppercase border tracking-widest ${mfa.enabled ? "border-kharon-green bg-kharon-green/10 text-kharon-green" : mfa.required ? "border-kharon-amber bg-kharon-amber/10 text-kharon-amber" : "border-kharon-cyan/20 bg-kharon-graphite text-kharon-light/60"}`}>
              {mfa.enabled ? "Protected" : mfa.required ? "Setup required" : "Optional"}
            </span>
          </div>

          {!mfa.enabled && (
            <div class="mt-6 grid gap-5">
              <button id="start-mfa" class="w-full kharon-command-button py-3.5" type="button">
                Generate Authenticator Setup
              </button>

              <div id="mfa-setup" class="hidden grid gap-5 rounded border border-kharon-cyan/10 bg-kharon-black/30 p-5">
                <p class="text-sm font-semibold text-white">Add this account manually in your authenticator app.</p>
                
                <div class="grid gap-1.5">
                  <label for="mfa-secret" class="text-xs font-bold uppercase tracking-widest text-kharon-cyan">Setup Key</label>
                  <input id="mfa-secret" class="kharon-field font-mono text-sm" readonly />
                </div>
                
                <div class="grid gap-1.5">
                  <label for="mfa-uri" class="text-xs font-bold uppercase tracking-widest text-kharon-cyan">Authenticator URI</label>
                  <textarea id="mfa-uri" class="kharon-field min-h-24 font-mono text-xs" readonly></textarea>
                </div>
                
                <form id="enable-mfa-form" class="grid gap-4 border-t border-kharon-cyan/10 pt-4">
                  <div class="grid gap-1.5">
                    <label for="mfa-code" class="text-xs font-bold uppercase tracking-widest text-kharon-cyan">6-digit Code</label>
                    <input id="mfa-code" class="kharon-field" name="code" inputmode="numeric" pattern="[0-9]{6}" autocomplete="one-time-code" required placeholder="000000" />
                  </div>
                  <button class="w-full kharon-command-button py-3.5" type="submit">
                    Verify & Enable MFA
                  </button>
                </form>
              </div>
            </div>
          )}

          {mfa.enabled && (
            <form id="disable-mfa-form" class="mt-6 grid gap-5 rounded border border-kharon-red/20 bg-kharon-red/5 p-5">
              <p class="text-sm font-semibold text-red-200">Disabling MFA requires verification code and confirmation.</p>
              
              <div class="grid gap-1.5">
                <label for="mfa-disable-code" class="text-xs font-bold uppercase tracking-widest text-kharon-cyan">6-digit Verification Code</label>
                <input id="mfa-disable-code" class="kharon-field" name="code" inputmode="numeric" pattern="[0-9]{6}" autocomplete="one-time-code" required placeholder="000000" />
              </div>
              
              <button class="w-full kharon-danger-button py-3.5" type="submit">
                Disable MFA Protection
              </button>
            </form>
          )}

          <p id="mfa-result" class="mt-5 hidden rounded border px-4 py-3 text-sm font-semibold" role="alert" aria-live="polite"></p>
        </article>
      )}
    </div>
  </section>

  <script>
    const startButton = document.querySelector<HTMLButtonElement>("#start-mfa");
    const setupPanel = document.querySelector<HTMLElement>("#mfa-setup");
    const secretInput = document.querySelector<HTMLInputElement>("#mfa-secret");
    const uriInput = document.querySelector<HTMLInputElement>("#mfa-uri");
    const enableForm = document.querySelector<HTMLFormElement>("#enable-mfa-form");
    const disableForm = document.querySelector<HTMLFormElement>("#disable-mfa-form");
    const result = document.querySelector<HTMLElement>("#mfa-result");

    function showResult(message: string, ok = false) {
      if (!result) return;
      result.textContent = message;
      result.className = ok
        ? "mt-5 rounded border border-kharon-green bg-kharon-green/10 px-4 py-3 text-sm font-semibold text-green-200"
        : "mt-5 rounded border border-kharon-red bg-kharon-red/10 px-4 py-3 text-sm font-semibold text-red-200";
      result.classList.remove("hidden");
    }

    startButton?.addEventListener("click", async () => {
      const response = await window.kharonPortalFetch("/portal/api/mfa", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ action: "setup" })
      });
      const body = await response.json().catch(() => ({ ok: false, message: "MFA setup could not be started." }));
      if (!response.ok || !body.ok) {
        showResult(body.message || "MFA setup could not be started.");
        return;
      }
      if (secretInput) secretInput.value = body.secret;
      if (uriInput) uriInput.value = body.provisioningUri;
      setupPanel?.classList.remove("hidden");
      showResult("Setup key generated. Verify the first authenticator code to enable MFA.", true);
    });

    enableForm?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const formData = new FormData(enableForm);
      const response = await window.kharonPortalFetch("/portal/api/mfa", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ action: "enable", secret: secretInput?.value || "", code: formData.get("code") })
      });
      const body = await response.json().catch(() => ({ ok: false, message: "MFA could not be enabled." }));
      if (!response.ok || !body.ok) {
        showResult(body.message || "MFA could not be enabled.");
        return;
      }
      showResult("MFA enabled. Redirecting...", true);
      window.location.href = body.redirectTo || "/portal";
    });

    disableForm?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!window.confirm("WARNING: Disabling MFA reduces your account security level. Are you sure you want to proceed?")) {
        return;
      }
      const formData = new FormData(disableForm);
      const response = await window.kharonPortalFetch("/portal/api/mfa", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ action: "disable", code: formData.get("code") })
      });
      const body = await response.json().catch(() => ({ ok: false, message: "MFA could not be disabled." }));
      if (!response.ok || !body.ok) {
        showResult(body.message || "MFA could not be disabled.");
        return;
      }
      window.location.href = body.redirectTo || "/portal/account/mfa";
    });
  </script>
</PortalLayout>
