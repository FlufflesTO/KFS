---
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";

export const prerender = false;

const user = Astro.locals.user;
---

<PortalLayout title="Password Control | Kharon Portal" active="password" user={user}>
  <section class="bg-kharon-black px-6 py-10 text-white">
    <div class="mx-auto max-w-4xl">
      <p class="text-xs font-bold uppercase text-kharon-cyan">Account control</p>
      <h1 class="mt-3 text-3xl font-bold">Password management</h1>
      <p class="mt-4 max-w-2xl text-white/65">
        Update your issued portal password. Accounts flagged for password rotation must complete this step before continuing to operational dashboards.
      </p>
    </div>
  </section>

  <section class="px-6 py-8">
    <div class="mx-auto max-w-2xl border border-kharon-border bg-white p-6">
      {user.forcePasswordChange && (
        <p class="mb-5 rounded-md border border-amber-300 bg-amber-50 px-4 py-3 text-sm font-semibold text-amber-900">
          Password rotation is required before portal access can continue.
        </p>
      )}

      <form id="password-form" class="grid gap-5">
        <label class="grid gap-2 text-sm font-semibold text-kharon-black">
          Current password
          <input class="rounded-md border border-kharon-border px-4 py-3 font-normal" name="currentPassword" type="password" autocomplete="current-password" required />
        </label>

        <label class="grid gap-2 text-sm font-semibold text-kharon-black">
          New password
          <input class="rounded-md border border-kharon-border px-4 py-3 font-normal" name="newPassword" type="password" autocomplete="new-password" minlength="14" required />
        </label>

        <label class="grid gap-2 text-sm font-semibold text-kharon-black">
          Confirm new password
          <input class="rounded-md border border-kharon-border px-4 py-3 font-normal" name="confirmPassword" type="password" autocomplete="new-password" minlength="14" required />
        </label>

        <p id="password-result" class="hidden rounded-md border px-4 py-3 text-sm font-semibold" role="alert" aria-live="polite"></p>

        <button class="rounded-md bg-kharon-purple px-6 py-4 font-semibold text-white hover:bg-kharon-blue">
          Update password
        </button>
      </form>
    </div>
  </section>

  <script>
    const form = document.querySelector("#password-form");
    const result = document.querySelector("#password-result");

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      result.classList.add("hidden");
      const formData = new FormData(form);
      const response = await window.kharonPortalFetch("/portal/api/change-password", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          currentPassword: formData.get("currentPassword"),
          newPassword: formData.get("newPassword"),
          confirmPassword: formData.get("confirmPassword")
        })
      });
      const body = await response.json();
      if (!response.ok || !body.ok) {
        result.textContent = body.message || "Password could not be updated.";
        result.className = "rounded-md border border-red-300 bg-red-50 px-4 py-3 text-sm font-semibold text-red-900";
        return;
      }
      result.textContent = "Password updated. Redirecting...";
      result.className = "rounded-md border border-emerald-300 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-900";
      window.location.href = body.redirectTo || "/portal";
    });
  </script>
</PortalLayout>
