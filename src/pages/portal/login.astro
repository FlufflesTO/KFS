---
import BaseLayout from "../../layouts/BaseLayout.astro";
import KharonCard from "../../components/ui/KharonCard.astro";
import { isLoggedIn } from "../../lib/server/middleware/auth";

if (await isLoggedIn(Astro.request)) {
  return Astro.redirect("/portal");
}
import CsrfInput from "../../components/ui/CsrfInput.astro";
---

<BaseLayout title="Login - Kharon Operations Portal" description="Secure login to the Kharon operations portal">
  <section class="min-h-screen flex items-center justify-center bg-gradient-to-br from-kharon-black to-kharon-charcoal kharon-environment kharon-logo-watermark">
    <div class="w-full max-w-sm px-4">
      <div class="text-center mb-6">
        <div class="flex justify-center mb-4">
          <div class="relative">
            <div class="absolute inset-0 bg-kharon-purple/30 blur-2xl rounded-full"></div>
            <img src="/brand/kharon-mark.svg" alt="Kharon Logo" class="login-mark relative z-10">
          </div>
        </div>
        <h1 class="text-xl font-bold text-white">Operations Portal</h1>
        <p class="text-kharon-light/70 mt-1 text-sm">Secure access to fire protection systems management</p>
      </div>

      <KharonCard variant="command" className="kharon-surface-strong">
        <form id="portal-login-form" method="post" action="/portal/api/auth" class="space-y-5">
          <CsrfInput />
          <div>
            <label class="block text-kharon-purple text-xs font-bold uppercase tracking-widest mb-2">Email Address</label>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              placeholder="Enter your email"
              class="w-full px-4 py-3 bg-kharon-graphite border border-kharon-purple/20 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-kharon-purple focus:border-transparent kharon-field kharon-focus-ring"
            />
          </div>
          
          <div>
            <label class="block text-kharon-purple text-xs font-bold uppercase tracking-widest mb-2">Password</label>
            <input
              type="password"
              name="password"
              required
              autocomplete="current-password"
              placeholder="Enter your password"
              class="w-full px-4 py-3 bg-kharon-graphite border border-kharon-purple/20 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-kharon-purple focus:border-transparent kharon-field kharon-focus-ring"
            />
          </div>

          <div>
            <label class="block text-kharon-purple text-xs font-bold uppercase tracking-widest mb-2">Authenticator Code</label>
            <input
              type="text"
              name="mfaCode"
              inputmode="numeric"
              autocomplete="one-time-code"
              pattern="[0-9]{6}"
              maxlength="6"
              placeholder="Required if MFA is enabled"
              class="w-full px-4 py-3 bg-kharon-graphite border border-kharon-purple/20 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-kharon-purple focus:border-transparent kharon-field kharon-focus-ring"
            />
          </div>
          
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <div class="flex items-center">
              <input 
                id="remember-me" 
                name="remember-me" 
                type="checkbox" 
                class="h-4 w-4 text-kharon-purple focus:ring-kharon-purple border-kharon-purple/20 rounded bg-kharon-graphite kharon-checkbox"
              />
              <label for="remember-me" class="ml-2 block text-sm text-kharon-light/80">
                Remember me
              </label>
            </div>
            
            <a href="/portal/reset" class="text-sm font-medium text-kharon-purple hover:text-kharon-purple/80 text-center sm:text-right">
              Forgot password?
            </a>
          </div>
          
          <button 
            type="submit"
            id="portal-login-submit"
            class="w-full px-4 py-4 bg-gradient-to-r from-kharon-purple to-kharon-blue text-white font-bold uppercase tracking-widest rounded-md hover:shadow-lg hover:shadow-kharon-purple/30 transition-all kharon-command-button"
          >
            Secure Login
          </button>
          <p id="portal-login-result" class="hidden rounded border px-4 py-3 text-sm font-semibold" aria-live="polite"></p>
        </form>
      </KharonCard>

      <div class="mt-5 text-center">
        <p class="text-kharon-light/70 text-sm">
          Need access? <a href="/contact" class="font-medium text-kharon-purple hover:text-kharon-purple/80">Contact support</a>
        </p>
      </div>
    </div>
  </section>
  <script>
    const form = document.querySelector("#portal-login-form");
    const submit = document.querySelector("#portal-login-submit");
    const result = document.querySelector("#portal-login-result");

    function setLoginResult(message: string, ok = false) {
      if (!(result instanceof HTMLElement)) return;
      result.textContent = message;
      result.classList.remove("hidden", "border-red-500", "bg-red-950/40", "text-red-100", "border-green-500", "bg-green-950/40", "text-green-100");
      result.classList.add(ok ? "border-green-500" : "border-red-500", ok ? "bg-green-950/40" : "bg-red-950/40", ok ? "text-green-100" : "text-red-100");
    }

    if (form instanceof HTMLFormElement) {
      form.addEventListener("submit", async (event: SubmitEvent) => {
        event.preventDefault();
        if (submit instanceof HTMLButtonElement) {
          submit.disabled = true;
          submit.textContent = "Checking...";
        }

        const payload = Object.fromEntries(new FormData(form).entries());
        try {
          const response = await fetch("/portal/api/auth", {
            method: "POST",
            headers: { "content-type": "application/json" },
            credentials: "same-origin",
            body: JSON.stringify(payload)
          });
          const body = await response.json().catch(() => ({})) as Record<string, any>;
          if (!response.ok || !body.ok) {
            setLoginResult(body.message || "Authentication could not be completed.");
            return;
          }
          setLoginResult("Login accepted. Redirecting...", true);
          window.location.assign(body.redirectTo || "/portal");
        } catch (error) {
          setLoginResult("Network error. Check your connection and try again.");
        } finally {
          if (submit instanceof HTMLButtonElement) {
            submit.disabled = false;
            submit.textContent = "Secure Login";
          }
        }
      });
    }
  </script>

  <style>
    /* Bypass Tailwind's max-width:100% img reset — explicit dimensions required */
    .login-mark { display: block; height: 72px; width: 72px; max-width: none; }
  </style>
</BaseLayout>
