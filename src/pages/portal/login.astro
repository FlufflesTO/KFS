---
import "../../styles/global.css";

export const prerender = false;

const next = Astro.url.searchParams.get("next") || "/portal";
---

<!doctype html>
<html lang="en-ZA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Kharon Portal Login</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-kharon-black text-white">
    <main class="grid min-h-screen place-items-center px-6 py-12">
      <section class="w-full max-w-md border border-white/10 bg-white/[0.04] p-6 sm:p-7">
        <img src="/brand/kharon-mark.svg" alt="" aria-hidden="true" width="42" height="57" class="mb-6" />
        <p class="text-xs font-bold uppercase text-kharon-cyan">Secure operations portal</p>
        <h1 class="mt-3 text-3xl font-bold">Kharon access gateway</h1>
        <p class="mt-4 leading-7 text-white/65">
          Sign in with your issued Kharon account to access lifecycle records, dispatches, client systems or finance workspaces.
        </p>

        <form id="login-form" class="mt-8 grid gap-5">
          <input type="hidden" name="next" value={next} />
          <label class="grid gap-2 text-sm font-semibold">
            Corporate email
            <input class="rounded-md border border-white/15 bg-black/30 px-4 py-3 text-white" name="email" type="email" autocomplete="email" required />
          </label>
          <label class="grid gap-2 text-sm font-semibold">
            Password
            <input class="rounded-md border border-white/15 bg-black/30 px-4 py-3 text-white" name="password" type="password" autocomplete="current-password" required />
          </label>
          <label class="grid gap-2 text-sm font-semibold">
            Authenticator code
            <input class="rounded-md border border-white/15 bg-black/30 px-4 py-3 text-white" name="mfaCode" inputmode="numeric" pattern="[0-9]{6}" autocomplete="one-time-code" placeholder="Required if MFA is enabled" />
          </label>
          <p
            id="login-error"
            role="alert"
            aria-live="polite"
            class="hidden rounded-md border px-4 py-3 text-sm font-semibold"
            style="border-color: #f87171; background: #fff1f2; color: #7f1d1d;"
          ></p>
          <button class="rounded-md bg-kharon-purple px-6 py-4 font-semibold text-white hover:bg-kharon-blue">
            Sign in
          </button>
          <p class="text-sm text-white/55">
            Need a reset? Ask an administrator to issue a password reset link through the portal operations screen.
          </p>
        </form>
      </section>
    </main>

    <script>
      const form = document.querySelector("#login-form");
      const error = document.querySelector("#login-error");

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();
        error.classList.add("hidden");
        const formData = new FormData(form);
        const response = await fetch("/portal/api/auth", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            email: formData.get("email"),
            password: formData.get("password"),
            mfaCode: formData.get("mfaCode")
          })
        });
        const result = await response.json();
        if (!response.ok || !result.ok) {
          error.textContent = result.message || "Sign in failed.";
          error.classList.remove("hidden");
          return;
        }
        const requestedNext = String(formData.get("next") || "");
        window.location.href = requestedNext.startsWith("/portal/") ? requestedNext : result.redirectTo;
      });
    </script>
  </body>
</html>
