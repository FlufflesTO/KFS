---
/**
 * Manager Portal Dashboard
 * Purpose: Operational overview for managers — read-only visibility across jobs, sites, systems, and compliance
 * Dependencies: PortalLayout, getDatabase, requireManager, DashboardService
 * Structural Role: Manager portal dashboard main view
 */

import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import { requireManager } from "../../../lib/server/access.js";
import { DashboardService, type DashboardStats } from "../../../lib/server/services/dashboard-service";
import { auditError } from "../../../lib/server/audit.js";
import DashboardFeatureCard from "../../../components/portal/DashboardFeatureCard.astro";
import PortalQuickActions from "../../../components/portal/PortalQuickActions.astro";

export const prerender = false;

const user = Astro.locals.user;

const guard = requireManager(user);
if (guard) return guard;

const managerActions = [
  { label: "Dispatch Board",  href: "/portal/admin/dispatch",            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />`, accent: "cyan"   as const },
  { label: "Jobs Registry",   href: "/portal/admin/jobs",                icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`, accent: "purple" as const },
  { label: "Planning",        href: "/portal/admin/planning",            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />`, accent: "amber"  as const },
  { label: "SANS Reports",    href: "/portal/admin/advanced-reporting",  icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />`, accent: "green"  as const },
];

let stats: DashboardStats = {
  activeJobs: 0, unassignedJobs: 0, overdueSystems: 0, openRequests: 0,
  missingDocuments: 0, openDefects: 0, criticalDefects: 0,
  blockedCertificates: 0, validCertificates: 0
};
let loadError = "";

try {
  const db = getDatabase();
  const service = new DashboardService(db);
  stats = await service.getAdminStats();
} catch (error) {
  await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "manager_dashboard" });
  loadError = "Operational data could not be loaded.";
}

const exceptions = [
  { condition: stats.unassignedJobs > 0,      count: stats.unassignedJobs,     label: "job(s) unassigned — technician allocation required",   href: "/portal/admin/dispatch",           severity: "red"   },
  { condition: stats.criticalDefects > 0,     count: stats.criticalDefects,    label: "critical defect(s) open — immediate remediation needed", href: "/portal/admin/systems",            severity: "red"   },
  { condition: stats.overdueSystems > 0,      count: stats.overdueSystems,     label: "system(s) overdue for scheduled service",               href: "/portal/admin/systems",            severity: "amber" },
  { condition: stats.openRequests > 0,        count: stats.openRequests,       label: "client request(s) awaiting review and scheduling",      href: "/portal/admin/dispatch",           severity: "amber" },
  { condition: stats.blockedCertificates > 0, count: stats.blockedCertificates, label: "certificate(s) blocked — compliance action needed",    href: "/portal/admin/compliance",         severity: "amber" },
].filter(e => e.condition);
---

<PortalLayout title="Manager Overview | Kharon Portal" active="manager" user={user}>

  <section class="bg-gradient-to-br from-kharon-black to-kharon-charcoal px-4 py-8 text-white sm:px-6 sm:py-10 rounded-xl border border-kharon-purple/10 mb-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(75,46,131,0.1),transparent)]"></div>
    <div class="mx-auto max-w-7xl relative z-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-kharon-purple/10 ring-1 ring-kharon-purple/20">
          <svg class="h-[1.1rem] w-[1.1rem] text-kharon-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 6a2 2 0 100-4 2 2 0 000 4z" />
          </svg>
        </div>
        <p class="text-base font-black uppercase tracking-[0.2em] text-kharon-cyan">Management Console</p>
      </div>
      <h1 class="text-2xl font-black sm:text-3xl tracking-tight text-white">Operations Overview</h1>
      <p class="mt-2 max-w-2xl text-base text-kharon-light/60">
        Live operational status for {user?.name || "Manager"}. All views are read-only — contact your administrator for changes.
      </p>
    </div>
  </section>

  {loadError && (
    <div class="mb-6 rounded-lg border border-kharon-amber/30 bg-kharon-amber/10 px-4 py-3 text-base text-kharon-amber">
      {loadError}
    </div>
  )}

  {exceptions.length > 0 && (
    <section class="mb-6 rounded-xl border border-kharon-red/20 bg-kharon-red/5 px-4 py-4">
      <h2 class="mb-3 text-base font-black uppercase tracking-widest text-kharon-red">Operational Alerts</h2>
      <ul class="space-y-2">
        {exceptions.map(e => (
          <li class="flex items-center gap-3 text-base">
            <span class={`inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full text-base font-black ${e.severity === 'red' ? 'bg-kharon-red/20 text-kharon-red' : 'bg-kharon-amber/20 text-kharon-amber'}`}>
              {e.count}
            </span>
            <a href={e.href} class="text-kharon-light/80 hover:text-white transition-colors underline-offset-2 hover:underline">
              {e.label}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <div class="mb-6 grid grid-cols-2 gap-3 sm:grid-cols-4 sm:gap-4">
    {[
      { label: "Active Jobs",        value: stats.activeJobs,         href: "/portal/admin/jobs",     color: "text-kharon-cyan"   },
      { label: "Unassigned",         value: stats.unassignedJobs,     href: "/portal/admin/dispatch", color: stats.unassignedJobs > 0 ? "text-kharon-red" : "text-kharon-green" },
      { label: "Overdue Systems",    value: stats.overdueSystems,     href: "/portal/admin/systems",  color: stats.overdueSystems > 0 ? "text-kharon-amber" : "text-kharon-green" },
      { label: "Open Defects",       value: stats.openDefects,        href: "/portal/admin/systems",  color: stats.openDefects > 0 ? "text-kharon-amber" : "text-kharon-green" },
    ].map(stat => (
      <a href={stat.href} class="group rounded-xl border border-kharon-purple/10 bg-kharon-charcoal/60 px-4 py-4 hover:border-kharon-purple/30 transition-colors">
        <div class={`text-2xl font-black ${stat.color}`}>{stat.value}</div>
        <div class="mt-1 text-base font-semibold uppercase tracking-wide text-kharon-light/50">{stat.label}</div>
      </a>
    ))}
  </div>

  <PortalQuickActions actions={managerActions} />

  <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <DashboardFeatureCard
      title="Dispatch Board"
      description="View active job assignments and technician allocation status."
      href="/portal/admin/dispatch"
      iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />`}
    />
    <DashboardFeatureCard
      title="Jobs Registry"
      description="Browse all active, scheduled, and completed service jobs."
      href="/portal/admin/jobs"
      iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`}
    />
    <DashboardFeatureCard
      title="Planning Calendar"
      description="View upcoming schedules and technician capacity."
      href="/portal/admin/planning"
      iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />`}
    />
    <DashboardFeatureCard
      title="Client Sites"
      description="Review site details, contacts, and system inventory."
      href="/portal/admin/sites"
      iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />`}
    />
    <DashboardFeatureCard
      title="Protection Systems"
      description="Monitor system health, service schedules, and defect status."
      href="/portal/admin/systems"
      iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18" />`}
    />
    <DashboardFeatureCard
      title="SANS Compliance"
      description="Review compliance posture and outstanding certificate actions."
      href="/portal/admin/compliance"
      iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />`}
    />
  </div>

</PortalLayout>
