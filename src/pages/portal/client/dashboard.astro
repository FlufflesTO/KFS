---
/**
 * Project Sentinel - Portal Client Dashboard
 * Purpose: Provides gateway dashboard for clients to view systems, defects, certs, and request support
 * Dependencies: PortalLayout, bindings, clientAccess, financial-utils
 * Structural Role: Client gateway main view
 */
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import { clientSites, inClause } from "../../../lib/server/clientAccess.js";
import { formatCurrency } from "../../../lib/utils/financial-utils.ts";

export const prerender = false;

const user = Astro.locals.user;
interface ClientSystem {
  id: string;
  site_id: string;
  system_type: string;
  coverage_area: string;
  last_service_date: string | null;
  next_due_date: string;
  owner_company_name: string;
  latest_job_id: string | null;
  documentation_path: string | null;
  completed_at: string | null;
}

interface ClientQuote {
  id: string;
  site_id: string;
  amount: number;
  item_type: string;
  payment_status: string;
  distribution_date: string;
  reference: string | null;
  owner_company_name: string;
}

let systems: ClientSystem[] = [];
let quotes: ClientQuote[] = [];
let requests = [];
let sites = [];
let openDefects = [];
let certificates = [];
let loadError = "";
const sectionErrors = [];
const today    = new Date().toISOString().slice(0, 10);
const soonDate = new Date(Date.now() + 30 * 86400000).toISOString().slice(0, 10);

try {
  const db = getDatabase();
  sites = await clientSites(db, user);
  const siteIds = sites.map((site) => site.id);
  if (siteIds.length === 0) {
    loadError = "This client account is not mapped to a site.";
  } else {
    const sitePlaceholders = inClause(siteIds);
    try {
      systems = (await db.prepare(
        `SELECT systems.id, systems.site_id, systems.system_type, systems.coverage_area, systems.last_service_date, systems.next_due_date,
                sites.owner_company_name,
                latest_jobs.id AS latest_job_id, latest_jobs.documentation_path, latest_jobs.completed_at
         FROM systems
         INNER JOIN sites ON sites.id = systems.site_id
         LEFT JOIN jobs AS latest_jobs ON latest_jobs.id = (
           SELECT j.id FROM jobs j
           WHERE j.system_id = systems.id AND j.documentation_path IS NOT NULL
           ORDER BY COALESCE(j.completed_at, j.updated_at, j.created_at) DESC
           LIMIT 1
         )
         WHERE systems.site_id IN (${sitePlaceholders})
         ORDER BY sites.owner_company_name ASC, systems.next_due_date ASC`
      ).bind(...siteIds).all()).results as ClientSystem[] || [];
    } catch (error) {
      console.error("client systems load failed", error);
      sectionErrors.push("System records could not be loaded.");
    }

    try {
      quotes = (await db.prepare(
        `SELECT financial_records.id, financial_records.site_id, financial_records.amount,
                financial_records.item_type, financial_records.payment_status,
                financial_records.distribution_date, financial_records.reference,
                sites.owner_company_name
         FROM financial_records
         INNER JOIN sites ON sites.id = financial_records.site_id
         WHERE financial_records.site_id IN (${sitePlaceholders})
           AND financial_records.item_type = 'Quote'
           AND financial_records.payment_status = 'Pending Approval'
         ORDER BY financial_records.distribution_date ASC`
      ).bind(...siteIds).all()).results as ClientQuote[] || [];
    } catch (error) {
      console.error("client quotes load failed", error);
      sectionErrors.push("Quote approvals could not be loaded.");
    }

    try {
      requests = (await db.prepare(
        `SELECT maintenance_requests.id, maintenance_requests.site_id,
                maintenance_requests.request_type, maintenance_requests.priority,
                maintenance_requests.status, maintenance_requests.subject, maintenance_requests.created_at,
                maintenance_requests.linked_job_id, systems.coverage_area, sites.owner_company_name
         FROM maintenance_requests
         INNER JOIN sites ON sites.id = maintenance_requests.site_id
         LEFT JOIN systems ON systems.id = maintenance_requests.system_id
         WHERE maintenance_requests.site_id IN (${sitePlaceholders})
         ORDER BY maintenance_requests.created_at DESC
         LIMIT 8`
      ).bind(...siteIds).all()).results || [];
    } catch (error) {
      console.error("client requests load failed", error);
      sectionErrors.push("Recent service requests could not be loaded.");
    }

    try {
      openDefects = (await db.prepare(
        `SELECT defects.id, defects.severity, defects.sans_clause_ref, defects.status,
                defects.remediation_notes, systems.id AS system_id, systems.system_type,
                systems.coverage_area, sites.owner_company_name
         FROM defects
         INNER JOIN systems ON systems.id = defects.system_id
         INNER JOIN sites ON sites.id = systems.site_id
         WHERE systems.site_id IN (${sitePlaceholders}) AND defects.status IN ('Open', 'In Progress')
         ORDER BY CASE defects.severity WHEN 'Critical' THEN 1 WHEN 'Major' THEN 2 ELSE 3 END,
                  defects.created_at DESC
         LIMIT 10`
      ).bind(...siteIds).all()).results || [];
    } catch (error) {
      console.error("client defects load failed", error);
      sectionErrors.push("Defect register could not be loaded.");
    }

    try {
      certificates = (await db.prepare(
        `SELECT certificates.id, certificates.certificate_type, certificates.status,
                certificates.issued_date, certificates.expiry_date,
                systems.id AS system_id, systems.system_type, systems.coverage_area,
                sites.owner_company_name
         FROM certificates
         INNER JOIN systems ON systems.id = certificates.system_id
         INNER JOIN sites ON sites.id = systems.site_id
         WHERE systems.site_id IN (${sitePlaceholders})
         ORDER BY COALESCE(certificates.expiry_date, certificates.issued_date) DESC
         LIMIT 10`
      ).bind(...siteIds).all()).results || [];
    } catch (error) {
      console.error("client certificates load failed", error);
      sectionErrors.push("Certificate register could not be loaded.");
    }
  }
} catch (error) {
  console.error("client dashboard failed", error);
  loadError = "Client system records could not be loaded.";
}

// Compliance summary counts — computed in frontmatter (< safe in TS, not JSX)
const overdueCount  = systems.filter((s) => s.next_due_date && s.next_due_date < today).length;
const dueSoonCount  = systems.filter((s) => s.next_due_date && s.next_due_date >= today && s.next_due_date <= soonDate).length;
const compliantCount = systems.filter((s) => !s.next_due_date || s.next_due_date > soonDate).length;
---

<PortalLayout title="Client Gateway | Kharon Portal" active="client" user={user}>
  <section class="bg-kharon-black px-4 py-8 text-white sm:px-6 sm:py-10">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-bold uppercase text-kharon-cyan">Client self-service gateway</p>
      <h1 class="mt-3 text-2xl font-bold sm:text-3xl">System status and lifecycle records</h1>
      <p class="mt-4 max-w-3xl text-white/65">Read-only visibility over protected systems, upcoming maintenance dates and completed jobcard records.</p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto max-w-7xl">
      {loadError && <p class="border border-red-300 bg-red-50 p-4 text-red-800 mb-6">{loadError}</p>}
      {!loadError && sectionErrors.length > 0 && (
        <div class="grid gap-2 mb-6">
          {sectionErrors.map((message) => <p class="border border-amber-300 bg-amber-50 p-4 text-amber-900">{message}</p>)}
        </div>
      )}

      <!-- Emergency Support Alert -->
      <div class="flex flex-wrap items-center justify-between gap-4 border border-kharon-red bg-red-50/50 px-4 py-3 mb-6 rounded-lg shadow-sm">
        <div>
          <p class="text-sm font-bold text-kharon-red">Urgent Technical Intervention Required?</p>
          <p class="text-xs text-kharon-grey mt-0.5">For live faults, compliance blockages, or emergency support:</p>
        </div>
        <a href="/emergency-support" class="rounded bg-kharon-red px-4 py-2 text-xs font-bold text-white hover:opacity-90 transition-opacity">
          Emergency support →
        </a>
      </div>

      <!-- Quick Stats Card Row -->
      {systems.length > 0 && (
        <div class="grid grid-cols-3 gap-4 mb-6">
          <div class={`rounded-xl border p-4 bg-white shadow-sm flex flex-col justify-between ${overdueCount > 0 ? "border-red-200" : "border-kharon-border"}`}>
            <span class="text-xs font-bold uppercase tracking-wider text-kharon-grey/65">Overdue Maintenance</span>
            <div class="flex items-baseline gap-2 mt-2">
              <span class={`text-3xl font-bold ${overdueCount > 0 ? "text-kharon-red" : "text-kharon-black"}`}>{overdueCount}</span>
              {overdueCount > 0 && <span class="text-[10px] font-bold text-kharon-red bg-red-50 border border-red-200 px-1.5 py-0.5 rounded">Action Required</span>}
            </div>
          </div>
          <div class={`rounded-xl border p-4 bg-white shadow-sm flex flex-col justify-between ${dueSoonCount > 0 ? "border-amber-200" : "border-kharon-border"}`}>
            <span class="text-xs font-bold uppercase tracking-wider text-kharon-grey/65">Due Within 30 Days</span>
            <div class="flex items-baseline gap-2 mt-2">
              <span class={`text-3xl font-bold ${dueSoonCount > 0 ? "text-kharon-amber" : "text-kharon-black"}`}>{dueSoonCount}</span>
              {dueSoonCount > 0 && <span class="text-[10px] font-bold text-kharon-amber bg-amber-50 border border-amber-200 px-1.5 py-0.5 rounded">Scheduled</span>}
            </div>
          </div>
          <div class="rounded-xl border border-kharon-border p-4 bg-white shadow-sm flex flex-col justify-between">
            <span class="text-xs font-bold uppercase tracking-wider text-kharon-grey/65">Compliant Systems</span>
            <div class="flex items-baseline gap-2 mt-2">
              <span class="text-3xl font-bold text-kharon-blue">{compliantCount}</span>
              <span class="text-[10px] font-bold text-kharon-blue bg-blue-50 border border-blue-100 px-1.5 py-0.5 rounded">Secure</span>
            </div>
          </div>
        </div>
      )}

      <!-- Main Dashboard Grid: Workspace + Sidebar -->
      <div class="grid gap-6 lg:grid-cols-[1.9fr_1.1fr]">
        
        <!-- ==================== LEFT / MAIN COLUMN ==================== -->
        <div class="space-y-6">
          
          <!-- Section: Systems under management -->
          <div class="rounded-xl border border-kharon-border bg-white p-5 shadow-sm">
            <div class="flex items-center justify-between border-b border-kharon-border pb-4 mb-4">
              <div>
                <p class="text-xs font-bold uppercase tracking-wider text-kharon-purple">Asset Lifecycle</p>
                <h2 class="text-lg font-bold text-kharon-black">Systems & Cadence Records</h2>
              </div>
              <a href="/compliance" class="text-xs font-bold text-kharon-purple hover:underline">Standards reference →</a>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              {systems.map((system) => (
                <article class="rounded-lg border border-kharon-border bg-kharon-light/50 p-4 flex flex-col justify-between">
                  <div>
                    <div class="flex items-start justify-between gap-2">
                      <span class="rounded bg-kharon-purple/10 px-2 py-0.5 text-[10px] font-bold uppercase text-kharon-purple">{system.system_type}</span>
                      <span class={`rounded px-2 py-0.5 text-[10px] font-bold uppercase border ${
                        system.next_due_date && system.next_due_date < today
                          ? "border-red-200 bg-red-50 text-kharon-red"
                          : system.next_due_date && system.next_due_date <= soonDate
                          ? "border-amber-200 bg-amber-50 text-kharon-amber"
                          : "border-kharon-border bg-white text-kharon-grey"
                      }`}>
                        {system.next_due_date && system.next_due_date < today ? "Overdue  -  " : "Due "}{system.next_due_date || "Not scheduled"}
                      </span>
                    </div>
                    <h3 class="mt-2.5 font-bold text-kharon-black leading-tight">{system.coverage_area}</h3>
                    <p class="text-xs text-kharon-grey mt-0.5">{system.owner_company_name}</p>
                    
                    <dl class="mt-4 grid grid-cols-2 gap-2 text-xs border-t border-kharon-border/60 pt-3">
                      <div>
                        <dt class="font-semibold text-kharon-grey/70 uppercase text-[9px] tracking-wider">Last Service</dt>
                        <dd class="mt-0.5 text-kharon-black font-medium">{system.last_service_date || "None"}</dd>
                      </div>
                      <div>
                        <dt class="font-semibold text-kharon-grey/70 uppercase text-[9px] tracking-wider">System ID</dt>
                        <dd class="mt-0.5 text-kharon-black font-mono break-all">{system.id.slice(0, 8)}...</dd>
                      </div>
                    </dl>
                  </div>
                  
                  <div class="mt-4 pt-3 border-t border-kharon-border/60">
                    {system.documentation_path ? (
                      <a class="inline-flex w-full justify-center items-center rounded bg-kharon-blue px-3 py-2 text-xs font-bold text-white hover:opacity-90 transition-opacity" href={`/portal/api/file/${system.documentation_path}`}>
                        Download Latest Jobcard
                      </a>
                    ) : (
                      <span class="text-xs text-kharon-grey/70 italic block text-center py-1">No completed jobcard file</span>
                    )}
                  </div>
                </article>
              ))}
            </div>
          </div>

          <!-- Section: Open Defects Register -->
          <div class="rounded-xl border border-kharon-border bg-white p-5 shadow-sm">
            <div class="flex items-center justify-between border-b border-kharon-border pb-4 mb-4">
              <div>
                <p class="text-xs font-bold uppercase tracking-wider text-kharon-red">Risk management</p>
                <h2 class="text-lg font-bold text-kharon-black">Open Defects Register</h2>
              </div>
              <details class="text-xs text-kharon-grey relative">
                <summary class="cursor-pointer font-semibold text-kharon-purple hover:underline">Status guide</summary>
                <div class="absolute right-0 mt-2 z-10 w-64 rounded-md border border-kharon-border bg-white p-3 shadow-md text-xs">
                  <ul class="grid gap-1.5">
                    <li><strong>Open</strong> — defect recorded; remediation pending.</li>
                    <li><strong>In Progress</strong> — work started on defect.</li>
                  </ul>
                </div>
              </details>
            </div>
            
            <div class="space-y-3">
              {openDefects.length === 0 && <p class="text-sm text-kharon-grey italic py-2">No open defects are recorded for your systems.</p>}
              {openDefects.map((item) => (
                <article class="flex items-start justify-between gap-4 p-4 rounded-lg border bg-kharon-light/30" class:list={[
                  item.severity === "Critical" ? "border-red-200 border-l-4 border-l-kharon-red" :
                  item.severity === "Major" ? "border-amber-200 border-l-4 border-l-kharon-amber" :
                  "border-kharon-border border-l-4 border-l-kharon-grey"
                ]}>
                  <div>
                    <h3 class="font-bold text-sm text-kharon-black">{item.owner_company_name} — {item.system_type}</h3>
                    <p class="text-xs text-kharon-grey mt-0.5">{item.coverage_area}</p>
                    {item.sans_clause_ref && <p class="mt-1.5 text-xs text-kharon-grey/85 font-mono">SANS clause ref: {item.sans_clause_ref}</p>}
                  </div>
                  <span class={`rounded border px-2.5 py-1 text-xs font-bold uppercase shadow-sm ${
                    item.severity === "Critical" ? "border-red-200 bg-red-50 text-kharon-red" :
                    item.severity === "Major" ? "border-amber-200 bg-amber-50 text-amber-700" :
                    "border-kharon-border bg-white text-kharon-grey"
                  }`}>{item.severity}</span>
                </article>
              ))}
            </div>
          </div>

          <!-- Section: Certificate Register -->
          <div class="rounded-xl border border-kharon-border bg-white p-5 shadow-sm">
            <div class="flex items-center justify-between border-b border-kharon-border pb-4 mb-4">
              <div>
                <p class="text-xs font-bold uppercase tracking-wider text-kharon-blue">Compliance records</p>
                <h2 class="text-lg font-bold text-kharon-black">Certificate Register</h2>
              </div>
              <details class="text-xs text-kharon-grey relative">
                <summary class="cursor-pointer font-semibold text-kharon-purple hover:underline">Status guide</summary>
                <div class="absolute right-0 mt-2 z-10 w-64 rounded-md border border-kharon-border bg-white p-3 shadow-md text-xs">
                  <ul class="grid gap-1.5">
                    <li><strong>Valid</strong> — current and active.</li>
                    <li><strong>Expired</strong> — past expiry; re-inspection required.</li>
                    <li><strong>Blocked</strong> — cannot be issued due to open Critical/Major defects.</li>
                  </ul>
                </div>
              </details>
            </div>

            <div class="space-y-3">
              {certificates.length === 0 && <p class="text-sm text-kharon-grey italic py-2">No certificates have been issued yet.</p>}
              {certificates.map((item) => (
                <article class="flex items-start justify-between gap-4 p-4 rounded-lg border bg-kharon-light/30" class:list={[
                  item.status === "Valid" ? "border-blue-200 border-l-4 border-l-kharon-blue" :
                  item.status === "Expired" ? "border-red-200 border-l-4 border-l-kharon-red" :
                  item.status === "Blocked" ? "border-amber-200 border-l-4 border-l-kharon-amber" :
                  "border-kharon-border border-l-4 border-l-kharon-grey"
                ]}>
                  <div>
                    <h3 class="font-bold text-sm text-kharon-black">{item.certificate_type}</h3>
                    <p class="text-xs text-kharon-grey mt-0.5">{item.owner_company_name} — {item.coverage_area}</p>
                    <p class="mt-1.5 text-xs text-kharon-grey/85">
                      Issued: {item.issued_date || "N/A"} {item.expiry_date && ` / Expires: ${item.expiry_date}`}
                    </p>
                  </div>
                  <span class={`rounded border px-2.5 py-1 text-xs font-bold uppercase shadow-sm ${
                    item.status === "Valid" ? "border-blue-200 bg-blue-50 text-kharon-blue" :
                    item.status === "Expired" ? "border-red-200 bg-red-50 text-kharon-red" :
                    item.status === "Blocked" ? "border-amber-200 bg-amber-50 text-amber-700" :
                    "border-kharon-border bg-white text-kharon-grey"
                  }`}>{item.status}</span>
                </article>
              ))}
            </div>
          </div>

        </div>

        <!-- ==================== RIGHT / SIDEBAR COLUMN ==================== -->
        <div class="space-y-6">
          
          <!-- Form: Request Maintenance Support -->
          <div class="rounded-xl border border-kharon-border bg-white p-5 shadow-sm">
            <h2 class="text-lg font-bold text-kharon-black">Request Maintenance Support</h2>
            <p class="text-xs text-kharon-grey mt-1">Submit request tied to your sites or systems.</p>
            
            <form id="maintenance-request-form" class="mt-4 space-y-3">
              <div class="grid gap-1">
                <label class="text-[10px] font-bold uppercase text-kharon-grey/70">Target Site</label>
                <select class="portal-field rounded border border-kharon-border bg-white px-3 py-2 text-xs focus:outline-none" name="siteId" required>
                  {sites.map((site) => <option value={site.id}>{site.owner_company_name}</option>)}
                </select>
              </div>

              <div class="grid gap-1">
                <label class="text-[10px] font-bold uppercase text-kharon-grey/70">Target System (Optional)</label>
                <select class="portal-field rounded border border-kharon-border bg-white px-3 py-2 text-xs focus:outline-none" name="systemId">
                  <option value="">General site request</option>
                  {systems.map((system) => <option value={system.id} data-site-id={system.site_id}>{system.owner_company_name} / {system.system_type} / {system.coverage_area}</option>)}
                </select>
              </div>

              <div class="grid gap-1">
                <label class="text-[10px] font-bold uppercase text-kharon-grey/70">Request Type</label>
                <select class="portal-field rounded border border-kharon-border bg-white px-3 py-2 text-xs focus:outline-none" name="requestType" required>
                  <option value="Maintenance">Maintenance</option>
                  <option value="Fault">Fault</option>
                  <option value="Compliance Documentation">Compliance Documentation</option>
                  <option value="Quote Request">Quote Request</option>
                  <option value="Emergency Follow-up">Emergency Follow-up</option>
                </select>
              </div>

              <div class="grid gap-1">
                <label class="text-[10px] font-bold uppercase text-kharon-grey/70">Priority</label>
                <select class="portal-field rounded border border-kharon-border bg-white px-3 py-2 text-xs focus:outline-none" name="priority" required>
                  <option value="Routine">Routine</option>
                  <option value="Urgent">Urgent</option>
                  <option value="Critical">Critical</option>
                </select>
              </div>

              <div class="grid gap-1">
                <label class="text-[10px] font-bold uppercase text-kharon-grey/70">Subject</label>
                <input class="portal-field rounded border border-kharon-border bg-white px-3 py-2 text-xs focus:outline-none" name="subject" maxlength="160" placeholder="e.g., Gas panel low battery light" required />
              </div>

              <div class="grid gap-1">
                <label class="text-[10px] font-bold uppercase text-kharon-grey/70">Requirement Details</label>
                <textarea class="portal-field min-h-24 rounded border border-kharon-border bg-white px-3 py-2 text-xs focus:outline-none" name="message" maxlength="2000" placeholder="Describe the symptom or specific requirements..." required></textarea>
              </div>

              <button class="w-full rounded bg-kharon-purple py-2.5 text-xs font-semibold text-white hover:opacity-90 transition-opacity">Submit Request</button>
              <p id="maintenance-request-result" class="hidden rounded border p-3 text-xs font-semibold"></p>
            </form>
          </div>

          <!-- List: Recent Service Requests -->
          <div class="rounded-xl border border-kharon-border bg-white p-5 shadow-sm">
            <h2 class="text-lg font-bold text-kharon-black">Recent Service Requests</h2>
            
            <div class="mt-4 space-y-3">
              {requests.length === 0 && <p class="text-sm text-kharon-grey italic py-2">No service requests submitted yet.</p>}
              {requests.map((request) => (
                <article class="p-3 rounded-lg border border-kharon-border bg-kharon-light/30">
                  <div class="flex items-start justify-between gap-2">
                    <div>
                      <h3 class="font-bold text-xs text-kharon-black leading-tight">{request.subject}</h3>
                      <p class="text-[10px] text-kharon-grey mt-0.5">{request.owner_company_name}</p>
                    </div>
                    <span class="rounded bg-white border border-kharon-border px-1.5 py-0.5 text-[9px] font-bold uppercase text-kharon-grey">{request.status}</span>
                  </div>
                  {request.linked_job_id && (
                    <p class="mt-2 text-[9px] font-bold uppercase text-kharon-blue">Scheduled Dispatch: {request.linked_job_id}</p>
                  )}
                  <div class="mt-2 flex items-center justify-between text-[9px] text-kharon-grey/80 border-t border-kharon-border/60 pt-2">
                    <span>Priority: <strong>{request.priority}</strong></span>
                    <span>{request.created_at.slice(0, 10)}</span>
                  </div>
                </article>
              ))}
            </div>
          </div>

          <!-- Section: Pending Quote Approvals -->
          <div class="rounded-xl border border-kharon-border bg-white p-5 shadow-sm">
            <div class="flex items-center justify-between border-b border-kharon-border pb-3 mb-3">
              <h2 class="text-lg font-bold text-kharon-black">Quote Approvals</h2>
              <a class="text-xs font-bold text-kharon-purple hover:underline" href="/portal/client/quotes">Ledger →</a>
            </div>

            <div class="space-y-3">
              {quotes.length === 0 && <p class="text-sm text-kharon-grey italic py-1">No pending quotes are awaiting approval.</p>}
              {quotes.map((quote) => (
                <article class="p-3 rounded-lg border border-kharon-border bg-kharon-light/30 flex flex-col justify-between">
                  <div>
                    <h3 class="font-bold text-xs text-kharon-black leading-tight">{quote.reference || quote.id.slice(0, 8)}</h3>
                    <p class="text-[10px] text-kharon-grey mt-0.5">{quote.owner_company_name}</p>
                    <p class="text-xs font-bold text-kharon-purple mt-2">{formatCurrency(quote.amount)}</p>
                  </div>
                  <button class="mt-3 w-full rounded border border-kharon-purple bg-white py-1.5 text-xs font-bold text-kharon-purple hover:bg-kharon-purple hover:text-white transition-colors" data-quote-id={quote.id}>
                    Approve Quote
                  </button>
                </article>
              ))}
            </div>
          </div>

          <!-- Section: Mapped Client Sites -->
          {sites.length > 0 && (
            <div class="rounded-xl border border-kharon-border bg-white p-5 shadow-sm">
              <div class="flex items-center justify-between border-b border-kharon-border pb-3 mb-3">
                <h2 class="text-lg font-bold text-kharon-black">Mapped client sites</h2>
                <a class="text-xs font-bold text-kharon-purple hover:underline" href="/portal/client/quotes">Ledger →</a>
              </div>
              
              <div class="space-y-3">
                {sites.map((site) => (
                  <article class="p-3 rounded-lg border border-kharon-border bg-kharon-light/30">
                    <h3 class="font-bold text-xs text-kharon-black leading-tight">{site.owner_company_name}</h3>
                    <p class="text-[10px] text-kharon-grey mt-1">{site.physical_address}</p>
                    <div class="mt-2 text-[9px] text-kharon-grey/80 border-t border-kharon-border/60 pt-2 flex items-center justify-between">
                      <span>Contact: {site.site_contact_person}</span>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          )}

        </div>

      </div>

    </div>
  </section>

  <script is:inline>
    const requestForm = document.querySelector("#maintenance-request-form");
    const siteSelect = requestForm?.querySelector('select[name="siteId"]');
    const systemSelect = requestForm?.querySelector('select[name="systemId"]');

    function filterSystemsForSite() {
      if (!siteSelect || !systemSelect) return;
      const siteId = siteSelect.value;
      for (const option of systemSelect.options) {
        const optionSiteId = option.getAttribute("data-site-id");
        option.hidden = Boolean(optionSiteId) && optionSiteId !== siteId;
      }
      const selectedSiteId = systemSelect.selectedOptions[0]?.getAttribute("data-site-id");
      if (selectedSiteId && selectedSiteId !== siteId) systemSelect.value = "";
    }

    siteSelect?.addEventListener("change", filterSystemsForSite);
    filterSystemsForSite();

    if (requestForm) {
      requestForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        const result = document.querySelector("#maintenance-request-result");
        const formData = new FormData(requestForm);
        result.classList.add("hidden");

        const response = await window.kharonPortalFetch("/portal/api/maintenance-request", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            siteId: formData.get("siteId"),
            systemId: formData.get("systemId"),
            requestType: formData.get("requestType"),
            priority: formData.get("priority"),
            subject: formData.get("subject"),
            message: formData.get("message")
          })
        });
        const body = await response.json();
        if (!response.ok || !body.ok) {
          result.textContent = body.message || "Request submission failed.";
          result.className = "rounded-md border border-red-300 bg-red-50 px-4 py-3 text-sm font-semibold text-red-900";
          return;
        }

        result.textContent = `Request submitted: ${body.id}`;
        result.className = "rounded-md border border-emerald-300 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-900";
        requestForm.reset();
        filterSystemsForSite();
      });
    }

    for (const button of document.querySelectorAll("[data-quote-id]")) {
      button.addEventListener("click", async () => {
        button.setAttribute("disabled", "true");
        const response = await window.kharonPortalFetch("/portal/api/approve-quote", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ recordId: button.getAttribute("data-quote-id") })
        });
        const result = await response.json();
        if (!response.ok || !result.ok) {
          button.removeAttribute("disabled");
          button.textContent = result.message || "Approval failed";
          button.classList.add("border-red-600", "text-red-700");
          return;
        }
        button.textContent = "Approved";
        button.classList.remove("border-kharon-purple", "text-kharon-purple");
        button.classList.add("border-kharon-blue", "text-kharon-blue");
      });
    }
  </script>
</PortalLayout>
