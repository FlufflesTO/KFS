---
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import { clientSites, inClause } from "../../../lib/server/clientAccess.js";

export const prerender = false;

const user = Astro.locals.user;
let systems = [];
let quotes = [];
let requests = [];
let sites = [];
let openDefects = [];
let certificates = [];
let loadError = "";
const sectionErrors = [];
const today    = new Date().toISOString().slice(0, 10);
const soonDate = new Date(Date.now() + 30 * 86400000).toISOString().slice(0, 10);

try {
  const db = getDatabase();
  sites = await clientSites(db, user);
  const siteIds = sites.map((site) => site.id);
  if (siteIds.length === 0) {
    loadError = "This client account is not mapped to a site.";
  } else {
    const sitePlaceholders = inClause(siteIds);
    try {
      systems = (await db.prepare(
        `SELECT systems.id, systems.site_id, systems.system_type, systems.coverage_area, systems.last_service_date, systems.next_due_date,
                sites.owner_company_name,
                latest_jobs.id AS latest_job_id, latest_jobs.documentation_path, latest_jobs.completed_at
         FROM systems
         INNER JOIN sites ON sites.id = systems.site_id
         LEFT JOIN jobs AS latest_jobs ON latest_jobs.id = (
           SELECT j.id FROM jobs j
           WHERE j.system_id = systems.id AND j.documentation_path IS NOT NULL
           ORDER BY COALESCE(j.completed_at, j.updated_at, j.created_at) DESC
           LIMIT 1
         )
         WHERE systems.site_id IN (${sitePlaceholders})
         ORDER BY sites.owner_company_name ASC, systems.next_due_date ASC`
      ).bind(...siteIds).all()).results || [];
    } catch (error) {
      console.error("client systems load failed", error);
      sectionErrors.push("System records could not be loaded.");
    }

    try {
      quotes = (await db.prepare(
        `SELECT financial_records.id, financial_records.site_id, financial_records.amount,
                financial_records.item_type, financial_records.payment_status,
                financial_records.distribution_date, financial_records.reference,
                sites.owner_company_name
         FROM financial_records
         INNER JOIN sites ON sites.id = financial_records.site_id
         WHERE financial_records.site_id IN (${sitePlaceholders})
           AND financial_records.item_type = 'Quote'
           AND financial_records.payment_status = 'Pending Approval'
         ORDER BY financial_records.distribution_date ASC`
      ).bind(...siteIds).all()).results || [];
    } catch (error) {
      console.error("client quotes load failed", error);
      sectionErrors.push("Quote approvals could not be loaded.");
    }

    try {
      requests = (await db.prepare(
        `SELECT maintenance_requests.id, maintenance_requests.site_id,
                maintenance_requests.request_type, maintenance_requests.priority,
                maintenance_requests.status, maintenance_requests.subject, maintenance_requests.created_at,
                maintenance_requests.linked_job_id, systems.coverage_area, sites.owner_company_name
         FROM maintenance_requests
         INNER JOIN sites ON sites.id = maintenance_requests.site_id
         LEFT JOIN systems ON systems.id = maintenance_requests.system_id
         WHERE maintenance_requests.site_id IN (${sitePlaceholders})
         ORDER BY maintenance_requests.created_at DESC
         LIMIT 8`
      ).bind(...siteIds).all()).results || [];
    } catch (error) {
      console.error("client requests load failed", error);
      sectionErrors.push("Recent service requests could not be loaded.");
    }

    try {
      openDefects = (await db.prepare(
        `SELECT defects.id, defects.severity, defects.sans_clause_ref, defects.status,
                defects.remediation_notes, systems.id AS system_id, systems.system_type,
                systems.coverage_area, sites.owner_company_name
         FROM defects
         INNER JOIN systems ON systems.id = defects.system_id
         INNER JOIN sites ON sites.id = systems.site_id
         WHERE systems.site_id IN (${sitePlaceholders}) AND defects.status IN ('Open', 'In Progress')
         ORDER BY CASE defects.severity WHEN 'Critical' THEN 1 WHEN 'Major' THEN 2 ELSE 3 END,
                  defects.created_at DESC
         LIMIT 10`
      ).bind(...siteIds).all()).results || [];
    } catch (error) {
      console.error("client defects load failed", error);
      sectionErrors.push("Defect register could not be loaded.");
    }

    try {
      certificates = (await db.prepare(
        `SELECT certificates.id, certificates.certificate_type, certificates.status,
                certificates.issued_date, certificates.expiry_date,
                systems.id AS system_id, systems.system_type, systems.coverage_area,
                sites.owner_company_name
         FROM certificates
         INNER JOIN systems ON systems.id = certificates.system_id
         INNER JOIN sites ON sites.id = systems.site_id
         WHERE systems.site_id IN (${sitePlaceholders})
         ORDER BY COALESCE(certificates.expiry_date, certificates.issued_date) DESC
         LIMIT 10`
      ).bind(...siteIds).all()).results || [];
    } catch (error) {
      console.error("client certificates load failed", error);
      sectionErrors.push("Certificate register could not be loaded.");
    }
  }
} catch (error) {
  console.error("client dashboard failed", error);
  loadError = "Client system records could not be loaded.";
}

// Compliance summary counts — computed in frontmatter (< safe in TS, not JSX)
const overdueCount  = systems.filter((s: any) => s.next_due_date && s.next_due_date < today).length;
const dueSoonCount  = systems.filter((s: any) => s.next_due_date && s.next_due_date >= today && s.next_due_date <= soonDate).length;
const compliantCount = systems.filter((s: any) => !s.next_due_date || s.next_due_date > soonDate).length;
---

<PortalLayout title="Client Gateway | Kharon Portal" active="client" user={user}>
  <section class="bg-kharon-black px-4 py-8 text-white sm:px-6 sm:py-10">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-bold uppercase text-kharon-cyan">Client self-service gateway</p>
      <h1 class="mt-3 text-2xl font-bold sm:text-3xl">System status and lifecycle records</h1>
      <p class="mt-4 max-w-3xl text-white/65">Read-only visibility over protected systems, upcoming maintenance dates and completed jobcard records.</p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto grid max-w-7xl gap-6">
      {loadError && <p class="border border-red-300 bg-red-50 p-4 text-red-800">{loadError}</p>}
      {!loadError && sectionErrors.length > 0 && (
        <div class="grid gap-2">
          {sectionErrors.map((message) => <p class="border border-amber-300 bg-amber-50 p-4 text-amber-900">{message}</p>)}
        </div>
      )}

      <div class="flex flex-wrap items-center justify-between gap-3 border border-kharon-border bg-white px-4 py-3">
        <p class="text-sm text-kharon-grey">For live faults, compliance interventions or urgent technical requests:</p>
        <a href="/emergency-support" class="rounded-md bg-kharon-red px-4 py-2 text-sm font-semibold text-white hover:opacity-90">
          Emergency support →
        </a>
      </div>

      {sites.length > 0 && (
        <section class="border border-kharon-border bg-white p-4 sm:p-5">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <p class="text-xs font-bold uppercase text-kharon-purple">Account access</p>
              <h2 class="mt-2 text-xl font-bold">Mapped client sites</h2>
            </div>
            <a class="rounded-md border border-kharon-purple px-4 py-2 text-sm font-semibold text-kharon-purple" href="/portal/client/quotes">
              View quote history
            </a>
          </div>
          <div class="mt-5 grid gap-3 md:grid-cols-2">
            {sites.map((site) => (
              <article class="border-l-4 border-kharon-blue bg-kharon-light p-4">
                <p class="font-semibold">{site.owner_company_name}</p>
                <p class="mt-1 text-sm text-kharon-grey">{site.physical_address}</p>
                <p class="mt-2 text-xs uppercase text-kharon-grey/70">{site.site_contact_person} / {site.site_contact_email || "No email recorded"}</p>
              </article>
            ))}
          </div>
        </section>
      )}

      {systems.length > 0 && (
        <div class="grid grid-cols-3 gap-3 border border-kharon-border bg-white p-4">
          <div class={`border-r border-kharon-border pr-4 ${overdueCount > 0 ? "text-red-900" : "text-kharon-grey"}`}>
            <p class="text-xs font-bold uppercase opacity-70">Overdue</p>
            <p class={`mt-1 text-2xl font-bold ${overdueCount > 0 ? "text-red-700" : ""}`}>{overdueCount}</p>
          </div>
          <div class={`border-r border-kharon-border px-4 ${dueSoonCount > 0 ? "text-amber-900" : "text-kharon-grey"}`}>
            <p class="text-xs font-bold uppercase opacity-70">Due soon</p>
            <p class={`mt-1 text-2xl font-bold ${dueSoonCount > 0 ? "text-amber-700" : ""}`}>{dueSoonCount}</p>
          </div>
          <div class="pl-4 text-kharon-grey">
            <p class="text-xs font-bold uppercase opacity-70">Compliant</p>
            <p class="mt-1 text-2xl font-bold text-kharon-black">{compliantCount}</p>
          </div>
        </div>
      )}

      <div class="flex items-center justify-between gap-3">
        <p class="text-sm font-semibold text-kharon-grey">Protection systems on account</p>
        <a href="/compliance" class="text-xs font-semibold text-kharon-purple hover:underline">Maintenance standards reference →</a>
      </div>

      <div class="grid gap-4 lg:grid-cols-2">
        {systems.map((system) => (
          <article class="border border-kharon-border bg-white p-4 sm:p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <p class="text-xs font-bold uppercase text-kharon-purple">{system.system_type}</p>
                <h2 class="mt-2 text-xl font-bold">{system.coverage_area}</h2>
                <p class="mt-1 text-sm text-kharon-grey">{system.owner_company_name}</p>
              </div>
              <span class={`rounded-md border px-3 py-2 text-xs font-bold uppercase ${
                system.next_due_date && system.next_due_date < today
                  ? "border-red-300 bg-red-50 text-red-900"
                  : system.next_due_date && system.next_due_date <= soonDate
                  ? "border-amber-300 bg-amber-50 text-amber-900"
                  : "border-kharon-border text-kharon-grey"
              }`}>
                {system.next_due_date && system.next_due_date < today ? "Warning: Overdue  -  " : "Due "}{system.next_due_date || "Not scheduled"}
              </span>
            </div>
            <dl class="mt-5 grid gap-3 text-sm sm:grid-cols-2">
              <div><dt class="font-bold uppercase text-kharon-grey/70">Last service</dt><dd>{system.last_service_date || "No service date recorded"}</dd></div>
              <div><dt class="font-bold uppercase text-kharon-grey/70">System ID</dt><dd>{system.id}</dd></div>
            </dl>
            {system.documentation_path ? (
              <a class="mt-5 inline-flex rounded-md bg-kharon-purple px-5 py-3 font-semibold text-white hover:bg-kharon-blue" href={`/portal/api/file/${system.documentation_path}`}>
                Download latest jobcard
              </a>
            ) : (
              <p class="mt-5 text-sm text-kharon-grey">No completed jobcard document is linked yet.</p>
            )}
          </article>
        ))}
      </div>

      <section class="border border-kharon-border bg-white p-4 sm:p-5">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <h2 class="text-xl font-bold">Pending quote approvals</h2>
          <a class="text-sm font-semibold text-kharon-purple" href="/portal/client/quotes">Open full quote ledger</a>
        </div>
        <div class="mt-5 grid gap-3">
          {quotes.length === 0 && <p class="text-kharon-grey">No pending quotes are awaiting approval.</p>}
          {quotes.map((quote) => (
            <article class="flex flex-wrap items-center justify-between gap-4 border border-kharon-border bg-kharon-light p-4">
              <div>
                <p class="font-semibold">{quote.reference || quote.id}</p>
                <p class="text-sm text-kharon-grey">{quote.owner_company_name} / R {Number(quote.amount).toFixed(2)} / {quote.distribution_date}</p>
              </div>
              <button class="rounded-md border border-kharon-purple px-5 py-3 font-semibold text-kharon-purple" data-quote-id={quote.id}>
                Approve quote
              </button>
            </article>
          ))}
        </div>
      </section>

      <section class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
        <article class="border border-kharon-border bg-white p-4 sm:p-5">
          <h2 class="text-xl font-bold">Request maintenance support</h2>
          <p class="mt-2 text-sm text-kharon-grey">Submit operational requests tied to this client account and site.</p>
          <form id="maintenance-request-form" class="mt-5 grid gap-3">
            <select class="portal-field rounded-md border border-kharon-border px-4 py-3" name="siteId" required>
              {sites.map((site) => <option value={site.id}>{site.owner_company_name}</option>)}
            </select>
            <select class="portal-field rounded-md border border-kharon-border px-4 py-3" name="systemId">
              <option value="">General site request</option>
              {systems.map((system) => <option value={system.id} data-site-id={system.site_id}>{system.owner_company_name} / {system.system_type} / {system.coverage_area}</option>)}
            </select>
            <select class="portal-field rounded-md border border-kharon-border px-4 py-3" name="requestType" required>
              <option value="Maintenance">Maintenance</option>
              <option value="Fault">Fault</option>
              <option value="Compliance Documentation">Compliance Documentation</option>
              <option value="Quote Request">Quote Request</option>
              <option value="Emergency Follow-up">Emergency Follow-up</option>
            </select>
            <select class="portal-field rounded-md border border-kharon-border px-4 py-3" name="priority" required>
              <option value="Routine">Routine</option>
              <option value="Urgent">Urgent</option>
              <option value="Critical">Critical</option>
            </select>
            <input class="portal-field rounded-md border border-kharon-border px-4 py-3" name="subject" maxlength="160" placeholder="Request subject" required />
            <textarea class="portal-field min-h-28 rounded-md border border-kharon-border px-4 py-3" name="message" maxlength="2000" placeholder="Describe the requirement, fault symptoms, documentation need or preferred timing." required></textarea>
            <button class="rounded-md bg-kharon-purple px-5 py-3 font-semibold text-white hover:bg-kharon-blue">Submit request</button>
            <p id="maintenance-request-result" class="hidden rounded-md border px-4 py-3 text-sm font-semibold"></p>
          </form>
        </article>

        <article class="border border-kharon-border bg-white p-4 sm:p-5">
          <h2 class="text-xl font-bold">Recent service requests</h2>
          <div class="mt-5 grid gap-3">
            {requests.length === 0 && <p class="text-kharon-grey">No client maintenance requests have been submitted.</p>}
            {requests.map((request) => (
              <article class="border-l-4 border-kharon-blue bg-kharon-light p-4">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div>
                    <p class="font-semibold">{request.subject}</p>
                    <p class="text-sm text-kharon-grey">{request.owner_company_name} / {request.request_type} / {request.coverage_area || "General site request"}</p>
                    {request.linked_job_id && <p class="mt-1 text-xs font-bold uppercase text-kharon-blue">Scheduled dispatch: {request.linked_job_id}</p>}
                  </div>
                  <span class="rounded-md border border-kharon-border px-3 py-2 text-xs font-bold uppercase text-kharon-grey">{request.status}</span>
                </div>
                <p class="mt-2 text-xs uppercase text-kharon-grey/70">{request.priority} / {request.created_at}</p>
              </article>
            ))}
          </div>
        </article>
      </section>

      <section class="grid gap-6 lg:grid-cols-2">
        <article class="border border-kharon-border bg-white p-4 sm:p-5">
          <h2 class="text-xl font-bold">Open defects</h2>
          <p class="mt-2 text-sm text-kharon-grey">Recorded defects tied to your systems that require remediation.</p>
          <details class="mt-3 text-xs text-kharon-grey">
            <summary class="cursor-pointer font-semibold text-kharon-purple">What do defect statuses mean?</summary>
            <ul class="mt-2 grid gap-1 pl-4">
              <li><strong>Open</strong> — defect recorded; remediation or quote pending.</li>
              <li><strong>In Progress</strong> — remediation work has started.</li>
              <li><strong>Resolved</strong> — defect has been remediated; awaiting verification.</li>
              <li><strong>Closed</strong> — defect confirmed resolved or no longer applicable.</li>
            </ul>
          </details>
          <div class="mt-5 grid gap-3">
            {openDefects.length === 0 && <p class="text-kharon-grey">No open defects are recorded for your systems.</p>}
            {openDefects.map((item) => (
              <article class="border-l-4 bg-kharon-light p-4" class:list={[
                item.severity === "Critical" ? "border-kharon-red" : item.severity === "Major" ? "border-amber-500" : "border-kharon-grey"
              ]}>
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div>
                    <p class="font-semibold">{item.owner_company_name} / {item.system_type}</p>
                    <p class="text-sm text-kharon-grey">{item.coverage_area}</p>
                    {item.sans_clause_ref && <p class="mt-1 text-xs text-kharon-grey">SANS clause: {item.sans_clause_ref}</p>}
                  </div>
                  <span class={`rounded-md border px-2 py-1 text-xs font-bold uppercase ${
                    item.severity === "Critical" ? "border-kharon-red bg-red-50 text-kharon-red" :
                    item.severity === "Major" ? "border-amber-500 bg-amber-50 text-amber-700" :
                    "border-kharon-border text-kharon-grey"
                  }`}>{item.severity} / {item.status}</span>
                </div>
              </article>
            ))}
          </div>
        </article>

        <article class="border border-kharon-border bg-white p-4 sm:p-5">
          <h2 class="text-xl font-bold">Certificate register</h2>
          <p class="mt-2 text-sm text-kharon-grey">Compliance certificates linked to your protected systems.</p>
          <details class="mt-3 text-xs text-kharon-grey">
            <summary class="cursor-pointer font-semibold text-kharon-purple">What do certificate statuses mean?</summary>
            <ul class="mt-2 grid gap-1 pl-4">
              <li><strong>Valid</strong> — current and active; expires on the listed date.</li>
              <li><strong>Expired</strong> — past expiry date; re-inspection required.</li>
              <li><strong>Revoked</strong> — withdrawn by Kharon; contact your administrator.</li>
              <li><strong>Blocked</strong> — cannot be issued while open certificate-blocking defects remain.</li>
            </ul>
          </details>
          <div class="mt-5 grid gap-3">
            {certificates.length === 0 && <p class="text-kharon-grey">No certificates have been issued yet.</p>}
            {certificates.map((item) => (
              <article class="border-l-4 bg-kharon-light p-4" class:list={[
                item.status === "Valid" ? "border-kharon-blue" :
                item.status === "Expired" ? "border-kharon-red" :
                item.status === "Blocked" ? "border-amber-500" : "border-kharon-grey"
              ]}>
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div>
                    <p class="font-semibold">{item.certificate_type}</p>
                    <p class="text-sm text-kharon-grey">{item.owner_company_name} / {item.coverage_area}</p>
                    <p class="mt-1 text-xs text-kharon-grey">
                      Issued: {item.issued_date || "N/A"}{item.expiry_date && ` / Expires: ${item.expiry_date}`}
                    </p>
                  </div>
                  <span class={`rounded-md border px-2 py-1 text-xs font-bold uppercase ${
                    item.status === "Valid" ? "border-kharon-blue bg-blue-50 text-kharon-blue" :
                    item.status === "Expired" ? "border-kharon-red bg-red-50 text-kharon-red" :
                    item.status === "Blocked" ? "border-amber-500 bg-amber-50 text-amber-700" :
                    "border-kharon-border text-kharon-grey"
                  }`}>{item.status}</span>
                </div>
              </article>
            ))}
          </div>
        </article>
      </section>
    </div>
  </section>

  <script is:inline>
    const requestForm = document.querySelector("#maintenance-request-form");
    const siteSelect = requestForm?.querySelector('select[name="siteId"]');
    const systemSelect = requestForm?.querySelector('select[name="systemId"]');

    function filterSystemsForSite() {
      if (!siteSelect || !systemSelect) return;
      const siteId = siteSelect.value;
      for (const option of systemSelect.options) {
        const optionSiteId = option.getAttribute("data-site-id");
        option.hidden = Boolean(optionSiteId) && optionSiteId !== siteId;
      }
      const selectedSiteId = systemSelect.selectedOptions[0]?.getAttribute("data-site-id");
      if (selectedSiteId && selectedSiteId !== siteId) systemSelect.value = "";
    }

    siteSelect?.addEventListener("change", filterSystemsForSite);
    filterSystemsForSite();

    if (requestForm) {
      requestForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        const result = document.querySelector("#maintenance-request-result");
        const formData = new FormData(requestForm);
        result.classList.add("hidden");

        const response = await window.kharonPortalFetch("/portal/api/maintenance-request", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            siteId: formData.get("siteId"),
            systemId: formData.get("systemId"),
            requestType: formData.get("requestType"),
            priority: formData.get("priority"),
            subject: formData.get("subject"),
            message: formData.get("message")
          })
        });
        const body = await response.json();
        if (!response.ok || !body.ok) {
          result.textContent = body.message || "Request submission failed.";
          result.className = "rounded-md border border-red-300 bg-red-50 px-4 py-3 text-sm font-semibold text-red-900";
          return;
        }

        result.textContent = `Request submitted: ${body.id}`;
        result.className = "rounded-md border border-emerald-300 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-900";
        requestForm.reset();
        filterSystemsForSite();
      });
    }

    for (const button of document.querySelectorAll("[data-quote-id]")) {
      button.addEventListener("click", async () => {
        button.setAttribute("disabled", "true");
        const response = await window.kharonPortalFetch("/portal/api/approve-quote", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ recordId: button.getAttribute("data-quote-id") })
        });
        const result = await response.json();
        if (!response.ok || !result.ok) {
          button.removeAttribute("disabled");
          button.textContent = result.message || "Approval failed";
          button.classList.add("border-red-600", "text-red-700");
          return;
        }
        button.textContent = "Approved";
        button.classList.remove("border-kharon-purple", "text-kharon-purple");
        button.classList.add("border-kharon-blue", "text-kharon-blue");
      });
    }
  </script>
</PortalLayout>
