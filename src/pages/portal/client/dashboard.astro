---
/**
 * Client Portal Landing Hub
 * Summary-level overview with navigation to detail pages.
 * No inline data lists — counts and heatmap only.
 */
import { auditError } from "../../../lib/server/audit.js";
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import { clientSites, inClause } from "../../../lib/server/access.ts";
import { formatCurrency } from "../../../lib/utils/financial-utils.ts";
import KharonButton from "../../../components/ui/KharonButton.astro";
import DashboardFeatureCard from "../../../components/portal/DashboardFeatureCard.astro";
import ComplianceHeatmap, { type SiteStatus } from "../../../components/portal/ComplianceHeatmap.astro";

export const prerender = false;

const user = Astro.locals.user;

interface SiteAggregate {
  id: string;
  owner_company_name: string;
  system_count: number;
  overdue_count: number;
  due_soon_count: number;
  defect_count: number;
  critical_count: number;
}

interface QuoteSummary {
  pending_count: number;
  pending_amount: number;
}

let sites: Array<any> = [];
let siteAggregates: SiteAggregate[] = [];
let pendingQuoteCount = 0;
let pendingQuoteAmount = 0;
let openRequestCount = 0;
let loadError = "";

const today    = new Date().toISOString().slice(0, 10);
const soonDate = new Date(Date.now() + 30 * 86400000).toISOString().slice(0, 10);

try {
  const db = getDatabase();
  sites = await clientSites(db, user);
  const siteIds = sites.map((s: any) => s.id);

  if (siteIds.length === 0) {
    loadError = "This client account is not mapped to a site.";
  } else {
    const sp = inClause(siteIds);

    try {
      const [aggResult, quoteResult, requestResult] = await db.batch([
        // Per-site aggregate for heatmap + overall stats
        db.prepare(
          `SELECT sites.id, sites.owner_company_name,
                  COUNT(DISTINCT s.id) AS system_count,
                  COUNT(DISTINCT CASE WHEN s.next_due_date < ? THEN s.id END) AS overdue_count,
                  COUNT(DISTINCT CASE WHEN s.next_due_date >= ? AND s.next_due_date <= ? THEN s.id END) AS due_soon_count,
                  COUNT(DISTINCT d.id) AS defect_count,
                  COUNT(DISTINCT CASE WHEN d.severity IN ('Critical', 'Major') THEN d.id END) AS critical_count
           FROM sites
           LEFT JOIN systems s ON s.site_id = sites.id AND s.deleted_at IS NULL
           LEFT JOIN defects d ON d.system_id = s.id AND d.deleted_at IS NULL
             AND d.status IN ('Open', 'In Progress')
           WHERE sites.id IN (${sp})
           GROUP BY sites.id, sites.owner_company_name`
        ).bind(today, today, soonDate, ...siteIds),

        // Pending quotes
        db.prepare(
          `SELECT COUNT(*) AS pending_count,
                  COALESCE(SUM(amount), 0) AS pending_amount
           FROM financial_records
           WHERE site_id IN (${sp})
             AND item_type = 'Quote' AND payment_status = 'Pending Approval'`
        ).bind(...siteIds),

        // Open/In-progress service requests
        db.prepare(
          `SELECT COUNT(*) AS cnt
           FROM maintenance_requests
           WHERE site_id IN (${sp})
             AND status NOT IN ('Closed', 'Resolved')`
        ).bind(...siteIds),
      ]);

      siteAggregates = (aggResult.results || []) as unknown as SiteAggregate[];
      const qs = (quoteResult.results[0] ?? {}) as Partial<QuoteSummary>;
      pendingQuoteCount  = Number(qs.pending_count  ?? 0);
      pendingQuoteAmount = Number(qs.pending_amount ?? 0);
      openRequestCount   = Number((requestResult.results[0] as any)?.cnt ?? 0);
    } catch (err) {
      await auditError(getDatabase(), Astro.request, err, { entityType: "system", entityId: "client_dashboard" });
      loadError = "Dashboard summary could not be loaded.";
    }
  }
} catch (err) {
  await auditError(getDatabase(), Astro.request, err, { entityType: "system", entityId: "client_dashboard" });
  loadError = "Dashboard could not be loaded.";
}

// Derive overall stats from site aggregates
const totalSystems    = siteAggregates.reduce((n, s) => n + s.system_count, 0);
const overdueCount    = siteAggregates.reduce((n, s) => n + s.overdue_count, 0);
const dueSoonCount    = siteAggregates.reduce((n, s) => n + s.due_soon_count, 0);
const totalDefects    = siteAggregates.reduce((n, s) => n + s.defect_count, 0);
const criticalDefects = siteAggregates.reduce((n, s) => n + s.critical_count, 0);
const compliantCount  = totalSystems - overdueCount;
const compliancePercentage = totalSystems > 0 ? Math.round((compliantCount / totalSystems) * 100) : 100;

// SVG gauge
const radius = 28;
const stroke = 5;
const circumference = 2 * Math.PI * radius;
const strokeDashoffset = circumference - (compliancePercentage / 100) * circumference;

// Heatmap data from per-site aggregates
const siteStatuses: SiteStatus[] = siteAggregates.map(site => {
  const isOverdue  = site.overdue_count > 0;
  const isCritical = site.critical_count > 0;
  const isDueSoon  = site.due_soon_count > 0;

  let status: "red" | "amber" | "green" = "green";
  let reason = "Compliant";

  if (isOverdue || isCritical) {
    status = "red";
    reason = isOverdue ? "Maintenance Overdue" : "Critical Defect";
  } else if (isDueSoon || site.defect_count > 0) {
    status = "amber";
    reason = isDueSoon ? "Due Soon" : "Minor Defects";
  }

  return { id: site.id, name: site.owner_company_name, status, reason };
});
---

<PortalLayout title="Client Portal | Kharon" active="client" user={user}>

  {/* ── Page Header ── */}
  <section class="bg-gradient-to-br from-kharon-black to-kharon-charcoal px-4 py-8 text-white sm:px-6 sm:py-10 rounded-xl border border-kharon-purple/10 mb-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_80%_50%,rgba(75,46,131,0.08),transparent)]"></div>
    <div class="relative z-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-kharon-purple/10 ring-1 ring-kharon-purple/20">
          <svg class="h-[1.1rem] w-[1.1rem] text-kharon-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
        </div>
        <p class="text-xs font-black uppercase tracking-[0.2em] text-kharon-cyan">Client Portal</p>
      </div>
      <h1 class="text-2xl font-black sm:text-3xl tracking-tight">
        Welcome{user?.name ? `, ${user.name.split(" ")[0]}` : ""}
      </h1>
      <p class="mt-2 max-w-2xl text-sm text-white/60">Your Kharon portal — system health, compliance status and service records at a glance.</p>
    </div>
  </section>

  <div class="px-1 sm:px-4 space-y-6 pb-10">
    <div class="mx-auto max-w-7xl space-y-6">

      {loadError && <p class="rounded-lg border border-kharon-red/40 bg-kharon-red/10 px-4 py-3 text-sm font-semibold text-kharon-red">{loadError}</p>}

      {/* ── Pending Quotes Action Strip ── approve via /portal/api/approve-quote; documents via /portal/api/file/ ── */}
      {pendingQuoteCount > 0 && (
        <div class="flex flex-wrap items-center justify-between gap-4 rounded-xl border border-kharon-amber/30 bg-kharon-amber/5 px-5 py-4 relative overflow-hidden">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_90%_50%,rgba(245,158,11,0.05),transparent)]"></div>
          <div class="relative z-10">
            <p class="text-sm font-black text-kharon-amber uppercase tracking-wider">
              {pendingQuoteCount === 1 ? "1 Quote" : `${pendingQuoteCount} Quotes`} Pending Your Approval
            </p>
            <p class="text-xs text-white/60 mt-0.5">
              Total value: <span class="font-bold text-white/80">{formatCurrency(pendingQuoteAmount)}</span> — action required before invoicing can proceed.
            </p>
          </div>
          <KharonButton href="/portal/client/quotes?filter=pending" variant="command" size="md" className="relative z-10 text-xs font-bold tracking-widest uppercase shrink-0">Review &amp; Approve →</KharonButton>
        </div>
      )}

      {/* ── Feature Navigation ── */}
      <div>
        <h2 class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple/80 mb-3 px-0.5">Functions</h2>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
          <DashboardFeatureCard
            title="System Register"
            description="All protected systems, maintenance dates and completed jobcard records."
            href="/portal/client/systems"
            iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`}
            badge={overdueCount > 0 ? `${overdueCount} overdue` : undefined}
            badgeVariant="danger"
          />
          <DashboardFeatureCard
            title="Quotes &amp; Approvals"
            description="Review, approve or decline outstanding service quotes."
            href="/portal/client/quotes"
            iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />`}
            badge={pendingQuoteCount > 0 ? pendingQuoteCount : undefined}
            badgeVariant="warning"
          />
          <DashboardFeatureCard
            title="Maintenance Requests"
            description="Log new requests or report urgent site issues."
            href="/portal/client/maintenance-request"
            iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />`}
            badge={openRequestCount > 0 ? openRequestCount : undefined}
            badgeVariant="default"
          />
          <DashboardFeatureCard
            title="Compliance Dashboard"
            description="SANS compliance status, defect tracking and certificate register."
            href="/portal/client/compliance-dashboard"
            iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />`}
            badge={criticalDefects > 0 ? `${criticalDefects} critical` : totalDefects > 0 ? totalDefects : undefined}
            badgeVariant={criticalDefects > 0 ? "danger" : "warning"}
          />
        </div>
      </div>

      {/* ── Portfolio Health Stats ── */}
      {totalSystems > 0 && (
        <div>
          <h2 class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple/80 mb-3 px-0.5">Portfolio Overview</h2>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            <div class={`rounded-xl border p-5 shadow-xl relative overflow-hidden ${overdueCount > 0 ? "border-kharon-red/30 bg-kharon-charcoal/80" : "border-kharon-purple/20 bg-kharon-charcoal/60"}`}>
              <span class="text-[10px] font-bold uppercase tracking-widest text-white/60 block">Overdue</span>
              <div class="flex items-baseline gap-2 mt-2">
                <span class={`text-3xl font-black tracking-tight ${overdueCount > 0 ? "text-kharon-red" : "text-white"}`}>{overdueCount}</span>
                <span class="text-[9px] text-white/40 uppercase font-mono">systems</span>
              </div>
              {overdueCount > 0 && (
                <a href="/portal/client/systems" class="mt-3 text-[10px] font-bold uppercase tracking-widest text-kharon-red/70 hover:text-kharon-red transition-colors block">View →</a>
              )}
            </div>

            <div class={`rounded-xl border p-5 shadow-xl relative overflow-hidden ${dueSoonCount > 0 ? "border-kharon-amber/30 bg-kharon-charcoal/80" : "border-kharon-purple/20 bg-kharon-charcoal/60"}`}>
              <span class="text-[10px] font-bold uppercase tracking-widest text-white/60 block">Due ≤ 30 Days</span>
              <div class="flex items-baseline gap-2 mt-2">
                <span class={`text-3xl font-black tracking-tight ${dueSoonCount > 0 ? "text-kharon-amber" : "text-white"}`}>{dueSoonCount}</span>
                <span class="text-[9px] text-white/40 uppercase font-mono">systems</span>
              </div>
              {dueSoonCount > 0 && (
                <a href="/portal/client/systems" class="mt-3 text-[10px] font-bold uppercase tracking-widest text-kharon-amber/70 hover:text-kharon-amber transition-colors block">View →</a>
              )}
            </div>

            <div class={`rounded-xl border p-5 shadow-xl relative overflow-hidden ${criticalDefects > 0 ? "border-kharon-red/30 bg-kharon-charcoal/80" : totalDefects > 0 ? "border-kharon-amber/30 bg-kharon-charcoal/80" : "border-kharon-purple/20 bg-kharon-charcoal/60"}`}>
              <span class="text-[10px] font-bold uppercase tracking-widest text-white/60 block">Open Defects</span>
              <div class="flex items-baseline gap-2 mt-2">
                <span class={`text-3xl font-black tracking-tight ${criticalDefects > 0 ? "text-kharon-red" : totalDefects > 0 ? "text-kharon-amber" : "text-white"}`}>{totalDefects}</span>
                {criticalDefects > 0 && <span class="text-[9px] font-black text-kharon-red bg-kharon-red/10 border border-kharon-red/20 px-2 py-0.5 rounded uppercase tracking-wider">{criticalDefects} critical</span>}
              </div>
              {totalDefects > 0 && (
                <a href="/portal/client/compliance-dashboard" class="mt-3 text-[10px] font-bold uppercase tracking-widest text-kharon-purple/60 hover:text-kharon-cyan transition-colors block">View →</a>
              )}
            </div>

            <div class="rounded-xl border border-kharon-purple/20 bg-kharon-charcoal/80 p-5 shadow-xl relative overflow-hidden flex items-center justify-between">
              <div>
                <span class="text-[10px] font-bold uppercase tracking-widest text-white/60 block">Portfolio Health</span>
                <div class="flex items-baseline gap-1 mt-2">
                  <span class="text-3xl font-black text-kharon-cyan tracking-tight">{compliancePercentage}%</span>
                </div>
                <span class="text-[9px] text-white/40 uppercase font-mono tracking-widest">{compliantCount}/{totalSystems} on schedule</span>
              </div>
              <div class="relative flex items-center justify-center h-16 w-16 shrink-0">
                <svg class="w-full h-full transform -rotate-90">
                  <circle cx="32" cy="32" r={radius} stroke="rgba(75, 46, 131, 0.15)" stroke-width={stroke} fill="transparent" />
                  <circle cx="32" cy="32" r={radius} stroke="var(--color-kharon-cyan)" stroke-width={stroke} fill="transparent"
                    stroke-dasharray={circumference} stroke-dashoffset={strokeDashoffset} stroke-linecap="round" />
                </svg>
                <div class="absolute text-[10px] font-black text-white">{compliantCount}/{totalSystems}</div>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* ── Compliance Heatmap ── */}
      {siteStatuses.length > 1 && (
        <div>
          <div class="flex items-center justify-between mb-3">
            <h2 class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple/80">Mapped client sites</h2>
            <span class="text-[10px] text-white/40 uppercase font-mono">{siteStatuses.length} sites</span>
          </div>
          <ComplianceHeatmap sites={siteStatuses} />
        </div>
      )}

      {/* ── Emergency Support ── */}
      <div class="flex flex-wrap items-center justify-between gap-4 border border-kharon-red/30 border-l-4 border-l-kharon-red bg-kharon-red/5 px-4 py-4 rounded-xl shadow-lg relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_90%_50%,rgba(196,51,47,0.05),transparent)]"></div>
        <div class="relative z-10">
          <p class="text-sm font-black text-kharon-red uppercase tracking-wider">Urgent Technical Intervention Required?</p>
          <p class="text-xs text-white/70 mt-1">For live faults, compliance blockages or emergency support:</p>
        </div>
        <KharonButton href="/emergency-support" variant="danger" size="md" className="relative z-10 text-xs font-bold tracking-widest uppercase">Emergency support →</KharonButton>
      </div>

    </div>
  </div>
</PortalLayout>
