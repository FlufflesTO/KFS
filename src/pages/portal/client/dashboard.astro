---
import { auditError } from "../../../lib/server/audit.js";
/**
 * Project Sentinel - Portal Client Dashboard
 * Purpose: Provides gateway dashboard for clients to view systems, defects, certs, and request support
 * Dependencies: PortalLayout, bindings, clientAccess, financial-utils, KharonCard, KharonButton
 * Structural Role: Client gateway main view
 */
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import { clientSites, inClause } from "../../../lib/server/access.ts";
import { formatCurrency } from "../../../lib/utils/financial-utils.ts";
import KharonCard from "../../../components/ui/KharonCard.astro";
import KharonButton from "../../../components/ui/KharonButton.astro";

export const prerender = false;

const user = Astro.locals.user;
interface ClientSystem {
  id: string;
  site_id: string;
  system_type: string;
  coverage_area: string;
  last_service_date: string | null;
  next_due_date: string;
  owner_company_name: string;
  latest_job_id: string | null;
  documentation_path: string | null;
  completed_at: string | null;
}

interface ClientQuote {
  id: string;
  site_id: string;
  amount: number;
  item_type: string;
  payment_status: string;
  distribution_date: string;
  reference: string | null;
  owner_company_name: string;
}

let systems: ClientSystem[] = [];
let quotes: ClientQuote[] = [];
let requests: Array<any> = [];
let sites: Array<any> = [];
let openDefects: Array<any> = [];
let certificates: Array<any> = [];
let loadError = "";
const sectionErrors: string[] = [];
const today    = new Date().toISOString().slice(0, 10);
const soonDate = new Date(Date.now() + 30 * 86400000).toISOString().slice(0, 10);

try {
  const db = getDatabase();
  sites = await clientSites(db, user);
  const siteIds = sites.map((site) => site.id);
  if (siteIds.length === 0) {
    loadError = "This client account is not mapped to a site.";
  } else {
    const sitePlaceholders = inClause(siteIds);
    try {
      systems = (await db.prepare(
        `SELECT systems.id, systems.site_id, systems.system_type, systems.coverage_area, systems.last_service_date, systems.next_due_date,
                sites.owner_company_name,
                latest_jobs.id AS latest_job_id, latest_jobs.documentation_path, latest_jobs.completed_at
         FROM systems
         INNER JOIN sites ON sites.id = systems.site_id
         LEFT JOIN jobs AS latest_jobs ON latest_jobs.id = (
           SELECT j.id FROM jobs j
           WHERE j.deleted_at IS NULL AND j.system_id = systems.id AND j.documentation_path IS NOT NULL
           ORDER BY COALESCE(j.completed_at, j.updated_at, j.created_at) DESC
           LIMIT 1
         )
         WHERE systems.deleted_at IS NULL AND systems.site_id IN (${sitePlaceholders})
         ORDER BY sites.owner_company_name ASC, systems.next_due_date ASC`
      ).bind(...siteIds).all()).results as unknown as ClientSystem[] || [];
    } catch (error) {
      await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "client_systems" });
      sectionErrors.push("System records could not be loaded.");
    }

    try {
      quotes = (await db.prepare(
        `SELECT financial_records.id, financial_records.site_id, financial_records.amount,
                financial_records.item_type, financial_records.payment_status,
                financial_records.distribution_date, financial_records.reference,
                sites.owner_company_name
         FROM financial_records
         INNER JOIN sites ON sites.id = financial_records.site_id
         WHERE financial_records.site_id IN (${sitePlaceholders})
           AND financial_records.item_type = 'Quote'
           AND financial_records.payment_status = 'Pending Approval'
         ORDER BY financial_records.distribution_date ASC`
      ).bind(...siteIds).all()).results as unknown as ClientQuote[] || [];
    } catch (error) {
      await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "client_quotes" });
      sectionErrors.push("Quote approvals could not be loaded.");
    }

    try {
      requests = (await db.prepare(
        `SELECT maintenance_requests.id, maintenance_requests.site_id,
                maintenance_requests.request_type, maintenance_requests.priority,
                maintenance_requests.status, maintenance_requests.subject, maintenance_requests.created_at,
                maintenance_requests.linked_job_id, systems.coverage_area, sites.owner_company_name
         FROM maintenance_requests
         INNER JOIN sites ON sites.id = maintenance_requests.site_id
         LEFT JOIN systems ON systems.id = maintenance_requests.system_id AND systems.deleted_at IS NULL
         WHERE maintenance_requests.site_id IN (${sitePlaceholders})
         ORDER BY maintenance_requests.created_at DESC
         LIMIT 8`
      ).bind(...siteIds).all()).results || [];
    } catch (error) {
      await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "client_requests" });
      sectionErrors.push("Recent service requests could not be loaded.");
    }

    try {
      openDefects = (await db.prepare(
        `SELECT defects.id, defects.severity, defects.sans_clause_ref, defects.status,
                defects.remediation_notes, systems.id AS system_id, systems.system_type,
                systems.coverage_area, sites.owner_company_name
         FROM defects
         INNER JOIN systems ON systems.id = defects.system_id
         INNER JOIN sites ON sites.id = systems.site_id
         WHERE defects.deleted_at IS NULL AND systems.deleted_at IS NULL
           AND systems.site_id IN (${sitePlaceholders}) AND defects.status IN ('Open', 'In Progress')
         ORDER BY CASE defects.severity WHEN 'Critical' THEN 1 WHEN 'Major' THEN 2 ELSE 3 END,
                  defects.created_at DESC
         LIMIT 10`
      ).bind(...siteIds).all()).results || [];
    } catch (error) {
      await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "client_defects" });
      sectionErrors.push("Defect register could not be loaded.");
    }

    try {
      certificates = (await db.prepare(
        `SELECT certificates.id, certificates.certificate_type, certificates.status,
                certificates.issued_date, certificates.expiry_date,
                systems.id AS system_id, systems.system_type, systems.coverage_area,
                sites.owner_company_name
         FROM certificates
         INNER JOIN systems ON systems.id = certificates.system_id
         INNER JOIN sites ON sites.id = systems.site_id
         WHERE certificates.deleted_at IS NULL AND systems.deleted_at IS NULL
           AND systems.site_id IN (${sitePlaceholders})
         ORDER BY COALESCE(certificates.expiry_date, certificates.issued_date) DESC
         LIMIT 10`
      ).bind(...siteIds).all()).results || [];
    } catch (error) {
      await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "client_certificates" });
      sectionErrors.push("Certificate register could not be loaded.");
    }
  }
} catch (error) {
  await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "client_dashboard" });
  loadError = "Client system records could not be loaded.";
}

// Compliance summary counts — computed in frontmatter (< safe in TS, not JSX)
const overdueCount  = systems.filter((s) => s.next_due_date && s.next_due_date < today).length;
const dueSoonCount  = systems.filter((s) => s.next_due_date && s.next_due_date >= today && s.next_due_date <= soonDate).length;
const compliantCount = systems.filter((s) => !s.next_due_date || s.next_due_date > soonDate).length;
import ComplianceHeatmap, { type SiteStatus } from "../../../components/portal/ComplianceHeatmap.astro";

const siteStatuses: SiteStatus[] = sites.map(site => {
  const siteSystems = systems.filter(s => s.site_id === site.id);
  const siteDefects = openDefects.filter(d => d.site_id === site.id);

  const isOverdue = siteSystems.some(s => s.next_due_date && s.next_due_date < today);
  const isCritical = siteDefects.some(d => d.severity === 'Critical' || d.severity === 'Major');
  const isDueSoon = siteSystems.some(s => s.next_due_date && s.next_due_date >= today && s.next_due_date <= soonDate);

  let status: 'red' | 'amber' | 'green' = 'green';
  let reason = 'Compliant';

  if (isOverdue || isCritical) {
    status = 'red';
    reason = isOverdue ? 'Maintenance Overdue' : 'Critical Defect';
  } else if (isDueSoon || siteDefects.length > 0) {
    status = 'amber';
    reason = isDueSoon ? 'Due Soon' : 'Minor Defects';
  }

  return { id: site.id, name: site.owner_company_name, status, reason };
});
---

<PortalLayout title="Client Gateway | Kharon Portal" active="client" user={user}>
  <section class="bg-gradient-to-r from-[#0B0D0F] to-[#1A1F26] px-4 py-10 text-white sm:px-6 sm:py-12 shadow-inner">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-bold uppercase tracking-wider text-kharon-purple">Client self-service gateway</p>
      <h1 class="mt-2 text-2xl font-bold sm:text-3xl tracking-tight">System status and lifecycle records</h1>
      <p class="mt-3 max-w-3xl text-sm text-white/60">Read-only visibility over protected systems, upcoming maintenance dates and completed jobcard records.</p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto max-w-7xl">
      {loadError && <p class="rounded border border-kharon-red/40 bg-kharon-red/10 px-4 py-3 text-sm font-semibold text-kharon-red mb-6">{loadError}</p>}
      {!loadError && sectionErrors.length > 0 && (
        <div class="grid gap-2 mb-6">
          {sectionErrors.map((message) => <p class="border border-amber-300 bg-amber-50 p-4 text-amber-900">{message}</p>)}
        </div>
      )}

      {/* Compliance Heatmap */}
      {siteStatuses.length > 1 && (
        <div class="mb-10">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-sm font-bold uppercase tracking-widest text-white/70">Portfolio Compliance Heatmap</h2>
            <span class="text-[0.65rem] text-white/40 uppercase font-mono">{siteStatuses.length} sites tracked</span>
          </div>
          <ComplianceHeatmap sites={siteStatuses} />
        </div>
      )}

      {/* Emergency Support Alert */}
      <div class="flex flex-wrap items-center justify-between gap-4 border border-red-200 border-l-4 border-l-kharon-red bg-red-50/50 px-4 py-3 mb-6 rounded-lg shadow-sm">
        <div>
          <p class="text-sm font-bold text-kharon-red">Urgent Technical Intervention Required?</p>
          <p class="text-xs text-kharon-grey mt-0.5">For live faults, compliance blockages, or emergency support:</p>
        </div>
        <KharonButton href="/emergency-support" variant="danger" size="md">Emergency support →</KharonButton>
      </div>

      {/* Quick Stats Card Row */}
      {systems.length > 0 && (
        <div class="grid grid-cols-3 gap-4 mb-6">
          <KharonCard variant={overdueCount > 0 ? "danger" : "default"}>
            <div class="flex flex-col justify-between h-full">
              <div>
                <span class="text-xs font-bold uppercase tracking-wider text-kharon-grey/65">Overdue Maintenance</span>
                <div class="flex items-baseline gap-2 mt-2">
                  <span class={`text-3xl font-bold ${overdueCount > 0 ? "text-kharon-red" : "text-kharon-black"}`}>{overdueCount}</span>
                  {overdueCount > 0 && <span class="text-[10px] font-bold text-kharon-red bg-red-50 border border-red-200 px-1.5 py-0.5 rounded">Action Required</span>}
                </div>
              </div>
            </div>
          </KharonCard>
          
          <KharonCard variant={dueSoonCount > 0 ? "warning" : "default"}>
            <div class="flex flex-col justify-between h-full">
              <div>
                <span class="text-xs font-bold uppercase tracking-wider text-kharon-grey/65">Due Within 30 Days</span>
                <div class="flex items-baseline gap-2 mt-2">
                  <span class={`text-3xl font-bold ${dueSoonCount > 0 ? "text-kharon-amber" : "text-kharon-black"}`}>{dueSoonCount}</span>
                  {dueSoonCount > 0 && <span class="text-[10px] font-bold text-kharon-amber bg-amber-50 border border-amber-200 px-1.5 py-0.5 rounded">Scheduled</span>}
                </div>
              </div>
            </div>
          </KharonCard>
          
          <KharonCard variant="success">
            <div class="flex flex-col justify-between h-full">
              <div>
                <span class="text-xs font-bold uppercase tracking-wider text-kharon-grey/65">Compliant Systems</span>
                <div class="flex items-baseline gap-2 mt-2">
                  <span class="text-3xl font-bold text-kharon-blue">{compliantCount}</span>
                  <span class="text-[10px] font-bold text-kharon-blue bg-blue-50 border border-blue-100 px-1.5 py-0.5 rounded">Secure</span>
                </div>
              </div>
            </div>
          </KharonCard>
        </div>
      )}

      {/* Main Dashboard Grid: Workspace + Sidebar */}
      <div class="grid gap-8 lg:grid-cols-[1.9fr_1.1fr]">
        
        {/* ==================== LEFT / MAIN COLUMN ==================== */}
        <div class="space-y-8">
          
          {/* Section: Systems under management */}
          <KharonCard title="Systems & Cadence Records" subtitle="Asset Lifecycle">
            <KharonButton href="/compliance" variant="secondary" size="sm">Standards reference →</KharonButton>
            
            <div class="mt-4 grid gap-6 sm:grid-cols-2">
              {systems.map((system) => (
                <article class="rounded-lg border border-kharon-border bg-kharon-light/50 p-5 flex flex-col justify-between">
                  <div>
                    <div class="flex items-start justify-between gap-2">
                      <span class="rounded bg-kharon-purple/10 px-2 py-0.5 text-[10px] font-bold uppercase text-kharon-purple">{system.system_type}</span>
                      <span class={`rounded px-2 py-0.5 text-[10px] font-bold uppercase border ${
                        system.next_due_date && system.next_due_date < today
                           ? "border-red-200 bg-red-50 text-kharon-red"
                           : system.next_due_date && system.next_due_date <= soonDate
                           ? "border-amber-200 bg-amber-50 text-kharon-amber"
                           : "border-kharon-border bg-white text-kharon-grey"
                      }`}>
                        {system.next_due_date && system.next_due_date < today ? "Overdue  -  " : "Due "}{system.next_due_date || "Not scheduled"}
                      </span>
                    </div>
                    <h3 class="mt-2.5 font-bold text-kharon-black leading-tight">{system.coverage_area}</h3>
                    <p class="text-xs text-kharon-grey mt-0.5">{system.owner_company_name}</p>
                    
                    <dl class="mt-4 grid grid-cols-2 gap-3 text-xs border-t border-kharon-border/60 pt-3">
                      <div>
                        <dt class="font-semibold text-kharon-grey/70 uppercase text-[9px] tracking-wider">Last Service</dt>
                        <dd class="mt-0.5 text-kharon-black font-medium">{system.last_service_date || "None"}</dd>
                      </div>
                      <div>
                        <dt class="font-semibold text-kharon-grey/70 uppercase text-[9px] tracking-wider">System ID</dt>
                        <dd class="mt-0.5 text-kharon-black font-mono break-all">{system.id.slice(0, 8)}...</dd>
                      </div>
                    </dl>
                  </div>
                  
                  <div class="mt-4 pt-3 border-t border-kharon-border/60">
                    {system.documentation_path ? (
                      <KharonButton href={`/portal/api/file/${system.documentation_path}`} variant="primary" size="sm" className="w-full">
                        Download Latest Jobcard
                      </KharonButton>
                    ) : (
                      <span class="text-xs text-kharon-grey/70 italic block text-center py-1.5">No completed jobcard file</span>
                    )}
                  </div>
                </article>
              ))}
            </div>
          </KharonCard>

          {/* Section: Open Defects Register */}
          <KharonCard title="Open Defects Register" subtitle="Risk management">
            <details class="text-xs text-kharon-grey relative float-right">
              <summary class="cursor-pointer font-semibold text-kharon-purple hover:underline">Status guide</summary>
              <div class="absolute right-0 mt-2 z-10 w-64 rounded-md border border-kharon-border bg-white p-3 shadow-md text-xs">
                <ul class="grid gap-1.5">
                  <li><strong>Open</strong> — defect recorded; remediation pending.</li>
                  <li><strong>In Progress</strong> — work started on defect.</li>
                </ul>
              </div>
            </details>
            
            <div class="mt-4 space-y-4">
              {openDefects.length === 0 && <p class="text-sm text-kharon-grey italic py-2">No open defects are recorded for your systems.</p>}
              {openDefects.map((item) => (
                <article class="flex flex-col sm:flex-row sm:items-start justify-between gap-4 p-5 rounded-lg border bg-kharon-light/30">
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center justify-between">
                      <span class="font-semibold text-kharon-black">{item.owner_company_name}</span>
                      <span class={`rounded px-1.5 py-0.5 text-[9px] font-bold uppercase border ${
                        item.severity === "Critical" ? "border-red-200 bg-red-50 text-kharon-red" :
                        item.severity === "Major" ? "border-amber-200 bg-amber-50 text-amber-700" :
                        "border-kharon-border bg-white text-kharon-grey"
                      }`}>{item.severity}</span>
                    </div>
                    <p class="text-kharon-grey mt-1">{item.system_type} / {item.coverage_area}</p>
                    {item.sans_clause_ref && <p class="mt-1 font-mono text-[10px] text-kharon-grey/70">SANS Clause: {item.sans_clause_ref}</p>}
                    <p class="mt-2 text-sm text-kharon-black bg-white border border-kharon-border/60 p-2.5 rounded">{item.description}</p>
                    {item.remediation_notes && (
                      <div class="mt-2">
                        <p class="text-[10px] font-bold uppercase text-kharon-purple">Remediation Notes</p>
                        <p class="text-xs text-kharon-black bg-blue-50 border border-blue-200 p-2.5 rounded">{item.remediation_notes}</p>
                      </div>
                    )}
                  </div>
                </article>
              ))}
            </div>
          </KharonCard>
        </div>

        {/* ==================== RIGHT / SIDEBAR ==================== */}
        <div class="space-y-8">
          
          {/* Section: Outstanding Quotes */}
          <KharonCard title="Outstanding Quotes" subtitle="Finance">
            <div class="mb-3 flex items-center justify-between gap-3 rounded-lg border border-kharon-border bg-white px-3 py-2 text-xs" data-approval-endpoint="/portal/api/approve-quote">
              <span class="font-semibold text-kharon-grey">Mapped client sites: {sites.length}</span>
              <KharonButton href="/portal/client/quotes" variant="secondary" size="sm">Review approvals</KharonButton>
            </div>
            <div class="mt-4 space-y-4">
              {quotes.length === 0 && <p class="text-sm text-kharon-grey italic py-2">No outstanding quotes require your approval.</p>}
              {quotes.map((quote) => (
                <article class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 p-4 rounded-lg border bg-kharon-light/30">
                  <div class="min-w-0 flex-1">
                    <p class="font-semibold text-kharon-black truncate">{quote.owner_company_name}</p>
                    <p class="text-xs text-kharon-grey mt-0.5">Quote #{quote.reference || quote.id.slice(0, 8)}</p>
                    <p class="mt-1 text-sm font-bold text-kharon-black">{formatCurrency(quote.amount)}</p>
                  </div>
                  <KharonButton href="/portal/client/quotes" variant="primary" size="sm">Review</KharonButton>
                </article>
              ))}
            </div>
          </KharonCard>

          {/* Section: Certificate Register */}
          <KharonCard title="Certificate Register" subtitle="Compliance">
            <div class="mt-4 space-y-4">
              {certificates.length === 0 && <p class="text-sm text-kharon-grey italic py-2">No certificates are registered for your systems.</p>}
              {certificates.map((cert) => (
                <article class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 p-4 rounded-lg border bg-white">
                  <div class="min-w-0 flex-1">
                    <p class="font-semibold text-kharon-black">{cert.certificate_type}</p>
                    <p class="text-xs text-kharon-grey mt-0.5">{cert.system_type} / {cert.coverage_area}</p>
                    <p class="mt-1 text-xs">
                      <span class="font-semibold">Issued:</span> {cert.issued_date}<br />
                      <span class="font-semibold">Expires:</span> {cert.expiry_date || "N/A"}
                    </p>
                  </div>
                  <span class={`rounded px-1.5 py-0.5 text-[9px] font-bold uppercase ${
                    cert.status === "Valid" ? "bg-green-100 text-green-800 border border-green-200" : 
                    cert.status === "Blocked" ? "bg-amber-100 text-amber-800 border border-amber-200" : 
                    cert.status === "Expired" ? "bg-red-100 text-red-800 border border-red-200" : 
                    "bg-slate-100 text-slate-700 border border-slate-200"
                  }`}>{cert.status}</span>
                </article>
              ))}
            </div>
          </KharonCard>

          {/* Section: Recent Service Requests */}
          <KharonCard title="Recent Service Requests" subtitle="Customer Support">
            <div class="mt-4 space-y-4">
              {requests.length === 0 && <p class="text-sm text-kharon-grey italic py-2">No recent service requests.</p>}
              {requests.map((request) => (
                <article class="p-4 rounded-lg border bg-white" class:list={[
                  request.priority === "Critical" ? "border-l-4 border-l-kharon-red bg-red-50/30" : 
                  request.priority === "Urgent" ? "border-l-4 border-l-kharon-amber bg-amber-50/30" : 
                  "border-l-4 border-l-kharon-purple bg-purple-50/30"
                ]}>
                  <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-3">
                    <div class="min-w-0 flex-1">
                      <p class="font-semibold text-kharon-black truncate">{request.owner_company_name}</p>
                      <p class="text-xs text-kharon-grey mt-0.5">{request.request_type}</p>
                      <p class="text-xs text-kharon-grey mt-0.5 truncate">{request.coverage_area || "General site request"}</p>
                      <p class="mt-1 text-xs">
                        <span class="font-semibold">Subject:</span> {request.subject}<br />
                        <span class="font-semibold">Created:</span> {request.created_at}
                      </p>
                    </div>
                    <span class={`rounded px-1 py-0.5 text-[9px] font-bold uppercase ${
                      request.priority === "Critical" ? "bg-red-100 text-red-800" : 
                      request.priority === "Urgent" ? "bg-amber-100 text-amber-800" : 
                      "bg-slate-100 text-slate-700"
                    }`}>{request.priority}</span>
                  </div>
                </article>
              ))}
            </div>
          </KharonCard>
        </div>
      </div>
    </div>
  </section>
</PortalLayout>
