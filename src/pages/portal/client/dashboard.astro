---
/**
 * Project Sentinel - Portal Client Dashboard
 * Purpose: Provides gateway dashboard for clients to view systems, defects, certs, and request support with compliance gauges.
 * Dependencies: PortalLayout, bindings, clientAccess, financial-utils, KharonCard, KharonButton.
 * Structural Role: Client gateway main view.
 */
import { auditError } from "../../../lib/server/audit.js";
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import { clientSites, inClause } from "../../../lib/server/access.ts";
import { formatCurrency } from "../../../lib/utils/financial-utils.ts";
import KharonCard from "../../../components/ui/KharonCard.astro";
import KharonButton from "../../../components/ui/KharonButton.astro";

export const prerender = false;

const user = Astro.locals.user;
interface ClientSystem {
  id: string;
  site_id: string;
  system_type: string;
  coverage_area: string;
  last_service_date: string | null;
  next_due_date: string;
  owner_company_name: string;
  latest_job_id: string | null;
  documentation_path: string | null;
  completed_at: string | null;
}

interface ClientQuote {
  id: string;
  site_id: string;
  amount: number;
  item_type: string;
  payment_status: string;
  distribution_date: string;
  reference: string | null;
  owner_company_name: string;
}

let systems: ClientSystem[] = [];
let quotes: ClientQuote[] = [];
let requests: Array<any> = [];
let sites: Array<any> = [];
let openDefects: Array<any> = [];
let certificates: Array<any> = [];
let loadError = "";
const sectionErrors: string[] = [];
const today    = new Date().toISOString().slice(0, 10);
const soonDate = new Date(Date.now() + 30 * 86400000).toISOString().slice(0, 10);

try {
  const db = getDatabase();
  sites = await clientSites(db, user);
  const siteIds = sites.map((site) => site.id);
  if (siteIds.length === 0) {
    loadError = "This client account is not mapped to a site.";
  } else {
    const sitePlaceholders = inClause(siteIds);
    try {
      systems = (await db.prepare(
        `SELECT systems.id, systems.site_id, systems.system_type, systems.coverage_area, systems.last_service_date, systems.next_due_date,
                sites.owner_company_name,
                latest_jobs.id AS latest_job_id, latest_jobs.documentation_path, latest_jobs.completed_at
         FROM systems
         INNER JOIN sites ON sites.id = systems.site_id
         LEFT JOIN jobs AS latest_jobs ON latest_jobs.id = (
           SELECT j.id FROM jobs j
           WHERE j.deleted_at IS NULL AND j.system_id = systems.id AND j.documentation_path IS NOT NULL
           ORDER BY COALESCE(j.completed_at, j.updated_at, j.created_at) DESC
           LIMIT 1
         )
         WHERE systems.deleted_at IS NULL AND systems.site_id IN (${sitePlaceholders})
         ORDER BY sites.owner_company_name ASC, systems.next_due_date ASC`
      ).bind(...siteIds).all()).results as unknown as ClientSystem[] || [];
    } catch (error) {
      await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "client_systems" });
      sectionErrors.push("System records could not be loaded.");
    }

    try {
      quotes = (await db.prepare(
        `SELECT financial_records.id, financial_records.site_id, financial_records.amount,
                financial_records.item_type, financial_records.payment_status,
                financial_records.distribution_date, financial_records.reference,
                sites.owner_company_name
         FROM financial_records
         INNER JOIN sites ON sites.id = financial_records.site_id
         WHERE financial_records.site_id IN (${sitePlaceholders})
           AND financial_records.item_type = 'Quote'
           AND financial_records.payment_status = 'Pending Approval'
         ORDER BY financial_records.distribution_date ASC`
      ).bind(...siteIds).all()).results as unknown as ClientQuote[] || [];
    } catch (error) {
      await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "client_quotes" });
      sectionErrors.push("Quote approvals could not be loaded.");
    }

    try {
      requests = (await db.prepare(
        `SELECT maintenance_requests.id, maintenance_requests.site_id,
                maintenance_requests.request_type, maintenance_requests.priority,
                maintenance_requests.status, maintenance_requests.subject, maintenance_requests.created_at,
                maintenance_requests.linked_job_id, systems.coverage_area, sites.owner_company_name
         FROM maintenance_requests
         INNER JOIN sites ON sites.id = maintenance_requests.site_id
         LEFT JOIN systems ON systems.id = maintenance_requests.system_id AND systems.deleted_at IS NULL
         WHERE maintenance_requests.site_id IN (${sitePlaceholders})
         ORDER BY maintenance_requests.created_at DESC
         LIMIT 8`
      ).bind(...siteIds).all()).results || [];
    } catch (error) {
      await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "client_requests" });
      sectionErrors.push("Recent service requests could not be loaded.");
    }

    try {
      openDefects = (await db.prepare(
        `SELECT defects.id, defects.severity, defects.sans_clause_ref, defects.status, defects.description,
                defects.remediation_notes, systems.id AS system_id, systems.system_type,
                systems.coverage_area, sites.owner_company_name
         FROM defects
         INNER JOIN systems ON systems.id = defects.system_id
         INNER JOIN sites ON sites.id = systems.site_id
         WHERE defects.deleted_at IS NULL AND systems.deleted_at IS NULL
           AND systems.site_id IN (${sitePlaceholders}) AND defects.status IN ('Open', 'In Progress')
         ORDER BY CASE defects.severity WHEN 'Critical' THEN 1 WHEN 'Major' THEN 2 ELSE 3 END,
                  defects.created_at DESC
         LIMIT 10`
      ).bind(...siteIds).all()).results || [];
    } catch (error) {
      await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "client_defects" });
      sectionErrors.push("Defect register could not be loaded.");
    }

    try {
      certificates = (await db.prepare(
        `SELECT certificates.id, certificates.certificate_type, certificates.status,
                certificates.issued_date, certificates.expiry_date,
                systems.id AS system_id, systems.system_type, systems.coverage_area,
                sites.owner_company_name
         FROM certificates
         INNER JOIN systems ON systems.id = certificates.system_id
         INNER JOIN sites ON sites.id = systems.site_id
         WHERE certificates.deleted_at IS NULL AND systems.deleted_at IS NULL
           AND systems.site_id IN (${sitePlaceholders})
         ORDER BY COALESCE(certificates.expiry_date, certificates.issued_date) DESC
         LIMIT 10`
      ).bind(...siteIds).all()).results || [];
    } catch (error) {
      await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "client_certificates" });
      sectionErrors.push("Certificate register could not be loaded.");
    }
  }
} catch (error) {
  await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "client_dashboard" });
  loadError = "Client system records could not be loaded.";
}

// Compliance summary counts
const overdueCount  = systems.filter((s) => s.next_due_date && s.next_due_date < today).length;
const dueSoonCount  = systems.filter((s) => s.next_due_date && s.next_due_date >= today && s.next_due_date <= soonDate).length;
const compliantCount = systems.filter((s) => !s.next_due_date || s.next_due_date > soonDate).length;
const compliancePercentage = systems.length > 0 ? Math.round((compliantCount / systems.length) * 100) : 100;

// SVG Circular Gauge variables
const radius = 28;
const stroke = 5;
const circumference = 2 * Math.PI * radius;
const strokeDashoffset = circumference - (compliancePercentage / 100) * circumference;

const systemsWithStatus = systems.map((system) => {
  const isOverdue = !!(system.next_due_date && system.next_due_date < today);
  const isDueSoon = !!(system.next_due_date && system.next_due_date >= today && system.next_due_date <= soonDate);
  return {
    ...system,
    isOverdue,
    isDueSoon
  };
});

import ComplianceHeatmap, { type SiteStatus } from "../../../components/portal/ComplianceHeatmap.astro";

const siteStatuses: SiteStatus[] = sites.map(site => {
  const siteSystems = systems.filter(s => s.site_id === site.id);
  const siteDefects = openDefects.filter(d => d.site_id === site.id);

  const isOverdue = siteSystems.some(s => s.next_due_date && s.next_due_date < today);
  const isCritical = siteDefects.some(d => d.severity === 'Critical' || d.severity === 'Major');
  const isDueSoon = siteSystems.some(s => s.next_due_date && s.next_due_date >= today && s.next_due_date <= soonDate);

  let status: 'red' | 'amber' | 'green' = 'green';
  let reason = 'Compliant';

  if (isOverdue || isCritical) {
    status = 'red';
    reason = isOverdue ? 'Maintenance Overdue' : 'Critical Defect';
  } else if (isDueSoon || siteDefects.length > 0) {
    status = 'amber';
    reason = isDueSoon ? 'Due Soon' : 'Minor Defects';
  }

  return { id: site.id, name: site.owner_company_name, status, reason };
});
---

<PortalLayout title="Client Gateway | Kharon Portal" active="client" user={user}>
  <section class="bg-gradient-to-r from-[#0B0D0F] to-[#1A1F26] px-4 py-8 text-white sm:px-6 sm:py-10 shadow-inner rounded-xl border border-kharon-purple/10 mb-6">
    <div class="mx-auto max-w-7xl">
      <p class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple">Client Console</p>
      <h1 class="mt-2 text-2xl font-black sm:text-3xl tracking-tight">System Status &amp; Compliance</h1>
      <p class="mt-2 max-w-3xl text-sm text-white/60">Read-only visibility over protected systems, upcoming maintenance dates and completed jobcard records.</p>
    </div>
  </section>

  <section class="px-1 py-4 sm:px-4">
    <div class="mx-auto max-w-7xl">
      {loadError && <p class="rounded-lg border border-kharon-red/40 bg-kharon-red/10 px-4 py-3 text-sm font-semibold text-kharon-red mb-6">{loadError}</p>}
      {!loadError && sectionErrors.length > 0 && (
        <div class="grid gap-2 mb-6">
          {sectionErrors.map((message) => <p class="border border-amber-500/30 bg-amber-950/20 p-4 text-kharon-amber rounded-lg text-xs font-bold">{message}</p>)}
        </div>
      )}

      {/* Compliance Heatmap */}
      {siteStatuses.length > 1 && (
        <div class="mb-8">
          <div class="flex items-center justify-between mb-3">
            <h2 class="text-xs font-black uppercase tracking-widest text-white/70">Portfolio Compliance Heatmap</h2>
            <span class="text-[10px] text-white/40 uppercase font-mono">{siteStatuses.length} sites tracked</span>
          </div>
          <ComplianceHeatmap sites={siteStatuses} />
        </div>
      )}

      {/* Emergency Support Alert */}
      <div class="flex flex-wrap items-center justify-between gap-4 border border-kharon-red/30 border-l-4 border-l-kharon-red bg-kharon-red/5 px-4 py-4 mb-8 rounded-xl shadow-lg relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_90%_50%,rgba(196,51,47,0.05),transparent)]"></div>
        <div class="relative z-10">
          <p class="text-sm font-black text-kharon-red uppercase tracking-wider">Urgent Technical Intervention Required?</p>
          <p class="text-xs text-white/70 mt-1">For live faults, compliance blockages, or emergency support:</p>
        </div>
        <KharonButton href="/emergency-support" variant="danger" size="md" className="relative z-10 text-xs font-bold tracking-widest uppercase">Emergency support →</KharonButton>
      </div>

      {/* Quick Stats Grid Row */}
      {systems.length > 0 && (
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
          <div class={`rounded-xl border p-5 shadow-xl backdrop-blur-md relative overflow-hidden flex flex-col justify-between ${overdueCount > 0 ? "border-kharon-red/30 bg-kharon-charcoal/80" : "border-kharon-purple/20 bg-kharon-charcoal/60"}`}>
            <div>
              <span class="text-[10px] font-bold uppercase tracking-widest text-white/60">Overdue Maintenance</span>
              <div class="flex items-baseline gap-2 mt-2">
                <span class={`text-3xl font-black tracking-tight ${overdueCount > 0 ? "text-kharon-red" : "text-white"}`}>{overdueCount}</span>
                {overdueCount > 0 && <span class="text-[9px] font-black text-kharon-red bg-kharon-red/10 border border-kharon-red/20 px-2 py-0.5 rounded uppercase tracking-wider">Overdue</span>}
              </div>
            </div>
          </div>
          
          <div class={`rounded-xl border p-5 shadow-xl backdrop-blur-md relative overflow-hidden flex flex-col justify-between ${dueSoonCount > 0 ? "border-kharon-amber/30 bg-kharon-charcoal/80" : "border-kharon-purple/20 bg-kharon-charcoal/60"}`}>
            <div>
              <span class="text-[10px] font-bold uppercase tracking-widest text-white/60">Due Within 30 Days</span>
              <div class="flex items-baseline gap-2 mt-2">
                <span class={`text-3xl font-black tracking-tight ${dueSoonCount > 0 ? "text-kharon-amber" : "text-white"}`}>{dueSoonCount}</span>
                {dueSoonCount > 0 && <span class="text-[9px] font-black text-kharon-amber bg-kharon-amber/10 border border-kharon-amber/20 px-2 py-0.5 rounded uppercase tracking-wider">Due Soon</span>}
              </div>
            </div>
          </div>
          
          <div class="rounded-xl border border-kharon-purple/20 bg-kharon-charcoal/80 p-5 shadow-xl backdrop-blur-md relative overflow-hidden flex items-center justify-between">
            <div>
              <span class="text-[10px] font-bold uppercase tracking-widest text-white/60">Portfolio Health</span>
              <div class="flex items-baseline gap-1 mt-2">
                <span class="text-3xl font-black text-kharon-cyan tracking-tight">{compliancePercentage}%</span>
                <span class="text-[9px] font-bold text-white/40 uppercase tracking-widest">certified</span>
              </div>
            </div>
            
            <!-- Radial SVG Gauge -->
            <div class="relative flex items-center justify-center h-16 w-16">
              <svg class="w-full h-full transform -rotate-90">
                <circle cx="32" cy="32" r={radius} stroke="rgba(75, 46, 131, 0.15)" stroke-width={stroke} fill="transparent" />
                <circle cx="32" cy="32" r={radius} stroke="var(--color-kharon-cyan)" stroke-width={stroke} fill="transparent"
                  stroke-dasharray={circumference} stroke-dashoffset={strokeDashoffset} stroke-linecap="round" />
              </svg>
              <div class="absolute text-[10px] font-black text-white">{compliantCount}/{systems.length}</div>
            </div>
          </div>
        </div>
      )}

      {/* Main Dashboard Grid */}
      <div class="grid gap-8 lg:grid-cols-[1.5fr_1fr]">
        
        {/* ==================== LEFT / MAIN COLUMN ==================== */}
        <div class="space-y-8">
          
          {/* Section: Systems under management */}
          <KharonCard title="Systems & Cadence Records" subtitle="Asset Lifecycle">
            <div class="mb-4">
              <KharonButton href="/compliance" variant="secondary" size="sm" className="text-[10px] tracking-widest uppercase font-bold">Standards reference →</KharonButton>
            </div>
            
            <div class="grid gap-6 sm:grid-cols-2">
              {systemsWithStatus.map((system) => {
                return (
                  <article class={`rounded-xl border p-5 flex flex-col justify-between bg-kharon-charcoal/60 hover:border-kharon-purple/40 transition-all duration-300 ${system.isOverdue ? 'border-kharon-red/20 shadow-lg shadow-kharon-red/2' : 'border-kharon-purple/20'}`}>
                    <div>
                      <div class="flex items-start justify-between gap-2">
                        <span class="rounded bg-kharon-purple/20 px-2 py-0.5 text-[9px] font-bold uppercase text-kharon-cyan border border-kharon-purple/30">{system.system_type}</span>
                        <span class={`rounded px-3 py-0.5 text-[9px] font-bold uppercase border ${
                          system.isOverdue
                             ? "border-kharon-red/30 bg-kharon-red/10 text-kharon-red"
                             : system.isDueSoon
                             ? "border-kharon-amber/30 bg-kharon-amber/10 text-kharon-amber"
                             : "border-kharon-purple/20 bg-kharon-purple/5 text-white/60"
                        }`}>
                          {system.isOverdue ? "Overdue: " : "Due "}{system.next_due_date || "Not scheduled"}
                        </span>
                      </div>
                      <h3 class="mt-4 font-bold text-white leading-snug">{system.coverage_area}</h3>
                      <p class="text-xs text-white/50 mt-1">{system.owner_company_name}</p>
                      
                      <dl class="mt-4 grid grid-cols-2 gap-3 text-xs border-t border-kharon-purple/10 pt-3 text-white/70">
                        <div>
                          <dt class="font-bold text-kharon-purple uppercase text-[9px] tracking-widest">Last Service</dt>
                          <dd class="mt-1 font-semibold text-white/90">{system.last_service_date || "None"}</dd>
                        </div>
                        <div>
                          <dt class="font-bold text-kharon-purple uppercase text-[9px] tracking-widest">System ID</dt>
                          <dd class="mt-1 font-mono font-bold text-white/60 truncate">{system.id.slice(0, 8)}...</dd>
                        </div>
                      </dl>
                    </div>
                    
                    <div class="mt-5 pt-3 border-t border-kharon-purple/10">
                      {system.documentation_path ? (
                        <a href={`/portal/api/file/${system.documentation_path}`} class="flex items-center justify-center gap-2 w-full px-4 py-3 bg-gradient-to-r from-kharon-purple to-kharon-blue text-white font-bold text-xs uppercase tracking-widest rounded-md text-center hover:shadow-lg hover:shadow-kharon-purple/30 transition-all min-h-[44px]">
                          Download Jobcard PDF
                        </a>
                      ) : (
                        <span class="text-xs text-white/40 italic block text-center py-2">No completed jobcard file</span>
                      )}
                    </div>
                  </article>
                );
              })}
            </div>
          </KharonCard>

          {/* Section: Open Defects Register */}
          <KharonCard title="Open Defects Register" subtitle="Risk management">
            <details class="text-xs text-kharon-purple relative float-right z-20">
              <summary class="cursor-pointer font-bold uppercase tracking-widest text-[10px] hover:text-kharon-cyan transition-colors">Status guide</summary>
              <div class="absolute right-0 mt-2 z-30 w-64 rounded-xl border border-kharon-purple/20 bg-kharon-charcoal p-4 shadow-2xl text-xs text-white/70">
                <ul class="grid gap-2">
                  <li><strong class="text-white">Open</strong> — defect recorded; remediation pending.</li>
                  <li><strong class="text-white">In Progress</strong> — work started on defect.</li>
                </ul>
              </div>
            </details>
            
            <div class="mt-4 space-y-4">
              {openDefects.length === 0 && <p class="text-xs text-white/50 italic py-2">No open defects are recorded for your systems.</p>}
              {openDefects.map((item) => (
                <article class="flex flex-col gap-4 p-5 rounded-xl border border-kharon-purple/20 bg-kharon-charcoal/60">
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center justify-between flex-wrap gap-2">
                      <span class="font-bold text-white text-sm">{item.owner_company_name}</span>
                      <span class={`rounded px-3 py-0.5 text-[9px] font-bold uppercase border ${
                        item.severity === "Critical" ? "border-kharon-red/30 bg-kharon-red/10 text-kharon-red" :
                        item.severity === "Major" ? "border-kharon-amber/30 bg-kharon-amber/10 text-kharon-amber" :
                        "border-kharon-purple/20 bg-kharon-purple/5 text-white/60"
                      }`}>{item.severity}</span>
                    </div>
                    <p class="text-xs text-kharon-cyan uppercase tracking-wider font-bold mt-2">{item.system_type} / {item.coverage_area}</p>
                    {item.sans_clause_ref && <p class="mt-1 font-mono text-[9px] text-white/40 font-bold uppercase tracking-wider">SANS Clause: {item.sans_clause_ref}</p>}
                    <p class="mt-3 text-xs text-white/80 bg-kharon-black/40 border border-kharon-purple/10 p-3 rounded-lg leading-relaxed">{item.description}</p>
                    {item.remediation_notes && (
                      <div class="mt-3">
                        <p class="text-[9px] font-bold uppercase text-kharon-cyan tracking-wider">Remediation Notes</p>
                        <p class="text-xs text-white/80 bg-kharon-purple/5 border border-kharon-purple/20 p-3 rounded-lg mt-1 leading-relaxed">{item.remediation_notes}</p>
                      </div>
                    )}
                  </div>
                </article>
              ))}
            </div>
          </KharonCard>
        </div>

        {/* ==================== RIGHT / SIDEBAR ==================== */}
        <div class="space-y-8">
          
          {/* Section: Outstanding Quotes */}
          <KharonCard title="Outstanding Quotes" subtitle="Finance">
            <div class="mb-4 flex items-center justify-between gap-3 rounded-xl border border-kharon-purple/20 bg-kharon-charcoal/40 px-4 py-3 text-xs" data-approval-endpoint="/portal/api/approve-quote">
              <span class="font-bold text-white/60">Mapped client sites: {sites.length}</span>
              <a href="/portal/client/quotes" class="px-3 py-2 border border-kharon-purple/30 text-white hover:bg-kharon-purple/10 font-bold text-[10px] uppercase tracking-widest rounded-md">Approvals</a>
            </div>
            <div class="mt-4 space-y-4">
              {quotes.length === 0 && <p class="text-xs text-white/50 italic py-2">No outstanding quotes require your approval.</p>}
              {quotes.map((quote) => (
                <article class="flex flex-col gap-3 p-4 rounded-xl border border-kharon-purple/20 bg-kharon-charcoal/60">
                  <div class="min-w-0 flex-1">
                    <p class="font-bold text-white truncate">{quote.owner_company_name}</p>
                    <p class="text-[9px] text-white/40 uppercase tracking-widest font-mono mt-0.5">Quote #{quote.reference || quote.id.slice(0, 8)}</p>
                    <p class="mt-2 text-base font-black text-kharon-cyan">{formatCurrency(quote.amount)}</p>
                  </div>
                  <a href="/portal/client/quotes" class="w-full text-center px-4 py-3 bg-gradient-to-r from-kharon-purple to-kharon-blue text-white font-bold text-xs uppercase tracking-widest rounded-md min-h-[44px] flex items-center justify-center">
                    Review Quote
                  </a>
                </article>
              ))}
            </div>
          </KharonCard>

          {/* Section: Certificate Register */}
          <KharonCard title="Certificate Register" subtitle="Compliance">
            <div class="mt-4 space-y-4">
              {certificates.length === 0 && <p class="text-xs text-white/50 italic py-2">No certificates are registered for your systems.</p>}
              {certificates.map((cert) => (
                <article class="flex flex-col gap-4 p-4 rounded-xl border border-kharon-purple/20 bg-kharon-charcoal/60">
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center justify-between gap-2">
                      <p class="font-bold text-white text-sm">{cert.certificate_type}</p>
                      <span class={`rounded px-2 py-0.5 text-[9px] font-black uppercase ${
                        cert.status === "Valid" ? "bg-kharon-green/20 text-kharon-green border border-kharon-green/30" : 
                        cert.status === "Blocked" ? "bg-kharon-amber/20 text-kharon-amber border border-kharon-amber/30" : 
                        cert.status === "Expired" ? "bg-kharon-red/20 text-kharon-red border border-kharon-red/30" : 
                        "bg-white/5 text-white/50 border border-white/10"
                      }`}>{cert.status}</span>
                    </div>
                    <p class="text-[10px] text-kharon-cyan uppercase font-bold tracking-wider mt-1">{cert.system_type} / {cert.coverage_area}</p>
                    <div class="mt-4 text-xs text-white/60 leading-relaxed grid grid-cols-2 gap-2 border-t border-kharon-purple/10 pt-2.5">
                      <div>
                        <span class="text-[9px] font-bold uppercase text-kharon-purple block">Issued</span>
                        <span class="font-medium text-white">{cert.issued_date}</span>
                      </div>
                      <div>
                        <span class="text-[9px] font-bold uppercase text-kharon-purple block">Expires</span>
                        <span class="font-medium text-white">{cert.expiry_date || "N/A"}</span>
                      </div>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </KharonCard>

          {/* Section: Recent Service Requests */}
          <KharonCard title="Recent Service Requests" subtitle="Customer Support">
            <div class="mt-4 space-y-4">
              {requests.length === 0 && <p class="text-xs text-white/50 italic py-2">No recent service requests.</p>}
              {requests.map((request) => (
                <article class={`p-4 rounded-xl border ${
                  request.priority === "Critical" ? "border-kharon-red/20 bg-kharon-red/5" : 
                  request.priority === "Urgent" ? "border-kharon-amber/20 bg-kharon-amber/5" : 
                  "border-kharon-purple/20 bg-kharon-purple/5"
                }`}>
                  <div class="flex flex-col gap-3">
                    <div class="min-w-0 flex-1">
                      <div class="flex justify-between items-start gap-2">
                        <p class="font-bold text-white truncate text-sm">{request.owner_company_name}</p>
                        <span class={`rounded px-2 py-0.5 text-[9px] font-black uppercase ${
                          request.priority === "Critical" ? "bg-kharon-red/20 text-kharon-red border border-kharon-red/30" : 
                          request.priority === "Urgent" ? "bg-kharon-amber/20 text-kharon-amber border border-kharon-amber/35" : 
                          "bg-white/5 text-white/50 border border-white/10"
                        }`}>{request.priority}</span>
                      </div>
                      <p class="text-xs font-bold text-kharon-cyan mt-1">{request.request_type}</p>
                      <p class="text-xs text-white/50 mt-1 truncate">{request.coverage_area || "General site request"}</p>
                      
                      <div class="mt-4 text-xs text-white/60 leading-normal border-t border-kharon-purple/10 pt-2.5">
                        <p class="truncate"><span class="font-bold text-kharon-purple uppercase text-[9px] tracking-widest block">Subject</span> {request.subject}</p>
                        <p class="mt-1"><span class="font-bold text-kharon-purple uppercase text-[9px] tracking-widest block">Created</span> {request.created_at}</p>
                      </div>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </KharonCard>
        </div>
      </div>
    </div>
  </section>
</PortalLayout>
