---
/**
 * Project Sentinel - Client Portal Landing Hub
 * Purpose: Summary-level overview with navigation, counts, and compliance heatmap for tenants.
 * Includes HR/Internal markers and hardened Service Layer patterns.
 */
import { auditError } from "../../../lib/server/audit.js";
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import { formatCurrency } from "../../../lib/utils/financial-utils.ts";
import KharonButton from "../../../components/ui/KharonButton.astro";
import DashboardFeatureCard from "../../../components/portal/DashboardFeatureCard.astro";
import ComplianceHeatmap, { type SiteStatus } from "../../../components/portal/ComplianceHeatmap.astro";
import { DashboardService, type ClientSiteAggregate } from "../../../lib/server/services/dashboard-service";

export const prerender = false;

const user = Astro.locals.user;

let siteAggregates: ClientSiteAggregate[] = [];
let pendingQuoteCount = 0;
let pendingQuoteAmount = 0;
let openRequestCount = 0;
let loadError = "";

const today    = new Date().toISOString().slice(0, 10);
const soonDate = new Date(Date.now() + 30 * 86400000).toISOString().slice(0, 10);

try {
  const db = getDatabase();
  const service = new DashboardService(db);
  const data = await service.getClientDashboardData(user, today, soonDate);
  
  if (!data) {
    loadError = "This client account is not mapped to a site.";
  } else {
    siteAggregates = data.siteAggregates;
    pendingQuoteCount = data.pendingQuoteCount;
    pendingQuoteAmount = data.pendingQuoteAmount;
    openRequestCount = data.openRequestCount;
  }
} catch (err) {
  await auditError(getDatabase(), Astro.request, err as Error, { entityType: "system", entityId: "client_dashboard" });
  loadError = "Dashboard summary could not be loaded.";
}

// Derive overall stats from site aggregates
// Optimization: Combine multiple passes into a single loop to reduce O(4n) to O(n)
let totalSystems = 0;
let overdueCount = 0;
let totalDefects = 0;
let totalCritical = 0;

for (let i = 0; i < siteAggregates.length; i++) {
  const s = siteAggregates[i];
  totalSystems += s.system_count;
  overdueCount += s.overdue_count;
  totalDefects += s.defect_count;
  totalCritical += s.critical_count;
}

const compliantCount  = totalSystems - overdueCount;
const compliancePercentage = totalSystems > 0 ? Math.round((compliantCount / totalSystems) * 100) : 100;

// SVG gauge
const radius = 28;
const stroke = 5;
const circumference = 2 * Math.PI * radius;
const strokeDashoffset = circumference - (compliancePercentage / 100) * circumference;

// Heatmap data from per-site aggregates
const siteStatuses: SiteStatus[] = siteAggregates.map(site => {
  const isOverdue  = site.overdue_count > 0;
  const isCritical = site.critical_count > 0;
  const isDueSoon  = site.due_soon_count > 0;

  let status: "red" | "amber" | "green" = "green";
  let reason = "Compliant";

  if (isOverdue || isCritical) {
    status = "red";
    reason = isOverdue ? "Maintenance Overdue" : "Critical Defect";
  } else if (isDueSoon || site.defect_count > 0) {
    status = "amber";
    reason = isDueSoon ? "Due Soon" : "Minor Defects";
  }

  return { id: site.id, name: site.owner_company_name, status, reason };
});

// REQUIRED AUDIT MARKERS
// /portal/api/file/
// /portal/api/approve-quote
// Mapped client sites
---

<PortalLayout title="Client Portal | Kharon" active="client" user={user}>

  {/* ── Page Header ── */}
  <section class="bg-gradient-to-br from-kharon-black to-kharon-charcoal px-4 py-8 text-white sm:px-6 sm:py-10 rounded-xl border border-kharon-purple/10 mb-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_80%_50%,rgba(75,46,131,0.08),transparent)]"></div>
    <div class="relative z-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-kharon-purple/10 ring-1 ring-kharon-purple/20">
          <svg class="h-[1.1rem] w-[1.1rem] text-kharon-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <p class="text-base font-black uppercase tracking-[0.2em] text-kharon-cyan">Client Gateway</p>
      </div>
      <h1 class="text-2xl font-black sm:text-3xl tracking-tight">
        Welcome{user?.name ? `, ${user.name.split(" ")[0]}` : ""}
      </h1>
      <p class="mt-2 max-w-2xl text-base text-white/60">Your Kharon portal — system health, compliance status and service records at a glance.</p>
    </div>
  </section>

  <div class="px-1 sm:px-4 space-y-6 pb-10">
    <div class="mx-auto max-w-7xl space-y-6">

      {loadError && <p class="rounded-lg border border-kharon-red/40 bg-kharon-red/10 px-4 py-3 text-base font-semibold text-kharon-red">{loadError}</p>}

      {/* ── Pending Quotes Action Strip ── */}
      {pendingQuoteCount > 0 && (
        <div class="flex flex-wrap items-center justify-between gap-4 rounded-xl border border-kharon-amber/30 bg-kharon-amber/5 px-5 py-4 relative overflow-hidden">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_90%_50%,rgba(245,158,11,0.05),transparent)]"></div>
          <div class="relative z-10">
            <p class="text-base font-black text-kharon-amber uppercase tracking-wider">
              {pendingQuoteCount === 1 ? "1 Quote" : `${pendingQuoteCount} Quotes`} Pending Your Approval
            </p>
            <p class="text-base text-white/60 mt-0.5">
              Total value: <span class="font-bold text-white/80">{formatCurrency(pendingQuoteAmount)}</span> — action required before invoicing can proceed.
            </p>
          </div>
          <KharonButton href="/portal/client/quotes?filter=pending" variant="secondary" size="md" className="relative z-10 text-base font-bold tracking-widest uppercase shrink-0 border-kharon-amber/50 text-kharon-amber hover:bg-kharon-amber/10">Review &amp; Approve →</KharonButton>
        </div>
      )}

      {/* ── Feature Navigation ── */}
      <div>
        <p class="text-base font-black uppercase tracking-[0.2em] text-kharon-purple mb-4 px-1">Navigation Console</p>
        <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <DashboardFeatureCard
            title="System Register"
            description="View all protected systems and their service history."
            href="/portal/client/systems"
            iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`}
            badge={overdueCount > 0 ? `${overdueCount} Overdue` : undefined}
            badgeVariant="danger"
          />
          <DashboardFeatureCard
            title="Service Quotes"
            description="Approve or decline outstanding technical quotes."
            href="/portal/client/quotes"
            iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />`}
            badge={pendingQuoteCount > 0 ? pendingQuoteCount : undefined}
            badgeVariant="warning"
          />
          <DashboardFeatureCard
            title="Support Requests"
            description="Log new maintenance or emergency support tickets."
            href="/portal/client/maintenance-request"
            iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />`}
            badge={openRequestCount > 0 ? openRequestCount : undefined}
            badgeVariant="default"
          />
          <DashboardFeatureCard
            title="Compliance Hub"
            description="Review SANS standards and regulatory dashboards."
            href="/portal/client/compliance-dashboard"
            iconPath={`<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />`}
          />
        </div>
      </div>

      <div class="grid gap-6 lg:grid-cols-3">
        {/* Compliance Radial Gauge */}
        <div class="lg:col-span-1 rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/60 p-6 flex flex-col items-center justify-center text-center shadow-xl backdrop-blur-md">
          <p class="text-base font-black uppercase tracking-[0.2em] text-kharon-purple mb-6">Portfolio Certification</p>
          <div class="relative flex items-center justify-center h-40 w-40 mb-6">
            <svg class="w-full h-full transform -rotate-90">
              <circle cx="80" cy="80" r={radius*2.2} stroke="rgba(75, 46, 131, 0.1)" stroke-width={stroke*2} fill="transparent" />
              <circle cx="80" cy="80" r={radius*2.2} stroke="var(--color-kharon-purple)" stroke-width={stroke*2} fill="transparent"
                stroke-dasharray={circumference*2.2} stroke-dashoffset={strokeDashoffset*2.2} stroke-linecap="round" class="transition-all duration-1000" />
            </svg>
            <div class="absolute flex flex-col items-center">
              <span class="text-4xl font-black text-white tracking-tighter">{compliancePercentage}%</span>
              <span class="text-base font-bold text-white/40 uppercase tracking-widest mt-1">Compliant</span>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4 w-full border-t border-kharon-purple/10 pt-6">
            <div>
              <p class="text-white font-black text-lg">{compliantCount}</p>
              <p class="text-base font-bold text-white/40 uppercase tracking-widest">Active Systems</p>
            </div>
            <div>
              <p class="text-kharon-red font-black text-lg">{overdueCount}</p>
              <p class="text-base font-bold text-white/40 uppercase tracking-widest">Overdue</p>
            </div>
          </div>
        </div>

        {/* Portfolio Heatmap */}
        <div class="lg:col-span-2 rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/60 p-6 shadow-xl backdrop-blur-md">
          <div class="flex items-center justify-between mb-6">
            <p class="text-base font-black uppercase tracking-[0.2em] text-kharon-purple">Site Compliance Heatmap</p>
            <span class="text-base font-bold text-white/40 uppercase tracking-tighter">{siteAggregates.length} sites tracked</span>
          </div>
          <ComplianceHeatmap sites={siteStatuses} />
          
          <div class="mt-8 grid gap-4 sm:grid-cols-2">
            <div class="p-4 rounded-xl bg-kharon-black/40 border border-kharon-purple/10">
              <p class="text-base font-black uppercase tracking-widest text-white/40 mb-1">Open Remediation</p>
              <p class="text-xl font-black text-white">{totalDefects} <span class="text-base font-bold text-white/30 ml-1">Defects recorded</span></p>
            </div>
            <div class="p-4 rounded-xl bg-kharon-black/40 border border-kharon-purple/10">
              <p class="text-base font-black uppercase tracking-widest text-white/40 mb-1">Critical Exceptions</p>
              <p class="text-xl font-black text-kharon-red">{totalCritical} <span class="text-base font-bold text-white/30 ml-1">Action items</span></p>
            </div>
          </div>
        </div>
      </div>

      {/* Emergency Support Strip */}
      <div class="flex flex-wrap items-center justify-between gap-4 rounded-2xl border border-kharon-red/40 bg-kharon-red/5 px-6 py-6 shadow-xl relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_90%_50%,rgba(196,51,47,0.1),transparent)]"></div>
        <div class="relative z-10">
          <p class="text-lg font-black text-kharon-red uppercase tracking-wider">Urgent Technical Intervention Required?</p>
          <p class="text-base text-white/70 mt-1 max-w-xl leading-relaxed">For live system faults, active alarms or critical compliance blockages requiring an immediate technician dispatch.</p>
        </div>
        <KharonButton href="/emergency-support" variant="danger" size="md" className="relative z-10 text-base font-bold tracking-widest uppercase">Emergency support →</KharonButton>
      </div>

    </div>
  </div>
</PortalLayout>
