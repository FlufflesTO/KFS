---
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import { clientSites, inClause } from "../../../lib/server/clientAccess.js";

export const prerender = false;

const user = Astro.locals.user;
let sites = [];
let records = [];
let totals = { pending: 0, unpaid: 0, settled: 0 };
let loadError = "";

try {
  const db = getDatabase();
  sites = await clientSites(db, user);
  const siteIds = sites.map((site) => site.id);
  if (siteIds.length === 0) {
    loadError = "This client account is not mapped to a site.";
  } else {
    const sitePlaceholders = inClause(siteIds);
    records = (await db.prepare(
      `SELECT financial_records.id, financial_records.site_id, financial_records.amount,
              financial_records.item_type, financial_records.payment_status,
              financial_records.distribution_date, financial_records.reference,
              sites.owner_company_name, jobs.id AS job_id, jobs.status AS job_status
       FROM financial_records
       INNER JOIN sites ON sites.id = financial_records.site_id
       LEFT JOIN jobs ON jobs.id = financial_records.job_id
       WHERE financial_records.site_id IN (${sitePlaceholders})
       ORDER BY financial_records.distribution_date DESC, financial_records.created_at DESC
       LIMIT 120`
    ).bind(...siteIds).all()).results || [];

    for (const record of records) {
      const amount = Number(record.amount || 0);
      if (record.payment_status === "Pending Approval") totals.pending += amount;
      if (record.payment_status === "Unpaid") totals.unpaid += amount;
      if (record.payment_status === "Settled") totals.settled += amount;
    }
  }
} catch (error) {
  console.error("client quote history failed", error);
  loadError = "Client quote history could not be loaded.";
}
---

<PortalLayout title="Quote History | Kharon Portal" active="client-quotes" user={user}>
  <section class="bg-kharon-black px-4 py-8 text-white sm:px-6 sm:py-10">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-bold uppercase text-kharon-cyan">Client commercial records</p>
      <h1 class="mt-3 text-2xl font-bold sm:text-3xl">Quote, invoice and payment history</h1>
      <p class="mt-4 max-w-3xl text-white/65">
        Read-only commercial history for mapped client sites, with pending quote approval actions where applicable.
      </p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto grid max-w-7xl gap-6">
      {loadError && <p class="border border-red-300 bg-red-50 p-4 text-red-800">{loadError}</p>}

      <div class="grid gap-4 md:grid-cols-3">
        <article class="border border-kharon-border bg-white p-4 sm:p-5">
          <p class="text-xs font-bold uppercase text-kharon-purple">Pending approval</p>
          <p class="mt-2 text-2xl font-bold">R {totals.pending.toFixed(2)}</p>
        </article>
        <article class="border border-kharon-border bg-white p-4 sm:p-5">
          <p class="text-xs font-bold uppercase text-kharon-red">Unpaid invoices</p>
          <p class="mt-2 text-2xl font-bold">R {totals.unpaid.toFixed(2)}</p>
        </article>
        <article class="border border-kharon-border bg-white p-4 sm:p-5">
          <p class="text-xs font-bold uppercase text-kharon-blue">Paid in Sage</p>
          <p class="mt-2 text-2xl font-bold">R {totals.settled.toFixed(2)}</p>
        </article>
      </div>

      <section class="border border-kharon-border bg-white p-4 sm:p-5">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="text-xs font-bold uppercase text-kharon-purple">Mapped sites</p>
            <h2 class="mt-2 text-xl font-bold">Commercial scope</h2>
          </div>
          <a class="rounded-md border border-kharon-purple px-4 py-2 text-sm font-semibold text-kharon-purple" href="/portal/client/dashboard">
            Back to systems
          </a>
        </div>
        <div class="mt-5 grid gap-3 md:grid-cols-2">
          {sites.map((site) => (
            <article class="border-l-4 border-kharon-blue bg-kharon-light p-4">
              <p class="font-semibold">{site.owner_company_name}</p>
              <p class="mt-1 text-sm text-kharon-grey">{site.physical_address}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="border border-kharon-border bg-white">
        <div class="border-b border-kharon-border p-4 sm:p-5">
          <h2 class="text-xl font-bold">Commercial ledger</h2>
          <p class="mt-2 text-sm text-kharon-grey">Records reflect Sage document status. Official quotes and invoices are issued from Sage.</p>
        </div>
        <div class="portal-scroll-x">
          <table class="w-full min-w-[760px] border-collapse text-left text-sm">
            <thead class="bg-kharon-charcoal text-white">
              <tr>
                <th class="p-4">Site</th>
                <th class="p-4">Reference</th>
                <th class="p-4">Type</th>
                <th class="p-4">Status</th>
                <th class="p-4">Amount</th>
                <th class="p-4">Date</th>
                <th class="p-4">Job</th>
                <th class="p-4">Action</th>
              </tr>
            </thead>
            <tbody>
              {records.length === 0 && (
                <tr><td class="p-4 text-kharon-grey" colspan="8">No quote, invoice or payment records are available.</td></tr>
              )}
              {records.map((record) => (
                <tr class="border-t border-kharon-border">
                  <td class="p-4 font-semibold">{record.owner_company_name}</td>
                  <td class="p-4">{record.reference || record.id}</td>
                  <td class="p-4">{record.item_type}</td>
                  <td class="p-4">{record.payment_status === "Settled" ? "Paid in Sage" : record.payment_status}</td>
                  <td class="p-4">R {Number(record.amount).toFixed(2)}</td>
                  <td class="p-4">{record.distribution_date}</td>
                  <td class="p-4">{record.job_id || "Not linked"}</td>
                  <td class="p-4">
                    {record.item_type === "Quote" && record.payment_status === "Pending Approval" ? (
                      <button class="rounded-md border border-kharon-purple px-4 py-2 text-sm font-semibold text-kharon-purple" data-quote-id={record.id}>
                        Approve quote
                      </button>
                    ) : (
                      <span class="text-xs uppercase text-kharon-grey/70">No action</span>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </section>

  <script is:inline>
    for (const button of document.querySelectorAll("[data-quote-id]")) {
      button.addEventListener("click", async () => {
        button.setAttribute("disabled", "true");
        const response = await window.kharonPortalFetch("/portal/api/approve-quote", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ recordId: button.getAttribute("data-quote-id") })
        });
        const result = await response.json();
        if (!response.ok || !result.ok) {
          button.removeAttribute("disabled");
          button.textContent = result.message || "Approval failed";
          button.classList.add("border-red-600", "text-red-700");
          return;
        }
        button.textContent = "Approved";
        button.classList.remove("border-kharon-purple", "text-kharon-purple");
        button.classList.add("border-kharon-blue", "text-kharon-blue");
      });
    }
  </script>
</PortalLayout>
