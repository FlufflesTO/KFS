---
import { auditError } from "../../../lib/server/audit";
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import { clientSites, inClause, type ClientSite } from "../../../lib/server/access";
import { formatCurrency } from "../../../lib/utils/financial-utils.ts";

export const prerender = false;

const user = Astro.locals.user;
interface ClientQuoteRecord {
  id: string;
  site_id: string;
  amount: number;
  item_type: string;
  payment_status: string;
  finance_task_status: string | null;
  distribution_date: string;
  reference: string | null;
  owner_company_name: string;
  job_id: string | null;
  job_status: string | null;
}

let sites: ClientSite[] = [];
let records: ClientQuoteRecord[] = [];
let totals = { pending: 0, unpaid: 0, settled: 0 };
let loadError = "";
let db: any = null;

try {
  db = getDatabase();
  sites = await clientSites(db, user);
  const siteIds = sites.map((site) => site.id);
  if (siteIds.length === 0) {
    loadError = "This client account is not mapped to a site.";
  } else {
    const sitePlaceholders = inClause(siteIds);

    const [aggResult, recordsResult] = await db.batch([
      db.prepare(
        `SELECT
           COALESCE(SUM(CASE WHEN payment_status = 'Pending Approval' THEN amount ELSE 0 END), 0) AS pending,
           COALESCE(SUM(CASE WHEN payment_status = 'Unpaid'           THEN amount ELSE 0 END), 0) AS unpaid,
           COALESCE(SUM(CASE WHEN payment_status = 'Settled'          THEN amount ELSE 0 END), 0) AS settled
         FROM financial_records
         WHERE site_id IN (${sitePlaceholders})`
      ).bind(...siteIds),
      db.prepare(
        `SELECT financial_records.id, financial_records.site_id, financial_records.amount,
                financial_records.item_type, financial_records.payment_status,
                financial_records.finance_task_status,
                financial_records.distribution_date, financial_records.reference,
                sites.owner_company_name, jobs.id AS job_id, jobs.status AS job_status
         FROM financial_records
         INNER JOIN sites ON sites.id = financial_records.site_id
         LEFT JOIN jobs ON jobs.id = financial_records.job_id AND jobs.deleted_at IS NULL
         WHERE financial_records.site_id IN (${sitePlaceholders})
         ORDER BY financial_records.distribution_date DESC, financial_records.created_at DESC
         LIMIT 120`
      ).bind(...siteIds)
    ]);

    interface ClientAgg {
      pending?: number;
      unpaid?: number;
      settled?: number;
    }
    const agg = (aggResult.results[0] as ClientAgg | undefined) || {};
    totals = {
      pending: Number(agg.pending ?? 0),
      unpaid:  Number(agg.unpaid  ?? 0),
      settled: Number(agg.settled ?? 0)
    };
    records = (recordsResult.results || []) as unknown as ClientQuoteRecord[];
  }
} catch (error) {
  await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "client_quotes" });
  loadError = "Client quote history could not be loaded.";
}
---

<PortalLayout title="Quote History | Kharon Portal" active="client-quotes" user={user}>
  <section class="bg-kharon-black px-4 py-8 text-white sm:px-6 sm:py-10">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-bold uppercase text-kharon-purple">Client commercial records</p>
      <h1 class="mt-3 text-2xl font-bold sm:text-3xl">Quote, invoice and payment history</h1>
      <p class="mt-4 max-w-3xl text-white/65">
        Read-only commercial history for mapped client sites, with pending quote approval actions where applicable.
      </p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto grid max-w-7xl gap-6">
      {loadError && <p class="rounded border border-kharon-red/40 bg-kharon-red/10 px-4 py-3 text-sm font-semibold text-kharon-red">{loadError}</p>}

      <div class="grid gap-4 md:grid-cols-3">
        <article class="kharon-surface p-4 sm:p-5">
          <p class="text-xs font-bold uppercase tracking-wider text-kharon-purple">Pending approval</p>
          <p class="mt-2 text-2xl font-bold text-white">{formatCurrency(totals.pending)}</p>
        </article>
        <article class="kharon-surface p-4 sm:p-5">
          <p class="text-xs font-bold uppercase tracking-wider text-kharon-red">Unpaid invoices</p>
          <p class="mt-2 text-2xl font-bold text-white">{formatCurrency(totals.unpaid)}</p>
        </article>
        <article class="kharon-surface p-4 sm:p-5">
          <p class="text-xs font-bold uppercase tracking-wider text-kharon-blue">Paid in Sage</p>
          <p class="mt-2 text-2xl font-bold text-white">{formatCurrency(totals.settled)}</p>
        </article>
      </div>

      <section class="kharon-surface p-4 sm:p-5">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="text-xs font-bold uppercase tracking-wider text-kharon-purple">Mapped sites</p>
            <h2 class="mt-2 text-xl font-bold text-white font-heading">Commercial scope</h2>
          </div>
          <a class="kharon-secondary-button py-2 text-xs" href="/portal/client/dashboard">
            ← Dashboard
          </a>
        </div>
        <div class="mt-5 grid gap-3 md:grid-cols-2">
          {sites.map((site) => (
            <article class="border-l-4 border-kharon-blue bg-surface-charcoal/60 border border-transparent p-4 rounded">
              <p class="font-semibold text-white">{site.owner_company_name}</p>
              <p class="mt-1 text-sm text-white/70">{site.physical_address}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="kharon-surface overflow-hidden">
        <div class="border-b border-line-cyan-soft p-4 sm:p-5">
          <h2 class="text-xl font-bold text-white font-heading">Commercial ledger</h2>
          <p class="mt-2 text-sm text-white/60">Records reflect Sage document status. Official quotes and invoices are issued from Sage.</p>
        </div>
        <div class="flex flex-wrap items-end gap-4 px-4 py-4 sm:px-5 border-b border-line-cyan-soft bg-surface-charcoal/40">
          <div class="grid gap-1">
            <label for="quotes-search" class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple">Search Site/Ref</label>
            <input
              id="quotes-search"
              type="search"
              class="kharon-field min-w-[200px]"
              placeholder="Search site or reference…"
            />
          </div>
          <div class="grid gap-1">
            <label for="quotes-status-filter" class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple">Status</label>
            <select id="quotes-status-filter" class="kharon-field">
              <option value="">All statuses</option>
              <option value="Pending Approval">Pending approval</option>
              <option value="Unpaid">Unpaid</option>
              <option value="Settled">Paid in Sage</option>
              <option value="Declined">Declined</option>
            </select>
          </div>
          <div class="grid gap-1">
            <label for="quotes-type-filter" class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple">Type</label>
            <select id="quotes-type-filter" class="kharon-field">
              <option value="">All types</option>
              <option value="Quote">Quote</option>
              <option value="Invoice">Invoice</option>
            </select>
          </div>
        </div>
        <p id="quotes-no-results" class="hidden px-4 py-3 text-sm text-white/70 sm:px-5">No records match your filter.</p>
        <div class="portal-scroll-x overflow-x-auto">
          <table class="kharon-table w-full min-w-[760px]">
            <thead>
              <tr>
                <th class="p-4">Site</th>
                <th class="p-4">Reference</th>
                <th class="p-4">Type</th>
                <th class="p-4">Status</th>
                <th class="p-4">Amount</th>
                <th class="p-4">Date</th>
                <th class="p-4">Job</th>
                <th class="p-4">Action</th>
              </tr>
            </thead>
            <tbody id="quotes-tbody">
              {records.length === 0 && (
                <tr><td class="p-4 text-white/70" colspan="8">No quote, invoice or payment records are available.</td></tr>
              )}
              {records.map((record) => (
                <tr
                  class="border-t border-line-cyan-soft hover:bg-surface-charcoal/20"
                  data-search={`${record.owner_company_name} ${record.reference || ""} ${record.item_type}`}
                  data-status={record.payment_status}
                  data-type={record.item_type}
                >
                  <td class="p-4 font-semibold text-white">{record.owner_company_name}</td>
                  <td class="p-4 font-mono">{record.reference || record.id}</td>
                  <td class="p-4">{record.item_type}</td>
                  <td class="p-4">
                    {record.finance_task_status === "Approved - Sage Invoice Required"
                      ? "Approved - Sage invoice required"
                      : record.payment_status === "Settled"
                        ? "Paid in Sage"
                        : record.payment_status}
                  </td>
                  <td class="p-4 font-mono text-white">{formatCurrency(Number(record.amount))}</td>
                  <td class="p-4">{record.distribution_date}</td>
                  <td class="p-4 font-mono">{record.job_id || "Not linked"}</td>
                  <td class="p-4">
                    {record.item_type === "Quote" && record.payment_status === "Pending Approval" && record.finance_task_status !== "Approved - Sage Invoice Required" ? (
                      <div class="flex gap-2">
                        <button class="kharon-command-button py-1.5 px-3 text-xs" data-quote-id={record.id} data-action="approved">
                          Approve
                        </button>
                        <button class="rounded border border-kharon-red/60 bg-kharon-red/10 px-3 py-1.5 text-xs font-semibold text-red-300 hover:bg-kharon-red/20" data-quote-id={record.id} data-action="rejected">
                          Decline
                        </button>
                      </div>
                    ) : (
                      <span class="text-xs uppercase text-white/40">No action</span>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </section>

  <script>
    const quotesSearch       = document.getElementById("quotes-search") as HTMLInputElement | null;
    const quotesStatusFilter = document.getElementById("quotes-status-filter") as HTMLSelectElement | null;
    const quotesTypeFilter   = document.getElementById("quotes-type-filter") as HTMLSelectElement | null;
    const quotesTbody        = document.getElementById("quotes-tbody");
    const quotesNoResults    = document.getElementById("quotes-no-results");

    function applyQuotesFilter() {
      if (!quotesTbody) return;
      const q  = (quotesSearch?.value  || "").toLowerCase().trim();
      const sv = quotesStatusFilter?.value || "";
      const tv = quotesTypeFilter?.value   || "";
      const rows = quotesTbody.querySelectorAll<HTMLTableRowElement>("tr[data-search]");
      let visible = 0;
      for (const row of rows) {
        const text = (row.dataset.search ?? "").toLowerCase();
        const show =
          (!q  || text.includes(q)) &&
          (!sv || (row.dataset.status ?? "") === sv) &&
          (!tv || (row.dataset.type   ?? "") === tv);
        row.style.display = show ? "" : "none";
        if (show) visible++;
      }
      if (quotesNoResults) quotesNoResults.style.display = visible === 0 ? "" : "none";
    }

    quotesSearch?.addEventListener("input",  applyQuotesFilter);
    quotesStatusFilter?.addEventListener("change", applyQuotesFilter);
    quotesTypeFilter?.addEventListener("change",   applyQuotesFilter);

    const params = new URLSearchParams(window.location.search);
    if (params.get("filter") === "pending" && quotesStatusFilter) {
      quotesStatusFilter.value = "Pending Approval";
      applyQuotesFilter();
    }
  </script>
  <script is:inline>
    for (const button of document.querySelectorAll("[data-quote-id]")) {
      button.addEventListener("click", async () => {
        const quoteId = button.getAttribute("data-quote-id");
        const action = button.getAttribute("data-action") || "approved";
        const isDecline = action === "rejected";
        const confirmMsg = isDecline
          ? `Decline Quote ${quoteId}? This will notify the finance team that the quote was not accepted.`
          : `Approve Quote ${quoteId}? This will trigger the Sage invoicing workflow.`;
        if (!window.confirm(confirmMsg)) return;

        const row = button.closest("tr");
        const allButtons = row ? row.querySelectorAll("[data-quote-id]") : [button];
        for (const b of allButtons) b.setAttribute("disabled", "true");
        button.textContent = isDecline ? "Declining..." : "Approving...";

        try {
          const response = await window.kharonPortalFetch("/portal/api/approve-quote", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ recordId: quoteId, status: action })
          });
          const result = await response.json();
          if (!response.ok || !result.ok) {
            for (const b of allButtons) b.removeAttribute("disabled");
            button.textContent = result.message || (isDecline ? "Decline failed" : "Approval failed");
            button.className = "rounded border border-kharon-red bg-kharon-red/10 px-3 py-1.5 text-xs font-semibold text-red-200";
            return;
          }
          if (row) {
            const cell = row.querySelector("td:last-child");
            if (cell) {
              const span = document.createElement("span");
              span.className = isDecline
                ? "text-xs font-semibold uppercase text-red-300"
                : "text-xs font-semibold uppercase text-green-300";
              span.textContent = isDecline ? "Declined" : "Approved";
              cell.replaceChildren(span);
            }
          }
        } catch {
          for (const b of allButtons) b.removeAttribute("disabled");
          button.textContent = "Network Error";
          button.className = "rounded border border-kharon-red bg-kharon-red/10 px-3 py-1.5 text-xs font-semibold text-red-200";
        }
      });
    }
  </script>
</PortalLayout>
