---
/**
 * Project Sentinel - Technician Upcoming Schedule
 * Purpose: Lists all upcoming jobs (scheduled_date > today) assigned to the current technician.
 * Dependencies: PortalLayout component, D1 database, OfflineBanner, auditError.
 * Structural Role: Extended schedule view linked from the technician dashboard.
 */
import { auditError } from "../../../lib/server/audit";
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import OfflineBanner from "../../../components/portal/OfflineBanner.astro";
import { JobService, type TechJob } from "../../../lib/server/services/job-service";

export const prerender = false;

const user = Astro.locals.user;
let upcomingJobs: TechJob[] = [];
let loadError = "";
const today = new Date().toISOString().slice(0, 10);

try {
  const db = getDatabase();
  const service = new JobService(db);
  upcomingJobs = await service.getUpcomingSchedule(user?.id || "", user?.role || "", today);
} catch (error) {
  await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "tech_schedule" });
  loadError = "Upcoming schedule could not be loaded.";
}

function priorityBadgeClass(priority: string): string {
  if (priority === "Critical") return "bg-kharon-red/20 text-kharon-red border border-kharon-red/30";
  if (priority === "High") return "bg-kharon-amber/20 text-kharon-amber border border-kharon-amber/30";
  return "bg-kharon-purple/20 text-kharon-purple border border-kharon-purple/30";
}
---

<PortalLayout title="Upcoming Schedule | Kharon Portal" active="tech-schedule" user={user}>
  <OfflineBanner initialQueueCount={0} />

  <section class="bg-gradient-to-br from-kharon-black to-kharon-charcoal px-4 py-8 text-white sm:px-6 sm:py-10 kharon-environment kharon-logo-watermark relative overflow-hidden rounded-xl border border-kharon-purple/10 mb-6">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(75,46,131,0.1),transparent)]"></div>
    <div class="mx-auto max-w-7xl relative z-10">
      <a href="/portal/tech/dashboard" class="inline-flex items-center gap-1.5 text-base font-bold uppercase tracking-[0.15em] text-kharon-cyan hover:text-white transition-colors mb-5">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Today's Dispatches
      </a>
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-kharon-purple/10 ring-1 ring-kharon-purple/20">
          <svg class="h-4.5 w-4.5 text-kharon-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <p class="text-base font-black uppercase tracking-[0.2em] text-kharon-cyan">Field Schedule</p>
      </div>
      <h1 class="text-2xl font-black sm:text-3xl tracking-tight text-white">Upcoming Schedule</h1>
      <p class="mt-2 max-w-2xl text-base text-kharon-light/60">
        Your scheduled fieldwork for the coming weeks.
      </p>
    </div>
  </section>

  <section class="px-1 py-4 sm:px-4">
    <div class="mx-auto max-w-7xl">

      {loadError && (
        <div class="rounded-lg border border-kharon-red/30 bg-kharon-red/10 p-4 mb-6">
          <p class="text-base font-bold text-kharon-red">{loadError}</p>
        </div>
      )}

      {!loadError && (
        <div class="rounded-xl border border-kharon-purple/20 bg-kharon-charcoal/80 p-5 text-center shadow-lg shadow-black/30 backdrop-blur-md relative overflow-hidden mb-8 max-w-xs">
          <div class="absolute top-0 right-0 h-16 w-16 bg-kharon-purple/5 rounded-bl-full pointer-events-none"></div>
          <p class="text-base font-bold uppercase tracking-widest text-kharon-purple mb-1.5">Total Upcoming</p>
          <p class="text-3xl font-black text-white">{upcomingJobs.length}</p>
          <div class="mt-2.5 flex items-center justify-center gap-1.5">
            <span class="h-2 w-2 rounded-full bg-kharon-purple/50"></span>
            <span class="text-base font-bold uppercase tracking-wider text-white/50">Scheduled queue</span>
          </div>
        </div>
      )}

      {upcomingJobs.length === 0 && !loadError && (
        <div class="rounded-xl border border-kharon-purple/20 bg-kharon-charcoal/60 p-8 text-center backdrop-blur-md">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-kharon-purple/10 mb-4 ring-1 ring-kharon-purple/20">
            <svg class="h-12 w-12 text-kharon-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <p class="text-lg font-black text-white">No upcoming jobs</p>
          <p class="mt-2 text-base text-kharon-light/70 max-w-sm mx-auto">
            You have no scheduled fieldwork beyond today. Contact the administration team if you expect jobs to appear here.
          </p>
        </div>
      )}

      <div class="space-y-4">
        {upcomingJobs.map((job) => (
          <article class="rounded-xl border border-kharon-purple/15 bg-kharon-charcoal/60 p-5 shadow-md backdrop-blur-md relative overflow-hidden transition-all duration-300 hover:border-kharon-purple/35">
            <div class="flex flex-wrap items-center gap-2 mb-3">
              <span class={`rounded-full px-2.5 py-0.5 text-base font-bold uppercase tracking-widest ${priorityBadgeClass(job.priority || "Normal")}`}>{job.priority || "Normal"}</span>
              <span class="rounded-full bg-kharon-purple/20 text-kharon-purple border border-kharon-purple/30 px-2.5 py-0.5 text-base font-bold uppercase tracking-widest">{job.status}</span>
            </div>

            <h2 class="text-lg font-black text-white/90 tracking-tight">{job.owner_company_name}</h2>
            <p class="text-base font-semibold text-kharon-purple mt-1">{job.system_type} | {job.coverage_area}</p>

            <div class="mt-4 grid grid-cols-2 gap-4 border-t border-kharon-purple/10 pt-4">
              <div>
                <p class="text-base font-bold uppercase tracking-wider text-kharon-purple mb-1">Scheduled Date</p>
                <p class="text-base font-semibold text-white/80">{job.scheduled_date}</p>
              </div>
              <div>
                <p class="text-base font-bold uppercase tracking-wider text-kharon-purple mb-1">Job Type</p>
                <p class="text-base font-semibold text-white/80">{job.job_type}</p>
              </div>
            </div>

            <div class="mt-4">
              <a href={`/portal/tech/jobs/${job.id}`} class="block w-full px-4 py-2.5 border border-kharon-purple/30 text-kharon-cyan hover:bg-kharon-purple/10 text-center font-bold text-base uppercase tracking-widest rounded-md transition-colors min-h-[44px] flex items-center justify-center">
                View Details
              </a>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>
</PortalLayout>
