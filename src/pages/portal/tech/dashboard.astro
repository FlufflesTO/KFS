---
/**
 * Project Sentinel - Technician Dashboard
 * Purpose: Lists dispatches assigned to the currently authenticated technician, split by action items and upcoming dispatches with premium glassmorphism.
 * Dependencies: PortalLayout component, D1 database, OfflineBanner, statusBadge helper.
 * Structural Role: Operational workspace view for technicians.
 */
import { auditError } from "../../../lib/server/audit";
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import OfflineBanner from "../../../components/portal/OfflineBanner.astro";
import PortalQuickActions from "../../../components/portal/PortalQuickActions.astro";

export const prerender = false;

const user = Astro.locals.user;
let jobs: Array<any> = [];
let loadError = "";
const today = new Date().toISOString().slice(0, 10);

const techActions = [
  { label: "Job History", href: "/portal/tech/history", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />`, accent: "purple" as const },
  { label: "Password Reset", href: "/portal/account/password", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />`, accent: "cyan" as const },
  { label: "Emergency", href: "/emergency-support", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />`, accent: "amber" as const },
  { label: "Open Map", href: "https://maps.google.com", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />`, accent: "green" as const }
];

try {
  const db = getDatabase();
  const query = user?.role === "admin"
    ? `SELECT jobs.id, jobs.system_id, jobs.scheduled_date, jobs.status, jobs.site_notes,
              jobs.job_type, jobs.priority, jobs.required_by_date, jobs.is_emergency,
              systems.system_type, systems.coverage_area,
              sites.owner_company_name, sites.physical_address
       FROM jobs
       INNER JOIN systems ON systems.id = jobs.system_id
       INNER JOIN sites ON sites.id = systems.site_id
       WHERE jobs.deleted_at IS NULL AND systems.deleted_at IS NULL
         AND jobs.status IN ('Scheduled', 'In Progress')
       ORDER BY jobs.scheduled_date ASC
       LIMIT 100`
    : `SELECT jobs.id, jobs.system_id, jobs.scheduled_date, jobs.status, jobs.site_notes,
              jobs.job_type, jobs.priority, jobs.required_by_date, jobs.is_emergency,
              systems.system_type, systems.coverage_area,
              sites.owner_company_name, sites.physical_address
       FROM jobs
       INNER JOIN systems ON systems.id = jobs.system_id
       INNER JOIN sites ON sites.id = systems.site_id
       WHERE jobs.deleted_at IS NULL AND systems.deleted_at IS NULL
         AND jobs.assigned_technician_id = ?1 AND jobs.status IN ('Scheduled', 'In Progress')
       ORDER BY jobs.scheduled_date ASC
       LIMIT 100`;

  const result = user?.role === "admin"
    ? await db.prepare(query).all()
    : await db.prepare(query).bind(user?.id).all();
  jobs = result.results || [];
} catch (error) {
  await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "tech_dashboard" });
  loadError = "Assigned dispatches could not be loaded.";
}

const actionJobs = jobs.filter((j: any) => j.scheduled_date <= today);
const upcomingJobs = jobs.filter((j: any) => j.scheduled_date > today);
const todayCount = jobs.filter((j: any) => j.scheduled_date === today).length;
const inProgressCount = jobs.filter((j: any) => j.status === "In Progress").length;

function priorityBadgeClass(priority: string): string {
  if (priority === "Critical") return "bg-kharon-red/20 text-kharon-red border border-kharon-red/30";
  if (priority === "High") return "bg-kharon-amber/20 text-kharon-amber border border-kharon-amber/30";
  return "bg-kharon-purple/20 text-kharon-purple border border-kharon-purple/30";
}
---

<PortalLayout title="Technician Dispatches | Kharon Portal" active="tech" user={user}>
  <OfflineBanner initialQueueCount={0} />
  
  <section class="bg-gradient-to-br from-kharon-black to-kharon-charcoal px-4 py-8 text-white sm:px-6 sm:py-10 kharon-environment kharon-logo-watermark relative overflow-hidden rounded-xl border border-kharon-purple/10 mb-6">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(75,46,131,0.1),transparent)]"></div>
    <div class="mx-auto max-w-7xl relative z-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-kharon-purple/10 ring-1 ring-kharon-purple/20">
          <svg class="h-4.5 w-4.5 text-kharon-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <p class="text-xs font-black uppercase tracking-[0.2em] text-kharon-cyan">Technician Console</p>
      </div>
      <h1 class="text-2xl font-black sm:text-3xl tracking-tight text-white">Field Operations Command</h1>
      <p class="mt-2 max-w-2xl text-sm text-kharon-light/60">
        Review assigned fieldwork, log arrival times, capture forensic evidence, and submit completed jobcards.
      </p>
    </div>
  </section>

  {/* ── Feature Navigation Hub ── */}
  <section class="px-1 pb-2 pt-0 sm:px-4 sm:pb-4">
    <div class="mx-auto max-w-7xl">
      <h2 class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple/80 mb-4 px-1">Field Command Matrix</h2>
      <PortalQuickActions actions={techActions} />
    </div>
  </section>

  <section id="action-required" class="px-1 py-4 sm:px-4">
    <div class="mx-auto max-w-7xl">
      {loadError && (
        <div class="rounded-lg border border-kharon-red/30 bg-kharon-red/10 p-4 mb-6">
          <p class="text-sm font-bold text-kharon-red">{loadError}</p>
        </div>
      )}

      {!loadError && jobs.length > 0 && (
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 mb-8">
          <div class="rounded-xl border border-kharon-purple/20 bg-kharon-charcoal/80 p-5 text-center shadow-lg shadow-black/30 backdrop-blur-md relative overflow-hidden group hover:border-kharon-purple/40 transition-all duration-300">
            <div class="absolute top-0 right-0 h-16 w-16 bg-kharon-purple/5 rounded-bl-full pointer-events-none"></div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple mb-1.5">Today's Dispatch</p>
            <p class="text-3xl font-black text-white">{todayCount}</p>
            <div class="mt-2.5 flex items-center justify-center gap-1.5">
              <span class="h-2 w-2 rounded-full bg-kharon-cyan animate-pulse"></span>
              <span class="text-[10px] font-bold uppercase tracking-wider text-kharon-cyan">Ready for field</span>
            </div>
          </div>
          <div class="rounded-xl border border-kharon-purple/20 bg-kharon-charcoal/80 p-5 text-center shadow-lg shadow-black/30 backdrop-blur-md relative overflow-hidden group hover:border-kharon-purple/40 transition-all duration-300">
            <div class="absolute top-0 right-0 h-16 w-16 bg-kharon-blue/5 rounded-bl-full pointer-events-none"></div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple mb-1.5">Upcoming Schedule</p>
            <p class="text-3xl font-black text-white">{upcomingJobs.length}</p>
            <div class="mt-2.5 flex items-center justify-center gap-1.5">
              <span class="h-2 w-2 rounded-full bg-kharon-purple/50"></span>
              <span class="text-[10px] font-bold uppercase tracking-wider text-white/50">Scheduled queue</span>
            </div>
          </div>
          <div class="rounded-xl border border-kharon-purple/20 bg-kharon-charcoal/80 p-5 text-center shadow-lg shadow-black/30 backdrop-blur-md relative overflow-hidden group hover:border-kharon-purple/40 transition-all duration-300">
            <div class="absolute top-0 right-0 h-16 w-16 bg-kharon-cyan/5 rounded-bl-full pointer-events-none"></div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-kharon-purple mb-1.5">Active In-Progress</p>
            <p class="text-3xl font-black text-kharon-cyan">{inProgressCount}</p>
            <div class="mt-2.5 flex items-center justify-center gap-1.5">
              <span class="h-2 w-2 rounded-full bg-kharon-green animate-pulse"></span>
              <span class="text-[10px] font-bold uppercase tracking-wider text-kharon-green">Live monitoring</span>
            </div>
          </div>
        </div>
      )}

      {jobs.length === 0 && !loadError && (
        <div class="rounded-xl border border-kharon-purple/20 bg-kharon-charcoal/60 p-8 text-center backdrop-blur-md">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-kharon-purple/10 mb-4 ring-1 ring-kharon-purple/20">
            <svg class="h-8 w-8 text-kharon-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <p class="text-lg font-black text-white">No dispatches assigned</p>
          <p class="mt-2 text-sm text-kharon-light/70 max-w-sm mx-auto">
            You currently have no scheduled dispatches. Contact the administration team if you expect jobs to appear here.
          </p>
        </div>
      )}

      {actionJobs.length > 0 && (
        <div class="mt-6 flex items-center gap-3 mb-4">
          <div class="flex items-center justify-center rounded-lg bg-kharon-purple/10 p-2 ring-1 ring-kharon-purple/20">
            <span class="h-2.5 w-2.5 rounded-full bg-kharon-cyan animate-pulse"></span>
          </div>
          <h2 class="text-xs font-black uppercase tracking-[0.15em] text-kharon-cyan">Action Required Today</h2>
        </div>
      )}

      <div class="space-y-6">
        {actionJobs.map((job) => {
          const isEmergency = job.is_emergency === 1;
          return (
            <article class={`rounded-xl border bg-kharon-charcoal/80 p-6 shadow-xl backdrop-blur-md relative overflow-hidden transition-all duration-300 ${isEmergency ? 'border-kharon-red/40 hover:border-kharon-red/60 shadow-kharon-red/5' : 'border-kharon-purple/25 hover:border-kharon-purple/40 shadow-black/30'}`}>
              {isEmergency && (
                <div class="absolute top-0 right-0 bg-kharon-red px-3 py-1 text-[10px] font-black uppercase tracking-widest text-white shadow-md flex items-center gap-1 z-10 rounded-bl-lg">
                  <span class="h-1.5 w-1.5 rounded-full bg-kharon-charcoal animate-pulse"></span>
                  Emergency dispatch
                </div>
              )}
              
              <div class="flex flex-wrap items-center gap-2 mb-4">
                <span class={`rounded-full px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-widest ${priorityBadgeClass(job.priority || "Normal")}`}>{job.priority || "Normal"}</span>
                <span class={`rounded-full px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-widest ${job.status === 'In Progress' ? 'bg-kharon-cyan/20 text-kharon-cyan border border-kharon-cyan/30' : 'bg-kharon-blue/20 text-kharon-blue border border-kharon-blue/30'}`}>{job.status}</span>
                {job.required_by_date && (
                  <span class="text-[10px] font-bold text-kharon-amber flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Required by {job.required_by_date}
                  </span>
                )}
              </div>
              
              <h2 class="text-xl font-black text-white tracking-tight">{job.owner_company_name}</h2>
              <p class="text-xs font-bold text-kharon-cyan uppercase tracking-wider mt-1">{job.system_type} | {job.coverage_area}</p>
              
              <div class="mt-4 flex items-start gap-2.5 text-white/90 bg-kharon-black/40 p-3.5 rounded-lg border border-kharon-purple/10">
                <svg class="h-4.5 w-4.5 shrink-0 mt-0.5 text-kharon-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span class="text-xs leading-relaxed font-medium">{job.physical_address}</span>
              </div>
              
              <div class="mt-4 grid grid-cols-2 gap-4 border-t border-kharon-purple/10 pt-4">
                <div>
                  <p class="text-[10px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Dispatch Type</p>
                  <p class="text-xs font-bold text-white/90">{job.job_type}</p>
                </div>
                <div>
                  <p class="text-[10px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Scheduled Date</p>
                  <p class="text-xs font-bold text-white/90">{job.scheduled_date}</p>
                </div>
                <div class="col-span-2">
                  <p class="text-[10px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Dispatch Core ID</p>
                  <p class="text-[10px] font-mono font-bold text-white/55 break-all">{job.id}</p>
                </div>
              </div>
              
              {job.site_notes && (
                <div class="mt-4 rounded-lg border border-kharon-purple/20 bg-kharon-purple/5 p-4 text-xs text-white relative overflow-hidden">
                  <div class="absolute top-0 left-0 w-1 h-full bg-kharon-cyan"></div>
                  <p class="font-bold text-[10px] text-kharon-cyan uppercase tracking-widest mb-1.5">Site Instructions</p>
                  <p class="leading-relaxed text-white/85 font-medium">{job.site_notes}</p>
                </div>
              )}
              
              <div class="mt-5 flex flex-col sm:flex-row gap-3">
                <a href={`/portal/tech/jobs/${job.id}`} class="flex-1 px-4 py-3 bg-gradient-to-r from-kharon-purple to-kharon-blue text-white font-bold text-xs uppercase tracking-widest rounded-md text-center hover:shadow-lg hover:shadow-kharon-purple/30 transition-all min-h-[44px] flex items-center justify-center">
                  Open Job Workspace
                </a>
                
                {job.physical_address && (
                  <a href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(String(job.physical_address))}`} target="_blank" rel="noopener noreferrer" class="flex-1 px-4 py-3 border border-kharon-purple/30 text-kharon-cyan font-bold text-xs uppercase tracking-widest rounded-md text-center hover:bg-kharon-purple/10 transition-colors min-h-[44px] flex items-center justify-center gap-1.5">
                    <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                    </svg>
                    Navigate to Site
                  </a>
                )}
              </div>
            </article>
          );
        })}
      </div>

      {upcomingJobs.length > 0 && (
        <div class="mt-8 flex items-center gap-3 mb-4">
          <div class="flex items-center justify-center rounded-lg bg-kharon-purple/10 p-2 ring-1 ring-kharon-purple/25">
            <svg class="h-4.5 w-4.5 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h2 class="text-xs font-black uppercase tracking-[0.15em] text-white/70">Upcoming Fieldwork</h2>
        </div>
      )}

      <div class="space-y-4">
        {upcomingJobs.map((job) => (
          <article class="rounded-xl border border-kharon-purple/15 bg-kharon-charcoal/60 p-5 shadow-md backdrop-blur-md relative overflow-hidden transition-all duration-300 hover:border-kharon-purple/35">
            <div class="flex flex-wrap items-center gap-2 mb-3">
              <span class={`rounded-full px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-widest ${priorityBadgeClass(job.priority || "Normal")}`}>{job.priority || "Normal"}</span>
              <span class="rounded-full bg-kharon-purple/20 text-kharon-purple border border-kharon-purple/30 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-widest">{job.status}</span>
            </div>
            
            <h2 class="text-lg font-black text-white/90 tracking-tight">{job.owner_company_name}</h2>
            <p class="text-xs font-semibold text-kharon-purple mt-1">{job.system_type} | {job.coverage_area}</p>
            
            <div class="mt-4 grid grid-cols-2 gap-4 border-t border-kharon-purple/10 pt-4">
              <div>
                <p class="text-[10px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Scheduled Date</p>
                <p class="text-xs font-semibold text-white/80">{job.scheduled_date}</p>
              </div>
              <div>
                <p class="text-[10px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Job Type</p>
                <p class="text-xs font-semibold text-white/80">{job.job_type}</p>
              </div>
            </div>
            
            <div class="mt-4">
              <a href={`/portal/tech/jobs/${job.id}`} class="block w-full px-4 py-2.5 border border-kharon-purple/30 text-kharon-cyan hover:bg-kharon-purple/10 text-center font-bold text-xs uppercase tracking-widest rounded-md transition-colors min-h-[44px] flex items-center justify-center">
                View Details
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</PortalLayout>
