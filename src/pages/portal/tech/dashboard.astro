---
import { auditError } from "../../../lib/server/audit";
/**
 * Project Sentinel - Technician Dashboard
 * Purpose: Lists dispatches assigned to the currently authenticated technician, split by action items and upcoming dispatches.
 * Dependencies: PortalLayout component, D1 database, KharonCard, KharonButton.
 * Structural Role: Operational workspace view for technicians.
 */
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import OfflineBanner from "../../../components/portal/OfflineBanner.astro";

export const prerender = false;

const user = Astro.locals.user;
let jobs: Array<any> = [];
let loadError = "";
const today = new Date().toISOString().slice(0, 10);

try {
  const db = getDatabase();
  const query = user?.role === "admin"
    ? `SELECT jobs.id, jobs.system_id, jobs.scheduled_date, jobs.status, jobs.site_notes,
              jobs.job_type, jobs.priority, jobs.required_by_date, jobs.is_emergency,
              systems.system_type, systems.coverage_area,
              sites.owner_company_name, sites.physical_address
       FROM jobs
       INNER JOIN systems ON systems.id = jobs.system_id
       INNER JOIN sites ON sites.id = systems.site_id
       WHERE jobs.deleted_at IS NULL AND systems.deleted_at IS NULL
         AND jobs.status IN ('Scheduled', 'In Progress')
       ORDER BY jobs.scheduled_date ASC
       LIMIT 100`
    : `SELECT jobs.id, jobs.system_id, jobs.scheduled_date, jobs.status, jobs.site_notes,
              jobs.job_type, jobs.priority, jobs.required_by_date, jobs.is_emergency,
              systems.system_type, systems.coverage_area,
              sites.owner_company_name, sites.physical_address
       FROM jobs
       INNER JOIN systems ON systems.id = jobs.system_id
       INNER JOIN sites ON sites.id = systems.site_id
       WHERE jobs.deleted_at IS NULL AND systems.deleted_at IS NULL
         AND jobs.assigned_technician_id = ?1 AND jobs.status IN ('Scheduled', 'In Progress')
       ORDER BY jobs.scheduled_date ASC
       LIMIT 100`;

  const result = user?.role === "admin"
    ? await db.prepare(query).all()
    : await db.prepare(query).bind(user?.id).all();
  jobs = result.results || [];
} catch (error) {
  await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "tech_dashboard" });
  loadError = "Assigned dispatches could not be loaded.";
}

const actionJobs = jobs.filter((j: any) => j.scheduled_date <= today);
const upcomingJobs = jobs.filter((j: any) => j.scheduled_date > today);
const todayCount = jobs.filter((j: any) => j.scheduled_date === today).length;
const inProgressCount = jobs.filter((j: any) => j.status === "In Progress").length;

function priorityBadgeClass(priority: string): string {
  if (priority === "Critical") return "bg-kharon-red/20 text-kharon-red";
  if (priority === "High") return "bg-kharon-amber/20 text-kharon-amber";
  return "bg-kharon-purple/20 text-kharon-purple";
}
---

<PortalLayout title="Technician Dispatches | Kharon Portal" active="tech" user={user}>
  <OfflineBanner initialQueueCount={0} />
  <section class="bg-gradient-to-br from-kharon-black to-kharon-charcoal px-4 py-8 text-white sm:px-6 sm:py-10 kharon-environment kharon-logo-watermark">
    <div class="mx-auto max-w-7xl">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-kharon-purple/10 ring-1 ring-kharon-purple/20">
          <svg class="h-4 w-4 text-kharon-purple" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <p class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Technician Workspace</p>
      </div>
      <h1 class="text-2xl font-bold sm:text-3xl">Active Dispatches</h1>
      <p class="mt-2 max-w-2xl text-sm text-white/70">
        Review assigned fieldwork, log arrival times, capture forensic evidence, and submit completed jobcards seamlessly.
      </p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6">
    <div class="mx-auto max-w-7xl gap-6">
      {loadError && <div class="rounded-lg border border-kharon-red/30 bg-kharon-red/10 p-4 mb-6"><p class="text-sm font-bold text-kharon-red">{loadError}</p></div>}

      {!loadError && jobs.length > 0 && (
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
          <div class="rounded-xl border border-kharon-purple/20 bg-kharon-surface-elevated p-4 kharon-surface text-center">
            <p class="text-xs font-bold uppercase tracking-widest text-kharon-purple mb-1">Today</p>
            <p class="text-2xl font-bold text-white">{todayCount}</p>
          </div>
          <div class="rounded-xl border border-kharon-purple/20 bg-kharon-surface-elevated p-4 kharon-surface text-center">
            <p class="text-xs font-bold uppercase tracking-widest text-kharon-purple mb-1">Upcoming</p>
            <p class="text-2xl font-bold text-white">{upcomingJobs.length}</p>
          </div>
          <div class="rounded-xl border border-kharon-purple/20 bg-kharon-surface-elevated p-4 kharon-surface text-center">
            <p class="text-xs font-bold uppercase tracking-widest text-kharon-purple mb-1">In Progress</p>
            <p class="text-2xl font-bold text-kharon-purple">{inProgressCount}</p>
          </div>
        </div>
      )}

      {jobs.length === 0 && !loadError && (
        <div class="rounded-xl border border-kharon-purple/20 bg-kharon-surface-elevated p-8 text-center kharon-surface">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-kharon-graphite mb-4">
            <svg class="h-8 w-8 text-kharon-light/50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          </div>
          <p class="text-lg font-bold text-white">No dispatches assigned</p>
          <p class="mt-2 text-sm text-kharon-light/70 max-w-sm mx-auto">You currently have no scheduled dispatches. Contact the administration team if you expect jobs to appear here.</p>
        </div>
      )}

      {actionJobs.length > 0 && (
        <div class="mt-6 flex items-center gap-3 mb-4">
          <div class="flex items-center justify-center rounded-lg bg-kharon-purple/10 p-2 ring-1 ring-kharon-purple/20">
            <span class="h-2 w-2 rounded-full bg-kharon-purple animate-pulse"></span>
          </div>
          <h2 class="text-sm font-bold uppercase tracking-widest text-kharon-purple">Action Required Today</h2>
        </div>
      )}

      <div class="space-y-4">
        {actionJobs.map((job) => (
          <article class="rounded-xl border border-kharon-purple/20 bg-kharon-surface-elevated p-4 kharon-surface">
            <div class="flex flex-wrap items-center gap-2 mb-3">
              <span class={`rounded-full px-3 py-1 text-xs font-bold uppercase tracking-widest ${priorityBadgeClass(job.priority || "Normal")}`}>{job.priority || "Normal"}</span>
              {job.is_emergency === 1 && <span class="rounded-full bg-kharon-red/20 text-kharon-red px-3 py-1 text-xs font-bold uppercase tracking-widest flex items-center gap-1"><span class="h-1.5 w-1.5 rounded-full bg-kharon-red animate-pulse"></span>Emergency</span>}
              <span class="rounded-full bg-kharon-blue/20 text-kharon-blue px-3 py-1 text-xs font-bold uppercase tracking-widest">{job.status}</span>
              {job.required_by_date && <span class="text-xs font-bold text-kharon-amber flex items-center gap-1"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>Required by {job.required_by_date}</span>}
            </div>
            
            <h2 class="text-lg font-bold text-white">{job.owner_company_name}</h2>
            <p class="text-sm font-bold text-kharon-purple mt-1">{job.system_type} | {job.coverage_area}</p>
            
            <div class="mt-3 flex items-start gap-2 text-kharon-light/80 bg-kharon-graphite/30 p-3 rounded-lg border border-kharon-purple/10">
              <svg class="h-4 w-4 shrink-0 mt-0.5 text-kharon-purple" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              <span class="text-sm">{job.physical_address}</span>
            </div>
            
            <div class="mt-4 grid grid-cols-2 gap-3 border-t border-kharon-purple/10 pt-3">
              <div><p class="text-xs text-kharon-purple mb-1">Job Type</p><p class="text-sm font-bold text-white">{job.job_type}</p></div>
              <div><p class="text-xs text-kharon-purple mb-1">Scheduled</p><p class="text-sm font-bold text-white">{job.scheduled_date}</p></div>
              <div class="col-span-2"><p class="text-xs text-kharon-purple mb-1">Dispatch ID</p><p class="text-xs font-mono font-bold text-kharon-light/70 break-all">{job.id}</p></div>
            </div>
            
            {job.site_notes && (
              <div class="mt-4 rounded-lg border border-kharon-blue/20 bg-kharon-blue/10 p-3 text-sm text-white relative overflow-hidden kharon-surface">
                <p class="font-bold text-xs text-kharon-blue uppercase tracking-widest mb-1">Site Instructions</p>
                <p class="leading-relaxed">{job.site_notes}</p>
              </div>
            )}
            
            <div class="mt-4 flex flex-col gap-3">
              <a href={`/portal/tech/jobs/${job.id}`} class="w-full px-4 py-3 bg-gradient-to-r from-kharon-purple to-kharon-blue text-white font-bold uppercase tracking-widest rounded-md text-center hover:shadow-lg hover:shadow-kharon-purple/30 transition-all kharon-command-button">
                Open Dispatch
              </a>
              
              {job.physical_address && (
                <a href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(String(job.physical_address))}`} target="_blank" rel="noopener noreferrer" class="w-full px-4 py-3 border border-kharon-purple/30 text-kharon-purple font-bold uppercase tracking-widest rounded-md text-center hover:bg-kharon-purple/10 transition-colors">
                  Navigate to Site
                </a>
              )}
            </div>
          </article>
        ))}
      </div>

      {upcomingJobs.length > 0 && (
        <div class="mt-8 flex items-center gap-3 mb-4">
          <div class="flex items-center justify-center rounded-lg bg-kharon-light/20 p-2">
            <svg class="h-3 w-3 text-kharon-light/60" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
          </div>
          <h2 class="text-sm font-bold uppercase tracking-widest text-kharon-light/70">Upcoming Fieldwork</h2>
        </div>
      )}

      <div class="space-y-4">
        {upcomingJobs.map((job) => (
          <article class="rounded-xl border border-kharon-purple/10 bg-kharon-surface-elevated p-4 kharon-surface">
            <div class="flex flex-wrap items-center gap-2 mb-3">
              <span class={`rounded-full px-3 py-1 text-xs font-bold uppercase tracking-widest ${priorityBadgeClass(job.priority || "Normal")}`}>{job.priority || "Normal"}</span>
              {job.is_emergency === 1 && <span class="rounded-full bg-kharon-red/20 text-kharon-red px-3 py-1 text-xs font-bold uppercase tracking-widest flex items-center gap-1"><span class="h-1.5 w-1.5 rounded-full bg-kharon-red animate-pulse"></span>Emergency</span>}
              <span class="rounded-full bg-kharon-purple/20 text-kharon-purple px-3 py-1 text-xs font-bold uppercase tracking-widest">{job.status}</span>
            </div>
            
            <h2 class="text-lg font-bold text-white">{job.owner_company_name}</h2>
            <p class="text-sm font-bold text-kharon-purple/80 mt-1">{job.system_type} | {job.coverage_area}</p>
            
            <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3 border-t border-kharon-purple/10 pt-3">
              <div><p class="text-xs text-kharon-purple mb-1">Scheduled</p><p class="text-sm font-bold text-white">{job.scheduled_date}</p></div>
              <div><p class="text-xs text-kharon-purple mb-1">Job Type</p><p class="text-sm font-bold text-white">{job.job_type}</p></div>
            </div>
            
            <div class="mt-4">
              <a href={`/portal/tech/jobs/${job.id}`} class="w-full px-4 py-3 border border-kharon-purple/30 text-kharon-purple font-bold uppercase tracking-widest rounded-md text-center hover:bg-kharon-purple/10 transition-colors">
                View Details
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</PortalLayout>
