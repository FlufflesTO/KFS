---
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";

export const prerender = false;

const user = Astro.locals.user;
let jobs = [];
let loadError = "";
const today = new Date().toISOString().slice(0, 10);

try {
  const db = getDatabase();
  const query = user.role === "admin"
    ? `SELECT jobs.id, jobs.system_id, jobs.scheduled_date, jobs.status, jobs.site_notes,
              jobs.job_type, jobs.priority, jobs.required_by_date, jobs.is_emergency,
              systems.system_type, systems.coverage_area,
              sites.owner_company_name, sites.physical_address
       FROM jobs
       INNER JOIN systems ON systems.id = jobs.system_id
       INNER JOIN sites ON sites.id = systems.site_id
       WHERE jobs.status IN ('Scheduled', 'In Progress')
       ORDER BY jobs.scheduled_date ASC`
    : `SELECT jobs.id, jobs.system_id, jobs.scheduled_date, jobs.status, jobs.site_notes,
              jobs.job_type, jobs.priority, jobs.required_by_date, jobs.is_emergency,
              systems.system_type, systems.coverage_area,
              sites.owner_company_name, sites.physical_address
       FROM jobs
       INNER JOIN systems ON systems.id = jobs.system_id
       INNER JOIN sites ON sites.id = systems.site_id
       WHERE jobs.assigned_technician_id = ?1 AND jobs.status IN ('Scheduled', 'In Progress')
       ORDER BY jobs.scheduled_date ASC`;

  const result = user.role === "admin"
    ? await db.prepare(query).all()
    : await db.prepare(query).bind(user.id).all();
  jobs = result.results || [];
} catch (error) {
  console.error("technician dashboard failed", error);
  loadError = "Assigned dispatches could not be loaded.";
}

const actionJobs = jobs.filter((j) => j.scheduled_date <= today);
const upcomingJobs = jobs.filter((j) => j.scheduled_date > today);
const todayCount = jobs.filter((j) => j.scheduled_date === today).length;
const inProgressCount = jobs.filter((j) => j.status === "In Progress").length;

function priorityClass(priority) {
  if (priority === "Critical") return "bg-kharon-red text-white";
  if (priority === "High") return "border border-amber-400 bg-amber-50 text-amber-800";
  if (priority === "Low") return "border border-kharon-border bg-white text-kharon-grey";
  return "bg-kharon-light text-kharon-grey";
}
---

<PortalLayout title="Technician Dispatches | Kharon Portal" active="tech" user={user}>
  <section class="bg-kharon-black px-4 py-8 text-white sm:px-6 sm:py-10">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-bold uppercase text-kharon-cyan">Technician workspace</p>
      <h1 class="mt-3 text-2xl font-bold sm:text-3xl">Assigned dispatches</h1>
      <p class="mt-4 max-w-3xl text-white/65">
        Open a dispatch to log arrival, capture evidence, record defects and submit the completed jobcard from a focused field workflow.
      </p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto grid max-w-7xl gap-5">
      {loadError && <p class="border border-red-300 bg-red-50 p-4 text-red-800">{loadError}</p>}

      {!loadError && jobs.length > 0 && (
        <div class="grid grid-cols-3 gap-3 border border-kharon-border bg-white p-4">
          <div class="border-r border-kharon-border pr-4">
            <p class="text-xs font-bold uppercase text-kharon-grey/60">Today</p>
            <p class="mt-1 text-2xl font-bold text-kharon-black">{todayCount}</p>
          </div>
          <div class="border-r border-kharon-border px-4">
            <p class="text-xs font-bold uppercase text-kharon-grey/60">Upcoming</p>
            <p class="mt-1 text-2xl font-bold text-kharon-black">{upcomingJobs.length}</p>
          </div>
          <div class="pl-4">
            <p class="text-xs font-bold uppercase text-kharon-grey/60">In progress</p>
            <p class="mt-1 text-2xl font-bold text-kharon-purple">{inProgressCount}</p>
          </div>
        </div>
      )}

      {jobs.length === 0 && !loadError && (
        <div class="border border-kharon-border bg-white p-6">
          <p class="font-semibold text-kharon-black">No dispatches assigned</p>
          <p class="mt-2 text-sm text-kharon-grey">No scheduled dispatches are currently assigned to this account. Contact the admin team if you expect jobs to appear here.</p>
        </div>
      )}

      {actionJobs.length > 0 && (
        <p class="border-l-4 border-kharon-cyan bg-kharon-light px-4 py-3 text-sm font-bold uppercase tracking-wide text-kharon-black">
          Today and overdue - action required
        </p>
      )}

      {[...actionJobs, ...upcomingJobs].map((job) => (
        <article class="grid gap-4 border border-kharon-border bg-white p-4 sm:p-5 lg:grid-cols-[1fr_auto]">
          <div class="min-w-0">
            <div class="flex flex-wrap items-center gap-2">
              <span class={`rounded px-2 py-0.5 text-xs font-bold ${priorityClass(job.priority || "Normal")}`}>{job.priority || "Normal"}</span>
              {job.is_emergency === 1 && <span class="rounded bg-kharon-red px-2 py-0.5 text-xs font-bold text-white">Emergency</span>}
              <span class="rounded bg-kharon-light px-2 py-0.5 text-xs font-bold uppercase text-kharon-grey">{job.status}</span>
              {job.required_by_date && <span class="text-xs font-semibold text-kharon-grey">Required by {job.required_by_date}</span>}
            </div>
            <h2 class="mt-3 text-xl font-bold text-kharon-black">{job.owner_company_name}</h2>
            <p class="mt-1 text-sm text-kharon-grey">{job.system_type} / {job.coverage_area}</p>
            <p class="mt-2 text-sm text-kharon-grey">{job.physical_address}</p>
            <dl class="mt-4 grid gap-2 text-sm sm:grid-cols-3">
              <div><dt class="font-bold uppercase text-kharon-grey/70">Job Type</dt><dd>{job.job_type}</dd></div>
              <div><dt class="font-bold uppercase text-kharon-grey/70">Scheduled</dt><dd>{job.scheduled_date}</dd></div>
              <div><dt class="font-bold uppercase text-kharon-grey/70">Job ID</dt><dd class="break-all">{job.id}</dd></div>
            </dl>
            {job.site_notes && <p class="mt-4 border-l-4 border-kharon-blue bg-kharon-light p-3 text-sm text-kharon-grey">{job.site_notes}</p>}
          </div>

          <aside class="grid content-start gap-3 sm:min-w-52">
            <a class="inline-flex justify-center rounded-md bg-kharon-purple px-5 py-3 text-sm font-semibold text-white hover:bg-kharon-blue" href={`/portal/tech/jobs/${job.id}`}>
              Open dispatch
            </a>
            {job.physical_address && (
              <a
                href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(String(job.physical_address))}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex justify-center rounded-md border border-kharon-border px-5 py-3 text-sm font-semibold text-kharon-grey hover:bg-kharon-light"
              >
                Navigate
              </a>
            )}
          </aside>
        </article>
      ))}
    </div>
  </section>
</PortalLayout>
