---
import { auditError } from "../../../lib/server/audit.js";
/**
 * Project Sentinel - Technician Dashboard
 * Purpose: Lists dispatches assigned to the currently authenticated technician, split by action items and upcoming dispatches.
 * Dependencies: PortalLayout component, D1 database, KharonCard, KharonButton.
 * Structural Role: Operational workspace view for technicians.
 */
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";
import KharonCard from "../../../components/ui/KharonCard.astro";
import KharonButton from "../../../components/ui/KharonButton.astro";

export const prerender = false;

const user = Astro.locals.user;
let jobs = [];
let loadError = "";
const today = new Date().toISOString().slice(0, 10);

try {
  const db = getDatabase();
  const query = user.role === "admin"
    ? `SELECT jobs.id, jobs.system_id, jobs.scheduled_date, jobs.status, jobs.site_notes,
              jobs.job_type, jobs.priority, jobs.required_by_date, jobs.is_emergency,
              systems.system_type, systems.coverage_area,
              sites.owner_company_name, sites.physical_address
       FROM jobs
       INNER JOIN systems ON systems.id = jobs.system_id
       INNER JOIN sites ON sites.id = systems.site_id
       WHERE jobs.deleted_at IS NULL AND systems.deleted_at IS NULL
         AND jobs.status IN ('Scheduled', 'In Progress')
       ORDER BY jobs.scheduled_date ASC
       LIMIT 100`
    : `SELECT jobs.id, jobs.system_id, jobs.scheduled_date, jobs.status, jobs.site_notes,
              jobs.job_type, jobs.priority, jobs.required_by_date, jobs.is_emergency,
              systems.system_type, systems.coverage_area,
              sites.owner_company_name, sites.physical_address
       FROM jobs
       INNER JOIN systems ON systems.id = jobs.system_id
       INNER JOIN sites ON sites.id = systems.site_id
       WHERE jobs.deleted_at IS NULL AND systems.deleted_at IS NULL
         AND jobs.assigned_technician_id = ?1 AND jobs.status IN ('Scheduled', 'In Progress')
       ORDER BY jobs.scheduled_date ASC
       LIMIT 100`;

  const result = user.role === "admin"
    ? await db.prepare(query).all()
    : await db.prepare(query).bind(user.id).all();
  jobs = result.results || [];
} catch (error) {
  await auditError(typeof db !== "undefined" ? db : Astro.locals.db, Astro.request, error, { user: typeof user !== "undefined" ? user : Astro.locals.user, metadata: { message: "technician dashboard failed" } });
  loadError = "Assigned dispatches could not be loaded.";
}

const actionJobs = jobs.filter((j) => j.scheduled_date <= today);
const upcomingJobs = jobs.filter((j) => j.scheduled_date > today);
const todayCount = jobs.filter((j) => j.scheduled_date === today).length;
const inProgressCount = jobs.filter((j) => j.status === "In Progress").length;

function priorityBadgeClass(priority) {
  if (priority === "Critical") return "bg-rose-500/10 text-rose-700 ring-1 ring-rose-600/20 shadow-sm shadow-rose-500/10";
  if (priority === "High") return "bg-amber-500/10 text-amber-700 ring-1 ring-amber-600/20 shadow-sm shadow-amber-500/10";
  return "bg-slate-100 text-slate-700 ring-1 ring-slate-400/20";
}
---

<PortalLayout title="Technician Dispatches | Kharon Portal" active="tech" user={user}>
  <section class="relative overflow-hidden bg-gradient-to-r from-[#0B0D0F] to-[#161C24] px-4 py-12 text-white sm:px-6 shadow-2xl">
    <!-- Subtle tech background element -->
    <div class="absolute right-0 top-0 w-1/2 h-full bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-kharon-cyan/10 via-transparent to-transparent opacity-80"></div>
    <div class="relative z-10 mx-auto max-w-7xl">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-white/10 ring-1 ring-white/20 shadow-inner">
          <svg class="h-4 w-4 text-kharon-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <p class="text-xs font-bold uppercase tracking-widest text-kharon-cyan">Technician Workspace</p>
      </div>
      <h1 class="text-3xl font-extrabold sm:text-4xl tracking-tight text-white drop-shadow-md">Active Dispatches</h1>
      <p class="mt-4 max-w-2xl text-base text-white/70 leading-relaxed font-medium">
        Review assigned fieldwork, log arrival times, capture forensic evidence, and submit completed jobcards seamlessly.
      </p>
    </div>
  </section>

  <section class="px-4 py-8 sm:px-6 sm:py-10">
    <div class="mx-auto grid max-w-7xl gap-8 relative">
      {loadError && <div class="rounded-xl border border-red-200 bg-red-50 p-5 shadow-sm"><p class="text-sm font-bold text-red-800">{loadError}</p></div>}

      {!loadError && jobs.length > 0 && (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="rounded-2xl border border-white bg-white/60 p-6 shadow-xl shadow-slate-200/50 backdrop-blur-md relative overflow-hidden group transition-all duration-300">
            <div class="absolute -right-4 -top-4 h-24 w-24 rounded-full bg-kharon-blue/5 blur-2xl group-hover:bg-kharon-blue/10 transition-colors"></div>
            <p class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Today</p>
            <p class="text-4xl font-extrabold text-slate-900 drop-shadow-sm">{todayCount}</p>
          </div>
          <div class="rounded-2xl border border-white bg-white/60 p-6 shadow-xl shadow-slate-200/50 backdrop-blur-md relative overflow-hidden group transition-all duration-300">
            <div class="absolute -right-4 -top-4 h-24 w-24 rounded-full bg-kharon-purple/5 blur-2xl group-hover:bg-kharon-purple/10 transition-colors"></div>
            <p class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Upcoming</p>
            <p class="text-4xl font-extrabold text-slate-900 drop-shadow-sm">{upcomingJobs.length}</p>
          </div>
          <div class="rounded-2xl border border-white bg-white/60 p-6 shadow-xl shadow-slate-200/50 backdrop-blur-md relative overflow-hidden group transition-all duration-300 ring-1 ring-kharon-purple/10">
            <div class="absolute -right-4 -top-4 h-24 w-24 rounded-full bg-kharon-purple/10 blur-2xl group-hover:bg-kharon-purple/20 transition-colors"></div>
            <p class="text-xs font-bold uppercase tracking-widest text-kharon-purple mb-2">In Progress</p>
            <p class="text-4xl font-extrabold text-kharon-purple drop-shadow-sm">{inProgressCount}</p>
          </div>
        </div>
      )}

      {jobs.length === 0 && !loadError && (
        <div class="rounded-2xl border-2 border-dashed border-slate-300 bg-white/50 p-12 text-center shadow-inner backdrop-blur-sm">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-slate-100 mb-4">
            <svg class="h-8 w-8 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          </div>
          <p class="text-lg font-bold text-slate-800">No dispatches assigned</p>
          <p class="mt-2 text-sm text-slate-500 max-w-sm mx-auto">You currently have no scheduled dispatches. Contact the administration team if you expect jobs to appear here.</p>
        </div>
      )}

      {actionJobs.length > 0 && (
        <div class="mt-4 flex items-center gap-3">
          <div class="flex items-center justify-center rounded-lg bg-kharon-cyan/10 p-2 ring-1 ring-kharon-cyan/20">
            <span class="h-2 w-2 rounded-full bg-kharon-cyan animate-pulse"></span>
          </div>
          <h2 class="text-sm font-extrabold uppercase tracking-widest text-slate-800">Action Required Today</h2>
          <div class="ml-4 h-px flex-1 bg-gradient-to-r from-slate-200 to-transparent"></div>
        </div>
      )}

      <div class="grid gap-6">
        {actionJobs.map((job) => (
          <article class="group relative grid gap-6 rounded-2xl border border-white bg-white/80 p-6 shadow-lg shadow-slate-200/40 backdrop-blur-md transition-all duration-300 hover:shadow-xl hover:shadow-slate-200/60 lg:grid-cols-[1fr_auto]">
            <div class="absolute inset-0 rounded-2xl ring-1 ring-inset ring-slate-900/5 group-hover:ring-kharon-cyan/20 transition-all pointer-events-none"></div>
            <div class="relative min-w-0 z-10">
              <div class="flex flex-wrap items-center gap-3">
                <span class={`rounded-full px-3 py-1 text-[10px] font-bold uppercase tracking-widest ${priorityBadgeClass(job.priority || "Normal")}`}>{job.priority || "Normal"}</span>
                {job.is_emergency === 1 && <span class="rounded-full bg-red-500/10 text-red-700 ring-1 ring-red-600/20 shadow-sm shadow-red-500/10 px-3 py-1 text-[10px] font-bold uppercase tracking-widest flex items-center gap-1"><span class="h-1.5 w-1.5 rounded-full bg-red-600 animate-pulse"></span>Emergency</span>}
                <span class="rounded-full bg-slate-100 text-slate-700 ring-1 ring-slate-400/20 px-3 py-1 text-[10px] font-bold uppercase tracking-widest">{job.status}</span>
                {job.required_by_date && <span class="text-xs font-bold text-slate-400 flex items-center gap-1.5"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>Required by {job.required_by_date}</span>}
              </div>
              
              <h2 class="mt-5 text-2xl font-extrabold text-slate-900 tracking-tight drop-shadow-sm">{job.owner_company_name}</h2>
              <p class="mt-1.5 text-base font-bold text-kharon-purple">{job.system_type} <span class="text-slate-300 mx-1">|</span> {job.coverage_area}</p>
              
              <div class="mt-3 flex items-start gap-2 text-slate-500 bg-slate-50/50 p-2.5 rounded-lg border border-slate-100">
                <svg class="h-4 w-4 shrink-0 mt-0.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                <span class="text-sm font-medium">{job.physical_address}</span>
              </div>
              
              <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-4 border-t border-slate-100 pt-5">
                <div><p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Job Type</p><p class="text-sm font-bold text-slate-800">{job.job_type}</p></div>
                <div><p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Scheduled</p><p class="text-sm font-bold text-slate-800">{job.scheduled_date}</p></div>
                <div><p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Dispatch ID</p><p class="text-xs font-mono font-bold text-slate-500 break-all bg-slate-100 px-2 py-1 rounded inline-block">{job.id}</p></div>
              </div>
              
              {job.site_notes && (
                <div class="mt-5 rounded-xl border border-kharon-blue/10 bg-gradient-to-r from-kharon-blue/5 to-transparent p-4 text-sm text-slate-700 relative overflow-hidden">
                  <div class="absolute left-0 top-0 bottom-0 w-1 bg-kharon-blue/50"></div>
                  <p class="font-bold text-[10px] text-kharon-blue uppercase tracking-widest mb-1.5">Site Instructions</p>
                  <p class="font-medium leading-relaxed">{job.site_notes}</p>
                </div>
              )}
            </div>

            <aside class="relative z-10 flex flex-col gap-3 justify-center sm:min-w-[16rem]">
              <a href={`/portal/tech/jobs/${job.id}`} class="group/btn relative flex items-center justify-center overflow-hidden rounded-xl bg-kharon-black px-6 py-4 text-sm font-bold uppercase tracking-widest text-white transition-all duration-300 hover:shadow-lg hover:shadow-black/20">
                <div class="absolute inset-0 bg-gradient-to-r from-kharon-purple/80 to-kharon-blue/80 opacity-0 transition-opacity duration-300 group-hover/btn:opacity-100"></div>
                <span class="relative z-10 flex items-center gap-2">Open Dispatch <svg class="h-4 w-4 transition-transform duration-300 group-hover/btn:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg></span>
              </a>
              
              {job.physical_address && (
                <a href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(String(job.physical_address))}`} target="_blank" rel="noopener noreferrer" class="group/nav flex items-center justify-center rounded-xl border-2 border-slate-200 bg-white px-6 py-4 text-sm font-bold uppercase tracking-widest text-slate-700 transition-all duration-300 hover:border-kharon-cyan/50 hover:bg-kharon-cyan/5 hover:text-kharon-cyan">
                  <span class="flex items-center gap-2"><svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg> Navigate</span>
                </a>
              )}
            </aside>
          </article>
        ))}
      </div>

      {upcomingJobs.length > 0 && (
        <div class="mt-8 flex items-center gap-3">
          <div class="flex items-center justify-center rounded-lg bg-slate-200 p-2">
            <svg class="h-3 w-3 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
          </div>
          <h2 class="text-sm font-extrabold uppercase tracking-widest text-slate-600">Upcoming Fieldwork</h2>
          <div class="ml-4 h-px flex-1 bg-gradient-to-r from-slate-200 to-transparent"></div>
        </div>
      )}

      <div class="grid gap-6 opacity-90">
        {upcomingJobs.map((job) => (
          <article class="group relative grid gap-6 rounded-2xl border border-white bg-white/60 p-6 shadow-md shadow-slate-200/30 backdrop-blur-sm transition-all duration-300 hover:bg-white/80 hover:shadow-lg lg:grid-cols-[1fr_auto]">
            <div class="relative min-w-0 z-10">
              <div class="flex flex-wrap items-center gap-3">
                <span class={`rounded-full px-3 py-1 text-[10px] font-bold uppercase tracking-widest ${priorityBadgeClass(job.priority || "Normal")}`}>{job.priority || "Normal"}</span>
                {job.is_emergency === 1 && <span class="rounded-full bg-red-500/10 text-red-700 ring-1 ring-red-600/20 shadow-sm shadow-red-500/10 px-3 py-1 text-[10px] font-bold uppercase tracking-widest flex items-center gap-1"><span class="h-1.5 w-1.5 rounded-full bg-red-600 animate-pulse"></span>Emergency</span>}
                <span class="rounded-full bg-slate-100 text-slate-700 ring-1 ring-slate-400/20 px-3 py-1 text-[10px] font-bold uppercase tracking-widest">{job.status}</span>
              </div>
              
              <h2 class="mt-4 text-xl font-bold text-slate-800 tracking-tight">{job.owner_company_name}</h2>
              <p class="mt-1 text-sm font-bold text-kharon-purple/80">{job.system_type} <span class="text-slate-300 mx-1">|</span> {job.coverage_area}</p>
              
              <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4 border-t border-slate-100 pt-4">
                <div><p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Scheduled</p><p class="text-sm font-bold text-slate-700">{job.scheduled_date}</p></div>
                <div><p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Job Type</p><p class="text-sm font-bold text-slate-700">{job.job_type}</p></div>
              </div>
            </div>

            <aside class="relative z-10 flex flex-col justify-center sm:min-w-[12rem]">
              <a href={`/portal/tech/jobs/${job.id}`} class="flex items-center justify-center rounded-xl border border-slate-200 bg-white px-5 py-3.5 text-xs font-bold uppercase tracking-widest text-slate-700 transition-all duration-300 hover:border-slate-300 hover:bg-slate-50">
                View Details
              </a>
            </aside>
          </article>
        ))}
      </div>
    </div>
  </section>
</PortalLayout>
