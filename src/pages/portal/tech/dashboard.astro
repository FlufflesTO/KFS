---
/**
 * Project Sentinel - Technician Dashboard
 * Purpose: Lists dispatches assigned to the currently authenticated technician, split by action items and upcoming dispatches.
 * Dependencies: PortalLayout component, D1 database.
 * Structural Role: Operational workspace view for technicians.
 */
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";

export const prerender = false;

const user = Astro.locals.user;
let jobs = [];
let loadError = "";
const today = new Date().toISOString().slice(0, 10);

try {
  const db = getDatabase();
  const query = user.role === "admin"
    ? `SELECT jobs.id, jobs.system_id, jobs.scheduled_date, jobs.status, jobs.site_notes,
              jobs.job_type, jobs.priority, jobs.required_by_date, jobs.is_emergency,
              systems.system_type, systems.coverage_area,
              sites.owner_company_name, sites.physical_address
       FROM jobs
       INNER JOIN systems ON systems.id = jobs.system_id
       INNER JOIN sites ON sites.id = systems.site_id
       WHERE jobs.status IN ('Scheduled', 'In Progress')
       ORDER BY jobs.scheduled_date ASC`
    : `SELECT jobs.id, jobs.system_id, jobs.scheduled_date, jobs.status, jobs.site_notes,
              jobs.job_type, jobs.priority, jobs.required_by_date, jobs.is_emergency,
              systems.system_type, systems.coverage_area,
              sites.owner_company_name, sites.physical_address
       FROM jobs
       INNER JOIN systems ON systems.id = jobs.system_id
       INNER JOIN sites ON sites.id = systems.site_id
       WHERE jobs.assigned_technician_id = ?1 AND jobs.status IN ('Scheduled', 'In Progress')
       ORDER BY jobs.scheduled_date ASC`;

  const result = user.role === "admin"
    ? await db.prepare(query).all()
    : await db.prepare(query).bind(user.id).all();
  jobs = result.results || [];
} catch (error) {
  console.error("technician dashboard failed", error);
  loadError = "Assigned dispatches could not be loaded.";
}

const actionJobs = jobs.filter((j) => j.scheduled_date <= today);
const upcomingJobs = jobs.filter((j) => j.scheduled_date > today);
const todayCount = jobs.filter((j) => j.scheduled_date === today).length;
const inProgressCount = jobs.filter((j) => j.status === "In Progress").length;

function priorityClass(priority) {
  if (priority === "Critical") return "bg-rose-50 text-rose-700 ring-1 ring-rose-600/10";
  if (priority === "High") return "bg-amber-50 text-amber-700 ring-1 ring-amber-600/10";
  return "bg-slate-50 text-slate-700 ring-1 ring-slate-600/10";
}
---

<PortalLayout title="Technician Dispatches | Kharon Portal" active="tech" user={user}>
  <section class="bg-gradient-to-r from-[#0B0D0F] to-[#1A1F26] px-4 py-10 text-white sm:px-6 sm:py-12 shadow-inner">
    <div class="mx-auto max-w-7xl">
      <p class="text-[10px] font-bold uppercase tracking-wider text-kharon-cyan">Technician Workspace</p>
      <h1 class="mt-2 text-2xl font-bold sm:text-3xl tracking-tight">Assigned dispatches</h1>
      <p class="mt-3 max-w-3xl text-sm text-white/60">
        Open a dispatch to log arrival, capture evidence, record defects and submit the completed jobcard from a focused field workflow.
      </p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto grid max-w-7xl gap-6">
      {loadError && <p class="rounded-lg border border-red-200 bg-red-50 p-4 text-sm font-semibold text-red-800">{loadError}</p>}

      {!loadError && jobs.length > 0 && (
        <div class="grid grid-cols-3 gap-6 rounded-xl border border-slate-200/80 bg-white p-5 shadow-sm">
          <div class="border-r border-slate-100 pr-4">
            <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Today</p>
            <p class="mt-1 text-2xl font-bold text-slate-800 leading-none">{todayCount}</p>
          </div>
          <div class="border-r border-slate-100 px-4">
            <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Upcoming</p>
            <p class="mt-1 text-2xl font-bold text-slate-800 leading-none">{upcomingJobs.length}</p>
          </div>
          <div class="pl-4">
            <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">In progress</p>
            <p class="mt-1 text-2xl font-bold text-kharon-purple leading-none">{inProgressCount}</p>
          </div>
        </div>
      )}

      {jobs.length === 0 && !loadError && (
        <div class="rounded-xl border border-slate-200/80 bg-white p-8 text-center shadow-sm">
          <p class="font-bold text-slate-800">No dispatches assigned</p>
          <p class="mt-2 text-sm text-slate-500">No scheduled dispatches are currently assigned to this account. Contact the admin team if you expect jobs to appear here.</p>
        </div>
      )}

      {actionJobs.length > 0 && (
        <div class="flex items-center gap-2 rounded-lg border-l-4 border-kharon-cyan bg-kharon-cyan/5 px-4 py-3 text-xs font-bold uppercase tracking-wider text-slate-800">
          <span>Today and Overdue — Action Required</span>
        </div>
      )}

      {[...actionJobs, ...upcomingJobs].map((job) => (
        <article class="grid gap-6 rounded-xl border border-slate-200/80 bg-white p-5 shadow-sm hover:shadow-md transition-all duration-200 lg:grid-cols-[1fr_auto]">
          <div class="min-w-0">
            <div class="flex flex-wrap items-center gap-2">
              <span class={`rounded-full px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider ${priorityClass(job.priority || "Normal")}`}>{job.priority || "Normal"} Priority</span>
              {job.is_emergency === 1 && <span class="rounded-full bg-red-100 text-red-800 ring-1 ring-red-600/10 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider">Emergency</span>}
              <span class="rounded-full bg-slate-100 text-slate-800 ring-1 ring-slate-600/10 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider">{job.status}</span>
              {job.required_by_date && <span class="text-xs font-medium text-slate-400">Required by {job.required_by_date}</span>}
            </div>
            <h2 class="mt-4 text-xl font-bold text-slate-800 tracking-tight">{job.owner_company_name}</h2>
            <p class="mt-1 text-sm font-semibold text-kharon-purple">{job.system_type} / {job.coverage_area}</p>
            <p class="mt-2 text-sm text-slate-500">{job.physical_address}</p>
            <dl class="mt-5 grid gap-4 text-xs sm:grid-cols-3 border-t border-slate-50 pt-4">
              <div><dt class="font-bold uppercase tracking-wider text-slate-400">Job Type</dt><dd class="mt-1 font-semibold text-slate-700">{job.job_type}</dd></div>
              <div><dt class="font-bold uppercase tracking-wider text-slate-400">Scheduled</dt><dd class="mt-1 font-semibold text-slate-700">{job.scheduled_date}</dd></div>
              <div><dt class="font-bold uppercase tracking-wider text-slate-400">Job ID</dt><dd class="mt-1 font-mono text-slate-500 break-all">{job.id}</dd></div>
            </dl>
            {job.site_notes && (
              <div class="mt-4 rounded-lg border-l-4 border-kharon-blue bg-kharon-blue/5 p-4 text-sm text-slate-600">
                <p class="font-semibold text-xs text-kharon-blue uppercase tracking-wider mb-1">Site Notes</p>
                {job.site_notes}
              </div>
            )}
          </div>

          <aside class="flex flex-col gap-3 justify-center sm:min-w-[14rem]">
            <a class="inline-flex justify-center rounded-lg bg-kharon-purple px-5 py-3 text-xs font-bold uppercase tracking-wider text-white shadow-md shadow-kharon-purple/10 hover:bg-kharon-blue transition-all duration-200" href={`/portal/tech/jobs/${job.id}`}>
              Open dispatch
            </a>
            {job.physical_address && (
              <a
                href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(String(job.physical_address))}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex justify-center rounded-lg border border-slate-200 bg-white px-5 py-3 text-xs font-bold uppercase tracking-wider text-slate-700 hover:bg-slate-50 transition-all duration-200"
              >
                Navigate
              </a>
            )}
          </aside>
        </article>
      ))}
    </div>
  </section>
</PortalLayout>
