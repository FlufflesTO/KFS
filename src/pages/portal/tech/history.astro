---
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";

export const prerender = false;

const user = Astro.locals.user;
const params = Astro.url.searchParams;
const page = Math.max(1, Math.min(999, parseInt(params.get("page") || "1", 10) || 1));
const perPage = 50;
const offset = (page - 1) * perPage;
let jobs = [];
let totalJobs = 0;
let loadError = "";

try {
  const db = getDatabase();
  const countQuery = user.role === "admin"
    ? `SELECT COUNT(*) AS total
       FROM jobs
       WHERE jobs.status IN ('Completed', 'Invoiced')`
    : `SELECT COUNT(*) AS total
       FROM jobs
       WHERE jobs.assigned_technician_id = ?1
         AND jobs.status IN ('Completed', 'Invoiced')`;

  const query = user.role === "admin"
    ? `SELECT jobs.id, jobs.completed_at, jobs.status, jobs.job_type,
              jobs.tech_comments, jobs.documentation_path,
              systems.system_type, systems.coverage_area,
              sites.owner_company_name
       FROM jobs
       INNER JOIN systems ON systems.id = jobs.system_id
       INNER JOIN sites ON sites.id = systems.site_id
       WHERE jobs.status IN ('Completed', 'Invoiced')
       ORDER BY jobs.completed_at DESC
       LIMIT ?1 OFFSET ?2`
    : `SELECT jobs.id, jobs.completed_at, jobs.status, jobs.job_type,
              jobs.tech_comments, jobs.documentation_path,
              systems.system_type, systems.coverage_area,
              sites.owner_company_name
       FROM jobs
       INNER JOIN systems ON systems.id = jobs.system_id
       INNER JOIN sites ON sites.id = systems.site_id
       WHERE jobs.assigned_technician_id = ?1
         AND jobs.status IN ('Completed', 'Invoiced')
       ORDER BY jobs.completed_at DESC
       LIMIT ?2 OFFSET ?3`;

  const [countResult, result] = user.role === "admin"
    ? await db.batch([
        db.prepare(countQuery),
        db.prepare(query).bind(perPage, offset)
      ])
    : await db.batch([
        db.prepare(countQuery).bind(user.id),
        db.prepare(query).bind(user.id, perPage, offset)
      ]);
  totalJobs = Number((countResult.results[0] as { total: number })?.total ?? 0);
  jobs = result.results || [];
} catch (error) {
  console.error("technician history failed", error);
  loadError = "Job history could not be loaded.";
}

const totalPages = Math.max(1, Math.ceil(totalJobs / perPage));
---

<PortalLayout title="Job History | Kharon Portal" active="tech-history" user={user}>
  <section class="bg-kharon-black px-4 py-8 text-white sm:px-6 sm:py-10">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-bold uppercase text-kharon-cyan">Technician records</p>
      <h1 class="mt-3 text-2xl font-bold sm:text-3xl">Completed job history</h1>
      <p class="mt-4 max-w-3xl text-white/65">
        Closed and invoiced dispatches for {user.role === "admin" ? "all technicians" : "your account"}.
        Page {page} of {totalPages}; {totalJobs} total records.
      </p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto max-w-7xl">
      {loadError && <p class="border border-red-300 bg-red-50 p-4 text-red-800">{loadError}</p>}

      {!loadError && jobs.length === 0 && (
        <p class="text-kharon-grey">No completed jobs found.</p>
      )}

      {jobs.length > 0 && (
        <>
          <div class="sticky top-0 z-10 mb-4 flex flex-wrap items-center gap-3 border-b border-kharon-border bg-kharon-light pb-3 pt-3">
            <input
              id="history-search"
              type="search"
              class="rounded-md border border-kharon-border bg-white px-3 py-2 text-sm"
              placeholder="Search site, system or comments…"
              size="26"
            />
            <select id="history-status-filter" class="rounded-md border border-kharon-border bg-white px-3 py-2 text-sm">
              <option value="">All statuses</option>
              <option value="Completed">Completed</option>
              <option value="Invoiced">Invoiced</option>
            </select>
            <select id="history-type-filter" class="rounded-md border border-kharon-border bg-white px-3 py-2 text-sm">
              <option value="">All job types</option>
              <option value="Routine service">Routine service</option>
              <option value="Compliance inspection">Compliance inspection</option>
              <option value="Fault response">Fault response</option>
              <option value="Panel issue">Panel issue</option>
              <option value="Detection device issue">Detection device issue</option>
              <option value="Suppression release infrastructure">Suppression release infrastructure</option>
              <option value="Follow-up required">Follow-up required</option>
            </select>
            <button id="history-clear" class="rounded-md border border-kharon-border bg-white px-3 py-2 text-xs font-semibold text-kharon-grey hover:bg-white">
              Clear filters
            </button>
          </div>
          <div class="overflow-x-auto">
            <table class="min-w-full border-collapse text-sm">
              <thead>
                <tr class="border-b border-kharon-border bg-kharon-light">
                  <th class="px-4 py-3 text-left font-semibold">Completed</th>
                  <th class="px-4 py-3 text-left font-semibold">Status</th>
                  <th class="px-4 py-3 text-left font-semibold">Site</th>
                  <th class="px-4 py-3 text-left font-semibold">System</th>
                  <th class="px-4 py-3 text-left font-semibold">Type</th>
                  <th class="px-4 py-3 text-left font-semibold">Comments</th>
                  <th class="px-4 py-3 text-left font-semibold">Jobcard</th>
                </tr>
              </thead>
              <tbody id="history-rows">
                {jobs.map((job) => (
                  <tr
                    class="border-b border-kharon-border hover:bg-kharon-light"
                    data-search={`${job.owner_company_name} ${job.coverage_area} ${job.system_type} ${job.job_type || ""} ${job.tech_comments || ""}`}
                    data-status={job.status}
                    data-jobtype={job.job_type || ""}
                  >
                    <td class="px-4 py-3 whitespace-nowrap">{job.completed_at ? job.completed_at.slice(0, 10) : "-"}</td>
                    <td class="px-4 py-3">
                      <span class={`inline-block rounded px-2 py-0.5 text-xs font-bold uppercase ${job.status === "Invoiced" ? "bg-emerald-100 text-emerald-800" : "bg-kharon-light text-kharon-grey"}`}>
                        {job.status}
                      </span>
                    </td>
                    <td class="px-4 py-3">{job.owner_company_name}</td>
                    <td class="px-4 py-3">{job.coverage_area}</td>
                    <td class="px-4 py-3 whitespace-nowrap">{job.system_type}</td>
                    <td class="px-4 py-3 max-w-xs truncate" title={job.tech_comments || ""}>{job.tech_comments || "-"}</td>
                    <td class="px-4 py-3">
                      {job.documentation_path ? (
                        <a
                          href={`/portal/api/file/${job.documentation_path}`}
                          class="font-semibold text-kharon-purple hover:underline"
                          target="_blank"
                          rel="noopener"
                        >
                          PDF
                        </a>
                      ) : "-"}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p id="history-no-results" class="hidden py-4 text-sm text-kharon-grey">No jobs match your filter.</p>
          {totalPages > 1 && (
            <nav class="mt-6 flex items-center justify-between border-t border-kharon-border pt-4">
              {page > 1 ? (
                <a href={`?page=${page - 1}`} class="rounded border border-kharon-border px-4 py-2 text-sm font-semibold text-kharon-black hover:bg-kharon-light">Previous</a>
              ) : (
                <span class="rounded border border-kharon-border px-4 py-2 text-sm font-semibold text-kharon-grey/50">Previous</span>
              )}
              <span class="text-sm text-kharon-grey">Page {page} of {totalPages}</span>
              {page < totalPages ? (
                <a href={`?page=${page + 1}`} class="rounded border border-kharon-border px-4 py-2 text-sm font-semibold text-kharon-black hover:bg-kharon-light">Next</a>
              ) : (
                <span class="rounded border border-kharon-border px-4 py-2 text-sm font-semibold text-kharon-grey/50">Next</span>
              )}
            </nav>
          )}
        </>
      )}
    </div>
  </section>
  <script>
    const search       = document.getElementById("history-search")       as HTMLInputElement  | null;
    const statusFilter = document.getElementById("history-status-filter") as HTMLSelectElement | null;
    const typeFilter   = document.getElementById("history-type-filter")   as HTMLSelectElement | null;
    const clearBtn     = document.getElementById("history-clear")         as HTMLButtonElement | null;
    const tbody        = document.getElementById("history-rows");
    const noResults    = document.getElementById("history-no-results");

    function applyFilter() {
      if (!search || !tbody) return;
      const q  = search.value.toLowerCase().trim();
      const sv = statusFilter?.value || "";
      const tv = typeFilter?.value   || "";
      const rows = tbody.querySelectorAll<HTMLTableRowElement>("[data-search]");
      let visible = 0;
      for (const row of rows) {
        const text    = (row.dataset.search   ?? "").toLowerCase();
        const status  = row.dataset.status    ?? "";
        const jobtype = row.dataset.jobtype   ?? "";
        const show = (!q  || text.includes(q))
                  && (!sv || status  === sv)
                  && (!tv || jobtype === tv);
        row.style.display = show ? "" : "none";
        if (show) visible++;
      }
      if (noResults) noResults.style.display = visible === 0 ? "" : "none";
    }

    function clearFilters() {
      if (search)       search.value       = "";
      if (statusFilter) statusFilter.value = "";
      if (typeFilter)   typeFilter.value   = "";
      applyFilter();
    }

    search?.addEventListener("input",   applyFilter);
    statusFilter?.addEventListener("change", applyFilter);
    typeFilter?.addEventListener("change",   applyFilter);
    clearBtn?.addEventListener("click",      clearFilters);
  </script>
</PortalLayout>
