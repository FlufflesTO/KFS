---
/**
 * Project Sentinel - Technician Job History
 * Purpose: Displays completed and invoiced jobs for the technician or admin.
 * Dependencies: PortalLayout, getDatabase, auditError
 * Structural Role: Completed jobs overview page.
 */
import { auditError } from "../../../lib/server/audit";
import PortalLayout from "../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../lib/server/bindings.js";

export const prerender = false;

const user = Astro.locals.user;
const params = Astro.url.searchParams;
const page = Math.max(1, Math.min(999, parseInt(params.get("page") || "1", 10) || 1));
const perPage = 10;
const offset = (page - 1) * perPage;

interface HistoryJob {
  id: string;
  completed_at: string | null;
  status: string;
  job_type: string | null;
  tech_comments: string | null;
  documentation_path: string | null;
  system_type: string;
  coverage_area: string;
  owner_company_name: string;
}

let jobs: Array<HistoryJob> = [];
let totalJobs = 0;
let loadError = "";

try {
  const db = getDatabase();
  const countQuery = user?.role === "admin"
    ? `SELECT 
        COUNT(*) AS total,
        SUM(CASE WHEN status = 'Completed' THEN 1 ELSE 0 END) AS completed,
        AVG(julianday(completed_at) - julianday(created_at)) * 24 AS avg_duration
       FROM jobs
       WHERE jobs.deleted_at IS NULL
         AND jobs.status IN ('Completed', 'Invoiced')`
    : `SELECT 
        COUNT(*) AS total,
        SUM(CASE WHEN status = 'Completed' THEN 1 ELSE 0 END) AS completed,
        AVG(julianday(completed_at) - julianday(created_at)) * 24 AS avg_duration
       FROM jobs
       WHERE jobs.deleted_at IS NULL
         AND jobs.assigned_technician_id = ?1
         AND jobs.status IN ('Completed', 'Invoiced')`;

  const query = user?.role === "admin"
    ? `SELECT jobs.id, jobs.completed_at, jobs.status, jobs.job_type,
              jobs.tech_comments, jobs.documentation_path,
              systems.system_type, systems.coverage_area,
              sites.owner_company_name
       FROM jobs
       INNER JOIN systems ON systems.id = jobs.system_id
       INNER JOIN sites ON sites.id = systems.site_id
       WHERE jobs.deleted_at IS NULL AND systems.deleted_at IS NULL
         AND jobs.status IN ('Completed', 'Invoiced')
       ORDER BY jobs.completed_at DESC
       LIMIT ?1 OFFSET ?2`
    : `SELECT jobs.id, jobs.completed_at, jobs.status, jobs.job_type,
              jobs.tech_comments, jobs.documentation_path,
              systems.system_type, systems.coverage_area,
              sites.owner_company_name
       FROM jobs
       INNER JOIN systems ON systems.id = jobs.system_id
       INNER JOIN sites ON sites.id = systems.site_id
       WHERE jobs.deleted_at IS NULL AND systems.deleted_at IS NULL
         AND jobs.assigned_technician_id = ?1
         AND jobs.status IN ('Completed', 'Invoiced')
       ORDER BY jobs.completed_at DESC
       LIMIT ?2 OFFSET ?3`;

  const [countResult, result] = user?.role === "admin"
    ? await db.batch([
        db.prepare(countQuery),
        db.prepare(query).bind(perPage, offset)
      ])
    : await db.batch([
        db.prepare(countQuery).bind(user?.id),
        db.prepare(query).bind(user?.id, perPage, offset)
      ]);
  
  if (countResult && result) {
    const countData = countResult.results[0] as { total: number, completed: number, avg_duration: number } | undefined;
    totalJobs = Number(countData?.total ?? 0);
    jobs = (result.results as unknown as HistoryJob[]) || [];
  }
} catch (error) {
  await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "tech_history" });
  loadError = "Job history could not be loaded.";
}

const totalPages = Math.max(1, Math.ceil(totalJobs / perPage));
---

<PortalLayout title="Job History | Kharon Portal" active="tech-history" user={user}>
  <section class="bg-kharon-black px-4 py-8 text-white sm:px-6 sm:py-10">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-bold uppercase text-kharon-purple">Technician records</p>
      <h1 class="mt-3 text-2xl font-bold sm:text-3xl">Completed job history</h1>
      <p class="mt-4 max-w-3xl text-white/65">
        Closed and invoiced dispatches for {user?.role === "admin" ? "all technicians" : "your account"}.
        Page {page} of {totalPages}; {totalJobs} total records.
      </p>
    </div>
  </section>

  <section class="bg-kharon-black px-4 py-6 sm:px-6 sm:py-8 min-h-[40vh]">
    <div class="mx-auto max-w-7xl">
      {loadError && <p class="rounded border border-kharon-red/40 bg-kharon-red/10 px-4 py-3 text-sm font-semibold text-kharon-red">{loadError}</p>}

      {!loadError && jobs.length === 0 && (
        <p class="text-white/50">No completed jobs found.</p>
      )}

      {jobs.length > 0 && (
        <>
          <div class="sticky top-0 z-10 mb-4 flex flex-wrap items-center gap-3 border-b border-kharon-purple/20 bg-kharon-black pb-3 pt-3">
            <input
              id="history-search"
              type="search"
              class="kharon-field text-sm"
              placeholder="Search site, system or comments…"
              size="26"
            />
            <select id="history-status-filter" class="kharon-field text-sm">
              <option value="">All statuses</option>
              <option value="Completed">Completed</option>
              <option value="Invoiced">Invoiced</option>
            </select>
            <select id="history-type-filter" class="kharon-field text-sm">
              <option value="">All job types</option>
              <option value="Routine service">Routine service</option>
              <option value="Compliance inspection">Compliance inspection</option>
              <option value="Fault response">Fault response</option>
              <option value="Panel issue">Panel issue</option>
              <option value="Detection device issue">Detection device issue</option>
              <option value="Suppression release infrastructure">Suppression release infrastructure</option>
              <option value="Follow-up required">Follow-up required</option>
            </select>
            <button id="history-clear" class="kharon-secondary-button px-3 py-2 text-xs font-semibold">
              Clear filters
            </button>
            </div>
            <div class="portal-scroll-x rounded-xl border border-kharon-purple/20 bg-kharon-black shadow-sm overflow-hidden">
            <table class="min-w-[1000px] border-collapse text-sm">
              <thead>
                <tr class="border-b border-kharon-purple/20 bg-kharon-charcoal">
                  <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-kharon-purple">Completed</th>
                  <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-kharon-purple">Status</th>
                  <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-kharon-purple">Site</th>
                  <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-kharon-purple">System</th>
                  <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-kharon-purple">Type</th>
                  <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-kharon-purple">Comments</th>
                  <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-widest text-kharon-purple">Jobcard</th>
                </tr>
              </thead>
              <tbody id="history-rows">
                {jobs.map((job) => (
                  <tr
                    class="border-b border-kharon-purple/10 hover:bg-kharon-purple/5 text-white/80"
                    data-search={`${job.owner_company_name} ${job.coverage_area} ${job.system_type} ${job.job_type || ""} ${job.tech_comments || ""}`}
                    data-status={job.status}
                    data-jobtype={job.job_type || ""}
                  >
                    <td class="px-4 py-3 whitespace-nowrap">{job.completed_at ? job.completed_at.slice(0, 10) : "-"}</td>
                    <td class="px-4 py-3">
                      <span class={`inline-block rounded px-2 py-0.5 text-xs font-bold uppercase ${job.status === "Invoiced" ? "bg-kharon-green/20 text-kharon-green" : "bg-kharon-purple/20 text-kharon-purple"}`}>
                        {job.status}
                      </span>
                    </td>
                    <td class="px-4 py-3">{job.owner_company_name}</td>
                    <td class="px-4 py-3">{job.coverage_area}</td>
                    <td class="px-4 py-3 whitespace-nowrap">{job.system_type}</td>
                    <td class="px-4 py-3 max-w-xs truncate" title={job.tech_comments || ""}>{job.tech_comments || "-"}</td>
                    <td class="px-4 py-3">
                      {job.documentation_path ? (
                        <a
                          href={`/portal/api/file/${job.documentation_path}`}
                          class="font-semibold text-kharon-purple hover:underline"
                          target="_blank"
                          rel="noopener"
                        >
                          PDF
                        </a>
                      ) : "-"}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p id="history-no-results" class="hidden py-4 text-sm text-white/70">No jobs match your filter.</p>
          {totalPages > 1 && (
            <nav class="mt-6 flex items-center justify-between border-t border-kharon-purple/20 pt-4">
              {page > 1 ? (
                <a href={`?page=${page - 1}`} class="rounded border border-kharon-purple/20 px-4 py-2 text-sm font-semibold text-white hover:bg-kharon-charcoal">Previous</a>
              ) : (
                <span class="rounded border border-kharon-purple/20 px-4 py-2 text-sm font-semibold text-white/40">Previous</span>
              )}
              <span class="text-sm text-white/70">Page {page} of {totalPages}</span>
              {page < totalPages ? (
                <a href={`?page=${page + 1}`} class="rounded border border-kharon-purple/20 px-4 py-2 text-sm font-semibold text-white hover:bg-kharon-charcoal">Next</a>
              ) : (
                <span class="rounded border border-kharon-purple/20 px-4 py-2 text-sm font-semibold text-white/40">Next</span>
              )}
            </nav>
          )}
        </>
      )}
    </div>
  </section>
  <script>
    // Mobile filter toggle
    const filterToggle = document.getElementById('mobile-filter-toggle');
    const filterPanel = document.getElementById('mobile-filter-panel');
    
    if (filterToggle && filterPanel) {
      filterToggle.addEventListener('click', () => {
        filterPanel.classList.toggle('hidden');
      });
    }
    
    // Filter functionality
    const search = document.getElementById('history-search') as HTMLInputElement | null;
    const statusFilter = document.getElementById('history-status-filter') as HTMLSelectElement | null;
    const typeFilter = document.getElementById('history-type-filter') as HTMLSelectElement | null;
    const clearBtn = document.getElementById('history-clear') as HTMLButtonElement | null;
    const tbody = document.getElementById('history-rows') as HTMLTableSectionElement | null;
    const noResults = document.getElementById('history-no-results') as HTMLElement | null;
    
    function applyFilter() {
      if (!search || !tbody) return;
      const q = search.value.toLowerCase().trim();
      const sv = statusFilter?.value || '';
      const tv = typeFilter?.value || '';
      const rows = tbody.querySelectorAll('[data-search]');
      let visible = 0;
      
      rows.forEach(row => {
        const htmlRow = row as HTMLElement;
        const text = (htmlRow.dataset.search || '').toLowerCase();
        const status = htmlRow.dataset.status || '';
        const jobtype = htmlRow.dataset.jobtype || '';
        const show = (!q || text.includes(q)) && 
                    (!sv || status === sv) && 
                    (!tv || jobtype === tv);
                    
        htmlRow.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      
      if (noResults) {
        noResults.style.display = visible === 0 ? 'block' : 'none';
      }
    }
    
    function clearFilters() {
      if (search) search.value = '';
      if (statusFilter) statusFilter.value = '';
      if (typeFilter) typeFilter.value = '';
      applyFilter();
    }
    
    // Event listeners
    search?.addEventListener('input', applyFilter);
    statusFilter?.addEventListener('change', applyFilter);
    typeFilter?.addEventListener('change', applyFilter);
    clearBtn?.addEventListener('click', clearFilters);
  </script>
</PortalLayout>
