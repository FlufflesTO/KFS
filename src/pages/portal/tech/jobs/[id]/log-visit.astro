---
/**
 * Project Sentinel - Technician Job Visit Logging
 * Purpose: Allows technicians to log site arrival, departure, and outcomes for assigned jobs.
 * Dependencies: PortalLayout, getDatabase, auditError
 * Structural Role: Technician field workflow component — two-phase (arrival → outcome) flow
 *                  posting JSON to /portal/api/job-visits to preserve endpoint payload contract.
 */
import PortalLayout from "../../../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../../../lib/server/bindings.js";
import { auditError } from "../../../../../lib/server/audit";

export const prerender = false;

/** Shape returned by the job details query (mirrors DB columns). */
interface JobDetails {
  id: string;
  system_id: string;
  scheduled_date: string;
  status: string;
  system_type: string;
  coverage_area: string;
  owner_company_name: string;
  physical_address: string;
}

const jobId = Astro.params.id;
const user = Astro.locals.user;
let job: JobDetails | null = null;
let loadError = "";

if (jobId && user) {
  try {
    const db = getDatabase();
    const result = await db.prepare(
      `SELECT jobs.id, jobs.system_id, jobs.scheduled_date, jobs.status,
              systems.system_type, systems.coverage_area,
              sites.owner_company_name, sites.physical_address
       FROM jobs
       INNER JOIN systems ON systems.id = jobs.system_id
       INNER JOIN sites ON sites.id = systems.site_id
       WHERE jobs.deleted_at IS NULL AND systems.deleted_at IS NULL
         AND jobs.id = ?1 AND jobs.assigned_technician_id = ?2`
    ).bind(jobId, user.id).first();

    if (result) {
      job = result as unknown as JobDetails;
    } else {
      loadError = "Job not found or not assigned to you.";
    }
  } catch (error) {
    await auditError(getDatabase(), Astro.request, error, { entityType: "system", entityId: "job_visit_logging" });
    loadError = "Could not load job details.";
  }
}

const visitStatuses = ["Travelling", "Arrived", "In Progress", "Completed", "Unable To Complete", "Follow-up Required", "Quote Required"];
const unableReasons = ["No Access", "Client Unavailable", "Unsafe To Proceed", "Parts Required", "System Isolated", "Quote Required", "Return Visit Required", "Cancelled On Site"];
import CsrfInput from "../../../../../components/ui/CsrfInput.astro";
---

<PortalLayout title={`Log Visit for Job ${jobId} | Kharon Portal`} active="tech" user={user}>
  <section class="bg-gradient-to-r from-kharon-black to-kharon-charcoal px-4 py-10 text-white sm:px-6 sm:py-12 shadow-inner">
    <div class="mx-auto max-w-4xl">
      <div class="flex items-center gap-3 mb-2">
        <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-kharon-purple/10 ring-1 ring-kharon-purple/20">
          <svg class="h-4 w-4 text-kharon-purple" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <p class="text-base font-bold uppercase tracking-wider text-kharon-purple">Field Operations</p>
      </div>
      <h1 class="mt-2 text-2xl font-bold sm:text-3xl tracking-tight">Log Site Visit Details</h1>
      <p class="mt-3 max-w-3xl text-base text-white/60">Record your arrival, departure, and job outcomes for accurate tracking.</p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto max-w-4xl">
      {loadError ? (
        <div class="rounded-xl border border-kharon-red bg-kharon-red/10 p-6 text-center shadow-sm">
          <p class="font-bold text-red-200">{loadError}</p>
          <a href="/portal/tech/dashboard" class="mt-4 inline-block kharon-secondary-button py-2 text-base">Back to Dashboard</a>
        </div>
      ) : !job ? (
        <div class="rounded-xl border border-line-cyan-soft/40 bg-surface-charcoal/40 p-6 sm:p-7 text-center shadow-sm">
          <p class="font-bold text-white">Job Not Found</p>
          <p class="mt-2 text-base text-white/60">The requested job does not exist or is not assigned to you.</p>
          <a href="/portal/tech/dashboard" class="mt-4 inline-block kharon-secondary-button py-2 text-base">Back to Dashboard</a>
        </div>
      ) : (
        <div class="kharon-surface p-6 sm:p-8">
          <!-- Job Details Card -->
          <div class="mb-6 border-b border-line-cyan-soft pb-4">
            <h2 class="text-lg font-bold text-white font-heading">Job Details</h2>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              <div>
                <p class="text-base font-semibold text-white">{job.owner_company_name}</p>
                <p class="text-base text-white/60">{job.system_type} / {job.coverage_area}</p>
              </div>
              <div class="sm:text-right">
                <p class="text-base text-kharon-purple font-mono uppercase">Job ID: {job.id}</p>
                <p class="text-base text-white/50 font-mono uppercase">Scheduled: {job.scheduled_date}</p>
              </div>
            </div>
          </div>

          <!-- Phase 1: Log Arrival -->
          <form class="log-arrival-form space-y-6" data-job-id={job.id}>
          <CsrfInput />
            <div class="grid gap-6 sm:grid-cols-2">
              <div class="grid gap-1">
                <label for="visit-date-input" class="block text-base font-bold uppercase tracking-widest text-kharon-purple">Visit Date</label>
                <input
                  id="visit-date-input"
                  type="date"
                  name="visitDate"
                  required
                  class="kharon-field"
                  value={new Date().toISOString().split('T')[0]}
                />
              </div>

              <div class="grid gap-1">
                <label for="arrival-time-input" class="block text-base font-bold uppercase tracking-widest text-kharon-purple">Arrival Time</label>
                <input
                  id="arrival-time-input"
                  type="time"
                  name="arrivalTime"
                  required
                  class="kharon-field"
                />
              </div>
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
              <div class="grid gap-1">
                <label for="gps-lat-input" class="block text-base font-bold uppercase tracking-widest text-kharon-purple">GPS Latitude (optional)</label>
                <input
                  id="gps-lat-input"
                  type="number"
                  name="gpsLat"
                  step="any"
                  placeholder="Auto-fill if available"
                  class="kharon-field"
                />
              </div>

              <div class="grid gap-1">
                <label for="gps-lng-input" class="block text-base font-bold uppercase tracking-widest text-kharon-purple">GPS Longitude (optional)</label>
                <input
                  id="gps-lng-input"
                  type="number"
                  name="gpsLng"
                  step="any"
                  placeholder="Auto-fill if available"
                  class="kharon-field"
                />
              </div>
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
              <div class="grid gap-1">
                <label for="customer-name-input" class="block text-base font-bold uppercase tracking-widest text-kharon-purple">Customer Name (optional)</label>
                <input
                  id="customer-name-input"
                  type="text"
                  name="customerName"
                  maxlength="160"
                  class="kharon-field"
                />
              </div>

              <div class="grid gap-1">
                <label for="customer-title-input" class="block text-base font-bold uppercase tracking-widest text-kharon-purple">Customer Title (optional)</label>
                <input
                  id="customer-title-input"
                  type="text"
                  name="customerTitle"
                  maxlength="80"
                  class="kharon-field"
                />
              </div>
            </div>

            <div class="grid gap-1">
              <label for="arrival-notes-input" class="block text-base font-bold uppercase tracking-widest text-kharon-purple">Notes (optional)</label>
              <textarea
                id="arrival-notes-input"
                name="notes"
                maxlength="1000"
                rows="3"
                class="kharon-field"
                placeholder="Any relevant notes about the visit..."
              ></textarea>
            </div>

            <div class="pt-4">
              <button type="submit" class="w-full kharon-command-button py-3">
                Log Arrival
              </button>
            </div>
          </form>

          <!-- Phase 2: Log Outcome (hidden until arrival is confirmed) -->
          <form class="log-outcome-form space-y-6 mt-8 hidden" data-job-id={job.id}>
          <CsrfInput />
            <div class="grid gap-6 sm:grid-cols-2">
              <div class="grid gap-1">
                <label for="departure-time-input" class="block text-base font-bold uppercase tracking-widest text-kharon-purple">Departure Time</label>
                <input
                  id="departure-time-input"
                  type="time"
                  name="departureTime"
                  required
                  class="kharon-field"
                />
              </div>

              <div class="grid gap-1">
                <label for="visit-status-select" class="block text-base font-bold uppercase tracking-widest text-kharon-purple">Visit Outcome</label>
                <select
                  id="visit-status-select"
                  name="visitStatus"
                  required
                  class="kharon-field"
                >
                  <option value="">Select outcome</option>
                  {visitStatuses.map(status => (
                    <option value={status}>{status}</option>
                  ))}
                </select>
              </div>
            </div>

            <div class="unable-reason-section hidden grid gap-1">
              <label for="unable-reason-select" class="block text-base font-bold uppercase tracking-widest text-kharon-purple">Unable-to-Complete Reason</label>
              <select
                id="unable-reason-select"
                name="unableReason"
                class="kharon-field"
              >
                <option value="">Select reason</option>
                {unableReasons.map(reason => (
                  <option value={reason}>{reason}</option>
                ))}
              </select>
            </div>

            <div class="grid gap-1">
              <label for="outcome-notes-input" class="block text-base font-bold uppercase tracking-widest text-kharon-purple">Outcome Notes (optional)</label>
              <textarea
                id="outcome-notes-input"
                name="notes"
                maxlength="1000"
                rows="3"
                class="kharon-field"
                placeholder="Any notes about the visit outcome..."
              ></textarea>
            </div>

            <div class="pt-4 flex gap-4">
              <button type="submit" class="flex-1 kharon-command-button py-3 text-base">
                Log Outcome
              </button>
              <button type="button" class="cancel-outcome-btn flex-1 kharon-secondary-button py-3 text-base">
                Cancel
              </button>
            </div>
          </form>

          <!-- Result banner for success / error feedback -->
          <div class="visit-result hidden mt-4 p-4 rounded-lg border"></div>
        </div>
      )}
    </div>
  </section>

  <script>
    import { safeQuerySelector } from "../../../../../lib/types/dom";
    /**
     * Client-side logic for the two-phase visit logging workflow.
     * Posts JSON to /portal/api/job-visits matching the existing payload contract:
     *   logArrival  → { action, jobId, visitDate, arrivalTime, gpsLat, gpsLng, customerName, customerTitle, notes }
     *   logOutcome  → { action, jobId, visitDate, departureTime, visitStatus, unableReason, notes }
     */
    async function postJson(url: string, payload: Record<string, unknown>): Promise<Record<string, unknown>> {
      const response = await window.kharonPortalFetch(url, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload)
      });
      const body = await response.json() as { ok?: boolean; message?: string; visitId?: string } | null;
      if (!response.ok || !body?.ok) throw new Error(body?.message || "Request failed.");
      return body || {};
    }

    // ── DOM references ────────────────────────────────────────────────────────
    const arrivalForm = safeQuerySelector<HTMLFormElement>(".log-arrival-form");
    const outcomeForm = safeQuerySelector<HTMLFormElement>(".log-outcome-form");
    const visitResult = safeQuerySelector<HTMLElement>(".visit-result");
    const outcomeSelect = safeQuerySelector<Element>('.log-outcome-form select[name="visitStatus"]') as HTMLSelectElement | null;
    const unableReasonSection = safeQuerySelector<HTMLElement>(".unable-reason-section");

    // ── Conditionally show "Unable to Complete" reason dropdown ────────────
    if (outcomeSelect) {
      outcomeSelect.addEventListener("change", function (this: HTMLSelectElement) {
        if (this.value === "Unable To Complete") {
          unableReasonSection?.classList.remove("hidden");
        } else {
          unableReasonSection?.classList.add("hidden");
        }
      });
    }

    // ── Phase 1: Log Arrival ──────────────────────────────────────────────
    if (arrivalForm) {
      arrivalForm.addEventListener("submit", async (event: Event) => {
        event.preventDefault();
        const formData = new FormData(arrivalForm);
        const jobId = arrivalForm.dataset.jobId;

        try {
          const result = await postJson("/portal/api/job-visits", {
            action: "logArrival",
            jobId,
            visitDate: formData.get("visitDate"),
            arrivalTime: formData.get("arrivalTime"),
            gpsLat: formData.get("gpsLat") || null,
            gpsLng: formData.get("gpsLng") || null,
            customerName: formData.get("customerName") || null,
            customerTitle: formData.get("customerTitle") || null,
            notes: formData.get("notes") || null
          });

          if (visitResult) {
            visitResult.textContent = String(result.message ?? "Arrival logged.");
            visitResult.className = "visit-result mt-4 p-4 rounded-lg border border-kharon-green bg-kharon-green/10 text-base font-semibold text-green-200";
            visitResult.classList.remove("hidden");
          }

          // Transition to Phase 2
          arrivalForm.classList.add("hidden");
          outcomeForm?.classList.remove("hidden");
        } catch (error) {
          if (visitResult) {
            visitResult.textContent = (error as Error).message;
            visitResult.className = "visit-result mt-4 p-4 rounded-lg border border-kharon-red bg-kharon-red/10 text-base font-semibold text-red-200";
            visitResult.classList.remove("hidden");
          }
        }
      });
    }

    // ── Phase 2: Log Outcome (with confirmation guard) ────────────────────
    if (outcomeForm) {
      outcomeForm.addEventListener("submit", async (event: Event) => {
        event.preventDefault();

        if (!window.confirm("Are you sure you want to log this job outcome? This will finalize the job card and submit the visit record.")) {
          return;
        }

        const formData = new FormData(outcomeForm);
        const jobId = outcomeForm.dataset.jobId;

        // Re-use the visit date from Phase 1
        const visitDateInput = document.querySelector<HTMLInputElement>('.log-arrival-form [name="visitDate"]');

        try {
          const result = await postJson("/portal/api/job-visits", {
            action: "logOutcome",
            jobId,
            visitDate: visitDateInput?.value,
            departureTime: formData.get("departureTime"),
            visitStatus: formData.get("visitStatus"),
            unableReason: formData.get("unableReason") || null,
            notes: formData.get("notes") || null
          });

          if (visitResult) {
            visitResult.textContent = String(result.message ?? "Visit outcome logged.");
            visitResult.className = "visit-result mt-4 p-4 rounded-lg border border-kharon-green bg-kharon-green/10 text-base font-semibold text-green-200";
            visitResult.classList.remove("hidden");
          }

          // Disable all form inputs after successful submission
          outcomeForm.querySelectorAll("input, select, textarea, button").forEach(
            (el: Element) => ((el as HTMLInputElement).disabled = true)
          );
        } catch (error) {
          if (visitResult) {
            visitResult.textContent = (error as Error).message;
            visitResult.className = "visit-result mt-4 p-4 rounded-lg border border-kharon-red bg-kharon-red/10 text-base font-semibold text-red-200";
            visitResult.classList.remove("hidden");
          }
        }
      });

      // Cancel button returns to Phase 1
      const cancelBtn = document.querySelector<HTMLButtonElement>(".cancel-outcome-btn");
      if (cancelBtn) {
        cancelBtn.addEventListener("click", () => {
          outcomeForm.classList.add("hidden");
          arrivalForm?.classList.remove("hidden");
          visitResult?.classList.add("hidden");
        });
      }
    }
  </script>
</PortalLayout>
