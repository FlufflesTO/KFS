---
import { auditError } from "../../../../../lib/server/audit.js";
/**
 * Project Sentinel - Technician Job Visit Logging
 * Purpose: Allows technicians to log site arrival, departure, and outcomes for assigned jobs
 * Dependencies: PortalLayout, bindings
 * Structural Role: Technician field workflow component
 */
import PortalLayout from "../../../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../../../lib/server/bindings.js";

export const prerender = false;

interface JobDetails {
  id: string;
  system_id: string;
  scheduled_date: string;
  status: string;
  system_type: string;
  coverage_area: string;
  owner_company_name: string;
  physical_address: string;
}

const jobId = Astro.params.id;
const user = Astro.locals.user;
let job: JobDetails | null = null;
let loadError = "";

if (jobId && user) {
  try {
    const db = getDatabase();
    const result = await db.prepare(
      `SELECT jobs.id, jobs.system_id, jobs.scheduled_date, jobs.status, 
              systems.system_type, systems.coverage_area,
              sites.owner_company_name, sites.physical_address
       FROM jobs
       INNER JOIN systems ON systems.id = jobs.system_id
       INNER JOIN sites ON sites.id = systems.site_id
       WHERE jobs.deleted_at IS NULL AND systems.deleted_at IS NULL
         AND jobs.id = ?1 AND jobs.assigned_technician_id = ?2`
    ).bind(jobId, user.id).first();
    
    if (result) {
      job = result;
    } else {
      loadError = "Job not found or not assigned to you.";
    }
  } catch (error) {
    await auditError(typeof db !== "undefined" ? db : Astro.locals.db, Astro.request, error, { user: typeof user !== "undefined" ? user : Astro.locals.user, metadata: { message: "job visit logging failed" } });
    loadError = "Could not load job details.";
  }
}

const visitStatuses = ["Travelling", "Arrived", "In Progress", "Completed", "Unable To Complete", "Follow-up Required", "Quote Required"];
const unableReasons = ["No Access", "Client Unavailable", "Unsafe To Proceed", "Parts Required", "System Isolated", "Quote Required", "Return Visit Required", "Cancelled On Site"];
---

<PortalLayout title={`Log Visit for Job ${jobId} | Kharon Portal`} active="tech" user={user}>
  <section class="bg-gradient-to-r from-[#0B0D0F] to-[#1A1F26] px-4 py-10 text-white sm:px-6 sm:py-12 shadow-inner">
    <div class="mx-auto max-w-4xl">
      <p class="text-xs font-bold uppercase tracking-wider text-kharon-cyan">Field Operations</p>
      <h1 class="mt-2 text-2xl font-bold sm:text-3xl tracking-tight">Log Site Visit Details</h1>
      <p class="mt-3 max-w-3xl text-sm text-white/60">Record your arrival, departure, and job outcomes for accurate tracking.</p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6 sm:py-8">
    <div class="mx-auto max-w-4xl">
      {loadError ? (
        <div class="rounded-xl border border-red-200 bg-red-50 p-6 text-center shadow-sm">
          <p class="font-bold text-red-800">{loadError}</p>
          <a href="/portal/tech/dashboard" class="mt-4 inline-block rounded bg-kharon-purple px-4 py-2 text-sm font-bold text-white hover:opacity-90">Back to Dashboard</a>
        </div>
      ) : !job ? (
        <div class="rounded-xl border border-slate-200/80 bg-white p-8 text-center shadow-sm">
          <p class="font-bold text-slate-800">Job Not Found</p>
          <p class="mt-2 text-sm text-slate-500">The requested job does not exist or is not assigned to you.</p>
          <a href="/portal/tech/dashboard" class="mt-4 inline-block rounded bg-kharon-purple px-4 py-2 text-sm font-bold text-white hover:opacity-90">Back to Dashboard</a>
        </div>
      ) : (
        <div class="rounded-xl border border-kharon-border bg-white p-6 shadow-sm">
          <div class="mb-6 border-b border-kharon-border pb-4">
            <h2 class="text-lg font-bold text-kharon-black">Job Details</h2>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              <div>
                <p class="text-sm font-semibold text-kharon-black">{job.owner_company_name}</p>
                <p class="text-xs text-kharon-grey">{job.system_type} / {job.coverage_area}</p>
              </div>
              <div>
                <p class="text-xs text-kharon-grey/70 uppercase">Job ID: {job.id}</p>
                <p class="text-xs text-kharon-grey/70 uppercase">Scheduled: {job.scheduled_date}</p>
              </div>
            </div>
          </div>

          <form class="log-arrival-form space-y-6" data-job-id={job.id}>
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label class="block text-xs font-bold uppercase text-kharon-grey/70 mb-1">Visit Date</label>
                <input 
                  type="date" 
                  name="visitDate" 
                  required 
                  class="portal-field w-full rounded border border-kharon-border bg-white px-3 py-2 text-xs focus:outline-none"
                  value={new Date().toISOString().split('T')[0]}
                />
              </div>
              
              <div>
                <label class="block text-xs font-bold uppercase text-kharon-grey/70 mb-1">Arrival Time</label>
                <input 
                  type="time" 
                  name="arrivalTime" 
                  required 
                  class="portal-field w-full rounded border border-kharon-border bg-white px-3 py-2 text-xs focus:outline-none"
                />
              </div>
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label class="block text-xs font-bold uppercase text-kharon-grey/70 mb-1">GPS Latitude (optional)</label>
                <input 
                  type="number" 
                  name="gpsLat" 
                  step="any"
                  placeholder="Auto-fill if available"
                  class="portal-field w-full rounded border border-kharon-border bg-white px-3 py-2 text-xs focus:outline-none"
                />
              </div>
              
              <div>
                <label class="block text-xs font-bold uppercase text-kharon-grey/70 mb-1">GPS Longitude (optional)</label>
                <input 
                  type="number" 
                  name="gpsLng" 
                  step="any"
                  placeholder="Auto-fill if available"
                  class="portal-field w-full rounded border border-kharon-border bg-white px-3 py-2 text-xs focus:outline-none"
                />
              </div>
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label class="block text-xs font-bold uppercase text-kharon-grey/70 mb-1">Customer Name (optional)</label>
                <input 
                  type="text" 
                  name="customerName" 
                  maxlength="160"
                  class="portal-field w-full rounded border border-kharon-border bg-white px-3 py-2 text-xs focus:outline-none"
                />
              </div>
              
              <div>
                <label class="block text-xs font-bold uppercase text-kharon-grey/70 mb-1">Customer Title (optional)</label>
                <input 
                  type="text" 
                  name="customerTitle" 
                  maxlength="80"
                  class="portal-field w-full rounded border border-kharon-border bg-white px-3 py-2 text-xs focus:outline-none"
                />
              </div>
            </div>

            <div>
              <label class="block text-xs font-bold uppercase text-kharon-grey/70 mb-1">Notes (optional)</label>
              <textarea 
                name="notes"
                maxlength="1000"
                rows="3"
                class="portal-field w-full rounded border border-kharon-border bg-white px-3 py-2 text-xs focus:outline-none"
                placeholder="Any relevant notes about the visit..."
              ></textarea>
            </div>

            <div class="pt-4">
              <button type="submit" class="w-full rounded bg-kharon-purple px-4 py-3 text-sm font-bold text-white hover:opacity-90 transition-opacity">
                Log Arrival
              </button>
            </div>
          </form>

          <form class="log-outcome-form space-y-6 mt-8 hidden" data-job-id={job.id}>
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label class="block text-xs font-bold uppercase text-kharon-grey/70 mb-1">Departure Time</label>
                <input 
                  type="time" 
                  name="departureTime" 
                  required 
                  class="portal-field w-full rounded border border-kharon-border bg-white px-3 py-2 text-xs focus:outline-none"
                />
              </div>
              
              <div>
                <label class="block text-xs font-bold uppercase text-kharon-grey/70 mb-1">Visit Outcome</label>
                <select 
                  name="visitStatus"
                  required 
                  class="portal-field w-full rounded border border-kharon-border bg-white px-3 py-2 text-xs focus:outline-none"
                >
                  <option value="">Select outcome</option>
                  {visitStatuses.map(status => (
                    <option value={status}>{status}</option>
                  ))}
                </select>
              </div>
            </div>

            <div class="unable-reason-section hidden">
              <label class="block text-xs font-bold uppercase text-kharon-grey/70 mb-1">Unable-to-Complete Reason</label>
              <select 
                name="unableReason"
                class="portal-field w-full rounded border border-kharon-border bg-white px-3 py-2 text-xs focus:outline-none"
              >
                <option value="">Select reason</option>
                {unableReasons.map(reason => (
                  <option value={reason}>{reason}</option>
                ))}
              </select>
            </div>

            <div>
              <label class="block text-xs font-bold uppercase text-kharon-grey/70 mb-1">Outcome Notes (optional)</label>
              <textarea 
                name="notes"
                maxlength="1000"
                rows="3"
                class="portal-field w-full rounded border border-kharon-border bg-white px-3 py-2 text-xs focus:outline-none"
                placeholder="Any notes about the visit outcome..."
              ></textarea>
            </div>

            <div class="pt-4 flex gap-3">
              <button type="submit" class="flex-1 rounded bg-kharon-purple px-4 py-3 text-sm font-bold text-white hover:opacity-90 transition-opacity">
                Log Outcome
              </button>
              <button type="button" class="cancel-outcome-btn flex-1 rounded border border-kharon-border px-4 py-3 text-sm font-bold text-kharon-black hover:bg-kharon-light transition-colors">
                Cancel
              </button>
            </div>
          </form>

          <div class="visit-result hidden mt-4 p-4 rounded-lg border border-kharon-border bg-kharon-light text-sm font-semibold"></div>
        </div>
      )}
    </div>
  </section>
  
  <script>
    async function postJson(url, payload) {
      const response = await window.kharonPortalFetch(url, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload)
      });
      const body = await response.json();
      if (!response.ok || !body.ok) throw new Error(body.message || "Request failed.");
      return body;
    }

    // Handle visit outcome selection
    const outcomeSelect = document.querySelector('.log-outcome-form select[name="visitStatus"]');
    const unableReasonSection = document.querySelector('.unable-reason-section');
    
    if (outcomeSelect) {
      outcomeSelect.addEventListener('change', function() {
        if (this.value === 'Unable To Complete') {
          unableReasonSection.classList.remove('hidden');
        } else {
          unableReasonSection.classList.add('hidden');
        }
      });
    }

    // Show outcome form after arrival is logged
    const arrivalForm = document.querySelector('.log-arrival-form');
    const outcomeForm = document.querySelector('.log-outcome-form');
    const visitResult = document.querySelector('.visit-result');
    
    if (arrivalForm) {
      arrivalForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        const formData = new FormData(arrivalForm);
        const jobId = arrivalForm.dataset.jobId;
        
        try {
          const result = await postJson('/portal/api/job-visits', {
            action: 'logArrival',
            jobId,
            visitDate: formData.get('visitDate'),
            arrivalTime: formData.get('arrivalTime'),
            gpsLat: formData.get('gpsLat') || null,
            gpsLng: formData.get('gpsLng') || null,
            customerName: formData.get('customerName') || null,
            customerTitle: formData.get('customerTitle') || null,
            notes: formData.get('notes') || null
          });
          
          visitResult.textContent = result.message;
          visitResult.className = 'visit-result mt-4 p-4 rounded-lg border border-green-200 bg-green-50 text-sm font-semibold text-green-800';
          visitResult.classList.remove('hidden');
          
          // Hide arrival form and show outcome form
          arrivalForm.classList.add('hidden');
          outcomeForm.classList.remove('hidden');
        } catch (error) {
          visitResult.textContent = error.message;
          visitResult.className = 'visit-result mt-4 p-4 rounded-lg border border-red-200 bg-red-50 text-sm font-semibold text-red-800';
          visitResult.classList.remove('hidden');
        }
      });
    }
    
    if (outcomeForm) {
      outcomeForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        const formData = new FormData(outcomeForm);
        const jobId = outcomeForm.dataset.jobId;
        
        try {
          const result = await postJson('/portal/api/job-visits', {
            action: 'logOutcome',
            jobId,
            visitDate: document.querySelector('.log-arrival-form [name="visitDate"]').value, // Use the same date as arrival
            departureTime: formData.get('departureTime'),
            visitStatus: formData.get('visitStatus'),
            unableReason: formData.get('unableReason') || null,
            notes: formData.get('notes') || null
          });
          
          visitResult.textContent = result.message;
          visitResult.className = 'visit-result mt-4 p-4 rounded-lg border border-green-200 bg-green-50 text-sm font-semibold text-green-800';
          visitResult.classList.remove('hidden');
          
          // Disable form after successful submission
          outcomeForm.querySelectorAll('input, select, textarea, button').forEach(el => el.disabled = true);
        } catch (error) {
          visitResult.textContent = error.message;
          visitResult.className = 'visit-result mt-4 p-4 rounded-lg border border-red-200 bg-red-50 text-sm font-semibold text-red-800';
          visitResult.classList.remove('hidden');
        }
      });
      
      // Cancel outcome logging
      const cancelBtn = document.querySelector('.cancel-outcome-btn');
      if (cancelBtn) {
        cancelBtn.addEventListener('click', () => {
          outcomeForm.classList.add('hidden');
          arrivalForm.classList.remove('hidden');
          visitResult.classList.add('hidden');
        });
      }
    }
  </script>
</PortalLayout>
