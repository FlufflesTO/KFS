---
import { auditError } from "../../../../lib/server/audit";
/**
 * Project Sentinel - Technician Job Detail
 * Purpose: Shows job details and allows technician actions like logging arrival, submitting jobcard, etc.
 * Dependencies: PortalLayout, D1 database, KharonCard.
 * Structural Role: Job detail view for technicians.
 */
import PortalLayout from "../../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../../lib/server/bindings.js";
import OfflineBanner from "../../../../components/portal/OfflineBanner.astro";

export const prerender = false;

const { params } = Astro;
const jobId = params.id;
const user = Astro.locals.user;
let job: any = null;
let loadError = "";
let jobHistory: Array<any> = [];

try {
  const db = getDatabase();
  
  // Get job details
  const jobResult = await db.prepare(`
    SELECT jobs.*, 
           systems.system_type, systems.coverage_area, systems.protocol_version,
           sites.owner_company_name, sites.physical_address, sites.site_notes,
           technicians.first_name as technician_first_name, technicians.last_name as technician_last_name
    FROM jobs 
    LEFT JOIN systems ON systems.id = jobs.system_id
    LEFT JOIN sites ON sites.id = systems.site_id
    LEFT JOIN users as technicians ON technicians.id = jobs.assigned_technician_id
    WHERE jobs.id = ?1 AND jobs.deleted_at IS NULL
  `).bind(jobId).first();

  if (!jobResult) {
    loadError = "Job not found";
  } else {
    job = jobResult;
    
    // Get job history
    const historyResult = await db.prepare(`
      SELECT *
      FROM job_history
      WHERE job_id = ?1
      ORDER BY created_at DESC
      LIMIT 20
    `).bind(jobId).all();
    jobHistory = historyResult.results || [];
  }
} catch (error) {
  await auditError(getDatabase(), Astro.request, error, { entityType: "job", entityId: jobId });
  loadError = "Job details could not be loaded.";
}

function priorityBadgeClass(priority: string): string {
  if (priority === "Critical") return "bg-kharon-red/20 text-kharon-red";
  if (priority === "High") return "bg-kharon-amber/20 text-kharon-amber";
  return "bg-kharon-cyan/20 text-kharon-cyan";
}
---

<PortalLayout title={`${job?.owner_company_name || 'Job'} | Kharon Portal`} active="tech" user={user}>
  <OfflineBanner initialQueueCount={0} />
  <section class="bg-gradient-to-br from-kharon-black to-kharon-charcoal px-4 py-8 text-white sm:px-6 sm:py-10 kharon-environment kharon-logo-watermark">
    <div class="mx-auto max-w-4xl">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-kharon-cyan/10 ring-1 ring-kharon-cyan/20">
          <svg class="h-4 w-4 text-kharon-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002-2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
        </div>
        <p class="text-xs font-bold uppercase tracking-widest text-kharon-cyan">Job Detail</p>
      </div>
      <h1 class="text-2xl font-bold sm:text-3xl">Job #{job?.id}</h1>
      <p class="mt-2 text-sm text-white/70">ID: {job?.id} • Status: {job?.status}</p>
    </div>
  </section>

  <section class="px-4 py-6 sm:px-6">
    <div class="mx-auto max-w-4xl">
      {loadError && <div class="rounded-lg border border-kharon-red/30 bg-kharon-red/10 p-4 mb-6"><p class="text-sm font-bold text-kharon-red">{loadError}</p></div>}
      
      {job && (
        <div class="space-y-6">
          {/* Job Status Card */}
          <div class="rounded-xl border border-kharon-cyan/20 bg-kharon-surface-elevated p-4 kharon-surface">
            <div class="flex flex-wrap items-center gap-3 mb-4">
              <span class={`rounded-full px-3 py-1 text-xs font-bold uppercase tracking-widest ${priorityBadgeClass(job.priority || "Normal")}`}>{job.priority || "Normal"}</span>
              <span class="rounded-full bg-kharon-blue/20 text-kharon-blue px-3 py-1 text-xs font-bold uppercase tracking-widest">{job.status}</span>
              {job.is_emergency === 1 && <span class="rounded-full bg-kharon-red/20 text-kharon-red px-3 py-1 text-xs font-bold uppercase tracking-widest flex items-center gap-1"><span class="h-1.5 w-1.5 rounded-full bg-kharon-red animate-pulse"></span>Emergency</span>}
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
              <div>
                <p class="text-xs text-kharon-cyan uppercase tracking-widest">Job Type</p>
                <p class="text-sm font-bold text-white">{job.job_type}</p>
              </div>
              <div>
                <p class="text-xs text-kharon-cyan uppercase tracking-widest">Scheduled Date</p>
                <p class="text-sm font-bold text-white">{job.scheduled_date}</p>
              </div>
              <div>
                <p class="text-xs text-kharon-cyan uppercase tracking-widest">Required By</p>
                <p class="text-sm font-bold text-white">{job.required_by_date || 'Not specified'}</p>
              </div>
              <div>
                <p class="text-xs text-kharon-cyan uppercase tracking-widest">Assigned Technician</p>
                <p class="text-sm font-bold text-white">{job.technician_first_name} {job.technician_last_name}</p>
              </div>
            </div>
          </div>

          {/* Site Information */}
          <div class="rounded-xl border border-kharon-cyan/20 bg-kharon-surface-elevated p-4 kharon-surface">
            <h2 class="text-lg font-bold text-white mb-3">Site Information</h2>
            
            <div class="space-y-4">
              <div>
                <p class="text-xs text-kharon-cyan uppercase tracking-widest mb-1">Company</p>
                <p class="text-lg font-bold text-white">{job.owner_company_name}</p>
              </div>
              
              <div>
                <p class="text-xs text-kharon-cyan uppercase tracking-widest mb-1">Address</p>
                <p class="text-sm text-white">{job.physical_address}</p>
              </div>
              
              <div>
                <p class="text-xs text-kharon-cyan uppercase tracking-widest mb-1">System</p>
                <p class="text-sm font-bold text-kharon-purple">{job.system_type} | {job.coverage_area}</p>
              </div>
              
              {job.site_notes && (
                <div class="rounded-lg border border-kharon-blue/20 bg-kharon-blue/10 p-3 text-sm text-white relative overflow-hidden kharon-surface">
                  <p class="font-bold text-xs text-kharon-blue uppercase tracking-widest mb-1">Site Instructions</p>
                  <p class="leading-relaxed">{job.site_notes}</p>
                </div>
              )}
            </div>
          </div>

          {/* System Information */}
          <div class="rounded-xl border border-kharon-cyan/20 bg-kharon-surface-elevated p-4 kharon-surface">
            <h2 class="text-lg font-bold text-white mb-3">System Information</h2>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <p class="text-xs text-kharon-cyan uppercase tracking-widest mb-1">System Type</p>
                <p class="text-sm font-bold text-white">{job.system_type}</p>
              </div>
              <div>
                <p class="text-xs text-kharon-cyan uppercase tracking-widest mb-1">Coverage Area</p>
                <p class="text-sm font-bold text-white">{job.coverage_area}</p>
              </div>
              <div>
                <p class="text-xs text-kharon-cyan uppercase tracking-widest mb-1">Protocol Version</p>
                <p class="text-sm font-bold text-white">{job.protocol_version || 'Not specified'}</p>
              </div>
            </div>
          </div>

          {/* Quick Actions */}
          <div class="rounded-xl border border-kharon-cyan/20 bg-kharon-surface-elevated p-4 kharon-surface">
            <h2 class="text-lg font-bold text-white mb-3">Quick Actions</h2>
            
            <div class="grid grid-cols-1 gap-3">
              <a href={`/portal/tech/jobs/${job.id}/log-visit`} class="w-full px-4 py-3 bg-gradient-to-r from-kharon-cyan to-kharon-blue text-white font-bold uppercase tracking-widest rounded-md text-center hover:shadow-lg hover:shadow-kharon-cyan/30 transition-all kharon-command-button">
                Log Visit
              </a>
              
              <a href={`/portal/tech/jobs/${job.id}/jobcard`} class="w-full px-4 py-3 border border-kharon-cyan/30 text-kharon-cyan font-bold uppercase tracking-widest rounded-md text-center hover:bg-kharon-cyan/10 transition-colors">
                Complete Jobcard
              </a>
              
              <a href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(String(job.physical_address))}`} target="_blank" rel="noopener noreferrer" class="w-full px-4 py-3 border border-kharon-cyan/30 text-kharon-cyan font-bold uppercase tracking-widest rounded-md text-center hover:bg-kharon-cyan/10 transition-colors">
                Navigate to Site
              </a>
            </div>
          </div>

          {/* Job History */}
          {jobHistory.length > 0 && (
            <div class="rounded-xl border border-kharon-cyan/20 bg-kharon-surface-elevated p-4 kharon-surface">
              <h2 class="text-lg font-bold text-white mb-3">Job History</h2>
              
              <div class="space-y-3">
                {jobHistory.map((entry: any, index: number) => (
                  <div key={index} class="border-b border-kharon-cyan/10 pb-3 last:border-0 last:pb-0">
                    <div class="flex justify-between items-start">
                      <div>
                        <p class="text-sm font-bold text-white">{entry.action}</p>
                        <p class="text-xs text-kharon-light/70">{entry.description}</p>
                      </div>
                      <p class="text-xs text-kharon-amber font-bold">{entry.created_at}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      )}
    </div>
  </section>
</PortalLayout>
