---
/**
 * Project Sentinel - Technician Job Detail
 * Purpose: Shows job details and allows technician actions like logging arrival, submitting jobcard, etc.
 * Dependencies: PortalLayout, D1 database, KharonCard.
 * Structural Role: Job detail view for technicians.
 */
import { auditError } from "../../../../lib/server/audit";
import PortalLayout from "../../../../layouts/portal/PortalLayout.astro";
import { getDatabase } from "../../../../lib/server/bindings.js";
import OfflineBanner from "../../../../components/portal/OfflineBanner.astro";

export const prerender = false;

const { params } = Astro;
const jobId = params.id;
const user = Astro.locals.user;

interface JobDetail {
  id: string;
  system_id: string;
  assigned_technician_id: string | null;
  scheduled_date: string;
  required_by_date: string | null;
  status: string;
  priority: string;
  job_type: string;
  is_emergency: number;
  completed_at: string | null;
  system_type: string;
  coverage_area: string;
  protocol_version: string | null;
  owner_company_name: string;
  physical_address: string;
  site_notes: string | null;
  technician_first_name: string | null;
  technician_last_name: string | null;
}

interface HistoryEntry {
  id: string;
  job_id: string;
  action: string;
  description: string;
  created_at: string;
}

let job: JobDetail | null = null;
let loadError = "";
let jobHistory: Array<HistoryEntry> = [];

try {
  const db = getDatabase();
  
  // Get job details
  const jobResult = await db.prepare(`
    SELECT jobs.*, 
           systems.system_type, systems.coverage_area, systems.protocol_version,
           sites.owner_company_name, sites.physical_address, sites.site_notes,
           technicians.first_name as technician_first_name, technicians.last_name as technician_last_name
    FROM jobs 
    LEFT JOIN systems ON systems.id = jobs.system_id
    LEFT JOIN sites ON sites.id = systems.site_id
    LEFT JOIN users as technicians ON technicians.id = jobs.assigned_technician_id
    WHERE jobs.id = ?1 AND jobs.deleted_at IS NULL
  `).bind(jobId).first();

  if (!jobResult) {
    loadError = "Job not found";
  } else {
    job = jobResult as unknown as JobDetail;
    
    // Get job history
    const historyResult = await db.prepare(`
      SELECT *
      FROM job_history
      WHERE job_id = ?1
      ORDER BY created_at DESC
      LIMIT 20
    `).bind(jobId).all();
    jobHistory = (historyResult.results as unknown as HistoryEntry[]) || [];
  }
} catch (error) {
  await auditError(getDatabase(), Astro.request, error, { entityType: "job", entityId: jobId || "unknown" });
  loadError = "Job details could not be loaded.";
}

function priorityBadgeClass(priority: string): string {
  if (priority === "Critical") return "bg-kharon-red/20 text-kharon-red border border-kharon-red/30";
  if (priority === "High") return "bg-kharon-amber/20 text-kharon-amber border border-kharon-amber/30";
  return "bg-kharon-purple/20 text-kharon-purple border border-kharon-purple/30";
}
---

<PortalLayout title={`${job?.owner_company_name || 'Job'} Workspace`} active="tech" user={user}>
  <OfflineBanner initialQueueCount={0} />
  
  <section class="bg-gradient-to-br from-kharon-black to-kharon-charcoal px-4 py-8 text-white sm:px-6 sm:py-10 kharon-environment kharon-logo-watermark relative overflow-hidden rounded-xl border border-kharon-purple/10 mb-6">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(75,46,131,0.1),transparent)]"></div>
    <div class="mx-auto max-w-4xl relative z-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-kharon-purple/10 ring-1 ring-kharon-purple/20">
          <svg class="h-4.5 w-4.5 text-kharon-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002-2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
        </div>
        <a href="/portal/tech/dashboard" class="text-xs font-black uppercase tracking-[0.2em] text-kharon-purple hover:text-kharon-cyan transition-colors">Back to Dispatches</a>
      </div>
      <h1 class="text-2xl font-black sm:text-3xl tracking-tight">Job Workspace</h1>
      <p class="mt-2 text-xs text-white/60 font-mono font-bold uppercase tracking-wider">ID: {job?.id} &bull; Status: {job?.status}</p>
    </div>
  </section>

  <section class="px-1 py-4 sm:px-4">
    <div class="mx-auto max-w-4xl">
      {loadError && (
        <div class="rounded-lg border border-kharon-red/30 bg-kharon-red/10 p-4 mb-6">
          <p class="text-sm font-bold text-kharon-red">{loadError}</p>
        </div>
      )}
      
      {job && (
        <div class="space-y-6">
          <!-- Responsive Segmented Tab Headers -->
          <div class="flex border border-kharon-purple/25 bg-kharon-charcoal/80 p-1.5 rounded-xl backdrop-blur-md shadow-lg shadow-black/20">
            <button id="tab-details-btn" class="flex-1 py-2.5 text-xs font-black uppercase tracking-widest text-center rounded-lg bg-kharon-purple/35 text-white transition-all duration-200 cursor-pointer">Details</button>
            <button id="tab-system-btn" class="flex-1 py-2.5 text-xs font-black uppercase tracking-widest text-center rounded-lg text-white/60 hover:text-white transition-all duration-200 cursor-pointer">System Specs</button>
            <button id="tab-actions-btn" class="flex-1 py-2.5 text-xs font-black uppercase tracking-widest text-center rounded-lg text-white/60 hover:text-white transition-all duration-200 cursor-pointer">Field Actions</button>
          </div>

          <!-- Tab 1: Details -->
          <div id="tab-details" class="space-y-6">
            <!-- Job Status Card -->
            <div class="rounded-xl border border-kharon-purple/25 bg-kharon-charcoal/80 p-6 shadow-xl backdrop-blur-md relative overflow-hidden">
              <div class="flex flex-wrap items-center gap-3 mb-5">
                <span class={`rounded-full px-2.5 py-0.5 text-[9px] font-bold uppercase tracking-widest ${priorityBadgeClass(job.priority || "Normal")}`}>{job.priority || "Normal"}</span>
                <span class={`rounded-full px-2.5 py-0.5 text-[9px] font-bold uppercase tracking-widest ${job.status === 'In Progress' ? 'bg-kharon-cyan/20 text-kharon-cyan border border-kharon-cyan/30' : 'bg-kharon-blue/20 text-kharon-blue border border-kharon-blue/30'}`}>{job.status}</span>
                {job.is_emergency === 1 && (
                  <span class="rounded-full bg-kharon-red/20 text-kharon-red border border-kharon-red/30 px-2.5 py-0.5 text-[9px] font-bold uppercase tracking-widest flex items-center gap-1">
                    <span class="h-1.5 w-1.5 rounded-full bg-kharon-red animate-pulse"></span>
                    Emergency
                  </span>
                )}
              </div>
              
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                <div>
                  <p class="text-[9px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Job Type</p>
                  <p class="text-sm font-bold text-white">{job.job_type}</p>
                </div>
                <div>
                  <p class="text-[9px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Scheduled Date</p>
                  <p class="text-sm font-bold text-white">{job.scheduled_date}</p>
                </div>
                <div>
                  <p class="text-[9px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Required By</p>
                  <p class="text-sm font-bold text-white">{job.required_by_date || 'Not specified'}</p>
                </div>
                <div>
                  <p class="text-[9px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Assigned Technician</p>
                  <p class="text-sm font-bold text-white">{job.technician_first_name} {job.technician_last_name}</p>
                </div>
              </div>
            </div>

            <!-- Site Information -->
            <div class="rounded-xl border border-kharon-purple/25 bg-kharon-charcoal/80 p-6 shadow-xl backdrop-blur-md relative overflow-hidden">
              <h2 class="text-lg font-black text-white tracking-tight mb-4">Site Information</h2>
              
              <div class="space-y-4">
                <div>
                  <p class="text-[9px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Client Entity</p>
                  <p class="text-lg font-black text-white tracking-tight">{job.owner_company_name}</p>
                </div>
                
                <div>
                  <p class="text-[9px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Physical Address</p>
                  <p class="text-sm text-white/95 leading-relaxed">{job.physical_address}</p>
                </div>
                
                <div>
                  <p class="text-[9px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Target Protection System</p>
                  <p class="text-sm font-bold text-kharon-cyan">{job.system_type} | {job.coverage_area}</p>
                </div>
                
                {job.site_notes && (
                  <div class="rounded-lg border border-kharon-purple/20 bg-kharon-purple/5 p-4 text-xs text-white relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-1 h-full bg-kharon-cyan"></div>
                    <p class="font-bold text-[10px] text-kharon-cyan uppercase tracking-widest mb-1.5">Site Instructions</p>
                    <p class="leading-relaxed text-white/85">{job.site_notes}</p>
                  </div>
                )}
              </div>
            </div>

            <!-- Job History -->
            {jobHistory.length > 0 && (
              <div class="rounded-xl border border-kharon-purple/25 bg-kharon-charcoal/80 p-6 shadow-xl backdrop-blur-md relative overflow-hidden">
                <h2 class="text-lg font-black text-white tracking-tight mb-4">Activity Timeline</h2>
                
                <div class="space-y-4 relative before:absolute before:inset-y-0 before:left-3 before:w-0.5 before:bg-kharon-purple/20">
                  {jobHistory.map((entry: any) => (
                    <div class="pl-7 relative flex items-start gap-4">
                      <div class="absolute left-1.5 top-1.5 h-3.5 w-3.5 rounded-full bg-kharon-charcoal border-2 border-kharon-cyan ring-4 ring-kharon-cyan/10"></div>
                      <div class="flex-1 bg-kharon-black/20 p-3 rounded-lg border border-kharon-purple/10">
                        <div class="flex justify-between items-center gap-2 flex-wrap mb-1">
                          <p class="text-xs font-bold text-white">{entry.action}</p>
                          <p class="text-[9px] text-kharon-amber font-mono font-bold">{entry.created_at}</p>
                        </div>
                        <p class="text-xs text-white/70 leading-normal">{entry.description}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>

          <!-- Tab 2: System Specs -->
          <div id="tab-system" class="space-y-6 hidden">
            <div class="rounded-xl border border-kharon-purple/25 bg-kharon-charcoal/80 p-6 shadow-xl backdrop-blur-md relative overflow-hidden">
              <h2 class="text-lg font-black text-white tracking-tight mb-4">Technical System Specifications</h2>
              
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <p class="text-[9px] font-bold uppercase tracking-wider text-kharon-purple mb-1">System Type</p>
                  <p class="text-sm font-bold text-white">{job.system_type}</p>
                </div>
                <div>
                  <p class="text-[9px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Coverage Area</p>
                  <p class="text-sm font-bold text-white">{job.coverage_area}</p>
                </div>
                <div>
                  <p class="text-[9px] font-bold uppercase tracking-wider text-kharon-purple mb-1">Protocol Version</p>
                  <p class="text-sm font-bold text-white">{job.protocol_version || 'Not specified'}</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Tab 3: Field Actions -->
          <div id="tab-actions" class="space-y-6 hidden">
            <div class="rounded-xl border border-kharon-purple/25 bg-kharon-charcoal/80 p-6 shadow-xl backdrop-blur-md relative overflow-hidden">
              <h2 class="text-lg font-black text-white tracking-tight mb-4">Field Actions</h2>
              
              <div class="grid grid-cols-1 gap-4">
                <a href={`/portal/tech/jobs/${job.id}/log-visit`} class="flex items-center justify-center gap-2 w-full px-4 py-3.5 bg-gradient-to-r from-kharon-purple to-kharon-blue text-white font-bold text-xs uppercase tracking-widest rounded-md text-center hover:shadow-lg hover:shadow-kharon-purple/30 transition-all min-h-[44px]">
                  <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  Log Visit Time
                </a>
                
                <a href={`/portal/tech/jobs/${job.id}/jobcard`} class="flex items-center justify-center gap-2 w-full px-4 py-3.5 border border-kharon-purple/35 text-white bg-kharon-purple/10 font-bold text-xs uppercase tracking-widest rounded-md text-center hover:bg-kharon-purple/20 transition-all min-h-[44px]">
                  <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                  Complete Jobcard
                </a>
                
                {job.physical_address && (
                  <a href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(String(job.physical_address))}`} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 w-full px-4 py-3.5 border border-kharon-purple/35 text-kharon-cyan font-bold text-xs uppercase tracking-widest rounded-md text-center hover:bg-kharon-purple/10 transition-colors min-h-[44px]">
                    <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                    </svg>
                    Navigate to Site
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  </section>

  <script is:inline>
    // Tab switching interactivity
    (function() {
      const detailsBtn = document.getElementById("tab-details-btn");
      const systemBtn = document.getElementById("tab-system-btn");
      const actionsBtn = document.getElementById("tab-actions-btn");

      const detailsTab = document.getElementById("tab-details");
      const systemTab = document.getElementById("tab-system");
      const actionsTab = document.getElementById("tab-actions");

      const btns = [detailsBtn, systemBtn, actionsBtn];
      const tabs = [detailsTab, systemTab, actionsTab];

      function activateTab(index) {
        btns.forEach((btn, idx) => {
          if (idx === index) {
            btn?.classList.add("bg-kharon-purple/35", "text-white");
            btn?.classList.remove("text-white/60");
          } else {
            btn?.classList.remove("bg-kharon-purple/35", "text-white");
            btn?.classList.add("text-white/60");
          }
        });

        tabs.forEach((tab, idx) => {
          if (idx === index) {
            tab?.classList.remove("hidden");
          } else {
            tab?.classList.add("hidden");
          }
        });
      }

      detailsBtn?.addEventListener("click", () => activateTab(0));
      systemBtn?.addEventListener("click", () => activateTab(1));
      actionsBtn?.addEventListener("click", () => activateTab(2));
    })();
  </script>
</PortalLayout>
