---
/**
 * Project Sentinel - Emergency Support Page
 * Purpose: Public profile detailing direct emergency support escalation routes and SLAs
 * Dependencies: BaseLayout, SectionHeading, SolutionHero, EmergencyResponse, pageMeta, site
 * Structural Role: Immediate response page for critical incidents
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import SolutionHero from "../components/sections/SolutionHero.astro";
import EmergencyResponse from "../components/sections/EmergencyResponse.astro";
import { pageMeta, site } from "../data/site.js";

const severityLevels = [
  {
    label: "Critical",
    description: "Fire panel fault, suppression impaired, system offline",
    telephone: "2-hr telephone response",
    onsite: "4-hr on-site response",
    borderClass: "border-kharon-red/40",
    bgClass: "bg-kharon-red/5",
    labelClass: "text-kharon-red",
    dotClass: "bg-kharon-red"
  },
  {
    label: "Urgent",
    description: "Detector fault, isolated zone, maintenance overrun",
    telephone: "Same-day telephone response",
    onsite: "Next business day on-site",
    borderClass: "border-kharon-amber/40",
    bgClass: "bg-kharon-amber/5",
    labelClass: "text-kharon-amber",
    dotClass: "bg-kharon-amber"
  },
  {
    label: "Planned",
    description: "Routine service, documentation update, minor fault",
    telephone: "Scheduled contact",
    onsite: "Scheduled maintenance visit",
    borderClass: "border-kharon-purple/30",
    bgClass: "bg-kharon-purple/5",
    labelClass: "text-kharon-purple",
    dotClass: "bg-kharon-purple"
  }
];

const escalationSteps = [
  { step: "1", title: "Fault detected or alarm raised", text: "System fault indicator or triggered alarm signals a protection condition requiring assessment." },
  { step: "2", title: "Contact Kharon on 061 545 8830", text: "Call our direct line to initiate the response process. Available for critical faults." },
  { step: "3", title: "Triage: severity classification within 30 min", text: "Kharon classifies the reported condition as Critical, Urgent or Planned within 30 minutes of contact." },
  { step: "4", title: "Technician dispatch per severity timeline", text: "Technician dispatched according to the classification: 4-hour on-site for Critical, next business day for Urgent." },
  { step: "5", title: "On-site assessment and remediation", text: "Technician arrives, assesses the fault, and carries out remediation or temporary protection measures." },
  { step: "6", title: "Documentation and close-out report issued", text: "All work is documented. A close-out report is issued and linked to the client's service record." }
];

const emergencyRoutes = [
  {
    title: "Critical system fault",
    text: "Live fire-panel faults, suppression impairments, isolated systems or a protection condition affecting operations.",
    action: "Escalate Fault",
    href: "/contact?intent=emergency-support",
    tel: "tel:+27615458830",
    icon: "/brand/icons/severity-critical.svg"
  },
  {
    title: "Existing client records",
    text: "Access service history, system records, maintenance requests and linked jobcard documentation.",
    action: "Access Records",
    href: site.portalLoginPath,
    icon: "/brand/icons/service-engineering.svg"
  },
  {
    title: "Urgent technical request",
    text: "Route urgent assessment requests where a technician review or system diagnosis is required.",
    action: "Request Support",
    href: "/contact?intent=urgent-technical-request",
    icon: "/brand/icons/severity-urgent.svg"
  },
  {
    title: "Compliance intervention",
    text: "Overdue inspections, missing documentation, insurer queries or audit-sensitive system concerns.",
    action: "Start Compliance Route",
    href: "/contact?intent=compliance-intervention",
    icon: "/brand/icons/severity-planned.svg"
  }
];
---

<BaseLayout title={pageMeta.emergencySupport.title} description={pageMeta.emergencySupport.description}>
  <SolutionHero
    title="Emergency Support"
    subtitle="Operational Response"
    description="Strategic response pathways for protection-system faults, compliance interventions, and mission-critical escalations."
    icon="/brand/icons/severity-critical.svg"
  />

  <section class="section-padding bg-kharon-black">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeading
        title="Severity Level Framework"
        subtitle="Response Classification"
        description="Every reported fault is classified on contact to ensure the right response reaches you at the right time."
        center={true}
      />

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {severityLevels.map((level) => (
          <div class={`rounded-xl border ${level.borderClass} ${level.bgClass} p-8 flex flex-col`}>
            <div class="flex items-center gap-3 mb-4">
              <span class={`h-3 w-3 rounded-full ${level.dotClass} flex-none`}></span>
              <span class={`text-xs font-black uppercase tracking-widest ${level.labelClass}`}>{level.label}</span>
            </div>
            <p class="text-white font-bold mb-4 leading-snug">{level.description}</p>
            <div class="space-y-2 mt-auto">
              <div class="flex items-center gap-2 text-xs text-kharon-light/60">
                <svg class="w-4 h-4 flex-none text-kharon-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                {level.telephone}
              </div>
              <div class="flex items-center gap-2 text-xs text-kharon-light/60">
                <svg class="w-4 h-4 flex-none text-kharon-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                {level.onsite}
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10 flex justify-center">
        <a href="tel:+27615458830" class="kharon-danger-button px-12 py-5 text-base font-black tracking-widest uppercase inline-flex items-center gap-3">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          061 545 8830
        </a>
      </div>
    </div>
  </section>

  <section class="section-padding bg-kharon-charcoal border-t border-kharon-purple/10">
    <div class="mx-auto max-w-4xl px-6">
      <SectionHeading
        title="Escalation Flowchart"
        subtitle="Incident Process"
        description="The structured path from fault detection to close-out documentation."
        center={true}
      />

      <div class="mt-12">
        <ol class="space-y-7 border-l-2 border-kharon-purple/30 pl-8 ml-3">
          {escalationSteps.map((item) => (
            <li class="relative">
              <span class="absolute -left-[2.6rem] top-0 flex h-7 w-7 items-center justify-center rounded-full bg-kharon-purple text-xs font-black text-white ring-4 ring-kharon-charcoal">
                {item.step}
              </span>
              <h3 class="text-base font-black tracking-tight text-white uppercase">{item.title}</h3>
              <p class="mt-1 text-sm leading-relaxed text-white/60">{item.text}</p>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <section class="section-padding bg-kharon-black">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeading
        title="Operational Response Pathways"
        subtitle="Emergency Protocols"
        description="Structured response procedures for protection system emergencies and critical incidents."
        center={true}
      />

      <div class="mt-12 grid gap-8 md:grid-cols-2">
        {emergencyRoutes.map((route) => (
          <div class="group relative rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/30 p-8 sm:p-12 transition-all hover:border-kharon-purple/40 hover:bg-kharon-charcoal/50 flex flex-col justify-between overflow-hidden">
            <div class={`absolute top-0 left-0 h-1 w-full bg-gradient-to-r ${route.tel ? 'from-kharon-red to-transparent' : 'from-kharon-purple to-transparent'} opacity-50`}></div>

            <div class="space-y-6">
              <div class="h-16 w-16 rounded-xl bg-kharon-black/40 border border-kharon-purple/20 p-4 group-hover:bg-kharon-purple/10 transition-colors">
                <img loading="lazy" decoding="async" src={route.icon} alt="" class="h-full w-full object-contain" />
              </div>

              <div>
                <h3 class="text-xl font-black text-white tracking-tight leading-tight mb-3 uppercase">{route.title}</h3>
                <p class="text-kharon-light/60 leading-relaxed font-medium">
                  {route.text}
                </p>
              </div>
            </div>

            <div class="mt-10 flex flex-wrap gap-4">
              {route.tel && (
                <a href={route.tel} class="kharon-danger-button px-8 py-3 text-xs font-black tracking-widest uppercase">
                  Voice Link
                </a>
              )}
              <a href={route.href} class="kharon-command-button px-8 py-3 text-xs font-black tracking-widest uppercase flex-1 text-center">
                {route.action}
              </a>
            </div>

            <div class={`absolute -right-12 -bottom-12 h-32 w-32 rounded-full blur-[64px] opacity-10 ${route.tel ? 'bg-kharon-red' : 'bg-kharon-purple'}`}></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <EmergencyResponse />

  <section class="section-padding bg-kharon-black border-t border-kharon-purple/10">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <SectionHeading
        title="Controlled Incident Management"
        subtitle="Reliability Discipline"
        description="Our protocols are designed to maintain operational control during critical incidents, prioritizing safety while minimizing disruption."
        center={true}
      />
      <div class="mt-10 flex justify-center gap-4">
        <a href="/portal" class="kharon-command-button px-10 py-5 text-sm uppercase tracking-widest font-black">
          Access Operations Portal
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
