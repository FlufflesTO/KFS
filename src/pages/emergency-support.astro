---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import EmergencyResponse from "../components/sections/EmergencyResponse.astro";
import ContextualInquiry from "../components/sections/ContextualInquiry.astro";
import { site } from "../data/site.js";

const emergencyRoutes = [
  {
    title: "Critical system fault",
    text: "Use this route for live fire-panel faults, suppression impairments, isolated systems or a protection condition affecting operations.",
    action: "Call / Escalate Fault",
    href: "/contact?intent=emergency-support"
  },
  {
    title: "Existing client records",
    text: "Open the portal for service history, system records, maintenance requests and linked jobcard documentation.",
    action: "Access Records",
    href: site.portalLoginPath
  },
  {
    title: "Urgent technical request",
    text: "Route urgent assessment requests where a technician review, system diagnosis or maintenance intervention is required.",
    action: "Request Urgent Support",
    href: "/contact?intent=urgent-technical-request"
  },
  {
    title: "Compliance intervention",
    text: "Use this path for overdue inspections, missing documentation, insurer queries or audit-sensitive system concerns.",
    action: "Start Compliance Route",
    href: "/contact?intent=compliance-intervention"
  }
];
---

<BaseLayout
  title="Emergency Support | Kharon"
  description="Operational support pathways for fire detection faults, gas suppression issues, urgent compliance interventions and maintenance escalations."
>
  <Hero
    title="Emergency and SLA support for protection-system issues."
    text="Route urgent faults, compliance interventions, maintenance escalations and system support requests with the operational context required for response."
  />

  <EmergencyResponse />

  <section class="bg-white py-16">
    <div class="mx-auto max-w-7xl px-6">
      <div class="max-w-3xl">
        <p class="text-sm font-bold uppercase text-kharon-purple">Decision Route</p>
        <h2 class="mt-3 text-3xl font-bold text-kharon-black">Select the route that matches the operational consequence.</h2>
        <p class="mt-4 leading-7 text-kharon-grey">
          Emergency handling should separate live system faults, existing client record access, urgent technical requests and compliance interventions.
        </p>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {emergencyRoutes.map((route) => (
          <article class="rounded-lg border border-kharon-border bg-kharon-light p-6">
            <h3 class="text-xl font-bold text-kharon-black">{route.title}</h3>
            <p class="mt-3 leading-7 text-kharon-grey">{route.text}</p>
            <a class="mt-6 inline-flex rounded-md bg-kharon-purple px-5 py-3 text-sm font-semibold text-white hover:bg-kharon-blue" href={route.href}>
              {route.action}
            </a>
          </article>
        ))}
      </div>

      <div class="mt-10 border-t border-kharon-border pt-8">
        <p class="text-sm text-kharon-grey">
          For inspection frequencies, maintenance cadence, defect classification and certificate-readiness guidance under SANS 10139 and SANS 14520, see the
          <a href="/compliance" class="font-semibold text-kharon-purple hover:underline">protection system compliance reference</a>.
        </p>
      </div>
    </div>
  </section>

  <ContextualInquiry
    eyebrow="Support Request"
    title="Start an emergency or SLA support request."
    text="Identify the protected area, system type, current fault state and operational consequence."
    requestType="Emergency / SLA support"
    fields={[
      { label: "Severity", name: "severity", options: ["Critical system fault", "Urgent service intervention", "Compliance intervention", "Planned support request"] },
      { label: "Affected System", name: "affected_system", options: ["Gas suppression", "Fire detection", "Fire panel", "Detection devices", "Integrated security support", "Unknown"] },
      { label: "Protected Area", name: "protected_area", options: ["Server room", "Electrical room", "Warehouse", "Control room", "Commercial facility", "Industrial area", "Other"] },
      { label: "Operational Status", name: "operational_status", options: ["Live fault", "System isolated", "Service overdue", "Audit pressure", "Preventive request"] }
    ]}
  />

  
</BaseLayout>
