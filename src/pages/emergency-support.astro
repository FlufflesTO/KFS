---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import SolutionHero from "../components/sections/SolutionHero.astro";
import EmergencyResponse from "../components/sections/EmergencyResponse.astro";
import { pageMeta, site } from "../data/site.js";

const emergencyRoutes = [
  {
    title: "Critical system fault",
    text: "Live fire-panel faults, suppression impairments, isolated systems or a protection condition affecting operations.",
    action: "Escalate Fault",
    href: "/contact?intent=emergency-support",
    tel: "tel:+27615458830",
    icon: "/brand/icons/severity-critical.svg"
  },
  {
    title: "Existing client records",
    text: "Access service history, system records, maintenance requests and linked jobcard documentation.",
    action: "Access Records",
    href: site.portalLoginPath,
    icon: "/brand/icons/service-engineering.svg"
  },
  {
    title: "Urgent technical request",
    text: "Route urgent assessment requests where a technician review or system diagnosis is required.",
    action: "Request Support",
    href: "/contact?intent=urgent-technical-request",
    icon: "/brand/icons/severity-urgent.svg"
  },
  {
    title: "Compliance intervention",
    text: "Overdue inspections, missing documentation, insurer queries or audit-sensitive system concerns.",
    action: "Start Compliance Route",
    href: "/contact?intent=compliance-intervention",
    icon: "/brand/icons/severity-planned.svg"
  }
];
---

<BaseLayout title={pageMeta.emergencySupport.title} description={pageMeta.emergencySupport.description}>
  <SolutionHero 
    title="Emergency Support" 
    subtitle="Operational Response" 
    description="Strategic response pathways for protection-system faults, compliance interventions, and mission-critical escalations."
    icon="/brand/icons/severity-critical.svg"
  />

  <section class="section-padding bg-kharon-black">
    <div class="mx-auto max-w-7xl px-6">
      <SectionHeading
        title="Operational Response Pathways"
        subtitle="Emergency Protocols"
        description="Structured response procedures for protection system emergencies and critical incidents."
        center={true}
      />
      
      <div class="mt-12 grid gap-8 md:grid-cols-2">
        {emergencyRoutes.map((route) => (
          <div class="group relative rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/30 p-8 sm:p-12 transition-all hover:border-kharon-purple/40 hover:bg-kharon-charcoal/50 flex flex-col justify-between overflow-hidden">
            <div class={`absolute top-0 left-0 h-1 w-full bg-gradient-to-r ${route.tel ? 'from-kharon-red to-transparent' : 'from-kharon-purple to-transparent'} opacity-50`}></div>
            
            <div class="space-y-6">
              <div class="h-16 w-16 rounded-xl bg-kharon-black/40 border border-kharon-purple/20 p-4 group-hover:bg-kharon-purple/10 transition-colors">
                <img src={route.icon} alt="" class="h-full w-full object-contain" />
              </div>
              
              <div>
                <h3 class="text-xl font-black text-white tracking-tight leading-tight mb-3 uppercase">{route.title}</h3>
                <p class="text-kharon-light/60 leading-relaxed font-medium">
                  {route.text}
                </p>
              </div>
            </div>

            <div class="mt-10 flex flex-wrap gap-4">
              {route.tel && (
                <a href={route.tel} class="kharon-danger-button px-8 py-3 text-xs font-black tracking-widest uppercase">
                  Voice Link
                </a>
              )}
              <a href={route.href} class="kharon-command-button px-8 py-3 text-xs font-black tracking-widest uppercase flex-1 text-center">
                {route.action}
              </a>
            </div>

            {/* Background decoration */}
            <div class={`absolute -right-12 -bottom-12 h-32 w-32 rounded-full blur-[64px] opacity-10 ${route.tel ? 'bg-kharon-red' : 'bg-kharon-purple'}`}></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <EmergencyResponse />

  <section class="section-padding bg-kharon-black border-t border-kharon-purple/10">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <SectionHeading
        title="Controlled Incident Management"
        subtitle="Reliability Discipline"
        description="Our protocols are designed to maintain operational control during critical incidents, prioritizing safety while minimizing disruption."
        center={true}
      />
      <div class="mt-10 flex justify-center gap-4">
        <a href="/portal" class="kharon-command-button px-10 py-5 text-sm uppercase tracking-widest font-black">
          Access Operations Portal
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
