---
/**
 * Project Sentinel - Contact Page
 * Purpose: Secure assessment intake form with POPIA-compliant design
 * Dependencies: BaseLayout, SolutionHero, SectionHeading, site data, forms data
 * Structural Role: Contact intake node for inquiries and support escalations
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import SolutionHero from "../components/sections/SolutionHero.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import WhatHappensNext from "../components/sections/WhatHappensNext.astro";
import { site } from "../data/site.js";
import {
  SERVICE_INTERESTS,
  URGENCY_LEVELS,
  SITE_TYPES,
  CLIENT_TYPES,
  ANALYTICS_EVENTS,
  PHONE_TEL,
  PHONE_DISPLAY,
  INTENT_TO_REQUEST_TYPE,
  resolveRequestType
} from "../data/forms";

const contactApiUrl = `${site.portalUrl.replace(/\/$/, "")}/api/contact`;
const formStartedAt = Date.now();
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || "";

// Submission context captured from the URL.
const sourcePage = Astro.url.pathname;
const intentParam = Astro.url.searchParams.get("intent") || "";
const intent = intentParam && INTENT_TO_REQUEST_TYPE[intentParam] ? intentParam : "";
const serviceSlug = Astro.url.searchParams.get("service") || "";
const sectorSlug = Astro.url.searchParams.get("sector") || "";
const ctaClicked = Astro.url.searchParams.get("cta") || "";

// requestType derived from intent for clarity (API also resolves this server-side).
const derivedRequestType = resolveRequestType(intent || null);

// Preselect a sensible service interest when the intent maps to a known option.
const intentRequestType = intent ? INTENT_TO_REQUEST_TYPE[intent] : "";
const presetServiceInterest = (SERVICE_INTERESTS as readonly string[]).includes(intentRequestType)
  ? intentRequestType
  : "";

const emergencyEvent = ANALYTICS_EVENTS.emergencyClick;
const phoneEvent = ANALYTICS_EVENTS.phoneClick;
const formStartEvent = ANALYTICS_EVENTS.formStart;
const formSubmitEvent = ANALYTICS_EVENTS.formSubmit;
---

<BaseLayout title="Contact Kharon Risk Specialists | Fire Protection Experts" description="Get in touch with industrial fire protection specialists. Request a site assessment, system consultation, or emergency support for mission-critical fire protection systems.">

  <SolutionHero
    title="Intake Command"
    subtitle="Strategic Engagement"
    description="Connect with our industrial command specialists for mission-critical fire protection consultation and site assessment."
    icon="/brand/icons/severity-urgent.svg"
  />

  <section class="section-padding bg-kharon-black">
    <div class="container mx-auto px-6">
      <div class="max-w-7xl mx-auto">
        <!-- Emergency separation: urgent faults routed away from the standard enquiry flow -->
        <div
          role="alert"
          class="mb-12 rounded-2xl border-2 border-kharon-red/60 bg-kharon-red/10 p-6 sm:p-8 flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between"
        >
          <div class="flex items-start gap-4">
            <span class="mt-1 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-kharon-red/40 bg-kharon-red/15">
              <svg class="h-5 w-5 text-kharon-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86l-8.48 14.7A1.5 1.5 0 003.1 21h17.8a1.5 1.5 0 001.29-2.44l-8.48-14.7a1.5 1.5 0 00-2.42 0z"></path>
              </svg>
            </span>
            <div>
              <h2 class="text-sm font-black uppercase tracking-[0.2em] text-kharon-red">Active fault or fire risk?</h2>
              <p class="mt-2 text-sm leading-relaxed text-white/80">
                This is for an active fire safety fault or an immediate risk to people or critical assets. Do not use the enquiry form below.
              </p>
            </div>
          </div>
          <div class="flex shrink-0 flex-col gap-3 sm:flex-row">
            <a
              href="/emergency-support"
              data-analytics={emergencyEvent}
              class="inline-flex min-h-[44px] items-center justify-center rounded-lg bg-kharon-red px-6 py-3 text-sm font-black uppercase tracking-[0.15em] text-white transition-colors hover:bg-kharon-red/85 focus:outline-none focus-visible:ring-2 focus-visible:ring-kharon-cyan"
            >
              Report a Fault
            </a>
            <a
              href={`tel:${PHONE_TEL}`}
              data-analytics={phoneEvent}
              class="inline-flex min-h-[44px] items-center justify-center gap-2 rounded-lg border border-kharon-red/50 px-6 py-3 text-sm font-black uppercase tracking-[0.15em] text-white transition-colors hover:border-kharon-cyan/60 focus:outline-none focus-visible:ring-2 focus-visible:ring-kharon-cyan"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" aria-hidden="true">
                <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
              Call Now
            </a>
          </div>
        </div>

        <div class="grid lg:grid-cols-12 gap-16">
          <div class="lg:col-span-7">
            <SectionHeading
              title="Secure Request Protocol"
              subtitle="Assessment Intake"
              description="Initialize a formal inquiry for site audit or technical consultation. For active faults, use the emergency panel above."
            />

            <form id="contact-form" method="post" action={contactApiUrl} class="mt-10 space-y-8">
              <input type="hidden" name="formStartedAt" value={formStartedAt} />
              <!-- Hidden submission context (resolved server-side into the stored message) -->
              <input type="hidden" name="sourcePage" value={sourcePage} />
              <input type="hidden" name="ctaClicked" value={ctaClicked} />
              <input type="hidden" name="serviceSlug" value={serviceSlug} />
              <input type="hidden" name="sectorSlug" value={sectorSlug} />
              <input type="hidden" name="intent" value={intent} />
              <input type="hidden" name="requestType" value={derivedRequestType} />

              <!-- Honeypot — must remain present and visually hidden -->
              <label class="sr-only" for="intake-website">Website</label>
              <input
                id="intake-website"
                type="text"
                name="website"
                autocomplete="off"
                class="honeypot"
                tabindex="-1"
                aria-hidden="true"
              />

              <div class="grid md:grid-cols-2 gap-6">
                <div class="grid gap-2">
                  <label for="intake-name" class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple px-1">Full Name</label>
                  <input
                    id="intake-name"
                    type="text"
                    name="name"
                    required
                    placeholder="Operational contact name"
                    class="kharon-field"
                  />
                </div>

                <div class="grid gap-2">
                  <label for="intake-email" class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple px-1">Email Infrastructure</label>
                  <input
                    id="intake-email"
                    type="email"
                    name="email"
                    required
                    placeholder="official@company.com"
                    class="kharon-field"
                  />
                </div>
              </div>

              <div class="grid md:grid-cols-2 gap-6">
                <div class="grid gap-2">
                  <label for="intake-phone" class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple px-1">Phone Link</label>
                  <input
                    id="intake-phone"
                    type="tel"
                    name="phone"
                    placeholder="+27 (0) 00 000 0000"
                    class="kharon-field"
                  />
                </div>

                <div class="grid gap-2">
                  <label for="intake-company" class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple px-1">Registered Company</label>
                  <input
                    id="intake-company"
                    type="text"
                    name="company"
                    placeholder="Entity name"
                    class="kharon-field"
                  />
                </div>
              </div>

              <div class="grid md:grid-cols-2 gap-6">
                <div class="grid gap-2">
                  <label for="intake-service-interest" class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple px-1">Service Interest <span class="text-white/40">(optional)</span></label>
                  <select
                    id="intake-service-interest"
                    name="serviceInterest"
                    class="kharon-field py-3"
                  >
                    <option value="">Select a service</option>
                    {SERVICE_INTERESTS.map((option) => (
                      <option value={option} selected={option === presetServiceInterest}>{option}</option>
                    ))}
                  </select>
                </div>

                <div class="grid gap-2">
                  <label for="intake-urgency" class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple px-1">Urgency <span class="text-white/40">(optional)</span></label>
                  <select
                    id="intake-urgency"
                    name="urgency"
                    class="kharon-field py-3"
                  >
                    <option value="">Select urgency</option>
                    {URGENCY_LEVELS.map((option) => (
                      <option value={option}>{option}</option>
                    ))}
                  </select>
                </div>
              </div>

              <div class="grid md:grid-cols-2 gap-6">
                <div class="grid gap-2">
                  <label for="intake-site-type" class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple px-1">Site Type <span class="text-white/40">(optional)</span></label>
                  <select
                    id="intake-site-type"
                    name="siteType"
                    class="kharon-field py-3"
                  >
                    <option value="">Select site type</option>
                    {SITE_TYPES.map((option) => (
                      <option value={option}>{option}</option>
                    ))}
                  </select>
                </div>

                <div class="grid gap-2">
                  <label for="intake-client-type" class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple px-1">Existing / New Client <span class="text-white/40">(optional)</span></label>
                  <select
                    id="intake-client-type"
                    name="clientType"
                    class="kharon-field py-3"
                  >
                    <option value="">Select one</option>
                    {CLIENT_TYPES.map((option) => (
                      <option value={option}>{option}</option>
                    ))}
                  </select>
                </div>
              </div>

              <div class="grid gap-2">
                <label for="intake-message" class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple px-1">Operational Requirements</label>
                <textarea
                  id="intake-message"
                  name="message"
                  rows={6}
                  required
                  placeholder="Describe your site infrastructure and protection priorities..."
                  class="kharon-field leading-relaxed"
                ></textarea>
              </div>

              <div class="flex items-start">
                <div class="flex h-5 items-center">
                  <input
                    id="intake-consent"
                    name="popiaConsent"
                    type="checkbox"
                    required
                    class="h-4 w-4 rounded border-kharon-purple/20 bg-kharon-charcoal text-kharon-purple focus:ring-kharon-purple"
                  />
                </div>
                <div class="ml-3 text-sm">
                  <label for="intake-consent" class="font-medium text-kharon-light/80">
                    I consent to the collection and processing of my data in accordance with POPIA so Kharon can respond to this inquiry.
                  </label>
                </div>
              </div>

              {turnstileSiteKey && (
                <div class="cf-turnstile" data-sitekey={turnstileSiteKey}></div>
              )}

              <button
                type="submit"
                class="kharon-command-button w-full py-5 text-sm font-black tracking-[0.2em]"
              >
                Initialize Secure Intake
              </button>

              <!-- Inline confirmation / error region -->
              <div
                id="contact-result"
                role="status"
                aria-live="polite"
                class="hidden rounded-xl border p-4 text-sm font-medium"
              ></div>
            </form>
          </div>

          <div class="lg:col-span-5 space-y-8">
            <SectionHeading
              title="Command Center"
              subtitle="Contact Nodes"
            />

            <div class="space-y-6 pt-2">
              <div class="p-8 rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/40 backdrop-blur-xl relative overflow-hidden group hover:border-kharon-purple/40 transition-all">
                <div class="absolute top-0 right-0 h-20 w-20 bg-kharon-purple/5 rounded-bl-full pointer-events-none"></div>
                <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple mb-4">Operational HQ</h3>
                <p class="text-white/80 font-medium leading-relaxed">{site.address}</p>
              </div>

              <div class="grid gap-6">
                <a
                  href={`tel:${PHONE_TEL}`}
                  data-analytics={phoneEvent}
                  class="p-6 rounded-xl border border-kharon-purple/10 bg-kharon-charcoal/20 hover:border-kharon-cyan/40 transition-all flex items-center justify-between group min-h-[44px]"
                >
                  <div>
                    <h3 class="text-[10px] font-black uppercase tracking-widest text-kharon-purple group-hover:text-kharon-cyan transition-colors">Call Now</h3>
                    <p class="text-white font-bold mt-1">{PHONE_DISPLAY}</p>
                  </div>
                  <div class="h-10 w-10 rounded-lg bg-kharon-purple/10 flex items-center justify-center border border-kharon-purple/20 group-hover:bg-kharon-cyan/10 group-hover:border-kharon-cyan/30 transition-all">
                    <svg class="w-5 h-5 text-kharon-purple group-hover:text-kharon-cyan transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" aria-hidden="true">
                      <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                    </svg>
                  </div>
                </a>

                <a href={`mailto:${site.email}`} class="p-6 rounded-xl border border-kharon-purple/10 bg-kharon-charcoal/20 hover:border-kharon-cyan/40 transition-all flex items-center justify-between group min-h-[44px]">
                  <div>
                    <h3 class="text-[10px] font-black uppercase tracking-widest text-kharon-purple group-hover:text-kharon-cyan transition-colors">Data Intake</h3>
                    <p class="text-white font-bold mt-1">{site.email}</p>
                  </div>
                  <div class="h-10 w-10 rounded-lg bg-kharon-purple/10 flex items-center justify-center border border-kharon-purple/20 group-hover:bg-kharon-cyan/10 group-hover:border-kharon-cyan/30 transition-all">
                    <svg class="w-5 h-5 text-kharon-purple group-hover:text-kharon-cyan transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" aria-hidden="true">
                      <path d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                    </svg>
                  </div>
                </a>
              </div>

              <div class="p-8 rounded-2xl border border-kharon-purple/20 bg-kharon-black/60 backdrop-blur-sm">
                <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple mb-6 border-b border-kharon-purple/10 pb-4">Response Protocol</h3>
                <ul class="space-y-4">
                  <li class="flex items-center gap-3 text-xs font-bold text-white/60">
                    <span class="h-1.5 w-1.5 rounded-full bg-kharon-cyan"></span>
                    Standard Inquiries: &lt; 2 Business Hours
                  </li>
                  <li class="flex items-center gap-3 text-xs font-bold text-white/60">
                    <span class="h-1.5 w-1.5 rounded-full bg-kharon-red animate-pulse"></span>
                    Emergency Support: Immediate Response
                  </li>
                  <li class="flex items-center gap-3 text-xs font-bold text-white/60">
                    <span class="h-1.5 w-1.5 rounded-full bg-kharon-amber"></span>
                    Consultations: Within 1 Business Day
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <WhatHappensNext intent={intent || "general"} />

  <script
    nonce={Astro.locals.nonce}
    is:inline
    data-form-start-event={formStartEvent}
    data-form-submit-event={formSubmitEvent}
    data-api-url={contactApiUrl}
  >
    (function () {
      var form = document.getElementById("contact-form");
      if (!form) return;
      var script = document.currentScript;
      var startEvent = script.getAttribute("data-form-start-event");
      var submitEvent = script.getAttribute("data-form-submit-event");
      var apiUrl = script.getAttribute("data-api-url");
      var result = document.getElementById("contact-result");

      function track(name) {
        if (typeof window.plausible === "function") {
          window.plausible(name);
        }
      }

      // Fire form_start once on first focus of any field.
      var started = false;
      form.addEventListener(
        "focusin",
        function () {
          if (started) return;
          started = true;
          track(startEvent);
        },
        { once: false }
      );

      function showResult(message, variant) {
        if (!result) return;
        result.textContent = message;
        result.classList.remove(
          "hidden",
          "border-kharon-green/40",
          "bg-kharon-green/10",
          "text-kharon-green",
          "border-kharon-red/40",
          "bg-kharon-red/10",
          "text-kharon-red"
        );
        if (variant === "success") {
          result.classList.add("border-kharon-green/40", "bg-kharon-green/10", "text-kharon-green");
        } else {
          result.classList.add("border-kharon-red/40", "bg-kharon-red/10", "text-kharon-red");
        }
      }

      form.addEventListener("submit", function (event) {
        event.preventDefault();
        track(submitEvent);

        var submitButton = form.querySelector('button[type="submit"]');
        if (submitButton) submitButton.disabled = true;

        fetch(apiUrl, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" }
        })
          .then(function (response) {
            return response
              .json()
              .catch(function () {
                return { ok: response.ok };
              })
              .then(function (data) {
                return { status: response.status, data: data };
              });
          })
          .then(function (res) {
            if (res.data && res.data.ok) {
              showResult(
                "Request received. Our team will respond within 2 business hours.",
                "success"
              );
              form.reset();
            } else {
              var msg =
                (res.data && res.data.message) ||
                "Submission failed. Please call us or email admin@kharon.co.za.";
              showResult(msg, "error");
              if (submitButton) submitButton.disabled = false;
            }
          })
          .catch(function () {
            showResult(
              "Network error. Please try again, call us, or email admin@kharon.co.za.",
              "error"
            );
            if (submitButton) submitButton.disabled = false;
          });
      });
    })();
  </script>
</BaseLayout>
