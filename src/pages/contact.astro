---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactForm from "../components/contact/ContactForm.astro";
import EmergencyResponse from "../components/sections/EmergencyResponse.astro";
import { pageMeta } from "../data/site.js";
---

<BaseLayout title={pageMeta.contact.title} description={pageMeta.contact.description}>
  <section class="bg-kharon-black px-4 pt-24 pb-12 sm:px-6 sm:pt-32 sm:pb-16 text-white overflow-hidden relative">
    <div class="mx-auto max-w-7xl relative z-10 text-center">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-kharon-cyan mb-4 animate-fade-in-up">Site Assessments</p>
      <h1 class="text-4xl font-bold sm:text-6xl tracking-tight mb-6 animate-fade-in-up [animation-delay:100ms]">
        Connect with <span class="text-transparent bg-clip-text bg-gradient-to-r from-kharon-purple to-kharon-blue">Authority.</span>
      </h1>
      <p class="max-w-2xl mx-auto text-lg text-white/65 animate-fade-in-up [animation-delay:200ms]">
        Request a professional site assessment or technical consultation for your critical environment.
      </p>
    </div>
  </section>

  <section class="section-padding">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-10 items-start">
        <div class="space-y-8">
          <div>
            <h2 class="text-3xl font-bold tracking-tight mb-4">Immediate Response</h2>
            <p class="text-slate-600 leading-relaxed">
              Our technical teams are on standby for emergency support and rapid infrastructure deployment across South Africa.
            </p>
          </div>

          <div class="grid sm:grid-cols-2 gap-6 lg:gap-10">
            <div class="p-6 bg-slate-50 rounded-xl border border-slate-100">
              <h3 class="font-bold text-sm uppercase tracking-widest text-kharon-purple mb-2">Technical Support</h3>
              <p class="text-slate-800 font-bold mb-1">support@kharon.co.za</p>
              <p class="text-xs text-slate-500">24/7 Monitoring Center</p>
            </div>
            <div class="p-6 bg-slate-50 rounded-xl border border-slate-100">
              <h3 class="font-bold text-sm uppercase tracking-widest text-kharon-blue mb-2">General Inquiries</h3>
              <p class="text-slate-800 font-bold mb-1">admin@kharon.co.za</p>
              <p class="text-xs text-slate-500">Business Hours: 08:00 - 17:00</p>
            </div>
          </div>
        </div>

        <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-xl shadow-slate-200/50 border border-slate-100">
          <ContactForm />
        </div>
      </div>
    </div>
  </section>

  <EmergencyResponse />
  
</BaseLayout>