---
import Footer from "../components/layout/Footer.astro";
import Header from "../components/layout/Header.astro";
import AnimationController from "../components/animations/AnimationController.astro";
import "../styles/global.css";

const SITE_CONFIG = {
  title: "Kharon Fire & Security",
  description: "Specialist Fire and Security Solutions",
  url: import.meta.env.PUBLIC_SITE_URL || "https://www.tequit.co.za"
};

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
}

const { title, description, canonical, noindex = false } = Astro.props;
const fullCanonical = canonical ? `${SITE_CONFIG.url}${canonical}` : `${SITE_CONFIG.url}${Astro.url.pathname}`;
const isStagingDomain = new URL(SITE_CONFIG.url).hostname.endsWith("tequit.co.za");
const robotsContent = noindex || isStagingDomain ? "noindex, nofollow" : "index, follow";

// Only load analytics on non-portal pages
const shouldLoadAnalytics = !Astro.url.pathname.startsWith('/portal');
const hasForms = Astro.url.pathname === '/contact' || Astro.url.pathname.startsWith('/portal');
const nonce = Astro.locals.nonce;
const organizationJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": SITE_CONFIG.title,
  "legalName": "Kharon Fire and Security Solutions",
  "url": SITE_CONFIG.url,
  "logo": `${SITE_CONFIG.url}/brand/kharon-full-logo.svg`,
  "description": SITE_CONFIG.description,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Unit 58, M5 Freeway Park, Cnr Uppercamp & Berkley Rd",
    "addressLocality": "Ndabeni, Maitland",
    "addressRegion": "Western Cape",
    "postalCode": "7405",
    "addressCountry": "ZA"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+27 61 545 8830",
    "contactType": "customer service",
    "areaServed": "ZA",
    "availableLanguage": "en"
  },
  "sameAs": [
    `${SITE_CONFIG.url}/contact`
  ],
  "foundingDate": "2016",
  "identifier": "2016/313076/07",
  "knowsAbout": [
    "Fire Detection Systems",
    "Gas Suppression Systems",
    "Security Systems",
    "SANS 10139",
    "SANS 14520"
  ]
});
---

<!DOCTYPE html>
<html lang="en-ZA">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/icons/icon-192.png" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content={robotsContent} />
  <meta name="description" content={description || SITE_CONFIG.description} />
  <meta name="theme-color" content="#0B0D0F" />
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={fullCanonical} />
  <meta property="og:title" content={title || SITE_CONFIG.title} />
  <meta property="og:description" content={description || SITE_CONFIG.description} />
  <meta property="og:image" content={`${SITE_CONFIG.url}/og/kharon-og.png`} />
  
  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={fullCanonical} />
  <meta property="twitter:title" content={title || SITE_CONFIG.title} />
  <meta property="twitter:description" content={description || SITE_CONFIG.description} />
  <meta property="twitter:image" content={`${SITE_CONFIG.url}/og/kharon-og.png`} />
  
  <title>{title ? `${title} | ${SITE_CONFIG.title}` : SITE_CONFIG.title}</title>
  
  <link rel="canonical" href={fullCanonical} />
  <link rel="stylesheet" media="print" href="/print.css" />
  
  <!-- Schema.org JSON-LD -->
  <script is:inline nonce={nonce} type="application/ld+json" set:html={organizationJsonLd}></script>

  <!-- POPIA-Compliant Analytics - Only load on non-portal pages -->
  {shouldLoadAnalytics && (
    <>
      {/* Plausible Analytics - Privacy-friendly */}
      <script
        is:inline
        nonce={nonce}
        defer
        src="https://plausible.io/js/script.js"
        data-domain={SITE_CONFIG.url.replace('https://', '')}
      ></script>
      
      {/* Alternative: Fathom Analytics - uncomment if using instead of Plausible */}
      {/* 
      <script 
        nonce={nonce}
        src="https://cdn.usefathom.com/script.js" 
        data-site="YOUR_FATHOM_SITE_ID" 
        defer
      ></script>
      */}
    </>
  )}
  
  {hasForms && (
    <script
      is:inline
      nonce={nonce}
      src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit"
      async
      defer
    ></script>
  )}
  
</head>
<body class="kharon-page-shell kharon-environment">
  <AnimationController>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </AnimationController>
  
  <!-- Skip link for accessibility -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-kharon-charcoal focus:px-4 focus:py-2 focus:border focus:border-kharon-purple focus:rounded focus:text-white">
    Skip to main content
  </a>
</body>
</html>
