<!doctype html>
<html lang="en-ZA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#0B0D0F" />
    <meta name="kharon-csrf-token" content={Astro.locals.csrfToken || ""} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="KFS Portal" />
    <script is:inline>
      // Register Service Worker
      if ('serviceWorker' in navigator) {
        const csrfToken = document.querySelector('meta[name="kharon-csrf-token"]')?.content || "";
        const sendPortalState = function(worker) {
          if (worker && csrfToken) worker.postMessage({ type: 'SET_CSRF_TOKEN', token: csrfToken });
        };

        navigator.serviceWorker.register('/sw.js', { scope: '/portal/' })
          .then(function(registration) {
            sendPortalState(registration.active || registration.waiting || registration.installing);
          })
          .catch(function(err) { console.warn('SW registration failed:', err); });

        navigator.serviceWorker.addEventListener('controllerchange', function() {
          sendPortalState(navigator.serviceWorker.controller);
        });

        navigator.serviceWorker.addEventListener('message', function(event) {
          if (!event.data) return;
          if (event.data.type === 'OFFLINE_SYNC_CONFLICT') {
            window.dispatchEvent(new CustomEvent('kharon-offline-conflict', { detail: event.data }));
          }
          if (event.data.type === 'OFFLINE_SYNC_COMPLETE' || event.data.type === 'QUEUE_DRAIN_COMPLETE') {
            window.dispatchEvent(new CustomEvent('kharon-offline-sync-complete', { detail: event.data }));
          }
        });

        // Listen for online event to trigger queue drain
        window.addEventListener('online', function() {
          if (navigator.serviceWorker.controller) {
            sendPortalState(navigator.serviceWorker.controller);
            navigator.serviceWorker.controller.postMessage({ type: 'DRAIN_QUEUE' });
            navigator.serviceWorker.controller.postMessage({ type: 'SYNC_DRAFTS' });
          }
        });
      }
    </script>
    <script is:inline>
      window.kharonPortalFetch = async (input, init = {}) => {
        const token = document.querySelector('meta[name="kharon-csrf-token"]')?.content || "";
        const headers = new Headers(init.headers || {});
        if (token && !headers.has("x-csrf-token")) headers.set("x-csrf-token", token);
        
        const maxAttempts = 3;
        const baseDelayMs = 500;
        const maxDelayMs = 5000;
        const retryableStatuses = [408, 500, 502, 503, 504]; // Exclude 429 here, let ClientOperationsManager handle it
        let attempt = 0;

        while (attempt < maxAttempts) {
          try {
            const response = await fetch(input, { ...init, headers });
            
            if (response.ok || !retryableStatuses.includes(response.status) || response.status === 429) {
              return response; // Return 429 directly to be handled by operations manager intercept
            }

            let delayMs = baseDelayMs * Math.pow(2, attempt);
            const retryAfter = response.headers.get('Retry-After');
            if (retryAfter) {
              const retryAfterSecs = parseInt(retryAfter, 10);
              if (!isNaN(retryAfterSecs)) {
                delayMs = retryAfterSecs * 1000;
              }
            }
            delayMs = Math.min(delayMs, maxDelayMs);
            
            attempt++;
            if (attempt >= maxAttempts) return response;
            await new Promise(r => setTimeout(r, delayMs));
          } catch (error) {
            attempt++;
            if (attempt >= maxAttempts) throw error;
            const delayMs = Math.min(baseDelayMs * Math.pow(2, attempt - 1), maxDelayMs);
            await new Promise(r => setTimeout(r, delayMs));
          }
        }
        throw new Error("Maximum retry attempts exceeded.");
      };
    </script>
  </head>
  <body data-variant={variant} class="portal-shell bg-kharon-black min-h-screen text-kharon-light selection:bg-kharon-purple/30 selection:text-kharon-purple overflow-x-hidden">
  <!-- Skip link for accessibility -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[200] focus:bg-kharon-charcoal focus:px-4 focus:py-2 focus:border focus:border-kharon-purple focus:rounded focus:text-white focus:shadow-lg">
    Skip to main content
  </a>
  <div id="offline-conflict-banner" class="hidden border-b border-kharon-amber/40 bg-kharon-amber/10 px-4 py-3 text-sm font-semibold text-kharon-amber" role="status" aria-live="polite">
    Offline change conflict detected. Review the latest server data before resubmitting this work.
  </div>

  <!-- Mobile Sliding Drawer Navigation -->
  <div id="mobile-nav-drawer" class="fixed inset-0 z-[150] lg:hidden pointer-events-none" role="dialog" aria-modal="true" aria-label="Navigation drawer">
    <!-- Overlay backdrop -->
    <div id="mobile-drawer-backdrop" class="absolute inset-0 bg-kharon-black/80 backdrop-blur-sm opacity-0 transition-opacity duration-300 ease-out pointer-events-none"></div>
    
    <!-- Drawer panel -->
    <div id="mobile-drawer-panel" class="absolute inset-y-0 left-0 w-80 max-w-[85vw] bg-kharon-charcoal border-r border-kharon-purple/20 shadow-2xl p-6 overflow-y-auto transform -translate-x-full transition-transform duration-300 ease-out pointer-events-auto flex flex-col">
      <div class="flex items-center justify-between mb-8 pb-4 border-b border-kharon-purple/10">
        <div class="flex items-center gap-3">
          <img src="/brand/kharon-mark.svg" alt="" aria-hidden="true" width="28" height="28" class="h-7 w-7" />
          <span class="text-xs font-black uppercase tracking-[0.15em] text-white">Kharon Command</span>
        </div>
        <button id="mobile-drawer-close" aria-label="Close navigation menu" class="text-white/60 hover:text-white transition-colors text-2xl font-bold h-10 w-10 flex items-center justify-center rounded-md hover:bg-kharon-purple/10">×</button>
      </div>

      <nav class="space-y-6 flex-1" aria-label="Portal mobile navigation">
        {categories.map((category) => (
          <div>
            <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple px-3 mb-2">{category.title}</h3>
            <div class="space-y-1">
              {category.links.map((link) => (
                <a
                  href={link.href}
                  aria-current={active === link.key ? "page" : undefined}
                  class={`flex items-center gap-3 w-full rounded-md px-3 py-2.5 text-xs font-bold uppercase tracking-wide transition-all duration-200 ${active === link.key ? "text-white bg-kharon-purple/20 border border-kharon-purple/40 border-l-4 border-l-kharon-cyan" : "text-white/70 hover:text-white hover:bg-kharon-purple/10 border border-transparent"}`}
                >
                  <svg class="h-4.5 w-4.5 shrink-0 text-kharon-cyan/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" set:html={getIconPath(link.key)}></svg>
                  <span>{link.label}</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </nav>

      <div class="mt-6 pt-4 border-t border-kharon-purple/10 flex items-center gap-3">
        <div class="h-1.5 w-1.5 rounded-full bg-kharon-green animate-pulse"></div>
        <span class="text-[10px] uppercase font-bold tracking-wider text-kharon-light/40">{user?.role} Active</span>
      </div>
    </div>
  </div>
  
  <!-- Top Navigation Command Center -->
  <header class="sticky top-0 z-50 w-full border-b border-kharon-purple/10 bg-kharon-black/90 backdrop-blur-md text-white shadow-lg">
    <div class="mx-auto flex min-h-[5rem] max-w-7xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
      <div class="flex items-center gap-3">
        <button id="mobile-drawer-toggle" class="lg:hidden flex items-center justify-center p-2 rounded-md text-white/80 hover:text-white hover:bg-kharon-purple/20 focus:outline-none focus:ring-2 focus:ring-kharon-cyan h-10 w-10" aria-label="Toggle navigation menu">
          <svg class="h-6 w-6 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>

        <a href="/portal" class="group flex shrink-0 items-center gap-3 transition-transform duration-300 hover:scale-[1.02]" aria-label="Kharon Operations Portal">
          <div class="relative flex-none">
            <div class="absolute inset-0 bg-kharon-purple/20 blur-lg group-hover:bg-kharon-purple/35 transition-colors duration-500 rounded-full"></div>
            <img src="/brand/kharon-mark.svg" alt="" aria-hidden="true" width="32" height="32" class="relative z-10 h-8 w-8 object-contain" />
          </div>
          <div class="hidden sm:block">
            <span class="block whitespace-nowrap text-sm font-black uppercase tracking-[0.15em] text-white">Kharon Command</span>
            <span class="block whitespace-nowrap text-[10px] font-bold uppercase text-kharon-purple tracking-widest">Secure Operations Console</span>
          </div>
        </a>
      </div>

      <div class="flex items-center gap-3 sm:gap-6">
        <div class="hidden md:flex flex-col items-end leading-tight border-r border-kharon-purple/20 pr-6">
          <p class="text-xs font-bold text-white/90">{user?.name}</p>
          <p class="mt-0.5 text-[10px] uppercase text-kharon-purple font-black tracking-widest">{user?.role}</p>
        </div>
        
        <button id="open-feedback" class="hidden sm:flex items-center gap-2 rounded border border-kharon-purple/30 bg-kharon-charcoal/50 px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest text-white/70 hover:text-white hover:border-kharon-cyan transition-all">
          Feedback
        </button>
        
        <form id="portal-logout-form">
          <button class="flex items-center justify-center rounded border border-kharon-red/40 bg-kharon-red/5 px-4 py-1.5 text-[10px] font-bold uppercase tracking-widest text-kharon-red hover:bg-kharon-red/10 hover:text-white transition-all" type="submit">
            Logout
          </button>
        </form>
      </div>
    </div>
  </header>

  <div class="flex flex-col lg:flex-row max-w-7xl mx-auto">
    <!-- Left Navigation Rail - Desktop -->
    <aside class="hidden lg:block w-64 h-[calc(100vh-5rem)] sticky top-[5rem] overflow-y-auto border-r border-kharon-purple/10 bg-kharon-black/40 p-4 custom-scrollbar">
      <nav class="space-y-8" aria-label="Portal navigation">
        {categories.map((category) => (
          <div class="space-y-2">
            <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-kharon-purple px-3">{category.title}</h3>
            <div class="space-y-1">
              {category.links.map((link) => (
                <a
                  href={link.href}
                  aria-current={active === link.key ? "page" : undefined}
                  class={`flex items-center gap-3 w-full rounded px-3 py-2 text-xs font-bold uppercase tracking-wider transition-all duration-200 ${active === link.key ? "text-white bg-kharon-purple/20 border border-kharon-purple/40 border-l-4 border-l-kharon-cyan shadow-lg shadow-kharon-purple/5" : "text-kharon-light/60 hover:text-white hover:bg-kharon-purple/10 border border-transparent"}`}
                >
                  <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" set:html={getIconPath(link.key)}></svg>
                  <span>{link.label}</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </nav>
    </aside>

    <!-- Main Content Area -->
    <main id="main-content" class="flex-1 min-h-[calc(100vh-5rem)]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-10 py-8 lg:py-12">
        <slot />
      </div>
    </main>
  </div>

  <div id="feedback-modal" class="fixed inset-0 z-[100] hidden items-center justify-center px-4 bg-[#0B0D0F]/70 backdrop-blur-md transition-all duration-300 opacity-0">
    <div class="w-full max-w-md scale-95 transition-transform duration-300 bg-kharon-charcoal rounded-xl shadow-2xl shadow-kharon-black/40 overflow-hidden border border-kharon-purple/20">
      <div class="bg-gradient-to-r from-kharon-purple to-kharon-blue px-6 py-4 flex items-center justify-between">
        <h3 class="text-white font-bold uppercase tracking-widest text-sm">Provide Feedback</h3>
        <button id="close-feedback" aria-label="Close feedback form" class="text-white/60 hover:text-white transition-colors text-xl font-bold">×</button>
      </div>
      <form id="feedback-form" class="p-6 space-y-4">
        <div>
          <label class="block text-[10px] font-bold uppercase tracking-widest text-kharon-purple/80 mb-1.5">Category</label>
          <select name="category" required class="w-full rounded-lg border border-kharon-purple/20 bg-kharon-charcoal px-3 py-2 text-sm focus:border-kharon-purple focus:ring-1 focus:ring-kharon-purple outline-none transition-all text-white">
            <option value="ui">UI / Layout</option>
            <option value="performance">Performance / Speed</option>
            <option value="bug">Bug / Error</option>
            <option value="suggestion">General Suggestion</option>
          </select>
        </div>
        <div>
          <label class="block text-[10px] font-bold uppercase tracking-widest text-kharon-purple/80 mb-1.5">Your Message</label>
          <textarea name="message" required rows="4" placeholder="How can we improve this page?" class="w-full rounded-lg border border-kharon-purple/20 bg-kharon-charcoal px-3 py-2 text-sm focus:border-kharon-purple focus:ring-1 focus:ring-kharon-purple outline-none transition-all resize-none text-white"></textarea>
        </div>
        <div id="feedback-result" class="hidden text-xs font-bold p-3 rounded-lg"></div>
        <button type="submit" class="w-full rounded-lg bg-gradient-to-r from-kharon-purple to-kharon-blue py-3 text-xs font-bold uppercase tracking-widest text-white shadow-lg shadow-kharon-purple/20 hover:shadow-kharon-purple/40 transition-all duration-300">
          Send Feedback
        </button>
      </form>
    </div>
  </div>

  <script>
    const logoutForm = document.querySelector("#portal-logout-form");
    logoutForm?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const response = await window.kharonPortalFetch("/portal/api/logout", { method: "POST" });
      const body = await response.json() as { redirectTo?: string } | null;
      window.location.href = body?.redirectTo || "/portal/login";
    });

    const openBtn = document.getElementById("open-feedback");
    const closeBtn = document.getElementById("close-feedback");
    const modal = document.getElementById("feedback-modal");
    const form = document.getElementById("feedback-form") as HTMLFormElement;
    const result = document.getElementById("feedback-result");

    function openModal() {
      modal?.classList.remove("hidden");
      modal?.classList.add("flex");
      requestAnimationFrame(() => {
        modal?.classList.add("opacity-100");
        modal?.querySelector(".max-w-md")?.classList.add("scale-100");
      });
    }

    function closeModal() {
      modal?.classList.remove("opacity-100");
      modal?.querySelector(".max-w-md")?.classList.remove("scale-100");
      setTimeout(() => {
        modal?.classList.remove("flex");
        modal?.classList.add("hidden");
        form.reset();
        if (result) {
          result.className = "hidden text-xs font-bold p-3 rounded-lg";
          result.textContent = "";
        }
      }, 300);
    }

    openBtn?.addEventListener("click", openModal);
    closeBtn?.addEventListener("click", closeModal);
    modal?.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });

    const conflictBanner = document.getElementById("offline-conflict-banner");
    window.addEventListener("kharon-offline-conflict", () => {
      conflictBanner?.classList.remove("hidden");
    });
    window.addEventListener("kharon-offline-sync-complete", (event) => {
      const detail = (event as CustomEvent).detail || {};
      if (!detail.conflicts || Number(detail.conflicts) === 0) {
        conflictBanner?.classList.add("hidden");
      }
    });

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const data = {
        category: formData.get("category"),
        message: formData.get("message"),
        path: window.location.pathname
      };

      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.textContent = "Sending...";

      try {
        const response = await window.kharonPortalFetch("/portal/api/feedback", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data)
        });

        const body = await response.json() as { ok?: boolean; message?: string } | null;
        if (result) {
          result.classList.remove("hidden");
          if (response.ok && body?.ok) {
            result.className = "text-emerald-400 bg-emerald-900/30 border border-emerald-700/50 p-3 rounded-lg text-xs font-bold";
            result.textContent = body.message || "Feedback sent successfully.";
            setTimeout(closeModal, 2000);
          } else {
            result.className = "text-rose-400 bg-rose-900/30 border border-rose-700/50 p-3 rounded-lg text-xs font-bold";
            result.textContent = body?.message || "Feedback could not be sent.";
          }
        }
      } catch (err) {
        if (result) {
          result.classList.remove("hidden");
          result.className = "text-rose-400 bg-rose-900/30 border border-rose-700/50 p-3 rounded-lg text-xs font-bold";
          result.textContent = "Network error occurred.";
        }
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Send Feedback";
      }
    });
  </script>
  <script is:inline>
    // Sliding mobile menu drawer interactivity
    (function() {
      const openBtn = document.getElementById("mobile-drawer-toggle");
      const closeBtn = document.getElementById("mobile-drawer-close");
      const backdrop = document.getElementById("mobile-drawer-backdrop");
      const drawer = document.getElementById("mobile-nav-drawer");
      const panel = document.getElementById("mobile-drawer-panel");

      function openDrawer() {
        if (!drawer || !panel || !backdrop) return;
        drawer.classList.remove("pointer-events-none");
        backdrop.classList.remove("pointer-events-none");
        backdrop.classList.add("opacity-100", "pointer-events-auto");
        panel.classList.remove("-translate-x-full");
      }

      function closeDrawer() {
        if (!drawer || !panel || !backdrop) return;
        backdrop.classList.remove("opacity-100", "pointer-events-auto");
        backdrop.classList.add("pointer-events-none");
        panel.classList.add("-translate-x-full");
        setTimeout(() => {
          drawer.classList.add("pointer-events-none");
        }, 300);
      }

      openBtn?.addEventListener("click", openDrawer);
      closeBtn?.addEventListener("click", closeDrawer);
      backdrop?.addEventListener("click", closeDrawer);
    })();
  </script>
  <ClientOperationsManager />
</body>
</html>
