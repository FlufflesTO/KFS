---
/**
 * Project Sentinel - Portal Layout Wrapper
 * Purpose: Renders the standard header, navigation bar, and main container layout for the operations portal.
 * Dependencies: global.css, session state, role links.
 * Structural Role: Shell layout component for all portal pages.
 */
import "../../styles/global.css";

const {
  title = "Kharon Portal",
  active = "",
  user = Astro.locals.user
} = Astro.props;

const roleLinks = {
  tech: [
    { label: "Dispatches", href: "/portal/tech/dashboard", key: "tech" },
    { label: "Job History", href: "/portal/tech/history", key: "tech-history" }
  ],
  admin: [
    { label: "Admin Matrix", href: "/portal/admin/dashboard", key: "admin" },
    { label: "Planning", href: "/portal/admin/planning", key: "planning" },
    { label: "Dispatch", href: "/portal/admin/dispatch", key: "dispatch" },
    { label: "Operations", href: "/portal/admin/operations", key: "operations" },
    { label: "Compliance", href: "/portal/admin/compliance", key: "compliance" },
    { label: "Audit", href: "/portal/admin/audit", key: "audit" },
    { label: "Technician View", href: "/portal/tech/dashboard", key: "tech" },
    { label: "Job History", href: "/portal/tech/history", key: "tech-history" },
    { label: "Finance", href: "/portal/finance/dashboard", key: "finance" }
  ],
  client: [
    { label: "Systems", href: "/portal/client/dashboard", key: "client" },
    { label: "Quotes", href: "/portal/client/quotes", key: "client-quotes" }
  ],
  finance: [{ label: "Ledger", href: "/portal/finance/dashboard", key: "finance" }]
};

const links = [
  ...(roleLinks[user?.role] || []),
  { label: "Password", href: "/portal/account/password", key: "password" },
  ...(["admin", "finance"].includes(user?.role) ? [{ label: "MFA", href: "/portal/account/mfa", key: "mfa" }] : [])
];
---

<!doctype html>
<html lang="en-ZA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#0B0D0F" />
    <meta name="kharon-csrf-token" content={Astro.locals.csrfToken || ""} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      window.kharonPortalFetch = (input, init = {}) => {
        const token = document.querySelector('meta[name="kharon-csrf-token"]')?.content || "";
        const headers = new Headers(init.headers || {});
        if (token && !headers.has("x-csrf-token")) headers.set("x-csrf-token", token);
        return fetch(input, { ...init, headers });
      };
    </script>
  </head>
  <body class="portal-shell bg-kharon-light">
    <header class="border-b border-white/5 bg-[#0B0D0F] text-white shadow-md shadow-black/25">
      <div class="mx-auto flex min-h-20 max-w-7xl flex-wrap items-center justify-between gap-6 px-4 py-4 sm:px-6">
        <a href="/portal" class="flex shrink-0 items-center gap-3">
          <img src="/brand/kharon-mark.svg" alt="" aria-hidden="true" width="28" height="38" class="flex-none" />
          <span>
            <span class="block whitespace-nowrap text-sm font-bold uppercase tracking-wide">Kharon Portal</span>
            <span class="block whitespace-nowrap text-[10px] uppercase text-white/40 tracking-wider">Lifecycle operations</span>
          </span>
        </a>

        <nav class="order-3 flex w-full items-center gap-1.5 overflow-x-auto pb-2 lg:order-none lg:w-auto lg:flex-wrap lg:overflow-visible lg:pb-0" aria-label="Portal navigation">
          {links.map((link) => (
            <a
              href={link.href}
              aria-current={active === link.key ? "page" : undefined}
              class={`shrink-0 rounded-lg px-3.5 py-2.5 text-xs font-semibold uppercase tracking-wider transition-all duration-200 ${active === link.key ? "bg-kharon-purple text-white shadow-md shadow-kharon-purple/20" : "text-white/60 hover:bg-white/5 hover:text-white"}`}
            >
              {link.label}
            </a>
          ))}
        </nav>

        <div class="ml-auto flex min-w-0 items-center gap-4 text-right text-xs sm:gap-5">
          <div class="min-w-0 leading-tight">
            <p class="font-bold text-white/95">{user?.name}</p>
            <p class="uppercase text-kharon-cyan font-semibold tracking-wider text-[9px] mt-0.5">{user?.role}</p>
          </div>
          <form id="portal-logout-form">
            <button class="rounded-lg border border-white/10 px-4 py-2.5 text-xs font-bold uppercase tracking-wider text-white/70 hover:bg-white/5 hover:text-white transition-all duration-200" type="submit">
              Logout
            </button>
          </form>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>
    <script>
      const logoutForm = document.querySelector("#portal-logout-form");
      logoutForm?.addEventListener("submit", async (event) => {
        event.preventDefault();
        const response = await window.kharonPortalFetch("/portal/api/logout", { method: "POST" });
        const body = await response.json().catch(() => ({ redirectTo: "/portal/login" }));
        window.location.href = body.redirectTo || "/portal/login";
      });
    </script>
  </body>
</html>
