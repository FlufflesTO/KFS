---
import "../../styles/global.css";

const {
  title = "Kharon Portal",
  active = "",
  user = Astro.locals.user
} = Astro.props;

const roleLinks = {
  tech: [
    { label: "Dispatches", href: "/portal/tech/dashboard", key: "tech" },
    { label: "Job History", href: "/portal/tech/history", key: "tech-history" }
  ],
  admin: [
    { label: "Admin Matrix", href: "/portal/admin/dashboard", key: "admin" },
    { label: "Planning", href: "/portal/admin/planning", key: "planning" },
    { label: "Operations", href: "/portal/admin/operations", key: "operations" },
    { label: "Technician View", href: "/portal/tech/dashboard", key: "tech" },
    { label: "Job History", href: "/portal/tech/history", key: "tech-history" },
    { label: "Finance", href: "/portal/finance/dashboard", key: "finance" }
  ],
  client: [
    { label: "Systems", href: "/portal/client/dashboard", key: "client" },
    { label: "Quotes", href: "/portal/client/quotes", key: "client-quotes" }
  ],
  finance: [{ label: "Ledger", href: "/portal/finance/dashboard", key: "finance" }]
};

const links = [
  ...(roleLinks[user?.role] || []),
  { label: "Password", href: "/portal/account/password", key: "password" },
  ...(["admin", "finance"].includes(user?.role) ? [{ label: "MFA", href: "/portal/account/mfa", key: "mfa" }] : [])
];
---

<!doctype html>
<html lang="en-ZA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#0B0D0F" />
    <meta name="kharon-csrf-token" content={Astro.locals.csrfToken || ""} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      window.kharonPortalFetch = (input, init = {}) => {
        const token = document.querySelector('meta[name="kharon-csrf-token"]')?.content || "";
        const headers = new Headers(init.headers || {});
        if (token && !headers.has("x-csrf-token")) headers.set("x-csrf-token", token);
        return fetch(input, { ...init, headers });
      };
    </script>
  </head>
  <body class="portal-shell bg-kharon-light">
    <header class="border-b border-white/10 bg-kharon-black text-white">
      <div class="mx-auto flex min-h-20 max-w-7xl flex-wrap items-center justify-between gap-4 px-4 py-4 sm:px-6">
        <a href="/portal" class="grid min-w-0">
          <span class="text-sm font-bold uppercase">Kharon Portal</span>
          <span class="text-xs uppercase text-white/55">Lifecycle operations</span>
        </a>

        <nav class="order-3 flex w-full items-center gap-2 overflow-x-auto pb-1 lg:order-none lg:w-auto lg:flex-wrap lg:overflow-visible lg:pb-0" aria-label="Portal navigation">
          {links.map((link) => (
            <a
              href={link.href}
              aria-current={active === link.key ? "page" : undefined}
              class={`shrink-0 rounded-md border px-4 py-2 text-sm font-semibold ${active === link.key ? "border-kharon-cyan bg-kharon-cyan/10 text-white" : "border-white/10 text-white/70 hover:border-white/30 hover:text-white"}`}
            >
              {link.label}
            </a>
          ))}
        </nav>

        <div class="ml-auto flex min-w-0 items-center gap-3 text-right text-sm sm:gap-4">
          <div class="min-w-0">
            <p class="font-semibold">{user?.name}</p>
            <p class="uppercase text-white/50">{user?.role}</p>
          </div>
          <form id="portal-logout-form">
            <button class="rounded-md border border-white/15 px-4 py-2 font-semibold text-white/70 hover:border-white/30 hover:text-white" type="submit">
              Logout
            </button>
          </form>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>
    <script>
      const logoutForm = document.querySelector("#portal-logout-form");
      logoutForm?.addEventListener("submit", async (event) => {
        event.preventDefault();
        const response = await window.kharonPortalFetch("/portal/api/logout", { method: "POST" });
        const body = await response.json().catch(() => ({ redirectTo: "/portal/login" }));
        window.location.href = body.redirectTo || "/portal/login";
      });
    </script>
  </body>
</html>
