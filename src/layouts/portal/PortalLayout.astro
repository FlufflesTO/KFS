---
/**
 * Project Sentinel - Portal Layout Wrapper
 * Purpose: Renders the standard header, navigation bar, and main container layout for the operations portal.
 * Dependencies: global.css, session state, role links.
 * Structural Role: Shell layout component for all portal pages.
 */
import "../../styles/global.css";
import ClientOperationsManager from "../../components/portal/ClientOperationsManager.astro";

const {
  title = "Kharon Portal",
  active = "",
  user = Astro.locals.user
} = Astro.props;

const variant = Astro.locals.variant || "A";

const roleLinks: Record<string, Array<{ label: string; href: string; key: string }>> = {
  tech: [
    { label: "Dispatches", href: "/portal/tech/dashboard", key: "tech" },
    { label: "Job History", href: "/portal/tech/history", key: "tech-history" }
  ],
  admin: [
    { label: "Admin Matrix", href: "/portal/admin/dashboard", key: "admin" },
    { label: "Planning", href: "/portal/admin/planning", key: "planning" },
    { label: "Dispatch", href: "/portal/admin/dispatch", key: "dispatch" },
    { label: "Operations", href: "/portal/admin/operations", key: "operations" },
    { label: "Jobs", href: "/portal/admin/jobs", key: "jobs" },
    { label: "Sites", href: "/portal/admin/sites", key: "sites" },
    { label: "Systems", href: "/portal/admin/systems", key: "systems" },
    { label: "Users", href: "/portal/admin/users", key: "users" },
    { label: "Data", href: "/portal/admin/exports", key: "exports" },
    { label: "Compliance", href: "/portal/admin/compliance", key: "compliance" },
    { label: "Audit", href: "/portal/admin/audit", key: "audit" },
    { label: "Clients", href: "/portal/admin/multi-client", key: "multi-client" },
    { label: "Reports", href: "/portal/admin/advanced-reporting", key: "advanced-reporting" },
    { label: "Feedback", href: "/portal/admin/feedback", key: "feedback" },
    { label: "Technician View", href: "/portal/tech/dashboard", key: "tech" },
    { label: "Job History", href: "/portal/tech/history", key: "tech-history" },
    { label: "Finance", href: "/portal/finance/dashboard", key: "finance" }
  ],
  client: [
    { label: "Systems", href: "/portal/client/dashboard", key: "client" },
    { label: "Quotes", href: "/portal/client/quotes", key: "client-quotes" }
  ],
  finance: [{ label: "Ledger", href: "/portal/finance/dashboard", key: "finance" }]
};

const links = [
  ...(roleLinks[user?.role || ""] || []),
  { label: "Password", href: "/portal/account/password", key: "password" },
  ...(["admin", "finance"].includes(user?.role || "") ? [{ label: "MFA", href: "/portal/account/mfa", key: "mfa" }] : [])
];
---

<!doctype html>
<html lang="en-ZA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#0B0D0F" />
    <meta name="kharon-csrf-token" content={Astro.locals.csrfToken || ""} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="KFS Portal" />
    <script is:inline>
      // Register Service Worker
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js', { scope: '/portal/' })
          .catch(function(err) { console.warn('SW registration failed:', err); });

        // Listen for online event to trigger queue drain
        window.addEventListener('online', function() {
          if (navigator.serviceWorker.controller) {
            navigator.serviceWorker.controller.postMessage({ type: 'DRAIN_QUEUE' });
          }
        });
      }
    </script>
    <script is:inline>
      window.kharonPortalFetch = async (input, init = {}) => {
        const token = document.querySelector('meta[name="kharon-csrf-token"]')?.content || "";
        const headers = new Headers(init.headers || {});
        if (token && !headers.has("x-csrf-token")) headers.set("x-csrf-token", token);
        
        const maxAttempts = 3;
        const baseDelayMs = 500;
        const maxDelayMs = 5000;
        const retryableStatuses = [408, 500, 502, 503, 504]; // Exclude 429 here, let ClientOperationsManager handle it
        let attempt = 0;

        while (attempt < maxAttempts) {
          try {
            const response = await fetch(input, { ...init, headers });
            
            if (response.ok || !retryableStatuses.includes(response.status) || response.status === 429) {
              return response; // Return 429 directly to be handled by operations manager intercept
            }

            let delayMs = baseDelayMs * Math.pow(2, attempt);
            const retryAfter = response.headers.get('Retry-After');
            if (retryAfter) {
              const retryAfterSecs = parseInt(retryAfter, 10);
              if (!isNaN(retryAfterSecs)) {
                delayMs = retryAfterSecs * 1000;
              }
            }
            delayMs = Math.min(delayMs, maxDelayMs);
            
            attempt++;
            if (attempt >= maxAttempts) return response;
            await new Promise(r => setTimeout(r, delayMs));
          } catch (error) {
            attempt++;
            if (attempt >= maxAttempts) throw error;
            const delayMs = Math.min(baseDelayMs * Math.pow(2, attempt - 1), maxDelayMs);
            await new Promise(r => setTimeout(r, delayMs));
          }
        }
        throw new Error("Maximum retry attempts exceeded.");
      };
    </script>
  </head>
  <body data-variant={variant} class="portal-shell bg-gradient-to-br from-kharon-black to-kharon-charcoal min-h-screen text-kharon-light selection:bg-kharon-purple/30 selection:text-kharon-purple">
  <!-- Skip link for accessibility -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[200] focus:bg-kharon-charcoal focus:px-4 focus:py-2 focus:border focus:border-kharon-purple focus:rounded focus:text-white focus:shadow-lg">
    Skip to main content
  </a>
  
  <!-- Top Navigation Command Center -->
  <header class="sticky top-0 z-50 w-full border-b border-kharon-purple/10 bg-kharon-black/80 backdrop-blur-md text-white shadow-lg shadow-kharon-black/20">
    <!-- Ambient top glow -->
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-kharon-purple/30 to-transparent"></div>
    
    <div class="mx-auto flex min-h-[5rem] max-w-7xl flex-wrap items-center justify-between gap-4 sm:gap-6 px-4 py-3 sm:px-6 relative">
      <a href="/portal" class="group flex shrink-0 items-center gap-4 transition-transform duration-300 hover:scale-[1.02]">
        <div class="relative flex h-10 w-8 items-center justify-center">
          <div class="absolute inset-0 bg-kharon-purple/15 blur-md group-hover:bg-kharon-purple/25 transition-colors duration-500"></div>
          <img src="/brand/letterhead/kharon-letterhead.svg" alt="" aria-hidden="true" width="110" height="38" class="relative z-10 flex-none" />
        </div>
        <span>
          <span class="block whitespace-nowrap text-sm font-bold uppercase tracking-widest text-kharon-purple group-hover:text-kharon-purple/90 transition-colors duration-300">Kharon Operations</span>
          <span class="block whitespace-nowrap text-[10px] uppercase text-white/40 tracking-wider">Secure Command Console</span>
        </span>
      </a>

      <nav class="order-3 flex w-full items-center gap-1.5 overflow-x-auto pb-2 lg:order-none lg:w-auto lg:flex-wrap lg:overflow-visible lg:pb-0 scrollbar-hide" aria-label="Portal navigation" style="scrollbar-width: none; -ms-overflow-style: none;">
        {links.map((link) => (
          <a
            href={link.href}
            aria-current={active === link.key ? "page" : undefined}
            class={`relative shrink-0 rounded-md px-3.5 py-2 text-xs font-semibold uppercase tracking-wide transition-all duration-200 min-h-[40px] flex items-center justify-center border border-transparent hover:border-kharon-purple/20 ${active === link.key ? "text-white bg-kharon-purple shadow-sm border-kharon-purple/50" : "text-white/70 hover:text-white hover:bg-kharon-purple/10"}`}
          >
            <span class="relative z-10">{link.label}</span>
          </a>
        ))}
      </nav>

      <div class="ml-auto flex min-w-0 items-center gap-3 sm:gap-4 text-right text-xs">
        <div class="min-w-0 leading-tight hidden xl:block">
          <p class="font-semibold text-white/90 truncate">{user?.name}</p>
          <div class="mt-0.5 flex items-center justify-end gap-1">
            <span class="h-1.5 w-1.5 rounded-full bg-kharon-purple"></span>
            <p class="uppercase text-kharon-purple/80 font-semibold tracking-wide text-xs">{user?.role}</p>
          </div>
        </div>
        <button id="open-feedback" class="hidden md:flex items-center gap-2 rounded-md border border-kharon-purple/20 bg-kharon-charcoal/50 px-3 py-2 text-xs font-semibold uppercase tracking-wide text-white/70 hover:text-white hover:border-kharon-purple/40 transition-all min-h-[40px] backdrop-blur-sm">
          Feedback
        </button>
        <form id="portal-logout-form">
          <button class="flex items-center justify-center rounded-md border border-kharon-red/30 bg-kharon-charcoal/50 px-4 py-2 text-xs font-semibold uppercase tracking-wide text-kharon-red/70 transition-all hover:border-kharon-red/50 hover:bg-kharon-red/10 hover:text-kharon-red min-h-[40px] backdrop-blur-sm" type="submit">
            Logout
          </button>
        </form>
      </div>
    </div>
  </header>

  <div class="flex max-w-7xl mx-auto">
    <!-- Left Navigation Rail - Desktop -->
    <aside class="hidden lg:block w-64 min-h-[calc(100vh-5rem)] border-r border-kharon-purple/10 bg-kharon-black/60 backdrop-blur-sm p-4">
      <nav class="space-y-1" aria-label="Portal navigation">
        {links.map((link) => (
          <a
            href={link.href}
            aria-current={active === link.key ? "page" : undefined}
            class={`block w-full text-left rounded-md px-4 py-3 text-sm font-semibold uppercase tracking-wide transition-all duration-200 ${active === link.key ? "text-white bg-kharon-purple/30 shadow-sm border border-kharon-purple/50" : "text-white/70 hover:text-white hover:bg-kharon-purple/10 border border-transparent"}`}
          >
            {link.label}
          </a>
        ))}
      </nav>
    </aside>

    <!-- Mobile/Responsive Navigation -->
    <div class="lg:hidden w-full px-4 py-3 border-b border-kharon-purple/10 bg-kharon-black/40 backdrop-blur-sm">
      <details class="mobile-menu">
        <summary class="flex items-center justify-between w-full px-3 py-2 text-sm font-semibold uppercase tracking-wide text-white/80 rounded-md bg-kharon-charcoal/50 border border-kharon-purple/20 hover:bg-kharon-purple/10 cursor-pointer">
          <span>Menu</span>
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
          </svg>
        </summary>
        <div class="mt-2 space-y-1 bg-kharon-charcoal/80 backdrop-blur-md rounded-lg p-2 border border-kharon-purple/20">
          {links.map((link) => (
            <a
              href={link.href}
              aria-current={active === link.key ? "page" : undefined}
              class={`block w-full text-left rounded-md px-4 py-3 text-sm font-semibold uppercase tracking-wide transition-all duration-200 ${active === link.key ? "text-white bg-kharon-purple/30 shadow-sm border border-kharon-purple/50" : "text-white/70 hover:text-white hover:bg-kharon-purple/10 border border-transparent"}`}
            >
              {link.label}
            </a>
          ))}
        </div>
      </details>
    </div>

    <!-- Main Content Area -->
    <main id="main-content" class="flex-1 min-h-[calc(100vh-5rem)] relative">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <slot />
      </div>
    </main>
  </div>

  <div id="feedback-modal" class="fixed inset-0 z-[100] hidden items-center justify-center px-4 bg-[#0B0D0F]/70 backdrop-blur-md transition-all duration-300 opacity-0">
    <div class="w-full max-w-md scale-95 transition-transform duration-300 bg-kharon-charcoal rounded-xl shadow-2xl shadow-kharon-black/40 overflow-hidden border border-kharon-purple/20">
      <div class="bg-gradient-to-r from-kharon-purple to-kharon-blue px-6 py-4 flex items-center justify-between">
        <h3 class="text-white font-bold uppercase tracking-widest text-sm">Provide Feedback</h3>
        <button id="close-feedback" class="text-white/60 hover:text-white transition-colors text-xl font-bold">×</button>
      </div>
      <form id="feedback-form" class="p-6 space-y-4">
        <div>
          <label class="block text-[10px] font-bold uppercase tracking-widest text-kharon-purple/80 mb-1.5">Category</label>
          <select name="category" required class="w-full rounded-lg border border-kharon-purple/20 bg-kharon-graphite px-3 py-2 text-sm focus:border-kharon-purple focus:ring-1 focus:ring-kharon-purple outline-none transition-all text-white">
            <option value="ui">UI / Layout</option>
            <option value="performance">Performance / Speed</option>
            <option value="bug">Bug / Error</option>
            <option value="suggestion">General Suggestion</option>
          </select>
        </div>
        <div>
          <label class="block text-[10px] font-bold uppercase tracking-widest text-kharon-purple/80 mb-1.5">Your Message</label>
          <textarea name="message" required rows="4" placeholder="How can we improve this page?" class="w-full rounded-lg border border-kharon-purple/20 bg-kharon-graphite px-3 py-2 text-sm focus:border-kharon-purple focus:ring-1 focus:ring-kharon-purple outline-none transition-all resize-none text-white"></textarea>
        </div>
        <div id="feedback-result" class="hidden text-xs font-bold p-3 rounded-lg"></div>
        <button type="submit" class="w-full rounded-lg bg-gradient-to-r from-kharon-purple to-kharon-blue py-3 text-xs font-bold uppercase tracking-widest text-white shadow-lg shadow-kharon-purple/20 hover:shadow-kharon-purple/40 transition-all duration-300">
          Send Feedback
        </button>
      </form>
    </div>
  </div>

  <script>
    const logoutForm = document.querySelector("#portal-logout-form");
    logoutForm?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const response = await window.kharonPortalFetch("/portal/api/logout", { method: "POST" });
      const body = await response.json().catch(() => ({ redirectTo: "/portal/login" }));
      window.location.href = body.redirectTo || "/portal/login";
    });

    const openBtn = document.getElementById("open-feedback");
    const closeBtn = document.getElementById("close-feedback");
    const modal = document.getElementById("feedback-modal");
    const form = document.getElementById("feedback-form") as HTMLFormElement;
    const result = document.getElementById("feedback-result");

    function openModal() {
      modal?.classList.remove("hidden");
      modal?.classList.add("flex");
      requestAnimationFrame(() => {
        modal?.classList.add("opacity-100");
        modal?.querySelector(".max-w-md")?.classList.add("scale-100");
      });
    }

    function closeModal() {
      modal?.classList.remove("opacity-100");
      modal?.querySelector(".max-w-md")?.classList.remove("scale-100");
      setTimeout(() => {
        modal?.classList.remove("flex");
        modal?.classList.add("hidden");
        form.reset();
        if (result) {
          result.className = "hidden text-xs font-bold p-3 rounded-lg";
          result.textContent = "";
        }
      }, 300);
    }

    openBtn?.addEventListener("click", openModal);
    closeBtn?.addEventListener("click", closeModal);
    modal?.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const data = {
        category: formData.get("category"),
        message: formData.get("message"),
        path: window.location.pathname
      };

      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.textContent = "Sending...";

      try {
        const response = await window.kharonPortalFetch("/portal/api/feedback", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data)
        });

        const body = await response.json();
        if (result) {
          result.classList.remove("hidden");
          if (response.ok && body.ok) {
            result.className = "text-emerald-400 bg-emerald-900/30 border border-emerald-700/50 p-3 rounded-lg text-xs font-bold";
            result.textContent = body.message;
            setTimeout(closeModal, 2000);
          } else {
            result.className = "text-rose-400 bg-rose-900/30 border border-rose-700/50 p-3 rounded-lg text-xs font-bold";
            result.textContent = body.message || "Feedback could not be sent.";
          }
        }
      } catch (err) {
        if (result) {
          result.classList.remove("hidden");
          result.className = "text-rose-400 bg-rose-900/30 border border-rose-700/50 p-3 rounded-lg text-xs font-bold";
          result.textContent = "Network error occurred.";
        }
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Send Feedback";
      }
    });
  </script>
  <ClientOperationsManager />
</body>
</html>
