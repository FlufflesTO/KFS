---
/**
 * ServicePage - reusable solution/service page template.
 * Page files pass structured data; this enforces consistent structure, tone hooks,
 * SANS proof, conversion (WhatHappensNext) and an optional related case study.
 */
import BaseLayout from "./BaseLayout.astro";
import SolutionHero from "../components/sections/SolutionHero.astro";
import ComplianceStrip from "../components/sections/ComplianceStrip.astro";
import SectionHeading from "../components/sections/SectionHeading.astro";
import WhatHappensNext from "../components/sections/WhatHappensNext.astro";
import CaseStudyCard from "../components/sections/CaseStudyCard.astro";
import DisclaimerNote from "../components/sections/DisclaimerNote.astro";

import LeadMagnetCard from "../components/blocks/LeadMagnetCard.astro";
import { leadMagnets } from "../data/leadMagnets.js";
import { getCaseStudy } from "../data/case-studies.js";
import Breadcrumbs from "../components/layout/Breadcrumbs.astro";
import { generateServiceSchema, generateFAQSchema } from "../lib/seo/schema.ts";

export interface Capability {
  title: string;
  text: string;
}

export interface Props {
  leadMagnetId?: string;
  proofItems?: { title: string; text: string }[];
  meta: { title: string; description: string };
  hero: { subtitle: string; title: string; description: string; icon: string };
  /** one-paragraph "what we do" */
  overview: string;
  /** problem-led framing */
  problem: { heading: string; body: string; points: string[] };
  /** systems / what's involved */
  capabilitiesHeading?: string;
  capabilities: Capability[];
  /** SANS / standards badges */
  standards: string[];
  /** optional FAQ */
  faqs?: { q: string; a: string }[];
  /** related case study slug (from case-studies.ts) */
  caseStudySlug?: string;
  /** contact form routing intent */
  intent: string;
  /** optional DisclaimerNote variant rendered before WhatHappensNext */
  disclaimerVariant?: "sans" | "privacy" | "sla" | "case-study" | "product-suitability" | "fire-door";
  cta?: { title: string; description: string; label?: string };
}

const {
  meta, hero, overview, problem,
  capabilitiesHeading = "What's involved",
  capabilities, standards, faqs, caseStudySlug, intent, cta,
  leadMagnetId, proofItems, disclaimerVariant
} = Astro.props;

const study = caseStudySlug ? getCaseStudy(caseStudySlug) : undefined;

const magnet = leadMagnetId ? leadMagnets[leadMagnetId] : undefined;

const breadcrumbItems = [
  { name: "Services", url: "/services" },
  { name: hero.title, url: Astro.url.pathname }
];
const serviceSchema = generateServiceSchema(hero.title, hero.description, Astro.url.pathname);
const faqSchema = faqs && faqs.length > 0 ? generateFAQSchema(faqs.map(f => ({ question: f.q, answer: f.a }))) : null;
---

<BaseLayout title={meta.title} description={meta.description}>
  {serviceSchema && <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} is:inline />}
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />}
  
  <div class="mx-auto max-w-7xl px-4 pt-6 sm:px-6">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <SolutionHero subtitle={hero.subtitle} title={hero.title} description={hero.description} icon={hero.icon} />
  <ComplianceStrip />

  <!-- What we do -->
  <section class="section-padding bg-kharon-black">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <p class="text-base font-bold uppercase tracking-[0.2em] text-kharon-cyan">What we do</p>
      <p class="mt-4 text-lg leading-relaxed text-kharon-light/80">{overview}</p>
    </div>
  </section>

  <!-- Problem-led -->
  <section class="section-padding bg-kharon-charcoal/30 border-y border-kharon-purple/10">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <SectionHeading title={problem.heading} subtitle="The problem" />
      <p class="max-w-3xl text-kharon-light/70 leading-relaxed">{problem.body}</p>
      <ul class="mt-8 grid gap-4 sm:grid-cols-2">
        {problem.points.map((p) => (
          <li class="flex items-start gap-3 rounded-lg border border-kharon-purple/15 bg-kharon-black/40 p-4">
            <span class="mt-1.5 h-1.5 w-1.5 flex-none rounded-full bg-kharon-red"></span>
            <span class="text-base leading-relaxed text-kharon-light/80">{p}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Capabilities / systems -->
  <section class="section-padding bg-kharon-black">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <SectionHeading title={capabilitiesHeading} subtitle="Our approach" />
      <div class="mt-4 grid gap-6 md:grid-cols-2">
        {capabilities.map((c) => (
          <div class="rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/30 p-8 transition-all hover:border-kharon-purple/40">
            <h3 class="text-lg font-bold text-white">{c.title}</h3>
            <p class="mt-3 leading-relaxed text-kharon-light/70">{c.text}</p>
          </div>
        ))}
      </div>

      {standards.length > 0 && (
        <div class="mt-10 flex flex-wrap items-center gap-3">
          <span class="text-base font-bold uppercase tracking-widest text-kharon-light/50">Aligned to</span>
          {standards.map((s) => (
            <span class="rounded border border-kharon-purple/40 bg-kharon-purple/10 px-3 py-1 text-base font-black uppercase tracking-wider text-white">{s}</span>
          ))}
        </div>
      )}
    </div>
  </section>

  <slot />

  {study && (
    <section class="section-padding bg-kharon-charcoal/30 border-t border-kharon-purple/10">
      <div class="mx-auto max-w-4xl px-4 sm:px-6">
        <SectionHeading title="Proof in practice" subtitle="Case study" />
        <CaseStudyCard study={study} variant="preview" />
      </div>
    </section>
  )}

  {faqs && faqs.length > 0 && (
    <section class="section-padding bg-kharon-black border-t border-kharon-purple/10">
      <div class="mx-auto max-w-3xl px-4 sm:px-6">
        <SectionHeading title="Frequently asked" subtitle="FAQ" />
        <div class="grid gap-4">
          {faqs.map((f) => (
            <details class="group rounded-lg border border-kharon-purple/15 bg-kharon-charcoal/30 p-5">
              <summary class="cursor-pointer list-none text-base font-bold text-white marker:hidden">{f.q}</summary>
              <p class="mt-3 text-base leading-relaxed text-kharon-light/70">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  
  {magnet && (
    <section class="section-padding bg-kharon-black border-t border-kharon-purple/10">
      <div class="mx-auto max-w-4xl px-4 sm:px-6">
        <LeadMagnetCard magnet={magnet} />
      </div>
    </section>
  )}

  {proofItems && proofItems.length > 0 && (
    <section class="section-padding bg-kharon-charcoal/30 border-t border-kharon-purple/10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6">
        <div class="mb-8">
          <p class="text-base font-bold uppercase tracking-[0.2em] text-kharon-cyan">Validation</p>
          <h2 class="kharon-h2 mt-3 text-white">Proof of Capability</h2>
        </div>
        <div class="grid gap-6 md:grid-cols-3">
          {proofItems.map((p) => (
            <div class="rounded-xl border border-kharon-purple/15 bg-kharon-black/40 p-5">
              <h3 class="font-bold text-white">{p.title}</h3>
              <p class="mt-2 text-base text-kharon-light/70">{p.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {disclaimerVariant && (
    <section class="bg-kharon-black">
      <div class="mx-auto max-w-4xl px-4 pb-4 sm:px-6">
        <DisclaimerNote variant={disclaimerVariant} />
      </div>
    </section>
  )}
<WhatHappensNext intent={intent} ctaLabel={cta?.label ?? "Request Site Assessment"} />
</BaseLayout>
