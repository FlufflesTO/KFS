---
/**
 * GuidePage - reusable resource/guide template (SEO long-form + checklists).
 * Emits breadcrumb JSON-LD and, when `faqs` are supplied, FAQ JSON-LD.
 */
import BaseLayout from "./BaseLayout.astro";
import SolutionHero from "../components/sections/SolutionHero.astro";
import WhatHappensNext from "../components/sections/WhatHappensNext.astro";
import Breadcrumbs from "../components/layout/Breadcrumbs.astro";
import DisclaimerNote from "../components/sections/DisclaimerNote.astro";
import { generateFAQSchema } from "../lib/seo/schema.ts";

export interface Props {
  meta: { title: string; description: string };
  hero: { subtitle: string; title: string; description: string; icon: string };
  intro: string;
  sections: { heading: string; body?: string; list?: string[] }[];
  checklists?: { title: string; items: string[] }[];
  /** optional FAQ block — renders an accordion and emits FAQ JSON-LD */
  faqs?: { q: string; a: string }[];
  related?: { label: string; href: string }[];
  /** optional DisclaimerNote variant rendered after the content */
  disclaimerVariant?: "sans" | "privacy" | "sla" | "case-study" | "product-suitability" | "fire-door";
  intent: string;
}

const { meta, hero, intro, sections, checklists, faqs, related, disclaimerVariant, intent } = Astro.props;

const breadcrumbItems = [
  { name: "Resources", url: "/resources" },
  { name: hero.title, url: Astro.url.pathname }
];

const faqSchema = faqs && faqs.length > 0
  ? generateFAQSchema(faqs.map((f) => ({ question: f.q, answer: f.a })))
  : null;
---

<BaseLayout title={meta.title} description={meta.description}>
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />}

  <SolutionHero subtitle={hero.subtitle} title={hero.title} description={hero.description} icon={hero.icon} />

  <section class="section-padding bg-kharon-black">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <Breadcrumbs items={breadcrumbItems} />

      <p class="text-lg leading-relaxed text-kharon-light/80">{intro}</p>

      <div class="mt-12 grid gap-10">
        {sections.map((s) => (
          <div>
            <h2 class="kharon-h3 text-white">{s.heading}</h2>
            {s.body && <p class="mt-3 leading-relaxed text-kharon-light/70">{s.body}</p>}
            {s.list && s.list.length > 0 && (
              <ul class="mt-4 grid gap-2">
                {s.list.map((li) => (
                  <li class="flex items-start gap-3 text-base leading-relaxed text-kharon-light/80">
                    <span class="mt-1.5 h-1.5 w-1.5 flex-none rounded-full bg-kharon-cyan"></span>{li}
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>

      {checklists && checklists.length > 0 && (
        <div class="mt-12 grid gap-6">
          {checklists.map((c) => (
            <div class="rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/30 p-6">
              <h3 class="text-base font-bold text-white">{c.title}</h3>
              <ul class="mt-4 grid gap-2">
                {c.items.map((item) => (
                  <li class="flex items-start gap-3 text-base leading-relaxed text-kharon-light/80">
                    <span class="mt-0.5 flex h-4 w-4 flex-none items-center justify-center rounded border border-kharon-cyan/40 text-base text-kharon-cyan">✓</span>{item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      )}

      {faqs && faqs.length > 0 && (
        <div class="mt-12">
          <h2 class="kharon-h3 text-white">Frequently asked</h2>
          <div class="mt-4 grid gap-4">
            {faqs.map((f) => (
              <details class="group rounded-lg border border-kharon-purple/15 bg-kharon-charcoal/30 p-5">
                <summary class="cursor-pointer list-none text-base font-bold text-white marker:hidden">{f.q}</summary>
                <p class="mt-3 text-base leading-relaxed text-kharon-light/70">{f.a}</p>
              </details>
            ))}
          </div>
        </div>
      )}

      {disclaimerVariant && <DisclaimerNote variant={disclaimerVariant} />}

      {related && related.length > 0 && (
        <div class="mt-12 border-t border-kharon-purple/10 pt-8">
          <p class="text-base font-bold uppercase tracking-[0.2em] text-kharon-cyan">Related</p>
          <div class="mt-4 flex flex-wrap gap-3">
            {related.map((r) => (
              <a href={r.href} data-analytics="resource_click" class="rounded-lg border border-kharon-purple/20 bg-kharon-charcoal/30 px-4 py-2 text-base font-bold text-white hover:border-kharon-cyan/40 hover:text-kharon-cyan">{r.label}</a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <WhatHappensNext intent={intent} ctaLabel="Request Site Assessment" />
</BaseLayout>
