---
/**
 * Project Sentinel - SansReferenceMatrix
 * Purpose: Matrix displaying SANS regulatory standards for fire, security, and support systems
 * Dependencies: None
 * Structural Role: Reusable compliance UI component
 */

const RED = "text-kharon-red border-red-500/20 bg-red-500/5";
const PURPLE = "text-kharon-purple border-kharon-purple/20 bg-kharon-purple/5";
const BLUE = "text-kharon-blue border-kharon-blue/20 bg-kharon-blue/5";

const categories = [
  {
    title: "Fire Detection & Alarm",
    color: RED,
    standards: [
      {
        code: "SANS 10139",
        name: "Detection & Alarm Systems",
        governs: "System design, installation, commissioning and servicing of fire detection and alarm systems in buildings."
      },
      {
        code: "SANS 322",
        name: "Healthcare Detection",
        governs: "Fire detection and alarm systems for hospitals, including healthcare evacuation strategy requirements."
      },
      {
        code: "SANS 246",
        name: "Electronic Equipment Protection",
        governs: "Fire protection for electronic equipment installations such as server rooms and data centres."
      },
      {
        code: "SANS 54 (EN 54)",
        name: "Component Standards",
        governs: "Product standards for detectors, manual call points and control and indicating equipment."
      }
    ]
  },
  {
    title: "Fire Suppression",
    color: RED,
    standards: [
      {
        code: "SANS 14520",
        name: "Gaseous Suppression",
        governs: "Clean-agent gaseous fire-extinguishing systems (e.g. FM-200, Novec 1230, Inergen) — design and room integrity."
      },
      {
        code: "SANS 15779",
        name: "Condensed Aerosol",
        governs: "Condensed aerosol fire-extinguishing systems."
      },
      {
        code: "SANS 13565",
        name: "Foam Systems",
        governs: "Fixed firefighting foam systems."
      },
      {
        code: "SANS 306-4",
        name: "CO₂ Systems",
        governs: "Fixed carbon-dioxide fire-extinguishing installations."
      },
      {
        code: "SANS 10108",
        name: "Hazardous Locations",
        governs: "Classification of hazardous locations and selection of apparatus for explosion-risk environments."
      }
    ]
  },
  {
    title: "Fire Doors & Ironmongery",
    color: PURPLE,
    standards: [
      {
        code: "SANS 1253",
        name: "Fire Doors & Shutters",
        governs: "Manufacturing and performance requirements for fire doors and fire shutters."
      },
      {
        code: "SANS 51155 (EN 1155)",
        name: "Hold-Open Devices",
        governs: "Electrically powered hold-open devices for swing doors integrating with fire detection."
      },
      {
        code: "SANS 10400-T",
        name: "Building Fire Regulations",
        governs: "Where fire doors are required and how fail-safe locks and hold-open devices must operate on alarm."
      }
    ]
  },
  {
    title: "Signage & Evacuation",
    color: PURPLE,
    standards: [
      {
        code: "SANS 1186-1",
        name: "Symbolic Safety Signs",
        governs: "Standard symbolic safety signs and general requirements."
      },
      {
        code: "SANS 1186-3",
        name: "Illuminated Signs",
        governs: "Internally illuminated symbolic safety signs."
      },
      {
        code: "SANS 1186-5",
        name: "Photoluminescent Signs",
        governs: "Photoluminescent symbolic safety signs."
      },
      {
        code: "SANS 10114-2",
        name: "Emergency Lighting",
        governs: "Emergency escape and standby lighting for safe evacuation of buildings."
      }
    ]
  },
  {
    title: "Public Address & Voice Evacuation",
    color: BLUE,
    standards: [
      {
        code: "SANS 60849",
        name: "Voice Evacuation",
        governs: "Sound systems for emergency purposes — voice evacuation."
      },
      {
        code: "SANS 54-16",
        name: "Voice Alarm Control (VACIE)",
        governs: "Voice alarm control and indicating equipment."
      },
      {
        code: "SANS 54-24",
        name: "Voice Alarm Components",
        governs: "Components of voice alarm systems, including loudspeakers."
      }
    ]
  },
  {
    title: "Electronic Security",
    color: PURPLE,
    standards: [
      {
        code: "SANS 60839-11-1",
        name: "Access Control",
        governs: "Electronic access control systems — system and component requirements."
      },
      {
        code: "SANS 62676",
        name: "Video Surveillance (CCTV)",
        governs: "Video surveillance systems for security — requirements, transmission and installation."
      },
      {
        code: "SANS 50131",
        name: "Intrusion Detection",
        governs: "Intrusion and hold-up alarm systems — security grading and system requirements."
      }
    ]
  },
  {
    title: "Building & Electrical Integration",
    color: BLUE,
    standards: [
      {
        code: "SANS 10400-T",
        name: "National Building Regulations",
        governs: "Part T fire protection — how all fire detection, suppression and evacuation systems interact with the building."
      },
      {
        code: "SANS 10142-1",
        name: "Electrical Wiring of Premises",
        governs: "Low-voltage installations feeding panels, access control and CCTV equipment (Certificate of Compliance required)."
      },
      {
        code: "SANS 10198",
        name: "Power Cabling",
        governs: "Selection, handling and installation of electric power cables."
      },
      {
        code: "SANS 10147",
        name: "HVAC Integration",
        governs: "Refrigeration and air-conditioning — HVAC shutdown interfacing with fire systems to limit smoke spread."
      }
    ]
  }
];
---

<div class="mt-12 grid gap-8 lg:grid-cols-3">
  {categories.map((category) => (
    <div class="rounded-xl border border-white/10 bg-kharon-charcoal/40 p-6 backdrop-blur-sm">
      <h3 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
        <span class="h-2 w-2 rounded-full bg-kharon-purple"></span>
        {category.title}
      </h3>
      <div class="space-y-4">
        {category.standards.map((std) => (
          <div class="group rounded-lg border border-white/5 bg-kharon-black/40 p-4 transition-all duration-300 hover:border-kharon-purple/30 hover:bg-kharon-black/60">
            <div class="flex items-center justify-between gap-2">
              <span class={`rounded px-3 py-0.5 text-xs font-black uppercase tracking-wider border ${category.color}`}>
                {std.code}
              </span>
            </div>
            <h4 class="mt-2 text-sm font-bold text-white group-hover:text-kharon-cyan transition-colors">
              {std.name}
            </h4>
            <p class="mt-2 text-xs leading-relaxed text-kharon-light/70">
              {std.governs}
            </p>
          </div>
        ))}
      </div>
    </div>
  ))}
</div>
