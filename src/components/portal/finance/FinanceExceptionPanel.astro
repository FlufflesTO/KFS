---
import { formatCurrency } from "../../../lib/utils/financial-utils.ts";
import type { DbFinanceTask, DbFinanceSummary } from "@sentinel/types";

interface Props {
  pendingTasks: DbFinanceTask[];
  summary: DbFinanceSummary;
}

const { pendingTasks, summary } = Astro.props;

// Filter for overdue invoices specifically
const overdueTasks = pendingTasks.filter(t => t.task_type.includes('Invoice'));
// Filter for other pending tasks
const otherTasks = pendingTasks.filter(t => !t.task_type.includes('Invoice'));
---

<div class="space-y-6">
  <!-- Pending Approvals -->
  <div class="rounded-xl border border-kharon-border bg-white p-5 shadow-sm">
    <div class="flex items-center justify-between border-b border-kharon-border pb-4 mb-4">
      <div>
        <p class="text-xs font-bold uppercase tracking-wider text-amber-600">Finance Tasks</p>
        <h2 class="text-lg font-bold text-kharon-black">Pending Actions</h2>
      </div>
      <span class="rounded-full bg-amber-100 px-3 py-0.5 text-[10px] font-bold uppercase text-amber-800">{otherTasks.length}</span>
    </div>
    <div class="space-y-3 max-h-96 overflow-y-auto">
      {otherTasks.length === 0 ? (
        <p class="text-sm text-kharon-grey italic py-2">No pending tasks.</p>
      ) : (
        otherTasks.map((task) => (
          <article class="flex items-start justify-between gap-4 p-4 rounded-lg border border-amber-200 bg-amber-50/30">
            <div class="min-w-0 flex-1">
              <div class="flex items-center justify-between">
                <span class="font-semibold text-kharon-black">{task.owner_company_name}</span>
                <span class="rounded bg-amber-100 px-2 py-0.5 text-[9px] font-bold uppercase text-amber-800">{task.task_type}</span>
              </div>
              <p class="text-sm text-kharon-grey mt-0.5">{task.job_type || 'General'} / {task.reference || "No ref"}</p>
              <p class="mt-2 text-xs text-kharon-black font-semibold">{formatCurrency(task.amount)}</p>
            </div>
            <a href={`/portal/finance/task/${task.id}`} class="rounded border border-kharon-blue bg-white px-3 py-2 text-[10px] font-bold text-kharon-blue hover:bg-kharon-blue hover:text-white transition-colors">
              Process
            </a>
          </article>
        ))
      )}
    </div>
  </div>

  <!-- Overdue Payments -->
  <div class="rounded-xl border border-kharon-border bg-white p-5 shadow-sm">
    <div class="flex items-center justify-between border-b border-kharon-border pb-4 mb-4">
      <div>
        <p class="text-xs font-bold uppercase tracking-wider text-kharon-red">Collections</p>
        <h2 class="text-lg font-bold text-kharon-black">Overdue Invoices</h2>
      </div>
      <span class="rounded-full bg-red-100 px-3 py-0.5 text-[10px] font-bold uppercase text-red-800">{summary.overdue_invoices}</span>
    </div>
    <div class="space-y-3 max-h-96 overflow-y-auto">
      {overdueTasks.length === 0 ? (
        <p class="text-sm text-kharon-grey italic py-2">No overdue invoices.</p>
      ) : (
        overdueTasks.map((task) => (
          <article class="flex items-start justify-between gap-4 p-4 rounded-lg border border-red-200 bg-red-50/30">
            <div class="min-w-0 flex-1">
              <div class="flex items-center justify-between">
                <span class="font-semibold text-kharon-black">{task.owner_company_name}</span>
                <span class="rounded bg-red-100 px-2 py-0.5 text-[9px] font-bold uppercase text-red-800">Overdue</span>
              </div>
              <p class="text-sm text-kharon-grey mt-0.5">{task.task_type} / Ref: {task.reference || "N/A"}</p>
              <p class="mt-2 text-xs text-kharon-black font-semibold">{formatCurrency(task.amount)}</p>
            </div>
            <a href={`/portal/finance/task/${task.id}`} class="rounded border border-kharon-blue bg-white px-3 py-2 text-[10px] font-bold text-kharon-blue hover:bg-kharon-blue hover:text-white transition-colors">
              Process
            </a>
          </article>
        ))
      )}
    </div>
  </div>
</div>
