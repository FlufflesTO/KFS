---
import { formatCurrency } from "../../../lib/utils/financial-utils.ts";
import type { DbFinanceTask } from "@sentinel/types";

interface Props {
  completedTasks: DbFinanceTask[];
}

const { completedTasks } = Astro.props;
---

<section class="px-4 py-6 sm:px-6 sm:py-8">
  <div class="mx-auto max-w-7xl">
    <div class="sticky top-0 z-10 bg-kharon-light pb-2 flex flex-wrap items-center justify-between gap-3">
      <div class="flex flex-wrap items-center gap-3">
        <input id="finance-search" type="search" class="rounded-md border border-kharon-border bg-white px-3 py-2 text-sm" placeholder="Search client or reference…" size="26" />
        <select id="finance-status-filter" class="rounded-md border border-kharon-border bg-white px-3 py-2 text-sm">
          <option value="">All task types</option>
          <option value="Invoice">Invoice Required</option>
          <option value="Quote">Quote Required</option>
          <option value="Payment">Payment Recorded</option>
        </select>
      </div>
      <a href="/portal/api/finance/export" class="rounded-md border border-kharon-border bg-white px-4 py-2 text-sm font-bold text-kharon-black hover:bg-kharon-light transition-colors">
        Export Ledger CSV
      </a>
    </div>
    <p id="finance-no-results" class="hidden py-3 text-sm text-kharon-grey">No records match your filter.</p>

    <div class="portal-scroll-x rounded-xl border border-kharon-border bg-white shadow-sm overflow-hidden">
      <table class="w-full min-w-[1200px] border-collapse text-left text-sm">
        <thead class="bg-kharon-charcoal text-white">
          <tr>
            <th class="p-4">Client</th>
            <th class="p-4">Task Type</th>
            <th class="p-4">Status</th>
            <th class="p-4">Ex VAT</th>
            <th class="p-4">VAT</th>
            <th class="p-4">Inc VAT</th>
            <th class="p-4">Created Date</th>
            <th class="p-4">Portal Ref</th>
            <th class="p-4">Sage Ref</th>
            <th class="p-4">Action</th>
          </tr>
        </thead>
        <tbody id="finance-tbody">
          {completedTasks.length === 0 && (
            <tr><td colspan="10" class="p-8 text-center text-kharon-grey italic">No completed tasks found.</td></tr>
          )}
          {completedTasks.map((task) => (
            <tr
              class="border-t border-kharon-border"
              data-search={`${task.owner_company_name} ${task.reference ?? ""} ${task.task_type} ${task.sage_document_ref ?? ""}`}
              data-type={task.task_type.includes("Invoice") ? "Invoice" : task.task_type.includes("Quote") ? "Quote" : task.task_type.includes("Payment") ? "Payment" : "Task"}
            >
              <td class="p-4 font-semibold">{task.owner_company_name}</td>
              <td class="p-4">{task.task_type}</td>
              <td class="p-4">
                <div class="inline-flex items-center gap-1.5 rounded-full bg-emerald-100 px-2 py-0.5 text-[10px] font-bold uppercase text-emerald-800">
                  {task.status}
                </div>
              </td>
              <td class="p-4">{formatCurrency(task.amount)}</td>
              <td class="p-4">{formatCurrency(task.vat_amount || 0)}</td>
              <td class="p-4 font-semibold">{formatCurrency(task.amount + (task.vat_amount || 0))}</td>
              <td class="p-4 whitespace-nowrap">{new Date(task.created_at).toLocaleDateString()}</td>
              <td class="p-4 text-xs text-kharon-grey">{task.reference || <span class="text-kharon-grey/40">—</span>}</td>
              <td class="p-4">
                {task.sage_document_ref ? (
                  <span class="font-mono text-xs text-kharon-grey bg-kharon-light px-2 py-1 rounded">
                    {task.sage_document_ref}
                  </span>
                ) : (
                  <div class="flex flex-col gap-1">
                    <span class="text-xs text-amber-600 font-semibold">Missing Ref</span>
                    {(task.task_type.includes("Invoice") || task.task_type.includes("Quote")) && (
                      <button class="push-to-sage-btn rounded bg-kharon-charcoal px-2 py-1 text-[10px] font-bold text-white hover:bg-kharon-black" data-task-id={task.id}>
                        Push to Sage
                      </button>
                    )}
                  </div>
                )}
              </td>
              <td class="p-4">
                <div class="flex min-w-52 flex-col gap-2">
                  <form class="sage-ref-form grid gap-1.5" data-task-id={task.id}>
                    <input class="rounded border border-kharon-border px-2 py-1.5 text-xs" name="sageDocumentRef" maxlength="60"
                      placeholder="Sage Document Ref"
                      value={task.sage_document_ref || ""} />
                    
                    <input class="rounded border border-kharon-border px-2 py-1.5 text-xs" name="notes" maxlength="500"
                      placeholder="Finance notes (optional)" value={task.notes || ""} />
                      
                    <button class="rounded bg-kharon-grey px-2 py-1.5 text-xs font-semibold text-white hover:bg-kharon-black" type="submit">
                      {task.sage_document_ref ? "Update Ref" : "Save Ref"}
                    </button>
                    <p class="sage-ref-result text-xs text-kharon-grey" aria-live="polite"></p>
                  </form>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

  </div>
</section>

<script>
  // Setup simple form submissions for Sage References
  document.querySelectorAll('.sage-ref-form').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formEl = e.target as HTMLFormElement;
      const taskId = formEl.dataset.taskId;
      const resultEl = formEl.querySelector('.sage-ref-result');
      if (!resultEl) return;
      
      const formData = new FormData(formEl);
      const data = Object.fromEntries(formData);
      
      try {
        resultEl.textContent = "Saving...";
        // @ts-ignore
        const res = await window.kharonPortalFetch(`/portal/api/finance/tasks`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: taskId, updates: data })
        });
        
        if (res.ok) {
          resultEl.textContent = "Saved successfully.";
          setTimeout(() => resultEl.textContent = "", 2000);
        } else {
          resultEl.textContent = "Failed to save.";
        }
      } catch (err) {
        resultEl.textContent = "Error saving.";
      }
    });
  });

  // Setup Sage Push Sync
  document.querySelectorAll('.push-to-sage-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      const buttonEl = e.currentTarget as HTMLButtonElement;
      const taskId = buttonEl.dataset.taskId;
      if (!taskId) return;
      
      const originalText = buttonEl.textContent;
      buttonEl.textContent = "Syncing...";
      buttonEl.disabled = true;
      
      try {
        // @ts-ignore
        const res = await window.kharonPortalFetch(`/portal/api/finance/sage-sync`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ taskId })
        });
        
        if (res.ok) {
          buttonEl.textContent = "Success";
          buttonEl.classList.add("bg-emerald-600");
          setTimeout(() => window.location.reload(), 1000); // Reload to show updated table
        } else {
          const data = await res.json().catch(() => ({}));
          alert(`Sage Sync Failed: ${data.error || 'Unknown error'}`);
          buttonEl.textContent = "Retry Sync";
          buttonEl.disabled = false;
        }
      } catch (err) {
        alert("Network error during Sage Sync");
        buttonEl.textContent = "Retry Sync";
        buttonEl.disabled = false;
      }
    });
  });

  const search = document.getElementById("finance-search") as HTMLInputElement | null;
  const typeFilter = document.getElementById("finance-status-filter") as HTMLSelectElement | null;
  const tbody = document.getElementById("finance-tbody");
  const noResults = document.getElementById("finance-no-results");

  function applyFilter() {
    if (!tbody) return;
    const q = (search?.value ?? "").toLowerCase().trim();
    const tv = typeFilter?.value ?? "";
    let visible = 0;
    
    for (const row of tbody.querySelectorAll<HTMLTableRowElement>("tr[data-search]")) {
      const show =
        (!q || (row.dataset.search ?? "").toLowerCase().includes(q)) &&
        (!tv || (row.dataset.type ?? "") === tv);
        
      row.style.display = show ? "" : "none";
      if (show) visible++;
    }
    
    if (noResults) noResults.style.display = visible === 0 ? "" : "none";
  }

  search?.addEventListener("input", applyFilter);
  typeFilter?.addEventListener("change", applyFilter);
</script>
