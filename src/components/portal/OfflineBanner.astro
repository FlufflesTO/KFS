---
/**
 * Project Sentinel - Offline Banner Component
 * Purpose: Displays a sticky banner when device is offline with queued items counter
 * Dependencies: None
 * Structural Role: UI indicator for offline status
 * Design: Industrial Command Intelligence - solid brand tokens per DESIGN_CONSTITUTION.md
 */
export interface Props {
  initialQueueCount?: number;
}

const { initialQueueCount = 0 } = Astro.props;
---

<div data-offline-banner data-initial-queue-count={initialQueueCount} class:list={['fixed bottom-4 left-4 right-4 mx-auto z-50 transition-all duration-300 px-4 py-3 rounded-md shadow-md font-semibold text-sm max-w-md w-full border', {
  'bg-kharon-purple/5 text-kharon-black border-kharon-purple/20 translate-y-0 opacity-100': initialQueueCount > 0,
  'opacity-0 translate-y-4 pointer-events-none': initialQueueCount === 0
}]}>
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <svg data-offline-icon="online" class="w-5 h-5 text-kharon-purple" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
      <svg data-offline-icon="offline" class="hidden w-5 h-5 text-kharon-amber" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      </svg>
      <span data-offline-message class="font-semibold">Online - Syncing {initialQueueCount} items</span>
    </div>

    <span data-offline-count class:list={['bg-kharon-purple text-white rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold leading-none', initialQueueCount > 0 ? 'flex' : 'hidden']}>
        {initialQueueCount}
    </span>
  </div>

  <div data-offline-detail class="mt-2 hidden text-xs text-kharon-grey font-medium items-center gap-2">
    <svg class="w-4 h-4 text-kharon-purple/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <span>Your changes are saved locally and will sync when connection is restored</span>
  </div>

  <div data-pwa-install class="mt-2 hidden flex-col gap-2 border-t border-kharon-purple/10 pt-2">
    <p class="text-[10px] text-kharon-purple/70 uppercase font-bold tracking-wider">Portal Update Available</p>
    <button data-install-btn class="w-full bg-kharon-purple text-white py-2 rounded-md text-xs font-bold hover:bg-kharon-purple/90 transition-colors">
      Install Portal App
    </button>
  </div>
  </div>

  <script>
  const bannerEl = document.querySelector('[data-offline-banner]');
  const messageEl = bannerEl?.querySelector('[data-offline-message]');
  const countEl = bannerEl?.querySelector('[data-offline-count]');
  const onlineIcon = bannerEl?.querySelector('[data-offline-icon="online"]');
  const offlineIcon = bannerEl?.querySelector('[data-offline-icon="offline"]');
  const detailEl = bannerEl?.querySelector('[data-offline-detail]');
  const installSection = bannerEl?.querySelector('[data-pwa-install]');
  const installBtn = bannerEl?.querySelector('[data-install-btn]');

  let queueCount = Number(bannerEl?.getAttribute('data-initial-queue-count') || 0);
  let isOffline = !navigator.onLine;
  let deferredPrompt: any = null;

  // PWA Install Logic
  window.addEventListener('beforeinstallprompt', (e) => {
    e.preventDefault();
    deferredPrompt = e;
    if (bannerEl && !isOffline) {
      bannerEl.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
      bannerEl.classList.add('bg-white', 'border-kharon-purple/20', 'translate-y-0', 'opacity-100');
      if (messageEl) messageEl.textContent = 'Enhance Your Workflow';
      installSection?.classList.remove('hidden');
      installSection?.classList.add('flex');
    }
  });

  installBtn?.addEventListener('click', async () => {
    if (!deferredPrompt) return;
    deferredPrompt.prompt();
    const { outcome } = await deferredPrompt.userChoice;
    if (outcome === 'accepted') {
      installSection?.classList.add('hidden');
    }
    deferredPrompt = null;
  });

  // Function to update banner visibility
  function updateBanner() {
    if (!bannerEl) return;
    bannerEl.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none', 'bg-kharon-amber/5', 'text-kharon-black', 'border-kharon-amber/20', 'bg-kharon-purple/5', 'text-kharon-black', 'border-kharon-purple/20', 'bg-white');
    countEl?.classList.toggle('hidden', queueCount === 0);
    countEl?.classList.toggle('flex', queueCount > 0);
    if (countEl) countEl.textContent = String(queueCount);

    if (isOffline) {
      installSection?.classList.add('hidden');
      bannerEl.classList.add('bg-kharon-amber/5', 'text-kharon-black', 'border-kharon-amber/20', 'translate-y-0', 'opacity-100');
      if (messageEl) messageEl.textContent = 'Offline Mode - Data queued for sync';
      onlineIcon?.classList.add('hidden');
      offlineIcon?.classList.remove('hidden');
      detailEl?.classList.remove('hidden');
      detailEl?.classList.add('flex');
    } else if (queueCount > 0) {
      installSection?.classList.add('hidden');
      bannerEl.classList.add('bg-kharon-purple/5', 'text-kharon-black', 'border-kharon-purple/20', 'translate-y-0', 'opacity-100');
      if (messageEl) messageEl.textContent = `Online - Syncing ${queueCount} items`;
      onlineIcon?.classList.remove('hidden');
      offlineIcon?.classList.add('hidden');
      detailEl?.classList.add('hidden');
      detailEl?.classList.remove('flex');
    } else if (deferredPrompt) {
      bannerEl.classList.add('bg-white', 'border-kharon-purple/20', 'translate-y-0', 'opacity-100');
      if (messageEl) messageEl.textContent = 'Enhance Your Workflow';
      installSection?.classList.remove('hidden');
      installSection?.classList.add('flex');
    } else {
      bannerEl.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
    }
  }
  
  // Listen for online/offline events
  window.addEventListener('online', () => {
    isOffline = false;
    updateBanner();
  });
  
  window.addEventListener('offline', () => {
    isOffline = true;
    updateBanner();
  });
  
  // Listen for custom service worker messages about queue status
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.addEventListener('message', (event) => {
      if (event.data && event.data.type === 'REQUEST_QUEUED') {
        queueCount = event.data.queueCount || 0;
        updateBanner();
      } else if (event.data && event.data.type === 'QUEUE_COUNT') {
        queueCount = event.data.count || 0;
        updateBanner();
      } else if (event.data && event.data.type === 'OFFLINE_SYNC_COMPLETE') {
        queueCount = event.data.remaining || 0;
        isOffline = false; // Assume we're online when sync completes
        updateBanner();
      }
    });
  }
  
  // Request initial queue count
  if ('serviceWorker' in navigator && navigator.serviceWorker.controller) {
    navigator.serviceWorker.controller.postMessage({ type: 'GET_QUEUE_COUNT' });
  }

  updateBanner();
</script>
