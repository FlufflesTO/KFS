---
import type { DbDefect, DbSystem } from "@sentinel/types";

interface Props {
  defects: DbDefect[];
  systems: DbSystem[];
}

const { defects, systems } = Astro.props;
---

<div id="ops-panel-defects" class="ops-panel mx-auto grid max-w-7xl gap-6 lg:gap-10">
  <article class="border border-kharon-border bg-white p-4 sm:p-5">
    <div class="sticky top-0 z-10 mb-4 flex flex-wrap items-center justify-between gap-3 bg-white">
      <h2 class="text-xl font-bold">
        Defects <span class="ml-2 text-sm font-normal text-kharon-grey">({defects.length})</span>
      </h2>
      <div class="flex flex-wrap gap-3">
        <input
          id="defects-search"
          type="search"
          class="rounded-md border border-kharon-border px-3 py-2 text-sm"
          placeholder="Search site, area, clause…"
          size="24"
        />
        <select id="defects-severity-filter" class="rounded-md border border-kharon-border px-3 py-2 text-sm">
          <option value="">All severities</option>
          <option value="Critical">Critical</option>
          <option value="Major">Major</option>
          <option value="Minor">Minor</option>
          <option value="Observation">Observation</option>
        </select>
        <select id="defects-status-filter" class="rounded-md border border-kharon-border px-3 py-2 text-sm">
          <option value="">All statuses</option>
          <option value="Open">Open</option>
          <option value="In Progress">In Progress</option>
          <option value="Resolved">Resolved</option>
          <option value="Closed">Closed</option>
        </select>
      </div>
    </div>

    <div id="defects-list" class="grid gap-4">
      {defects.map((item) => (
        <form
          class="admin-form grid gap-3 border border-kharon-border bg-kharon-light p-4 lg:grid-cols-7"
          data-endpoint="/portal/api/admin/defects"
          data-search={`${item.owner_company_name} ${item.coverage_area || ""} ${item.sans_clause_ref || ""} ${item.description || ""}`}
          data-severity={item.severity}
          data-status={item.status}
        >
          <input type="hidden" name="action" value="update" />
          <input type="hidden" name="id" value={item.id} />
          <select class="rounded-md border border-kharon-border px-3 py-2" name="severity">
            {(["Critical", "Major", "Minor", "Observation"] as const).map((s) => (
              <option value={s} selected={item.severity === s}>{s}</option>
            ))}
          </select>
          <input
            class="rounded-md border border-kharon-border px-3 py-2"
            name="sansClauseRef"
            list="sans-clauses"
            value={item.sans_clause_ref || ""}
            placeholder="SANS clause"
          />
          <select class="rounded-md border border-kharon-border px-3 py-2" name="status">
            {(["Open", "In Progress", "Resolved", "Closed"] as const).map((s) => (
              <option value={s} selected={item.status === s}>{s}</option>
            ))}
          </select>
          <label class="grid gap-1 text-sm">
            <span class="text-xs text-kharon-grey">Blocking</span>
            <select name="certificateBlocking">
              <option value="1" selected={Boolean(item.certificate_blocking)}>Yes</option>
              <option value="0" selected={!Boolean(item.certificate_blocking)}>No</option>
            </select>
          </label>
          <div class="lg:col-span-2">
            <textarea class="min-h-16 w-full rounded-md border border-kharon-border px-3 py-2 text-sm" name="description">{item.description}</textarea>
          </div>
          <div class="flex items-center gap-2 text-xs">
            <span class={`rounded px-2 py-1 font-bold ${
              item.severity === "Critical" ? "bg-kharon-red text-white" :
              item.severity === "Major"    ? "bg-amber-200 text-amber-800" :
              item.severity === "Minor"    ? "bg-blue-100 text-blue-800" :
                                            "bg-kharon-grey/10 text-kharon-grey"
            }`}>{item.severity}</span>
            {item.certificate_blocking ? (
              <span class="rounded border border-amber-300 bg-amber-50 px-2 py-1 font-bold text-amber-700">Blocks cert</span>
            ) : null}
          </div>
          <div class="flex flex-wrap gap-2">
            <button class="rounded-md bg-kharon-blue px-4 py-2 font-semibold text-white">Save</button>
            {item.status !== "Resolved" && (
              <button type="button" class="resolve-defect rounded-md border border-emerald-600 px-4 py-2 text-sm font-semibold text-emerald-700" data-id={item.id}>Resolve</button>
            )}
            {item.status !== "Closed" && (
              <button type="button" class="close-defect rounded-md border border-kharon-grey px-4 py-2 text-sm font-semibold text-kharon-grey" data-id={item.id}>Close</button>
            )}
            {(["Open", "In Progress"] as const).includes(item.status as "Open" | "In Progress") && (
              <button type="button" class="quote-defect rounded-md border border-amber-500 px-4 py-2 text-sm font-semibold text-amber-700" data-id={item.id}>Quote Required</button>
            )}
          </div>
          <p class="admin-result hidden rounded-md border px-4 py-3 text-sm font-semibold lg:col-span-7"></p>
        </form>
      ))}
    </div>
    <p id="defects-no-results" class="hidden py-4 text-sm text-kharon-grey">No defects match your filter.</p>
  </article>

  <article class="border border-kharon-border bg-white p-4 sm:p-5">
    <h2 class="text-xl font-bold">Create defect</h2>
    <form class="admin-form mt-5 grid gap-3" data-endpoint="/portal/api/admin/defects">
      <input type="hidden" name="action" value="create" />
      <select class="rounded-md border border-kharon-border px-4 py-3" name="systemId" required>
        <option value="">Select system</option>
        {systems.map((s) => (
          <option value={s.id}>{s.owner_company_name} / {s.coverage_area}</option>
        ))}
      </select>
      <input class="rounded-md border border-kharon-border px-4 py-3" name="jobId" placeholder="Job ID (optional)" />
      <div class="grid gap-3 sm:grid-cols-3">
        <select class="rounded-md border border-kharon-border px-4 py-3" name="severity" required>
          <option value="Critical">Critical</option>
          <option value="Major">Major</option>
          <option value="Minor" selected>Minor</option>
          <option value="Observation">Observation</option>
        </select>
        <input class="rounded-md border border-kharon-border px-4 py-3" name="sansClauseRef" list="sans-clauses" placeholder="SANS clause (e.g. SANS 10139-8.3)" />
        <label class="flex items-center gap-3 rounded-md border border-kharon-border px-4 py-3">
          <input type="checkbox" name="certificateBlocking" value="1" />
          <span class="text-sm font-semibold">Certificate blocking</span>
        </label>
      </div>
      <textarea class="min-h-20 rounded-md border border-kharon-border px-4 py-3" name="description" placeholder="Defect description (5–2000 characters)" required></textarea>
      <button class="rounded-md bg-kharon-red px-5 py-3 font-semibold text-white">Create defect</button>
      <p class="admin-result hidden rounded-md border px-4 py-3 text-sm font-semibold"></p>
    </form>
  </article>
</div>
