---
/**
 * Trust Bar Component
 * Purpose: Displays trust signals and certifications
 * Dependencies: None
 * Structural Role: Credibility and trust indicator
 */
export interface Props {
  signals: Array<{
    icon: string;
    label: string;
    value: string;
  }>;
}

const { signals } = Astro.props;
---

<section class="py-8 bg-gray-50 border-t border-b border-gray-200">
  <div class="container mx-auto px-4">
    <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12">
      {signals.map((signal) => (
        <div class="flex items-center space-x-3" key={signal.label}>
          <div class="flex-shrink-0" aria-hidden="true">
            {signal.icon}
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-900">{signal.value}</p>
            <p class="text-xs text-gray-600">{signal.label}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>