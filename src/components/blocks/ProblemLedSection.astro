---
/**
 * Project Sentinel - Problem Led Section
 * Purpose: Addresses pain points (Failed inspections, false alarms, downtime)
 * Dependencies: KharonButton
 * Structural Role: Reusable block
 */

import KharonButton from '../ui/KharonButton.astro';

export interface Problem {
  title: string;
  description: string;
}

export interface Props {
  headline: string;
  problems: Problem[];
  ctaText?: string;
  ctaLink?: string;
}

const { headline, problems, ctaText = "Get a Risk Assessment", ctaLink = "/contact" } = Astro.props;
---

<section class="py-16 lg:py-24 bg-kharon-black">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl leading-tight mb-6">
          {headline}
        </h2>
        <div class="space-y-8">
          {problems.map((problem) => (
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-kharon-red/20 flex items-center justify-center text-kharon-red mt-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"></path>
                  <line x1="12" y1="9" x2="12" y2="13"></line>
                  <line x1="12" y1="17" x2="12.01" y2="17"></line>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-white mb-2">{problem.title}</h3>
                <p class="text-kharon-light/80 leading-relaxed">{problem.description}</p>
              </div>
            </div>
          ))}
        </div>
        
        {ctaText && ctaLink && (
          <div class="mt-10">
            <KharonButton href={ctaLink} variant="danger" size="lg" className="min-h-[44px] min-w-[44px]">
              {ctaText}
            </KharonButton>
          </div>
        )}
      </div>
      
      <div class="relative hidden lg:block">
        <div class="absolute inset-0 bg-gradient-to-r from-kharon-red/20 to-transparent blur-3xl rounded-full"></div>
        {/* Placeholder for an image or illustration */}
        <div class="relative bg-kharon-surface-elevated border border-kharon-red/20 rounded-xl aspect-square flex items-center justify-center overflow-hidden">
           <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-kharon-red/20">
             <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path>
           </svg>
        </div>
      </div>
    </div>
  </div>
</section>
