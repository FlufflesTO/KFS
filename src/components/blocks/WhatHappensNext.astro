---
/**
 * Project Sentinel - What Happens Next
 * Purpose: Standard post-form expectation block
 * Dependencies: None
 * Structural Role: Reusable block
 */

export interface Step {
  title: string;
  description: string;
}

export interface Props {
  title?: string;
  steps?: Step[];
}

const defaultSteps = [
  { title: "We receive your request", description: "Our technical team reviews your submission immediately." },
  { title: "Rapid Contact", description: "We'll call you within 2 hours during business hours." },
  { title: "Site Assessment", description: "We schedule a comprehensive survey if required." }
];

const { title = "What happens next?", steps = defaultSteps } = Astro.props;
---

<div class="bg-kharon-surface-elevated border border-kharon-purple/20 p-6 sm:p-8 rounded-lg mt-8">
  <h3 class="text-lg font-bold text-white mb-6 flex items-center gap-3">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-kharon-purple">
      <circle cx="12" cy="12" r="10"></circle>
      <polyline points="12 6 12 12 16 14"></polyline>
    </svg>
    {title}
  </h3>
  <div class="space-y-6 relative before:absolute before:inset-0 before:ml-3.5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-kharon-purple/30 before:to-transparent">
    {steps.map((step, i) => (
      <div class="relative flex items-start gap-6">
        <div class="flex items-center justify-center w-8 h-8 rounded-full bg-kharon-surface-charcoal border-2 border-kharon-purple text-white font-bold text-sm z-10 shrink-0">
          {i + 1}
        </div>
        <div>
          <h4 class="text-white font-semibold mb-1">{step.title}</h4>
          <p class="text-sm text-kharon-light/70">{step.description}</p>
        </div>
      </div>
    ))}
  </div>
</div>
