---
/**
 * Project Sentinel - Case Study Preview Grid
 * Purpose: Mock or real case study cards
 * Dependencies: KharonCard
 * Structural Role: Reusable block
 */

import KharonCard from '../ui/KharonCard.astro';

export interface CaseStudy {
  id: string;
  title: string;
  client: string;
  summary: string;
  href: string;
  image?: string;
  tags?: string[];
}

export interface Props {
  title: string;
  studies: CaseStudy[];
}

const { title, studies } = Astro.props;
---

<section class="py-16 bg-kharon-surface-elevated">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-end mb-10">
      <h2 class="text-3xl font-extrabold text-white">{title}</h2>
      <a href="/case-studies" class="hidden sm:flex items-center text-kharon-purple hover:text-white font-semibold transition-colors min-h-[44px]">
        View All Work
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {studies.map((study) => (
        <KharonCard border={false} className="bg-kharon-surface-charcoal overflow-hidden p-0 group">
          <div class="flex flex-col h-full">
            <div class="relative h-48 sm:h-64 overflow-hidden bg-kharon-black">
              {study.image ? (
                <img src={study.image} alt="" class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500" />
              ) : (
                <div class="w-full h-full bg-gradient-to-br from-kharon-purple/20 to-kharon-blue/20"></div>
              )}
              {study.tags && study.tags.length > 0 && (
                <div class="absolute top-4 left-4 flex gap-2 flex-wrap">
                  {study.tags.map(tag => (
                    <span class="bg-kharon-black/80 backdrop-blur-sm text-xs font-semibold text-white px-3 py-1 uppercase tracking-wider rounded">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
            <div class="p-6 lg:p-8 flex-grow flex flex-col">
              <span class="text-sm text-kharon-purple font-semibold uppercase tracking-widest mb-2">{study.client}</span>
              <h3 class="text-2xl font-bold text-white mb-4"><a href={study.href} class="hover:underline focus:outline-none focus:ring-2 focus:ring-kharon-purple rounded">{study.title}</a></h3>
              <p class="text-kharon-light/80 leading-relaxed mb-6 flex-grow">{study.summary}</p>
              <a href={study.href} class="inline-flex items-center text-white font-bold uppercase tracking-widest text-sm hover:text-kharon-purple transition-colors min-h-[44px]">
                Read Case Study
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            </div>
          </div>
        </KharonCard>
      ))}
    </div>
    
    <div class="mt-8 sm:hidden">
      <a href="/case-studies" class="flex justify-center items-center text-white bg-kharon-surface-glass border border-kharon-purple/30 py-3 rounded hover:bg-kharon-purple/10 font-bold uppercase tracking-widest text-sm min-h-[44px]">
        View All Work
      </a>
    </div>
  </div>
</section>
