---
/**
 * Project Sentinel - Service Card Grid
 * Purpose: Service routing cards by group
 * Dependencies: KharonCard
 * Structural Role: Reusable block
 */

import KharonCard from '../ui/KharonCard.astro';

export interface ServiceItem {
  id: string;
  title: string;
  description: string;
  href: string;
  iconSvg?: string;
}

export interface Props {
  title: string;
  services: ServiceItem[];
}

const { title, services } = Astro.props;
---

<section class="py-16 bg-kharon-surface-charcoal">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl sm:text-3xl font-extrabold text-white mb-10 text-center">{title}</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <a href={service.href} class="group block h-full focus:outline-none focus:ring-2 focus:ring-kharon-purple rounded-lg">
          <KharonCard variant="default" className="h-full group-hover:border-kharon-purple/60 transition-all duration-300 group-hover:-translate-y-1 group-hover:shadow-lg group-hover:shadow-kharon-purple/20 cursor-pointer">
            <div class="w-12 h-12 bg-kharon-surface-glass rounded flex items-center justify-center text-kharon-purple mb-5 group-hover:bg-kharon-purple group-hover:text-white transition-colors">
              {service.iconSvg ? (
                 <Fragment set:html={service.iconSvg} />
              ) : (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>
                </svg>
              )}
            </div>
            <h3 class="text-xl font-bold text-white mb-2 group-hover:text-kharon-purple transition-colors">{service.title}</h3>
            <p class="text-kharon-light/70 text-sm leading-relaxed mb-4">{service.description}</p>
            <div class="mt-auto flex items-center text-kharon-purple font-semibold text-sm uppercase tracking-wider">
              <span>Explore Service</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2 group-hover:translate-x-1 transition-transform">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </div>
          </KharonCard>
        </a>
      ))}
    </div>
  </div>
</section>
