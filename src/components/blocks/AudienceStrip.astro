---
/**
 * Project Sentinel - Audience Strip
 * Purpose: Displays a strip of supported environments (data centres, etc.)
 * Dependencies: None
 * Structural Role: Reusable block
 */

export interface AudienceItem {
  id: string;
  name: string;
  iconSvg?: string; // Expecting raw SVG string
}

export interface Props {
  items: AudienceItem[];
  title?: string;
}

const { items, title = "Trusted in critical environments" } = Astro.props;
---

<section class="py-12 bg-kharon-surface-elevated border-y border-kharon-purple/20">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-sm font-semibold tracking-widest uppercase text-kharon-purple/70 text-center mb-8">
      {title}
    </h2>
    <div class="flex flex-wrap justify-center items-center gap-6 md:gap-12 lg:gap-16">
      {items.map((item) => (
        <div class="flex items-center gap-3 text-kharon-light/80 hover:text-white transition-colors">
          {item.iconSvg ? (
             <Fragment set:html={item.iconSvg} />
          ) : (
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-kharon-purple">
              <path d="M4 22h14a2 2 0 0 0 2-2V7l-5-5H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2Z"></path>
              <path d="M14 2v4a2 2 0 0 0 2 2h4"></path>
            </svg>
          )}
          <span class="font-medium text-sm sm:text-base">{item.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
