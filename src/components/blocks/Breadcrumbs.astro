---
/**
 * Project Sentinel - Breadcrumbs
 * Purpose: SEO and UX navigation
 * Dependencies: None
 * Structural Role: Reusable component
 */

export interface Breadcrumb {
  label: string;
  href?: string;
}

export interface Props {
  crumbs: Breadcrumb[];
}

const { crumbs } = Astro.props;
---

<nav aria-label="Breadcrumb" class="py-4 overflow-x-auto">
  <ol class="flex items-center space-x-2 sm:space-x-4 min-w-max px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
    <li>
      <a href="/" class="text-kharon-light/60 hover:text-white transition-colors focus:outline-none focus:ring-2 focus:ring-kharon-purple rounded min-h-[44px] flex items-center justify-center p-1">
        <span class="sr-only">Home</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
          <polyline points="9 22 9 12 15 12 15 22"></polyline>
        </svg>
      </a>
    </li>
    {crumbs.map((crumb, index) => (
      <li class="flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-kharon-purple/50 mr-2 sm:mr-4">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
        {crumb.href && index !== crumbs.length - 1 ? (
          <a href={crumb.href} class="text-sm font-medium text-kharon-light/60 hover:text-white transition-colors focus:outline-none focus:ring-2 focus:ring-kharon-purple rounded min-h-[44px] flex items-center px-1">
            {crumb.label}
          </a>
        ) : (
          <span class="text-sm font-bold text-white min-h-[44px] flex items-center px-1" aria-current="page">
            {crumb.label}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>
