---
/**
 * Project Sentinel - Mobile Table Cards
 * Purpose: Mobile fallback for technical tables
 * Dependencies: KharonCard
 * Structural Role: Reusable block
 */

import KharonCard from '../ui/KharonCard.astro';

export interface TableRow {
  id: string;
  [key: string]: any; // Allow arbitrary column names
}

export interface Props {
  headers: { key: string; label: string }[];
  data: TableRow[];
  title?: string;
}

const { headers, data, title } = Astro.props;
---

<div class="w-full">
  {title && <h3 class="text-xl font-bold text-white mb-6">{title}</h3>}
  
  {/* Desktop Table view (hidden on mobile) */}
  <div class="hidden md:block overflow-x-auto rounded-lg border border-kharon-purple/20">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-kharon-surface-glass border-b border-kharon-purple/20">
          {headers.map(header => (
            <th class="py-4 px-6 text-xs font-bold uppercase tracking-wider text-kharon-purple">{header.label}</th>
          ))}
        </tr>
      </thead>
      <tbody class="divide-y divide-kharon-purple/10 bg-kharon-surface-elevated">
        {data.map(row => (
          <tr class="hover:bg-kharon-surface-charcoal transition-colors">
            {headers.map(header => (
              <td class="py-4 px-6 text-sm text-kharon-light/90">{row[header.key]}</td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  {/* Mobile Cards view (hidden on desktop) */}
  <div class="md:hidden space-y-4">
    {data.map(row => (
      <KharonCard variant="default" padding="sm" className="border-kharon-purple/20">
        <dl class="space-y-3">
          {headers.map(header => (
            <div class="flex flex-col sm:flex-row sm:justify-between gap-1">
              <dt class="text-xs font-bold uppercase tracking-wider text-kharon-purple">{header.label}</dt>
              <dd class="text-sm text-white font-medium">{row[header.key]}</dd>
            </div>
          ))}
        </dl>
      </KharonCard>
    ))}
  </div>
</div>
