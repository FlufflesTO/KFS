---
/**
 * Project Sentinel - What We Do Grid
 * Purpose: Features our core offerings (Design, Installation, Inspection, Maintenance)
 * Dependencies: KharonCard
 * Structural Role: Reusable block
 */

import KharonCard from '../ui/KharonCard.astro';

export interface ServicePhase {
  id: string;
  title: string;
  description: string;
  iconSvg?: string;
}

export interface Props {
  title: string;
  subtitle?: string;
  phases: ServicePhase[];
}

const { title, subtitle, phases } = Astro.props;
---

<section class="py-16 lg:py-24 bg-kharon-surface-charcoal">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center mb-16">
      {subtitle && <span class="text-sm font-semibold tracking-widest uppercase text-kharon-purple">{subtitle}</span>}
      <h2 class="mt-2 text-3xl font-extrabold text-white sm:text-4xl">{title}</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {phases.map((phase, index) => (
        <KharonCard variant="default" className="flex flex-col h-full hover:border-kharon-purple/50 transition-colors">
          <div class="mb-6 flex justify-between items-start">
            <div class="w-12 h-12 bg-kharon-purple/10 rounded-lg flex items-center justify-center text-kharon-purple">
              {phase.iconSvg ? (
                 <Fragment set:html={phase.iconSvg} />
              ) : (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                  <line x1="8" y1="21" x2="16" y2="21"></line>
                  <line x1="12" y1="17" x2="12" y2="21"></line>
                </svg>
              )}
            </div>
            <span class="text-5xl font-black text-kharon-surface-glass select-none">
              0{index + 1}
            </span>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">{phase.title}</h3>
          <p class="text-kharon-light/80 leading-relaxed flex-grow">
            {phase.description}
          </p>
        </KharonCard>
      ))}
    </div>
  </div>
</section>
