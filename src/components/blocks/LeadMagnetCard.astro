---
import type { LeadMagnet } from "../../data/leadMagnets.js";

export interface Props {
  magnet: LeadMagnet;
}

const { magnet } = Astro.props;
const isComingSoon = magnet.status === "coming-soon";
const trackingEvent = magnet.trackingEvent ?? "lead_magnet_download";
---
<div class="rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/30 p-6 flex flex-col sm:flex-row items-center justify-between gap-6">
  <div>
    <div class="flex items-center gap-3">
      <h3 class="text-lg font-bold text-white">{magnet.title}</h3>
      {isComingSoon && (
        <span class="rounded-full border border-kharon-amber/40 bg-kharon-amber/10 px-2.5 py-0.5 text-[0.65rem] font-black uppercase tracking-widest text-kharon-amber">
          Preview
        </span>
      )}
    </div>
    <p class="mt-2 text-base text-kharon-light/70">{magnet.description}</p>
  </div>
  {isComingSoon ? (
    <span
      class="inline-flex min-h-[44px] cursor-not-allowed items-center whitespace-nowrap rounded-lg border border-kharon-purple/20 bg-kharon-black/40 px-6 py-3 text-base font-bold text-kharon-light/40"
      aria-disabled="true"
    >
      Preview
    </span>
  ) : (
    <a
      href={magnet.href}
      data-analytics={trackingEvent}
      data-lead-magnet={magnet.id}
      class="kharon-command-button whitespace-nowrap px-6 py-3 text-base"
    >
      {magnet.buttonText}
    </a>
  )}
</div>
