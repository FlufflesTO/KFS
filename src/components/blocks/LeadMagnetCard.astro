---
/**
 * Project Sentinel - Lead Magnet Card
 * Purpose: Checklist/download CTA
 * Dependencies: KharonButton, KharonCard
 * Structural Role: Reusable block
 */

import KharonButton from '../ui/KharonButton.astro';
import KharonCard from '../ui/KharonCard.astro';

export interface Props {
  title: string;
  description: string;
  buttonText: string;
  fileUrl: string;
  image?: string;
}

const { title, description, buttonText, fileUrl, image } = Astro.props;
---

<KharonCard variant="primary" className="overflow-hidden p-0 relative">
  <div class="absolute inset-0 bg-gradient-to-br from-kharon-purple/10 to-transparent"></div>
  <div class="flex flex-col md:flex-row relative z-10">
    {image && (
      <div class="w-full md:w-1/3 bg-kharon-black">
        <img src={image} alt="Download resource" class="w-full h-full object-cover opacity-80" />
      </div>
    )}
    <div class={`p-8 ${image ? 'md:w-2/3' : 'w-full'}`}>
      <div class="flex items-center gap-3 mb-4 text-kharon-purple">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        <span class="text-xs font-bold uppercase tracking-widest">Free Download</span>
      </div>
      <h3 class="text-2xl font-bold text-white mb-3">{title}</h3>
      <p class="text-kharon-light/80 mb-6 leading-relaxed max-w-2xl">{description}</p>
      <KharonButton href={fileUrl} variant="primary" className="min-h-[44px]">
        {buttonText}
      </KharonButton>
    </div>
  </div>
</KharonCard>
