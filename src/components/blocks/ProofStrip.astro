---
/**
 * Project Sentinel - Proof Strip
 * Purpose: Shows alignment with SAQCC, SANS, etc.
 * Dependencies: None
 * Structural Role: Reusable block
 */

export interface ProofItem {
  label: string;
  description?: string;
  iconSvg?: string; 
}

export interface Props {
  proofs: ProofItem[];
}

const { proofs } = Astro.props;
---

<div class="bg-kharon-black py-8 border-t border-kharon-purple/10">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center divide-y md:divide-y-0 md:divide-x divide-kharon-purple/20">
      {proofs.map((proof) => (
        <div class="py-4 md:py-0 px-6 flex flex-col items-center justify-center">
          <div class="w-12 h-12 rounded-full bg-kharon-surface-glass flex items-center justify-center mb-3 text-kharon-purple">
            {proof.iconSvg ? (
               <Fragment set:html={proof.iconSvg} />
            ) : (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            )}
          </div>
          <h3 class="text-white font-bold text-lg">{proof.label}</h3>
          {proof.description && <p class="text-sm text-kharon-light/70 mt-1">{proof.description}</p>}
        </div>
      ))}
    </div>
  </div>
</div>
