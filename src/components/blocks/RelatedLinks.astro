---
/**
 * Project Sentinel - Related Links
 * Purpose: Related services/resources/sectors for internal linking
 * Dependencies: None
 * Structural Role: Reusable block
 */

export interface LinkItem {
  label: string;
  href: string;
}

export interface Props {
  title?: string;
  links: LinkItem[];
}

const { title = "Explore Related", links } = Astro.props;
---

<div class="bg-kharon-surface-elevated rounded-lg p-6 lg:p-8 border border-kharon-purple/10">
  <h3 class="text-sm font-bold uppercase tracking-widest text-kharon-purple mb-6">{title}</h3>
  <ul class="space-y-4">
    {links.map((link) => (
      <li>
        <a href={link.href} class="group flex items-center text-white/90 hover:text-white transition-colors focus:outline-none focus:ring-2 focus:ring-kharon-purple rounded p-1 -m-1 min-h-[44px]">
          <span class="w-6 h-6 rounded bg-kharon-surface-glass flex items-center justify-center mr-3 group-hover:bg-kharon-purple/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-kharon-purple">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </span>
          <span class="font-medium group-hover:underline decoration-kharon-purple/50 underline-offset-4">{link.label}</span>
        </a>
      </li>
    ))}
  </ul>
</div>
