---
/**
 * Project Sentinel - Sticky Emergency CTA
 * Purpose: Fixed mobile emergency call button
 * Dependencies: None
 * Structural Role: Reusable block
 */

export interface Props {
  phoneNumber: string;
  ctaText?: string;
}

const { phoneNumber, ctaText = "24/7 EMERGENCY CALL" } = Astro.props;
const telLink = `tel:${phoneNumber.replace(/\s+/g, '')}`;
---

<div class="fixed bottom-0 left-0 right-0 z-50 md:hidden bg-kharon-black border-t border-kharon-red/30 p-4 pb-safe backdrop-blur-md bg-opacity-90">
  <a href={telLink} class="flex items-center justify-center w-full bg-gradient-to-r from-kharon-red to-kharon-red/80 text-white font-bold uppercase tracking-widest py-3 px-4 rounded-lg shadow-lg shadow-kharon-red/20 min-h-[44px] active:scale-[0.98] transition-transform">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-3">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
    </svg>
    {ctaText}
  </a>
</div>

<style>
  /* Safe area padding for modern mobile browsers (iOS) */
  .pb-safe {
    padding-bottom: max(1rem, env(safe-area-inset-bottom));
  }
</style>
