---
/**
 * Project Sentinel - FAQ Accordion
 * Purpose: FAQPage-ready structure
 * Dependencies: None
 * Structural Role: Reusable block
 */

export interface FAQ {
  question: string;
  answer: string;
}

export interface Props {
  title?: string;
  faqs: FAQ[];
}

const { title = "Frequently Asked Questions", faqs } = Astro.props;
// Note: Interactivity requires client-side JS or details/summary. Using details/summary for zero-JS.
---

<section class="py-16 lg:py-24 bg-kharon-surface-charcoal">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
    <h2 class="text-3xl font-extrabold text-white mb-10 text-center">{title}</h2>
    
    <div class="space-y-4" itemscope itemtype="https://schema.org/FAQPage">
      {faqs.map((faq) => (
        <details class="group bg-kharon-surface-elevated border border-kharon-purple/20 rounded-lg overflow-hidden [&_summary::-webkit-details-marker]:hidden" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
          <summary class="flex justify-between items-center font-bold cursor-pointer p-6 text-white min-h-[44px] focus:outline-none focus:bg-kharon-surface-glass transition-colors">
            <span itemprop="name">{faq.question}</span>
            <span class="transition-transform duration-300 group-open:-rotate-180 text-kharon-purple ml-4 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </span>
          </summary>
          <div class="p-6 pt-0 text-kharon-light/80 leading-relaxed border-t border-kharon-purple/10 mt-2" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
            <p itemprop="text">{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
