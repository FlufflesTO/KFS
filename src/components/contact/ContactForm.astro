---
/**
 * Contact Form Component
 * Purpose: Provides contact form with honeypot anti-spam protection
 * Dependencies: None
 * Structural Role: Contact submission form
 */
export interface Props {
  variant?: 'standard' | 'inquiry';
}

const { variant = 'standard' } = Astro.props;
---

<form 
  id="contact-form" 
  class="space-y-6" 
  method="POST" 
  action="/api/contact"
  x-data="{ submitted: false, submitting: false }"
  x-show="!submitted"
  x-transition
>
  <input 
    type="text" 
    name="website" 
    autocomplete="off"
    style="display: none !important; position: absolute !important; left: -9999px !important;"
    tabindex="-1"
    aria-hidden="true"
  />
  
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Full Name *</label>
      <input 
        type="text" 
        id="name" 
        name="name" 
        required 
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-kharon-blue focus:border-kharon-blue transition"
        placeholder="Enter your full name"
      />
    </div>
    
    <div>
      <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address *</label>
      <input 
        type="email" 
        id="email" 
        name="email" 
        required 
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-kharon-blue focus:border-kharon-blue transition"
        placeholder="your.email@example.com"
      />
    </div>
  </div>
  
  <div>
    <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
    <input 
      type="tel" 
      id="phone" 
      name="phone" 
      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-kharon-blue focus:border-kharon-blue transition"
      placeholder="+27 11 000 0000"
    />
  </div>
  
  <div>
    <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">Subject *</label>
    <input 
      type="text" 
      id="subject" 
      name="subject" 
      required 
      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-kharon-blue focus:border-kharon-blue transition"
      placeholder="How can we help you?"
    />
  </div>
  
  <div>
    <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message *</label>
    <textarea 
      id="message" 
      name="message" 
      rows="5" 
      required 
      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-kharon-blue focus:border-kharon-blue transition"
      placeholder="Please provide details about your inquiry..."
    ></textarea>
  </div>
  
  <div class="flex items-start">
    <div class="flex items-center h-5">
      <input 
        id="consent" 
        name="consent" 
        type="checkbox" 
        required 
        class="focus:ring-kharon-blue h-4 w-4 text-kharon-blue border-gray-300 rounded"
      />
    </div>
    <div class="ml-3 text-sm">
      <label for="consent" class="font-medium text-gray-700">
        I consent to the collection and processing of my data in accordance with POPIA so Kharon can respond to my inquiry. *
      </label>
    </div>
  </div>
  
  <div class="pt-4">
    <button 
      type="submit"
      :disabled="submitting"
      class="w-full bg-kharon-blue hover:bg-kharon-purple text-white font-bold py-3 px-6 rounded-lg transition duration-300 disabled:opacity-50 disabled:cursor-not-allowed"
      x-bind:class="{ 'opacity-75': submitting }"
    >
      <span x-show="!submitting" x-cloak>Send Message</span>
      <span x-show="submitting" x-cloak>Sending...</span>
    </button>
  </div>
</form>

<div 
  id="success-message" 
  class="hidden text-center py-12"
  x-show="submitted"
  x-transition
>
  <div class="max-w-md mx-auto">
    <svg class="mx-auto h-16 w-16 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
    </svg>
    <h3 class="mt-4 text-2xl font-bold text-gray-900">Thank You!</h3>
    <p class="mt-2 text-gray-600">Your message has been sent successfully. We'll get back to you within 24 hours.</p>
    <button 
      type="button"
      data-reset-contact-form
      class="mt-6 bg-kharon-blue hover:bg-kharon-purple text-white font-bold py-2 px-6 rounded-lg transition"
    >
      Send Another Message
    </button>
  </div>
</div>

<script>
  document.querySelector("[data-reset-contact-form]")?.addEventListener("click", () => {
    document.getElementById("contact-form")?.classList.remove("hidden");
    document.getElementById("success-message")?.classList.add("hidden");
  });
</script>
