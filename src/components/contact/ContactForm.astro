---
/**
 * Contact Form Component
 * Purpose: Provides contact form with honeypot anti-spam protection and POPIA compliance
 * Dependencies: DESIGN_CONSTITUTION
 * Structural Role: Contact submission form styled with Kharon Design tokens
 */
---

<form 
  id="contact-form" 
  class="space-y-6" 
  method="POST" 
  action="/api/contact"
  x-data="{ submitted: false, submitting: false }"
  x-show="!submitted"
  x-transition
>
  <input 
    type="text" 
    name="website" 
    autocomplete="off"
    style="display: none !important; position: absolute !important; left: -9999px !important;"
    tabindex="-1"
    aria-hidden="true"
  />
  
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div class="grid gap-1.5">
      <label for="name" class="block text-xs font-bold uppercase tracking-widest text-kharon-purple">Full Name *</label>
      <input 
        type="text" 
        id="name" 
        name="name" 
        required 
        class="kharon-field"
        placeholder="Enter your full name"
      />
    </div>
    
    <div class="grid gap-1.5">
      <label for="email" class="block text-xs font-bold uppercase tracking-widest text-kharon-purple">Email Address *</label>
      <input 
        type="email" 
        id="email" 
        name="email" 
        required 
        class="kharon-field"
        placeholder="your.email@example.com"
      />
    </div>
  </div>
  
  <div class="grid gap-1.5">
    <label for="phone" class="block text-xs font-bold uppercase tracking-widest text-kharon-purple">Phone Number</label>
    <input 
      type="tel" 
      id="phone" 
      name="phone" 
      class="kharon-field"
      placeholder="+27 11 000 0000"
    />
  </div>
  
  <div class="grid gap-1.5">
    <label for="subject" class="block text-xs font-bold uppercase tracking-widest text-kharon-purple">Subject *</label>
    <input 
      type="text" 
      id="subject" 
      name="subject" 
      required 
      class="kharon-field"
      placeholder="How can we help you?"
    />
  </div>
  
  <div class="grid gap-1.5">
    <label for="message" class="block text-xs font-bold uppercase tracking-widest text-kharon-purple">Message *</label>
    <textarea 
      id="message" 
      name="message" 
      rows="5" 
      required 
      class="kharon-field"
      placeholder="Please provide details about your inquiry..."
    ></textarea>
  </div>
  
  <div class="flex items-start">
    <div class="flex items-center h-5">
      <input 
        id="consent" 
        name="consent" 
        type="checkbox" 
        required 
        class="focus:ring-kharon-purple h-4 w-4 text-kharon-purple border-kharon-purple/20 bg-kharon-charcoal rounded cursor-pointer"
      />
    </div>
    <div class="ml-3 text-sm">
      <label for="consent" class="font-medium text-kharon-light/80">
        I consent to the collection and processing of my data in accordance with POPIA so Kharon can respond to my inquiry. *
      </label>
    </div>
  </div>
  
  <div class="pt-4">
    <button 
      type="submit"
      :disabled="submitting"
      class="w-full kharon-command-button py-3.5 disabled:opacity-50 disabled:cursor-not-allowed"
      x-bind:class="{ 'opacity-75': submitting }"
    >
      <span x-show="!submitting" x-cloak>Send Message</span>
      <span x-show="submitting" x-cloak>Sending...</span>
    </button>
  </div>
</form>

<div 
  id="success-message" 
  class="hidden text-center py-12"
  x-show="submitted"
  x-transition
>
  <div class="max-w-md mx-auto">
    <svg class="mx-auto h-16 w-16 text-kharon-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
    </svg>
    <h3 class="mt-4 text-2xl font-bold text-white">Thank You!</h3>
    <p class="mt-2 text-kharon-light/75">Your message has been sent successfully. We'll get back to you within 24 hours.</p>
    <button 
      type="button"
      data-reset-contact-form
      class="mt-6 kharon-secondary-button py-2.5 px-6"
    >
      Send Another Message
    </button>
  </div>
</div>

<script>
  document.querySelector("[data-reset-contact-form]")?.addEventListener("click", () => {
    document.getElementById("contact-form")?.classList.remove("hidden");
    document.getElementById("success-message")?.classList.add("hidden");
  });
</script>
