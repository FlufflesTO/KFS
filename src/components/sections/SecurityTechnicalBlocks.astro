---
/**
 * Project Sentinel - Security Technical Blocks
 * Purpose: Access control tiers, POPIA CCTV retention planning, integrated security points
 * Structural Role: Deep technical depth section for the Security Systems page
 */

const accessTiers = [
  {
    level: 1,
    label: "Perimeter Control",
    purpose: "Control site entry/exit",
    tech: ["RFID cards", "Number plate recognition", "Intercom"],
    examples: "Turnstiles, boom gates, vehicle access"
  },
  {
    level: 2,
    label: "Departmental Control",
    purpose: "Restrict sensitive areas",
    tech: ["Biometric readers", "PIN + card", "Time-based scheduling"],
    examples: "Internal door access, lift control"
  },
  {
    level: 3,
    label: "Restricted Zone",
    purpose: "Maximum accountability",
    tech: ["Multi-factor (biometric + card + PIN)", "Mantrap interlocks", "Real-time logging + alerts"],
    examples: "Server rooms, vaults, control rooms"
  }
];

const cctvZones = [
  { zone: "Entry / Exit Points",   description: "All pedestrian and vehicle access recorded 24/7",                                  retention: "30-day minimum" },
  { zone: "Perimeter",             description: "Fence line coverage with motion-triggered recording",                              retention: "30-day minimum" },
  { zone: "High-Value Zones",      description: "Cash handling, server rooms, stock areas — continuous recording",                  retention: "90-day high-risk" },
  { zone: "Blind-Spot Elimination",description: "Corridor intersections, stairwells, behind columns",                               retention: "30-day minimum" },
  { zone: "POPIA Retention",       description: "POPIA-compliant storage with audit-grade retrieval and chain-of-custody logging",  retention: "30–90 day tiered" }
];

const integrationNodes = [
  { id: "access",   label: "Access Control",   cx: 300, cy: 60  },
  { id: "cctv",     label: "CCTV",             cx: 510, cy: 155 },
  { id: "fire",     label: "Fire Detection",   cx: 450, cy: 355 },
  { id: "gas",      label: "Gas Suppression",  cx: 150, cy: 355 },
  { id: "intruder", label: "Intruder Alarm",   cx: 90,  cy: 155 }
];

const integrationEvents = [
  { label: "Fire alarm",   detail: "Doors unlock (egress), Lifts recall, CCTV flags event",                  color: "#C4332F" },
  { label: "Gas release",  detail: "Access lockout (zone), CCTV records pre/post",                            color: "#C4332F" },
  { label: "Intrusion",    detail: "CCTV switches to live view, Access logs frozen, Alert dispatched",        color: "#C4332F" },
  { label: "After-hours",  detail: "Reduced access zones, CCTV motion sensitivity increased",                 color: "#00C2FF" }
];
---

<!-- Block 1: Access Control Tiers -->
<section class="section-padding bg-kharon-black border-t border-kharon-purple/10">
  <div class="mx-auto max-w-7xl px-6">
    <div class="max-w-3xl">
      <span class="text-base font-bold uppercase tracking-widest text-kharon-purple">Access Control Tiers — SANS 60839-11-1</span>
      <h2 class="mt-2 text-3xl font-bold leading-tight text-white">
        Escalating control levels matched to zone sensitivity.
      </h2>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {accessTiers.map((tier) => (
        <article class={`rounded-lg border border-kharon-purple/20 bg-kharon-charcoal p-6 ${tier.level === 3 ? "border-l-4 border-l-kharon-purple" : ""}`}>
          <div class="flex items-center gap-3">
            <span class={`flex h-9 w-9 items-center justify-center rounded-md text-base font-bold text-white ${tier.level === 3 ? "bg-kharon-purple" : "bg-kharon-blue"}`}>
              L{tier.level}
            </span>
            <div>
              <p class="text-base font-bold uppercase tracking-widest text-white/40">Level {tier.level}</p>
              <h3 class="text-lg font-bold text-white">{tier.label}</h3>
            </div>
          </div>

          <p class="mt-4 text-base font-semibold text-kharon-cyan">Purpose: {tier.purpose}</p>
          <p class="mt-2 text-base text-white/60">{tier.examples}</p>

          <div class="mt-4 border-t border-kharon-purple/20 pt-4">
            <p class="mb-2 text-base font-bold uppercase tracking-widest text-white/40">Technology</p>
            <ul class="space-y-2">
              {tier.tech.map((t) => (
                <li class="flex items-start gap-2 text-base text-white/70">
                  <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-kharon-purple"></span>
                  {t}
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- Block 2: CCTV Coverage Planning -->
<section class="section-padding bg-kharon-charcoal">
  <div class="mx-auto max-w-7xl px-6">
    <div class="max-w-3xl">
      <span class="text-base font-bold uppercase tracking-widest text-kharon-purple">CCTV Coverage Planning — SANS 62676</span>
      <h2 class="mt-2 text-3xl font-bold leading-tight text-white">
        Camera placement by zone, retention by risk.
      </h2>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {cctvZones.map((item) => (
        <article class="rounded-lg border border-kharon-purple/20 bg-kharon-charcoal p-6">
          <div class="flex items-start justify-between gap-4">
            <h3 class="text-lg font-bold text-white">{item.zone}</h3>
            <span class="shrink-0 rounded-md bg-kharon-cyan/20 px-3 py-1 text-base font-bold text-kharon-cyan">
              {item.retention}
            </span>
          </div>
          <p class="mt-2 text-base leading-7 text-white/60">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- Block 3: Integration Points Diagram -->
<section class="section-padding bg-kharon-black">
  <div class="mx-auto max-w-7xl px-6">
    <div class="max-w-3xl">
      <span class="text-base font-bold uppercase tracking-widest text-kharon-purple">Integration Points</span>
      <h2 class="mt-2 text-3xl font-bold leading-tight text-white">
        Security systems integrated with fire and life-safety.
      </h2>
    </div>

    <div class="mt-10 grid gap-10 lg:grid-cols-12 items-center">
      <div class="lg:col-span-7">
        <svg viewBox="0 0 600 420" role="img" aria-label="Integration diagram: Building Management System connected to Access Control, CCTV, Fire Detection, Gas Suppression and Intruder Alarm" class="h-auto w-full">
          <!-- Connector lines from hub to nodes -->
          {integrationNodes.map((node) => (
            <line x1="300" y1="240" x2={node.cx} y2={node.cy} stroke="#4B2E83" stroke-width="1.5" stroke-dasharray="4 3" opacity="0.5"/>
          ))}

          <!-- Central hub node -->
          <rect x="205" y="200" width="190" height="80" rx="10" fill="#4B2E83" stroke="#00C2FF" stroke-width="1.5"/>
          <text x="300" y="235" text-anchor="middle" fill="white" font-size="13" font-weight="700">Building Management</text>
          <text x="300" y="255" text-anchor="middle" fill="white" font-size="13" font-weight="700">System</text>

          <!-- System nodes -->
          {integrationNodes.map((node) => (
            <g>
              <rect x={node.cx - 60} y={node.cy - 22} width="120" height="44" rx="8" fill="#1F4E79" stroke="#00C2FF" stroke-width="1"/>
              <text x={node.cx} y={node.cy + 5} text-anchor="middle" fill="white" font-size="12" font-weight="600">{node.label}</text>
            </g>
          ))}
        </svg>
      </div>

      <div class="lg:col-span-5 space-y-6">
        <p class="text-[0.625rem] font-bold uppercase tracking-[0.2em] text-kharon-purple">Integration Scenarios</p>
        <div class="grid gap-4">
          {integrationEvents.map((evt) => (
            <div class="rounded-xl border border-kharon-purple/20 p-5 bg-kharon-charcoal hover:bg-kharon-charcoal/70 transition-colors">
              <div class="flex items-center gap-2">
                <span class="h-2 w-2 rounded-full" style={`background-color: ${evt.color}`}></span>
                <h4 class="font-bold tracking-tight text-white">{evt.label}</h4>
              </div>
              <p class="mt-2 text-base font-semibold leading-relaxed text-white/60">{evt.detail}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Integration event legend -->
    <div class="mx-auto mt-12 flex max-w-3xl flex-wrap items-center gap-6 text-[0.625rem] font-bold uppercase tracking-widest text-white/50">
      <span class="flex items-center gap-2">
        <span class="inline-block h-3 w-6 rounded-sm bg-kharon-purple"></span>
        Central BMS
      </span>
      <span class="flex items-center gap-2">
        <span class="inline-block h-3 w-6 rounded-sm bg-kharon-blue"></span>
        Subsystem
      </span>
      <span class="flex items-center gap-2">
        <span class="inline-block h-0.5 w-6 bg-kharon-red"></span>
        Alert path
      </span>
      <span class="flex items-center gap-2">
        <span class="inline-block h-0.5 w-6 bg-kharon-cyan"></span>
        Status path
      </span>
    </div>
  </div>
</section>
