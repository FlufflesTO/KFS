---
const routes = [
  {
    title: "Gas Suppression",
    label: "Primary",
    href: "/gas-suppression",
    text: "Clean-agent and engineered suppression for critical rooms, electronics and operational assets."
  },
  {
    title: "Fire Detection",
    label: "Primary",
    href: "/fire-detection",
    text: "Addressable detection architecture, control panels, zoning, fault logic and response paths."
  },
  {
    title: "Compliance & Lifecycle",
    label: "Governance",
    href: "/compliance-maintenance",
    text: "Inspection readiness, maintenance cadence, defect management and service evidence."
  },
  {
    title: "Critical Infrastructure",
    label: "Continuity",
    href: "/critical-infrastructure",
    text: "Protection models for data centres, electrical rooms, control rooms and high-consequence sites."
  },
  {
    title: "Emergency Support",
    label: "Response",
    href: "/emergency-support",
    text: "Operational support paths for faults, urgent interventions and maintenance escalations."
  },
  {
    title: "Integrated Security",
    label: "Support",
    href: "/security-systems",
    text: "Access control, CCTV, IDS and monitoring as subordinate infrastructure support."
  }
];
---

<section class="bg-white py-14">
  <div class="mx-auto max-w-7xl px-6">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <div class="max-w-3xl">
        <p class="mb-3 text-sm font-bold uppercase text-kharon-purple">Operational Routing</p>
        <h2 class="text-3xl font-bold leading-tight text-kharon-black sm:text-4xl">
          Move directly to the system, risk or response path.
        </h2>
      </div>
      <a href="/contact?intent=site-assessment" class="rounded-md border border-kharon-border px-5 py-3 text-sm font-bold text-kharon-grey hover:border-kharon-purple hover:text-kharon-purple">
        Assessment Intake
      </a>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {routes.map((route) => (
        <a href={route.href} class="group rounded-md border border-kharon-border bg-kharon-light p-6 hover:border-kharon-purple/45 hover:bg-white">
          <p class="text-xs font-bold uppercase text-kharon-purple">{route.label}</p>
          <h3 class="mt-3 text-xl font-bold text-kharon-black">{route.title}</h3>
          <p class="mt-3 text-sm leading-7 text-kharon-grey">{route.text}</p>
          <span class="mt-5 inline-flex text-sm font-bold text-kharon-purple">Open pathway -&gt;</span>
        </a>
      ))}
    </div>
  </div>
</section>
