---
/**
 * Project Sentinel - RouteMatrix
 * Purpose: Operational routing map component
 * Dependencies: SectionHeading.astro
 * Structural Role: Reusable sections UI component
 */
import SectionHeading from "./SectionHeading.astro";

interface Route {
  title: string;
  type: string;
  description: string;
  tags: string[];
}

interface Props {
  routes?: Route[];
}

const defaultRoutes: Route[] = [
  {
    title: "Critical Telemetry Routing",
    type: "Suppression Path",
    description: "Multi-point detector triggering initiates automatic clean-agent gas release and control panel signal routing to central dispatch.",
    tags: ["SANS 14520", "Double-Knock", "Auto-Release"]
  },
  {
    title: "Compliance Certification",
    type: "Verification Path",
    description: "Inspections feed into the forensic ledger, generating verification tokens for insurers and local fire authorities.",
    tags: ["SANS 10139", "Ledger Event", "Auditable"]
  },
  {
    title: "Field Dispatch Orchestration",
    type: "Response Path",
    description: "Automated routing connects urgent defect alarms with the nearest qualified SAQCC technician for rapid field response.",
    tags: ["GPS Route", "POPIA Safe", "Rugged Mobile"]
  }
];

const { routes = defaultRoutes } = Astro.props;
---

<section class="section-padding bg-gradient-to-b from-kharon-black to-kharon-charcoal">
  <div class="mx-auto max-w-7xl px-6">
    <SectionHeading
      title="Operational Routing Map"
      subtitle="Orchestration Matrix"
      description="Command routing infrastructure for mission-critical operations and response pathways."
      center={true}
    />

    <div class="mt-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {routes.map((route) => (
          <div class="rounded-lg border border-kharon-purple/15 bg-kharon-surface-elevated p-6 backdrop-blur-sm kharon-surface">
            <div class="flex items-center justify-between">
              <h3 class="text-lg font-semibold text-white">{route.title}</h3>
              <span class="text-xs font-bold uppercase tracking-widest px-2 py-1 rounded-full bg-kharon-purple/20 text-kharon-purple">
                {route.type}
              </span>
            </div>
            <p class="mt-3 text-kharon-light/70">{route.description}</p>
            <div class="mt-4 pt-4 border-t border-kharon-purple/10">
              <div class="flex flex-wrap gap-2">
                {route.tags?.map((tag) => (
                  <span class="text-xs px-2 py-1 rounded bg-kharon-graphite text-kharon-purple">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
