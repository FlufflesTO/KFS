/**
 * Project Sentinel - Suppression Technical Blocks
 * Purpose: Renders room readiness checklist, agent comparison matrix, discharge sequence timelines, and pre-quote summaries.
 * Dependencies: Astro section layout, SVG.
 * Structural Role: Presentation component for suppression page.
 */
<section class="section-padding bg-kharon-light relative overflow-hidden">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Block 1: Protected Room Readiness Checklist -->
    <div class="reveal">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-1 w-8 bg-kharon-purple"></div>
        <p class="text-[0.625rem] font-black uppercase tracking-[0.2em] text-kharon-purple">Room Readiness</p>
      </div>
      <h2 class="kharon-h2 text-kharon-black">Protected enclosure integrity standards.</h2>
      <p class="mt-6 text-lg text-kharon-grey leading-relaxed max-w-3xl">
        Before a gas suppression system can be commissioned, the protected enclosure must meet strict integrity standards. Every item below must be verified.
      </p>

      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { title: "Sealed penetrations", text: "All cable trays, conduits and pipework sealed with rated fire-stopping." },
          { title: "Automatic door closers", text: "Every access door must be self-closing to prevent agent loss." },
          { title: "Drop seals on doors", text: "Threshold gaps sealed with automatic drop-down seals for retention." },
          { title: "Warning signage", text: "Bilingual warning signs at every entrance indicating gas hazard." },
          { title: "Abort switches", text: "Manual abort stations positioned at each exit for emergency cancellation." },
          { title: "Dedicated dampers", text: "HVAC dampers must close on activation and reopen for purge." }
        ].map(item => (
          <div class="group rounded-xl border border-kharon-border p-6 bg-white transition-all hover:border-kharon-purple/20 hover:shadow-md">
            <div class="flex items-start gap-4">
              <div class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-kharon-purple/10 text-kharon-purple transition-colors group-hover:bg-kharon-purple group-hover:text-white">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"></path></svg>
              </div>
              <div>
                <p class="font-extrabold text-sm uppercase tracking-wider text-kharon-black">{item.title}</p>
                <p class="mt-2 text-xs leading-relaxed text-kharon-grey/80">{item.text}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Block 2: Agent Selection Matrix -->
    <div class="mt-24 reveal reveal-delayed">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-1 w-8 bg-kharon-purple"></div>
        <p class="text-[0.625rem] font-black uppercase tracking-[0.2em] text-kharon-purple">Agent Selection</p>
      </div>
      <h2 class="kharon-h2 text-kharon-black">Agent performance comparison matrix.</h2>
      <p class="mt-6 text-lg text-kharon-grey leading-relaxed max-w-3xl">
        Agents carry different environmental, spatial, and safety profiles. Kharon selects based on the specific risk, not inventory preference.
      </p>

      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {[
          { name: "FM-200", type: "Chemical Clean Agent", code: "HFC-227ea", gwp: "High", space: "Low", safety: "Design Conc.", cost: "$$", use: "IT & Server Rooms" },
          { name: "Inergen", type: "Inert Gas Blend", code: "IG-541", gwp: "0", space: "High", safety: "Safe (Inert)", cost: "$$$", use: "Archives & Heritage" },
          { name: "Novec 1230", type: "Fluoroketone", code: "FK-5-1-12", gwp: "1", space: "Low", safety: "Safe", cost: "$$$", use: "Data Centres" },
          { name: "CO2", type: "High Pressure Gas", code: "Carbon Dioxide", gwp: "0", space: "Moderate", safety: "LETHAL", cost: "$", use: "Plant Rooms (Unmanned)", lethal: true }
        ].map(agent => (
          <article class={`rounded-xl border ${agent.lethal ? 'border-kharon-red/30 bg-red-50/30' : 'border-kharon-border bg-white'} p-8 transition-all hover:shadow-xl`}>
            <p class={`text-[0.625rem] font-black uppercase tracking-widest ${agent.lethal ? 'text-kharon-red' : 'text-kharon-purple'}`}>{agent.type}</p>
            <h3 class="mt-4 text-2xl font-black tracking-tight text-kharon-black">{agent.name}</h3>
            <p class="text-[0.625rem] font-bold text-kharon-grey/60 uppercase tracking-widest">{agent.code}</p>
            
            <dl class="mt-8 space-y-4">
              {[['GWP', agent.gwp], ['Space', agent.space], ['Safety', agent.safety], ['Cost', agent.cost]].map(([label, val]) => (
                <div class="flex items-center justify-between border-b border-kharon-border/30 pb-2">
                  <dt class="text-[0.625rem] font-bold uppercase tracking-widest text-kharon-grey/50">{label}</dt>
                  <dd class={`text-[0.625rem] font-black uppercase tracking-widest ${val === 'LETHAL' ? 'text-kharon-red' : 'text-kharon-black'}`}>{val}</dd>
                </div>
              ))}
            </dl>
            
            <p class="mt-8 text-[0.625rem] font-bold leading-relaxed text-kharon-grey/70 uppercase tracking-widest">
              <span class="block text-kharon-black/40 mb-1">Typical use:</span>
              {agent.use}
            </p>
          </article>
        ))}
      </div>
    </div>

    <!-- Block 3: Discharge Sequence Diagram -->
    <div class="mt-24 reveal reveal-delayed">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-1 w-8 bg-kharon-purple"></div>
        <p class="text-[0.625rem] font-black uppercase tracking-[0.2em] text-kharon-purple">System Sequence</p>
      </div>
      <h2 class="kharon-h2 text-kharon-black">Automated discharge timeline.</h2>
      <p class="mt-6 text-lg text-kharon-grey leading-relaxed max-w-3xl">
        From first detection to post-discharge ventilation, every stage is timed and logged for compliance traceability.
      </p>

      <div class="mt-16 w-full max-w-5xl mx-auto overflow-hidden rounded-2xl border border-kharon-border bg-white p-8 lg:p-12 shadow-sm">
        <div class="overflow-x-auto pb-6">
          <div class="min-w-[55rem]">
            <div class="relative">
              <div class="absolute top-1/2 left-0 w-full h-0.5 bg-kharon-border/50 -translate-y-1/2" aria-hidden="true"></div>
              <div class="relative z-10 flex justify-between">
                {[
                  { id: "01", label: "Detection", sub: "Logic Trigger" },
                  { id: "02", label: "Stage 1", sub: "Pre-alarm" },
                  { id: "03", label: "Countdown", sub: "30-60s Delay" },
                  { id: "04", label: "Agent", sub: "Discharge" },
                  { id: "05", label: "Hold", sub: "Retention" },
                  { id: "06", label: "Vent", sub: "Post-purge" }
                ].map((step, idx) => (
                  <div class="flex flex-col items-center text-center">
                    <div class="flex h-12 w-12 items-center justify-center rounded-full bg-kharon-purple text-white font-black text-sm ring-8 ring-white">
                      {step.id}
                    </div>
                    <div class="mt-6">
                      <p class="text-xs font-black uppercase tracking-widest text-kharon-black">{step.label}</p>
                      <p class="mt-1 text-[0.625rem] font-bold uppercase tracking-widest text-kharon-grey/60">{step.sub}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Block 4: Pre-Quote Data Capture -->
    <div class="mt-24 reveal reveal-delayed">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-1 w-8 bg-kharon-purple"></div>
        <p class="text-[0.625rem] font-black uppercase tracking-[0.2em] text-kharon-purple">Pre-Quote Requirements</p>
      </div>
      <h2 class="kharon-h2 text-kharon-black">Data capture summary.</h2>
      <p class="mt-6 text-lg text-kharon-grey leading-relaxed max-w-3xl">
        Accurate quoting requires precise room data. Providing these details upfront avoids site revisits and ensures correct sizing.
      </p>

      <div class="mt-12 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {[
          { title: "Room Dimensions", text: "Length, width and clear height to underside of slab for volume calculations." },
          { title: "Opening Count", text: "Doors and windows affect retention time and determine sealing requirements." },
          { title: "Penetrations", text: "Unsealed penetrations cause integrity failures. Count informs fire-stopping scope." },
          { title: "Construction", text: "Raised floor or solid slab? Determines nozzle placement and routing." },
          { title: "Existing Systems", text: "Current detection types (smoke, heat, aspiration) for interface logic." },
          { title: "Occupancy", text: "Occupied rooms require safer agents and extended countdown logic." }
        ].map(item => (
          <div class="group rounded-xl border border-kharon-border bg-white p-8 transition-all hover:border-kharon-purple/20 hover:shadow-md">
            <h3 class="text-sm font-black uppercase tracking-widest text-kharon-black group-hover:text-kharon-purple transition-colors">{item.title}</h3>
            <p class="mt-4 text-xs leading-relaxed text-kharon-grey/80">{item.text}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
