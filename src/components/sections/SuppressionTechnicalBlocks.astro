---
/**
 * Project Sentinel - SuppressionTechnicalBlocks
 * Purpose: Framework section display for suppression capabilities
 * Dependencies: SectionHeading.astro, KharonCard.astro
 * Structural Role: Reusable sections UI component
 */
import SectionHeading from "./SectionHeading.astro";
import KharonCard from "../ui/KharonCard.astro";

const { 
  suppression = [],
  detection = [],
  compliance = [],
  security = []
} = Astro.props;
---

<section class="section-padding bg-gradient-to-b from-kharon-charcoal to-kharon-black">
  <div class="mx-auto max-w-7xl px-6">
    <SectionHeading
      title="Technical Capability Framework"
      subtitle="Engineered Systems"
      description="Comprehensive technical framework for fire protection and security systems."
      center={true}
    />

    <div class="mt-16 space-y-20">
      <!-- Gas Suppression Systems -->
      <div>
        <h2 class="text-2xl font-bold text-kharon-cyan mb-8 flex items-center">
          <span class="mr-3 w-10 h-10 rounded-md bg-kharon-purple/20 flex items-center justify-center">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd" />
            </svg>
          </span>
          Gas Suppression Systems
        </h2>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
          {suppression.map((item: string) => (
            <KharonCard variant="command" className="kharon-surface">
              <div class="flex items-center">
                <div class="mr-3 w-8 h-8 rounded-md bg-kharon-cyan/10 flex items-center justify-center">
                  <svg class="w-4 h-4 text-kharon-cyan" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                </div>
                <span class="text-white font-medium">{item}</span>
              </div>
            </KharonCard>
          ))}
        </div>
      </div>

      <!-- Fire Detection Systems -->
      <div>
        <h2 class="text-2xl font-bold text-kharon-cyan mb-8 flex items-center">
          <span class="mr-3 w-10 h-10 rounded-md bg-kharon-blue/20 flex items-center justify-center">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5 2a1 1 0 011 1v1h1a1 1 0 010 2H6v1a1 1 0 01-2 0V6H3a1 1 0 010-2h1V3a1 1 0 011-1zm0 10a1 1 0 011 1v1h1a1 1 0 110 2H6v1a1 1 0 11-2 0v-1H3a1 1 0 110-2h1v-1a1 1 0 011-1zM12 2a1 1 0 01.967.744L14.146 7.2 13.047 14.01c-.04.27-.31.458-.582.458-.272 0-.542-.188-.582-.458L10.854 7.2 12.033 2.744A1 1 0 0113 2h5a1 1 0 110 2h-1.146l-.5 2h3.146a1 1 0 110 2h-2.5l-.5 2h2.5a1 1 0 110 2H15v1a1 1 0 11-2 0v-1h-1v1a1 1 0 11-2 0v-1H9v1a1 1 0 01-2 0v-1H6a1 1 0 010-2h.146l.5-2H4a1 1 0 110-2h2.5l.5-2H4a1 1 0 110-2h2.146l.5-2H12z" clip-rule="evenodd" />
            </svg>
          </span>
          Fire Detection Systems
        </h2>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
          {detection.map((item: string) => (
            <KharonCard variant="command" className="kharon-surface">
              <div class="flex items-center">
                <div class="mr-3 w-8 h-8 rounded-md bg-kharon-cyan/10 flex items-center justify-center">
                  <svg class="w-4 h-4 text-kharon-cyan" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                </div>
                <span class="text-white font-medium">{item}</span>
              </div>
            </KharonCard>
          ))}
        </div>
      </div>

      <!-- Compliance & Maintenance -->
      <div>
        <h2 class="text-2xl font-bold text-kharon-cyan mb-8 flex items-center">
          <span class="mr-3 w-10 h-10 rounded-md bg-kharon-green/20 flex items-center justify-center">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V4a2 2 0 00-2-2H6zm1 2a1 1 0 000 2h6a1 1 0 100-2H7zm6 7a1 1 0 011 1v3a1 1 0 11-2 0v-3a1 1 0 011-1zm-3 3a1 1 0 100 2h.01a1 1 0 100-2H10zm-4 1a1 1 0 011-1h.01a1 1 0 110 2H7a1 1 0 01-1-1zm1-4a1 1 0 100 2h.01a1 1 0 100-2H7zm2 0a1 1 0 100 2h.01a1 1 0 100-2H9zm2 0a1 1 0 100 2h.01a1 1 0 100-2H11z" clip-rule="evenodd" />
            </svg>
          </span>
          Compliance & Maintenance
        </h2>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
          {compliance.map((item: string) => (
            <KharonCard variant="command" className="kharon-surface">
              <div class="flex items-center">
                <div class="mr-3 w-8 h-8 rounded-md bg-kharon-cyan/10 flex items-center justify-center">
                  <svg class="w-4 h-4 text-kharon-cyan" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                </div>
                <span class="text-white font-medium">{item}</span>
              </div>
            </KharonCard>
          ))}
        </div>
      </div>

      <!-- Integrated Security -->
      <div>
        <h2 class="text-2xl font-bold text-kharon-cyan mb-8 flex items-center">
          <span class="mr-3 w-10 h-10 rounded-md bg-kharon-amber/20 flex items-center justify-center">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
            </svg>
          </span>
          Integrated Security
        </h2>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
          {security.map((item: string) => (
            <KharonCard variant="command" className="kharon-surface">
              <div class="flex items-center">
                <div class="mr-3 w-8 h-8 rounded-md bg-kharon-cyan/10 flex items-center justify-center">
                  <svg class="w-4 h-4 text-kharon-cyan" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                </div>
                <span class="text-white font-medium">{item}</span>
              </div>
            </KharonCard>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>