---
/**
 * Project Sentinel - Compliance Technical Blocks
 * Purpose: Displays compliance maintenance cadence, defect severity classification, certificate flow, and service report structure.
 * Dependencies: None
 * Structural Role: Deep technical depth section for the Compliance page.
 */

const cadenceRows = [
  { system: "Fire Detection",        monthly: true,  quarterly: true,  half: true,  annual: true },
  { system: "Gas Suppression",       monthly: true,  quarterly: true,  half: true,  annual: true },
  { system: "Emergency Lighting",    monthly: false, quarterly: true,  half: true,  annual: true },
  { system: "Portable Extinguishers",monthly: true,  quarterly: false, half: false, annual: true },
  { system: "Hose Reels",            monthly: false, quarterly: true,  half: false, annual: true }
];

const severities = [
  {
    band: "Category 1 — Critical",
    tone: "red",
    heading: "Life safety impairment",
    body: "System non-functional or unable to perform its primary protection role. Immediate risk to occupant safety.",
    action: "Priority rectification",
    examples: [
      "Fire panel offline or in fault state",
      "Gas suppression agent leak",
      "Emergency lighting total failure"
    ]
  },
  {
    band: "Category 2 — Major",
    tone: "amber",
    heading: "Impaired function",
    body: "Degraded protection or partial system failure. The system operates but with reduced reliability or coverage.",
    action: "Targeted 7-day rectification",
    examples: [
      "Zone detector fault on one zone",
      "Extinguisher missing from designated point",
      "Hose reel valve seized"
    ]
  },
  {
    band: "Category 3 — Minor",
    tone: "neutral",
    heading: "Cosmetic or advisory",
    body: "Non-critical cosmetic damage, advisory notes, or items flagged for future monitoring without current safety impact.",
    action: "Next scheduled visit",
    examples: [
      "Extinguisher label faded",
      "Paint damage on enclosure",
      "Advisory note for future system upgrade"
    ]
  }
];

const reportSteps = [
  { title: "Site Information",       text: "Client name, site address, building type, contact details and service order reference." },
  { title: "System Inventory",       text: "Full listing of installed protection systems, zones, device types and quantities under scope." },
  { title: "Test Results (per zone)",text: "Individual zone test outcomes — detector responses, alarm activations, suppression readiness — recorded per area." },
  { title: "Defect Register",        text: "All faults and deficiencies classified by severity category with required rectification timeframe." },
  { title: "Recommendations",        text: "Forward-looking guidance covering system improvements, lifecycle planning and compliance positioning." },
  { title: "Client Sign-off",        text: "Client acknowledgment of service completion, defect awareness and acceptance of the report content." },
  { title: "Next Service Date",      text: "Calculated next inspection or service due date based on system type, interval schedule and current completion." }
];

const sansLinks = [
  { code: "SANS 10139", scope: "Fire detection — design, installation, commissioning, maintenance" },
  { code: "SANS 14520", scope: "Gas suppression — agent calculations, integrity, discharge" },
  { code: "SANS 10114-2", scope: "Emergency lighting — design, performance, testing" },
  { code: "SANS 10400-T", scope: "National building regulations — fire protection requirements" }
];
---

<section class="section-padding bg-kharon-black border-t border-kharon-purple/10">
  <div class="mx-auto max-w-7xl px-6">

    <!-- ─── Block 1: Maintenance Cadence Table ─── -->
    <div>
      <span class="text-base font-bold uppercase tracking-widest text-kharon-purple">Service Frequencies</span>
      <h2 class="text-3xl font-bold leading-tight text-white mt-2">Maintenance Cadence</h2>
      <p class="mt-4 max-w-3xl leading-7 text-white/70">
        Each protection system follows a defined inspection and service cycle aligned to its operational risk and SANS regulatory requirement.
      </p>

      <div class="mt-8 overflow-x-auto">
        <table class="w-full min-w-[480px] border-collapse text-base">
          <thead>
            <tr class="border-b border-kharon-purple/20">
              <th class="py-3 pr-4 text-left text-base font-bold uppercase tracking-widest text-kharon-purple">System</th>
              <th class="py-3 px-2 text-center text-base font-bold uppercase tracking-widest text-kharon-purple">Monthly</th>
              <th class="py-3 px-2 text-center text-base font-bold uppercase tracking-widest text-kharon-purple">Quarterly</th>
              <th class="py-3 px-2 text-center text-base font-bold uppercase tracking-widest text-kharon-purple">6-Monthly</th>
              <th class="py-3 px-2 text-center text-base font-bold uppercase tracking-widest text-kharon-purple">Annual</th>
            </tr>
            <tr class="border-b border-kharon-purple/10 text-base text-white/40">
              <th class="py-1 pr-4 text-left"></th>
              <th class="py-1 px-2 text-center font-normal">Visual</th>
              <th class="py-1 px-2 text-center font-normal">Functional</th>
              <th class="py-1 px-2 text-center font-normal">Comprehensive</th>
              <th class="py-1 px-2 text-center font-normal">Certification</th>
            </tr>
          </thead>
          <tbody>
            {cadenceRows.map((row) => (
              <tr class="border-b border-kharon-purple/10">
                <td class="py-3 pr-4 font-medium text-white">{row.system}</td>
                {[row.monthly, row.quarterly, row.half, row.annual].map((on) => (
                  <td class="py-3 px-2 text-center">
                    {on
                      ? <span class="inline-block h-4 w-4 rounded-full bg-kharon-cyan shadow-glow-cyan"></span>
                      : <span class="inline-block h-4 w-4 rounded-full border border-white/20"></span>}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="mt-4 text-base leading-6 text-white/40">
        Filled cyan dots indicate required service intervals. Hollow rings indicate intervals not applicable to that system type. All cadences are SANS 10139 / SANS 14520 aligned.
      </p>
    </div>

    <!-- ─── Block 2: Defect Severity Classification ─── -->
    <div class="mt-20">
      <span class="text-base font-bold uppercase tracking-widest text-kharon-purple">Defect Classification</span>
      <h2 class="text-3xl font-bold leading-tight text-white mt-2">Severity Categories</h2>
      <p class="mt-4 max-w-3xl leading-7 text-white/70">
        Every defect recorded during inspection or service is classified by severity to determine the required response timeframe and escalation path.
      </p>

      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {severities.map((sev) => {
          const tones = {
            red:     { border: "border-kharon-red/40",    bg: "bg-kharon-red/10",    label: "text-kharon-red"    },
            amber:   { border: "border-kharon-amber/40",  bg: "bg-kharon-amber/10",  label: "text-kharon-amber"  },
            neutral: { border: "border-kharon-purple/30", bg: "bg-kharon-charcoal",  label: "text-kharon-purple" }
          };
          const t = tones[sev.tone as keyof typeof tones];
          return (
            <div class={`rounded-lg border ${t.border} ${t.bg} p-6`}>
              <p class={`text-base font-bold uppercase tracking-widest ${t.label}`}>{sev.band}</p>
              <h3 class="mt-2 text-xl font-semibold text-white">{sev.heading}</h3>
              <p class="mt-3 leading-7 text-white/70">{sev.body}</p>
              <div class="mt-4 border-t border-white/10 pt-4">
                <p class="text-base font-bold uppercase tracking-widest text-white/50">Required action</p>
                <p class="mt-1 text-base leading-6 text-white">{sev.action}</p>
              </div>
              <div class="mt-3">
                <p class="text-base font-bold uppercase tracking-widest text-white/50">Examples</p>
                <ul class="mt-1 space-y-1 text-base leading-5 text-white/60">
                  {sev.examples.map((ex) => <li>· {ex}</li>)}
                </ul>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- ─── Block 3: Certificate Readiness Flowchart ─── -->
    <div class="mt-20">
      <span class="text-base font-bold uppercase tracking-widest text-kharon-purple">Certification Path</span>
      <h2 class="text-3xl font-bold leading-tight text-white mt-2">Certificate Readiness Flow</h2>
      <p class="mt-4 max-w-3xl leading-7 text-white/70">
        Decision logic governing whether a Certificate of Compliance can be issued, or whether an Advisory Notice is required pending defect resolution.
      </p>

      <div class="mt-10 w-full max-w-3xl mx-auto overflow-x-auto">
        <div class="min-w-[320px] px-2">
        <svg viewBox="0 0 600 660" class="w-full h-auto" role="img" aria-label="Certificate readiness decision flowchart">
          <!-- Connectors -->
          <line x1="300" y1="56" x2="300" y2="100" stroke="#00C2FF" stroke-width="2.5"/>
          <line x1="220" y1="140" x2="160" y2="140" stroke="#C4332F" stroke-width="2.5"/>
          <line x1="100" y1="140" x2="100" y2="68" stroke="#C4332F" stroke-width="2.5"/>
          <line x1="100" y1="68" x2="300" y2="68" stroke="#C4332F" stroke-width="2.5"/>
          <line x1="300" y1="180" x2="300" y2="230" stroke="#00C2FF" stroke-width="2.5"/>
          <line x1="380" y1="270" x2="440" y2="270" stroke="#C4332F" stroke-width="2.5"/>
          <line x1="495" y1="270" x2="495" y2="198" stroke="#C4332F" stroke-width="2.5"/>
          <line x1="495" y1="198" x2="300" y2="198" stroke="#C4332F" stroke-width="2.5"/>
          <line x1="300" y1="310" x2="300" y2="360" stroke="#00C2FF" stroke-width="2.5"/>
          <line x1="220" y1="400" x2="160" y2="400" stroke="#C4332F" stroke-width="2.5"/>
          <line x1="100" y1="400" x2="100" y2="328" stroke="#C4332F" stroke-width="2.5"/>
          <line x1="100" y1="328" x2="300" y2="328" stroke="#C4332F" stroke-width="2.5"/>
          <line x1="300" y1="440" x2="300" y2="500" stroke="#00C2FF" stroke-width="2.5"/>
          <line x1="300" y1="500" x2="440" y2="500" stroke="#C4332F" stroke-width="2.5"/>
          <line x1="440" y1="500" x2="440" y2="555" stroke="#C4332F" stroke-width="2.5"/>
          <line x1="300" y1="500" x2="160" y2="500" stroke="#16A34A" stroke-width="2.5"/>
          <line x1="160" y1="500" x2="160" y2="555" stroke="#16A34A" stroke-width="2.5"/>

          <!-- Nodes -->
          <rect x="235" y="30" width="130" height="26" rx="13" fill="#1F4E79" stroke="#00C2FF" stroke-width="1"/>
          <text x="300" y="47" text-anchor="middle" fill="#FFFFFF" font-size="12" font-weight="700">Start</text>

          <polygon points="300,100 380,140 300,180 220,140" fill="#4B2E83" stroke="#00C2FF" stroke-width="1"/>
          <text x="300" y="137" text-anchor="middle" fill="#FFFFFF" font-size="10.5" font-weight="600">All zones</text>
          <text x="300" y="149" text-anchor="middle" fill="#FFFFFF" font-size="10.5" font-weight="600">tested?</text>
          <text x="195" y="133" text-anchor="middle" fill="#C4332F" font-size="9.5" font-weight="700">No</text>
          <text x="315" y="205" fill="#00C2FF" font-size="9.5" font-weight="700">Yes</text>

          <rect x="50" y="127" width="110" height="26" rx="6" fill="#C4332F"/>
          <text x="105" y="143" text-anchor="middle" fill="#FFFFFF" font-size="9.5" font-weight="600">Complete tests</text>

          <polygon points="300,230 380,270 300,310 220,270" fill="#4B2E83" stroke="#00C2FF" stroke-width="1"/>
          <text x="300" y="267" text-anchor="middle" fill="#FFFFFF" font-size="10" font-weight="600">Open Cat 1</text>
          <text x="300" y="279" text-anchor="middle" fill="#FFFFFF" font-size="10" font-weight="600">defects?</text>
          <text x="405" y="263" text-anchor="middle" fill="#C4332F" font-size="9.5" font-weight="700">Yes</text>
          <text x="315" y="335" fill="#00C2FF" font-size="9.5" font-weight="700">No</text>

          <rect x="440" y="257" width="110" height="26" rx="6" fill="#C4332F"/>
          <text x="495" y="273" text-anchor="middle" fill="#FFFFFF" font-size="9.5" font-weight="600">Rectify</text>

          <polygon points="300,360 380,400 300,440 220,400" fill="#4B2E83" stroke="#00C2FF" stroke-width="1"/>
          <text x="300" y="397" text-anchor="middle" fill="#FFFFFF" font-size="10" font-weight="600">Docs</text>
          <text x="300" y="409" text-anchor="middle" fill="#FFFFFF" font-size="10" font-weight="600">complete?</text>
          <text x="195" y="393" text-anchor="middle" fill="#C4332F" font-size="9.5" font-weight="700">No</text>
          <text x="315" y="465" fill="#00C2FF" font-size="9.5" font-weight="700">Yes</text>

          <rect x="50" y="387" width="110" height="26" rx="6" fill="#C4332F"/>
          <text x="105" y="403" text-anchor="middle" fill="#FFFFFF" font-size="9.5" font-weight="600">Compile records</text>

          <text x="210" y="490" text-anchor="middle" fill="#16A34A" font-size="9.5" font-weight="600">All Cat 1 resolved</text>
          <text x="390" y="490" text-anchor="middle" fill="#C4332F" font-size="9.5" font-weight="600">Unresolved Cat 1</text>

          <rect x="55" y="555" width="210" height="44" rx="8" fill="#16A34A"/>
          <text x="160" y="577" text-anchor="middle" fill="#FFFFFF" font-size="11" font-weight="700">Certificate of</text>
          <text x="160" y="590" text-anchor="middle" fill="#FFFFFF" font-size="11" font-weight="700">Compliance Issued</text>

          <rect x="335" y="555" width="210" height="44" rx="8" fill="#C4332F"/>
          <text x="440" y="577" text-anchor="middle" fill="#FFFFFF" font-size="11" font-weight="700">Advisory Notice</text>
          <text x="440" y="590" text-anchor="middle" fill="#FFFFFF" font-size="11" font-weight="700">Issued</text>
        </svg>
        </div>
      </div>
    </div>

    <!-- ─── Block 4: Service Report Structure ─── -->
    <div class="mt-20">
      <span class="text-base font-bold uppercase tracking-widest text-kharon-purple">Reporting Standard</span>
      <h2 class="text-3xl font-bold leading-tight text-white mt-2">Service Report Structure</h2>
      <p class="mt-4 max-w-3xl leading-7 text-white/70">
        Every Kharon service engagement produces a structured report capturing site conditions, test outcomes, defects and forward recommendations.
      </p>

      <div class="mt-10 max-w-3xl">
        <ol class="space-y-7 border-l-2 border-kharon-purple/30 pl-8 ml-3">
          {reportSteps.map((step, i) => (
            <li class="relative">
              <span class="absolute -left-[2.6rem] top-0 flex h-7 w-7 items-center justify-center rounded-full bg-kharon-purple text-base font-bold text-white shadow-glow-purple ring-4 ring-kharon-black">{i + 1}</span>
              <h3 class="text-base font-bold tracking-tight text-white">{step.title}</h3>
              <p class="mt-1 text-base leading-relaxed text-white/60">{step.text}</p>
            </li>
          ))}
        </ol>
      </div>
    </div>

    <!-- ─── Block 5: SANS Standards Linked to This Page ─── -->
    <div class="mt-20">
      <span class="text-base font-bold uppercase tracking-widest text-kharon-purple">Regulatory Reference</span>
      <h2 class="text-3xl font-bold leading-tight text-white mt-2">SANS Standards Applied</h2>
      <p class="mt-4 max-w-3xl leading-7 text-white/70">
        Every cadence, classification, and certification decision on this page is grounded in published South African National Standards.
      </p>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {sansLinks.map((s) => (
          <div class="rounded-lg border border-kharon-purple/20 bg-kharon-charcoal p-5">
            <p class="text-base font-bold text-kharon-cyan tracking-tight">{s.code}</p>
            <p class="mt-2 text-base leading-relaxed text-white/60">{s.scope}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
