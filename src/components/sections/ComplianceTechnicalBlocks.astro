---
/* ComplianceTechnicalBlocks  -  self-contained technical detail section
   for the compliance-maintenance service page.
   No props; all content is static. */
---

<section class="section-padding bg-white">
  <div class="mx-auto max-w-7xl px-6">

    <!-- ─── Block 1: Maintenance Cadence Table ─── -->
    <div>
      <span class="text-sm font-bold uppercase tracking-wider text-kharon-purple">Service Frequencies</span>
      <h2 class="text-3xl font-bold leading-tight text-kharon-black mt-2">Maintenance Cadence</h2>
      <p class="mt-4 max-w-3xl leading-7 text-kharon-grey">
        Each protection system follows a defined inspection and service cycle aligned to its operational risk and regulatory requirement.
      </p>

      <div class="mt-8 overflow-x-auto">
        <table class="w-full min-w-[540px] border-collapse text-sm">
          <thead>
            <tr class="border-b border-kharon-border">
              <th class="py-3 pr-4 text-left font-semibold text-kharon-black">System</th>
              <th class="py-3 px-2 text-center font-semibold text-kharon-purple">Monthly</th>
              <th class="py-3 px-2 text-center font-semibold text-kharon-purple">Quarterly</th>
              <th class="py-3 px-2 text-center font-semibold text-kharon-purple">6-Monthly</th>
              <th class="py-3 px-2 text-center font-semibold text-kharon-purple">Annual</th>
            </tr>
            <tr class="border-b border-kharon-border text-xs text-kharon-grey">
              <th class="py-1 pr-4 text-left"></th>
              <th class="py-1 px-2 text-center">Visual</th>
              <th class="py-1 px-2 text-center">Functional</th>
              <th class="py-1 px-2 text-center">Comprehensive</th>
              <th class="py-1 px-2 text-center">Certification</th>
            </tr>
          </thead>
          <tbody>
            <!-- Fire Detection: all four -->
            <tr class="border-b border-kharon-border/50">
              <td class="py-3 pr-4 font-medium text-kharon-black">Fire Detection</td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full bg-kharon-purple"></span></td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full bg-kharon-purple"></span></td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full bg-kharon-purple"></span></td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full bg-kharon-purple"></span></td>
            </tr>
            <!-- Gas Suppression: all four -->
            <tr class="border-b border-kharon-border/50">
              <td class="py-3 pr-4 font-medium text-kharon-black">Gas Suppression</td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full bg-kharon-purple"></span></td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full bg-kharon-purple"></span></td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full bg-kharon-purple"></span></td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full bg-kharon-purple"></span></td>
            </tr>
            <!-- Emergency Lighting: quarterly, 6-monthly, annual -->
            <tr class="border-b border-kharon-border/50">
              <td class="py-3 pr-4 font-medium text-kharon-black">Emergency Lighting</td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full border-2 border-kharon-border"></span></td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full bg-kharon-purple"></span></td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full bg-kharon-purple"></span></td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full bg-kharon-purple"></span></td>
            </tr>
            <!-- Portable Extinguishers: monthly + annual -->
            <tr class="border-b border-kharon-border/50">
              <td class="py-3 pr-4 font-medium text-kharon-black">Portable Extinguishers</td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full bg-kharon-purple"></span></td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full border-2 border-kharon-border"></span></td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full border-2 border-kharon-border"></span></td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full bg-kharon-purple"></span></td>
            </tr>
            <!-- Hose Reels: quarterly + annual -->
            <tr class="border-b border-kharon-border/50">
              <td class="py-3 pr-4 font-medium text-kharon-black">Hose Reels</td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full border-2 border-kharon-border"></span></td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full bg-kharon-purple"></span></td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full border-2 border-kharon-border"></span></td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full bg-kharon-purple"></span></td>
            </tr>
            <!-- Sprinklers: quarterly, 6-monthly, annual -->
            <tr>
              <td class="py-3 pr-4 font-medium text-kharon-black">Sprinklers</td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full border-2 border-kharon-border"></span></td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full bg-kharon-purple"></span></td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full bg-kharon-purple"></span></td>
              <td class="py-3 px-2 text-center"><span class="inline-block h-4 w-4 rounded-full bg-kharon-purple"></span></td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="mt-4 text-xs leading-6 text-kharon-grey/70">
        Filled circles indicate required service intervals. Empty circles indicate intervals not applicable to that system type.
      </p>
    </div>

    <!-- ─── Block 2: Defect Severity Classification ─── -->
    <div class="mt-16">
      <span class="text-sm font-bold uppercase tracking-wider text-kharon-purple">Defect Classification</span>
      <h2 class="text-3xl font-bold leading-tight text-kharon-black mt-2">Severity Categories</h2>
      <p class="mt-4 max-w-3xl leading-7 text-kharon-grey">
        Every defect recorded during inspection or service is classified by severity to determine the required response timeframe and escalation path.
      </p>

      <div class="mt-8 grid gap-5 md:grid-cols-3">
        <!-- Category 1  -  Critical -->
        <div class="rounded-lg border border-kharon-red/40 bg-red-50 p-6">
          <p class="text-xs font-bold uppercase tracking-wider text-kharon-red">Category 1  -  Critical</p>
          <h3 class="mt-2 text-xl font-semibold text-kharon-black">Life safety impairment</h3>
          <p class="mt-3 leading-7 text-kharon-grey">
            System non-functional or unable to perform its primary protection role. Immediate risk to occupant safety.
          </p>
          <div class="mt-4 border-t border-kharon-red/20 pt-4">
            <p class="text-sm font-semibold text-kharon-black">Required action</p>
            <p class="mt-1 text-sm leading-6 text-kharon-grey">24-hour rectification</p>
          </div>
          <div class="mt-3">
            <p class="text-xs font-semibold text-kharon-grey">Examples</p>
            <ul class="mt-1 space-y-1 text-xs leading-5 text-kharon-grey/80">
              <li>Fire panel offline or in fault state</li>
              <li>Gas suppression agent leak</li>
              <li>Emergency lighting total failure</li>
            </ul>
          </div>
        </div>

        <!-- Category 2  -  Major -->
        <div class="rounded-lg border border-kharon-amber/40 bg-amber-50 p-6">
          <p class="text-xs font-bold uppercase tracking-wider text-kharon-amber">Category 2  -  Major</p>
          <h3 class="mt-2 text-xl font-semibold text-kharon-black">Impaired function</h3>
          <p class="mt-3 leading-7 text-kharon-grey">
            Degraded protection or partial system failure. The system operates but with reduced reliability or coverage.
          </p>
          <div class="mt-4 border-t border-kharon-amber/20 pt-4">
            <p class="text-sm font-semibold text-kharon-black">Required action</p>
            <p class="mt-1 text-sm leading-6 text-kharon-grey">7-day rectification</p>
          </div>
          <div class="mt-3">
            <p class="text-xs font-semibold text-kharon-grey">Examples</p>
            <ul class="mt-1 space-y-1 text-xs leading-5 text-kharon-grey/80">
              <li>Zone detector fault on one zone</li>
              <li>Extinguisher missing from designated point</li>
              <li>Hose reel valve seized</li>
            </ul>
          </div>
        </div>

        <!-- Category 3  -  Minor -->
        <div class="rounded-lg border border-kharon-border bg-white p-6">
          <p class="text-xs font-bold uppercase tracking-wider text-kharon-purple">Category 3  -  Minor</p>
          <h3 class="mt-2 text-xl font-semibold text-kharon-black">Cosmetic or advisory</h3>
          <p class="mt-3 leading-7 text-kharon-grey">
            Non-critical cosmetic damage, advisory notes, or items flagged for future monitoring without current safety impact.
          </p>
          <div class="mt-4 border-t border-kharon-border pt-4">
            <p class="text-sm font-semibold text-kharon-black">Required action</p>
            <p class="mt-1 text-sm leading-6 text-kharon-grey">Next scheduled visit</p>
          </div>
          <div class="mt-3">
            <p class="text-xs font-semibold text-kharon-grey">Examples</p>
            <ul class="mt-1 space-y-1 text-xs leading-5 text-kharon-grey/80">
              <li>Extinguisher label faded</li>
              <li>Paint damage on enclosure</li>
              <li>Advisory note for future system upgrade</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- ─── Block 3: Certificate Readiness Flowchart ─── -->
    <div class="mt-16">
      <span class="text-sm font-bold uppercase tracking-wider text-kharon-purple">Certification Path</span>
      <h2 class="text-3xl font-bold leading-tight text-kharon-black mt-2">Certificate Readiness Flowchart</h2>
      <p class="mt-4 max-w-3xl leading-7 text-kharon-grey">
        Decision logic governing whether a Certificate of Compliance can be issued, or whether an Advisory Notice is required pending defect resolution.
      </p>

      <div class="mt-8 w-full max-w-3xl mx-auto">
        <svg viewBox="0 0 420 820" class="w-full h-auto" role="img" aria-label="Certificate readiness decision flowchart">
          <!-- Connectors (drawn first so nodes overlay junctions) -->
          <!-- Start -> Decision 1 -->
          <line x1="210" y1="56" x2="210" y2="100" stroke="#00C2FF" stroke-width="2.5"/>
          <!-- Decision 1 No -> Process 1 -->
          <line x1="70" y1="140" x2="140" y2="140" stroke="#00C2FF" stroke-width="2.5"/>
          <!-- Process 1 -> loop back up to Decision 1 -->
          <line x1="140" y1="164" x2="140" y2="68" stroke="#00C2FF" stroke-width="2.5"/>
          <line x1="140" y1="68" x2="210" y2="68" stroke="#00C2FF" stroke-width="2.5"/>
          <!-- Decision 1 Yes -> Decision 2 -->
          <line x1="210" y1="180" x2="210" y2="230" stroke="#00C2FF" stroke-width="2.5"/>
          <!-- Decision 2 Yes -> Process 2 -->
          <line x1="350" y1="270" x2="280" y2="270" stroke="#C4332F" stroke-width="2.5"/>
          <!-- Process 2 -> loop back up to Decision 2 -->
          <line x1="280" y1="294" x2="280" y2="198" stroke="#00C2FF" stroke-width="2.5"/>
          <line x1="280" y1="198" x2="210" y2="198" stroke="#00C2FF" stroke-width="2.5"/>
          <!-- Decision 2 No -> Decision 3 -->
          <line x1="210" y1="310" x2="210" y2="360" stroke="#00C2FF" stroke-width="2.5"/>
          <!-- Decision 3 No -> Process 3 -->
          <line x1="70" y1="400" x2="140" y2="400" stroke="#00C2FF" stroke-width="2.5"/>
          <!-- Process 3 -> loop back up to Decision 3 -->
          <line x1="140" y1="424" x2="140" y2="328" stroke="#00C2FF" stroke-width="2.5"/>
          <line x1="140" y1="328" x2="210" y2="328" stroke="#00C2FF" stroke-width="2.5"/>
          <!-- Decision 3 Yes -> Split to two outcomes -->
          <line x1="210" y1="440" x2="210" y2="510" stroke="#00C2FF" stroke-width="2.5"/>
          <!-- Split line to Advisory -->
          <line x1="210" y1="510" x2="340" y2="510" stroke="#C4332F" stroke-width="2.5"/>
          <line x1="340" y1="510" x2="340" y2="570" stroke="#C4332F" stroke-width="2.5"/>
          <!-- Split line to Certificate -->
          <line x1="210" y1="510" x2="210" y2="570" stroke="#00C2FF" stroke-width="2.5"/>

          <!-- Nodes -->

          <!-- START -->
          <rect x="145" y="30" width="130" height="26" rx="13" fill="#1F4E79"/>
          <text x="210" y="47" text-anchor="middle" fill="#FFFFFF" font-size="12" font-weight="700">Start</text>

          <!-- Decision 1: All zones tested? -->
          <polygon points="210,100 280,140 210,180 140,140" fill="#4B2E83" stroke="#4B2E83" stroke-width="1"/>
          <text x="210" y="143" text-anchor="middle" fill="#FFFFFF" font-size="10.5" font-weight="600">All zones</text>
          <text x="210" y="155" text-anchor="middle" fill="#FFFFFF" font-size="10.5" font-weight="600">tested?</text>
          <!-- No label -->
          <text x="100" y="133" text-anchor="middle" fill="#C4332F" font-size="9" font-weight="700">No</text>
          <!-- Yes label -->
          <text x="225" y="200" fill="#1F4E79" font-size="9" font-weight="700">Yes down</text>

          <!-- Process 1: Complete zone testing -->
          <rect x="60" y="140" width="80" height="24" rx="6" fill="#1F4E79"/>
          <text x="100" y="155" text-anchor="middle" fill="#FFFFFF" font-size="9" font-weight="600">Complete</text>

          <!-- Decision 2: Open Category 1 defects? -->
          <polygon points="210,230 280,270 210,310 140,270" fill="#4B2E83" stroke="#4B2E83" stroke-width="1"/>
          <text x="210" y="266" text-anchor="middle" fill="#FFFFFF" font-size="10" font-weight="600">Open Cat 1</text>
          <text x="210" y="278" text-anchor="middle" fill="#FFFFFF" font-size="10" font-weight="600">defects?</text>
          <!-- Yes label -->
          <text x="315" y="263" text-anchor="middle" fill="#C4332F" font-size="9" font-weight="700">Yes</text>
          <!-- No label -->
          <text x="225" y="332" fill="#1F4E79" font-size="9" font-weight="700">No down</text>

          <!-- Process 2: Rectify before certification -->
          <rect x="200" y="270" width="80" height="24" rx="6" fill="#C4332F"/>
          <text x="240" y="285" text-anchor="middle" fill="#FFFFFF" font-size="9" font-weight="600">Rectify</text>

          <!-- Decision 3: Documentation complete? -->
          <polygon points="210,360 280,400 210,440 140,400" fill="#4B2E83" stroke="#4B2E83" stroke-width="1"/>
          <text x="210" y="396" text-anchor="middle" fill="#FFFFFF" font-size="10" font-weight="600">Docs</text>
          <text x="210" y="408" text-anchor="middle" fill="#FFFFFF" font-size="10" font-weight="600">complete?</text>
          <!-- No label -->
          <text x="100" y="393" text-anchor="middle" fill="#C4332F" font-size="9" font-weight="700">No</text>
          <!-- Yes label -->
          <text x="225" y="462" fill="#1F4E79" font-size="9" font-weight="700">Yes down</text>

          <!-- Process 3: Compile service records -->
          <rect x="60" y="400" width="80" height="24" rx="6" fill="#1F4E79"/>
          <text x="100" y="415" text-anchor="middle" fill="#FFFFFF" font-size="9" font-weight="600">Compile</text>

          <!-- Outcome label at split -->
          <text x="160" y="522" text-anchor="middle" fill="#0B0D0F" font-size="8.5" font-weight="600">All Cat 1</text>
          <text x="160" y="532" text-anchor="middle" fill="#0B0D0F" font-size="8.5" font-weight="600">resolved?</text>
          <text x="290" y="522" text-anchor="middle" fill="#C4332F" font-size="8.5" font-weight="600">Unresolved</text>
          <text x="290" y="532" text-anchor="middle" fill="#C4332F" font-size="8.5" font-weight="600">Cat 1</text>

          <!-- Certificate of Compliance Issued -->
          <rect x="115" y="570" width="190" height="44" rx="8" fill="#1F4E79"/>
          <text x="210" y="592" text-anchor="middle" fill="#FFFFFF" font-size="11" font-weight="700">Certificate of</text>
          <text x="210" y="605" text-anchor="middle" fill="#FFFFFF" font-size="11" font-weight="700">Compliance Issued</text>

          <!-- Advisory Notice Issued -->
          <rect x="245" y="570" width="190" height="44" rx="8" fill="#C4332F"/>
          <text x="340" y="592" text-anchor="middle" fill="#FFFFFF" font-size="11" font-weight="700">Advisory Notice</text>
          <text x="340" y="605" text-anchor="middle" fill="#FFFFFF" font-size="11" font-weight="700">Issued</text>

          <!-- Legend -->
          <rect x="20" y="660" width="380" height="140" rx="8" fill="none" stroke="#D6D9DD" stroke-width="1"/>
          <text x="210" y="682" text-anchor="middle" fill="#0B0D0F" font-size="10" font-weight="700">Legend</text>
          <!-- Decision -->
          <polygon points="40,708 56,700 72,708 56,716" fill="#4B2E83"/>
          <text x="84" y="712" fill="#0B0D0F" font-size="9">Decision point</text>
          <!-- Process -->
          <rect x="36" y="728" width="36" height="16" rx="4" fill="#1F4E79"/>
          <text x="84" y="740" fill="#0B0D0F" font-size="9">Process / action</text>
          <!-- Blocker -->
          <rect x="36" y="750" width="36" height="16" rx="4" fill="#C4332F"/>
          <text x="84" y="762" fill="#0B0D0F" font-size="9">Blocker / failure path</text>
          <!-- Connector -->
          <line x1="200" y1="708" x2="240" y2="708" stroke="#00C2FF" stroke-width="2.5"/>
          <text x="252" y="712" fill="#0B0D0F" font-size="9">Connector / flow</text>
          <!-- Loop -->
          <path d="M200,730 L240,730 L240,748 L200,748" fill="none" stroke="#00C2FF" stroke-width="2" stroke-dasharray="4 3"/>
          <text x="252" y="740" fill="#0B0D0F" font-size="9">Loop-back path</text>
        </svg>
      </div>
    </div>

    <!-- ─── Block 4: Sample Service Report Structure ─── -->
    <div class="mt-16">
      <span class="text-sm font-bold uppercase tracking-wider text-kharon-purple">Reporting Standard</span>
      <h2 class="text-3xl font-bold leading-tight text-kharon-black mt-2">Service Report Structure</h2>
      <p class="mt-4 max-w-3xl leading-7 text-kharon-grey">
        Every Kharon service engagement produces a structured report capturing site conditions, test outcomes, defects and forward recommendations.
      </p>

      <div class="mt-8 max-w-2xl">
        <div class="rounded-lg border border-kharon-border bg-white p-6">

          <ol class="space-y-5 border-l-2 border-kharon-purple/30 pl-6">

            <li class="relative">
              <span class="absolute -left-[1.85rem] top-1 flex h-5 w-5 items-center justify-center rounded-full bg-kharon-purple text-xs font-bold text-white">1</span>
              <h3 class="text-lg font-semibold text-kharon-black">Site Information</h3>
              <p class="mt-1 leading-6 text-sm text-kharon-grey">Client name, site address, building type, contact details and service order reference.</p>
            </li>

            <li class="relative">
              <span class="absolute -left-[1.85rem] top-1 flex h-5 w-5 items-center justify-center rounded-full bg-kharon-purple text-xs font-bold text-white">2</span>
              <h3 class="text-lg font-semibold text-kharon-black">System Inventory</h3>
              <p class="mt-1 leading-6 text-sm text-kharon-grey">Full listing of installed protection systems, zones, device types and quantities under scope.</p>
            </li>

            <li class="relative">
              <span class="absolute -left-[1.85rem] top-1 flex h-5 w-5 items-center justify-center rounded-full bg-kharon-purple text-xs font-bold text-white">3</span>
              <h3 class="text-lg font-semibold text-kharon-black">Test Results (per zone)</h3>
              <p class="mt-1 leading-6 text-sm text-kharon-grey">Individual zone test outcomes  -  detector responses, alarm activations, suppression readiness  -  recorded per area.</p>
            </li>

            <li class="relative">
              <span class="absolute -left-[1.85rem] top-1 flex h-5 w-5 items-center justify-center rounded-full bg-kharon-purple text-xs font-bold text-white">4</span>
              <h3 class="text-lg font-semibold text-kharon-black">Defect Register</h3>
              <p class="mt-1 leading-6 text-sm text-kharon-grey">All faults and deficiencies classified by severity category with required rectification timeframe.</p>
            </li>

            <li class="relative">
              <span class="absolute -left-[1.85rem] top-1 flex h-5 w-5 items-center justify-center rounded-full bg-kharon-purple text-xs font-bold text-white">5</span>
              <h3 class="text-lg font-semibold text-kharon-black">Recommendations</h3>
              <p class="mt-1 leading-6 text-sm text-kharon-grey">Forward-looking guidance covering system improvements, lifecycle planning and compliance positioning.</p>
            </li>

            <li class="relative">
              <span class="absolute -left-[1.85rem] top-1 flex h-5 w-5 items-center justify-center rounded-full bg-kharon-purple text-xs font-bold text-white">6</span>
              <h3 class="text-lg font-semibold text-kharon-black">Client Sign-off</h3>
              <p class="mt-1 leading-6 text-sm text-kharon-grey">Client acknowledgment of service completion, defect awareness and acceptance of the report content.</p>
            </li>

            <li class="relative">
              <span class="absolute -left-[1.85rem] top-1 flex h-5 w-5 items-center justify-center rounded-full bg-kharon-purple text-xs font-bold text-white">7</span>
              <h3 class="text-lg font-semibold text-kharon-black">Next Service Date</h3>
              <p class="mt-1 leading-6 text-sm text-kharon-grey">Calculated next inspection or service due date based on system type, interval schedule and current completion.</p>
            </li>

          </ol>

        </div>
      </div>
    </div>

  </div>
</section>