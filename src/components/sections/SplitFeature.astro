---
/**
 * Project Sentinel - Split Feature
 * Purpose: A split-screen feature presentation layout showing content alongside a premium glassmorphic tech-grid visualization.
 * Dependencies: Astro props, Button component.
 * Structural Role: Reusable presentation section block for service pages.
 */
import Button from "../ui/Button.astro";

const {
  eyebrow,
  title,
  text,
  bullets = [],
  visual = "systems",
  imageAlt = "Industrial fire and security infrastructure",
  reverse = false,
  href = "/contact?intent=site-assessment",
  cta = "Discuss Requirements"
} = Astro.props;

const visualLabels = {
  suppression: ["Cylinder bank", "Release panel", "Protected room"],
  detection: ["Addressable loop", "Control panel", "Response zones"],
  compliance: ["Inspection", "Service record", "Lifecycle plan"],
  security: ["Access control", "CCTV", "Monitoring"],
  systems: ["Risk input", "System design", "Operational support"]
};

const labels = visualLabels[visual] || visualLabels.systems;

const labelIcons = {
  // Suppression
  "Cylinder bank": `<svg class="h-6 w-6 text-kharon-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M7 5h10M7 9h10M7 13h10M7 17h10" stroke-linecap="round"/></svg>`,
  "Release panel": `<svg class="h-6 w-6 text-kharon-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><circle cx="15" cy="9" r="2"/><path d="M6 15h12" stroke-linecap="round"/></svg>`,
  "Protected room": `<svg class="h-6 w-6 text-kharon-red" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 22V12h6v10"/></svg>`,
  
  // Detection
  "Addressable loop": `<svg class="h-6 w-6 text-kharon-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 2a10 10 0 0 1 10 10" stroke-dasharray="2 2"/></svg>`,
  "Control panel": `<svg class="h-6 w-6 text-kharon-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h6M9 13h6"/></svg>`,
  "Response zones": `<svg class="h-6 w-6 text-kharon-red" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h18v18H3zM9 3v18M15 3v18M3 9h18M3 15h18" stroke-linecap="round"/></svg>`,
  
  // Compliance
  "Inspection": `<svg class="h-6 w-6 text-kharon-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" stroke-linecap="round"/></svg>`,
  "Service record": `<svg class="h-6 w-6 text-kharon-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8" stroke-linecap="round"/></svg>`,
  "Lifecycle plan": `<svg class="h-6 w-6 text-kharon-red" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" stroke-linecap="round"/></svg>`,
  
  // Security
  "Access control": `<svg class="h-6 w-6 text-kharon-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4" stroke-linecap="round"/></svg>`,
  "CCTV": `<svg class="h-6 w-6 text-kharon-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>`,
  "Monitoring": `<svg class="h-6 w-6 text-kharon-red" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12h20M12 2v20" stroke-dasharray="3 3"/><circle cx="12" cy="12" r="9"/></svg>`,
  
  // Systems
  "Risk input": `<svg class="h-6 w-6 text-kharon-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5M16 19H8" stroke-linecap="round"/></svg>`,
  "System design": `<svg class="h-6 w-6 text-kharon-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9M3 20v-8a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v8M13 20v-4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v8" stroke-linecap="round"/></svg>`,
  "Operational support": `<svg class="h-6 w-6 text-kharon-red" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`
};
---

<section class="section-padding bg-kharon-light relative overflow-hidden">
  <!-- Subtle background ambient light -->
  <div class="absolute top-1/2 left-0 -translate-y-1/2 w-[800px] h-[800px] bg-kharon-cyan/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class={`relative z-10 mx-auto grid max-w-7xl items-center gap-16 px-6 lg:grid-cols-2 ${reverse ? "lg:[&>*:first-child]:order-2" : ""}`}>
    <div class="flex flex-col justify-center" data-animate="slide-up">
      <p class="mb-4 text-sm font-bold uppercase tracking-widest text-kharon-purple">
        {eyebrow}
      </p>

      <h2 class="text-3xl font-bold leading-tight text-kharon-black sm:text-4xl lg:text-5xl">
        {title}
      </h2>

      <p class="mt-6 text-lg leading-8 text-kharon-grey">
        {text}
      </p>

      <ul class="mt-8 grid gap-5">
        {bullets.map((bullet) => (
          <li class="flex items-start gap-4 text-kharon-grey group">
            <div class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-kharon-purple/10 text-kharon-purple transition-transform duration-300 group-hover:scale-110">
              <span class="h-2 w-2 rounded-full bg-kharon-purple"></span>
            </div>
            <span class="leading-relaxed">{bullet}</span>
          </li>
        ))}
      </ul>

      <div class="mt-10">
        <Button href={href} label={cta} variant="dark" />
      </div>
    </div>

    <!-- Glassmorphic Bento Visualization -->
    <div class="relative w-full aspect-square md:aspect-[4/3] lg:aspect-square xl:aspect-[4/3] rounded-2xl" data-animate="fade-in">
      <div class="absolute inset-0 grid grid-cols-2 grid-rows-2 gap-4 p-4">
        {labels.map((label, index) => {
          const iconHtml = labelIcons[label] || `<svg class="h-8 w-8 text-kharon-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/></svg>`;
          const isFirst = index === 0;
          const isLast = index === labels.length - 1;
          
          return (
            <div class={`group relative flex flex-col justify-between overflow-hidden rounded-2xl border transition-all duration-500 hover:shadow-xl ${isFirst ? 'col-span-2 row-span-1 border-kharon-blue/20 bg-gradient-to-br from-white to-slate-50 shadow-lg shadow-kharon-blue/5 hover:border-kharon-blue/40' : (isLast ? 'col-span-1 row-span-1 border-kharon-red/20 bg-gradient-to-br from-white to-rose-50 shadow-lg shadow-kharon-red/5 hover:border-kharon-red/40' : 'col-span-1 row-span-1 border-kharon-cyan/20 bg-gradient-to-br from-white to-cyan-50 shadow-lg shadow-kharon-cyan/5 hover:border-kharon-cyan/40')} p-6`}>
              
              <!-- Subtle inner ambient glow -->
              <div class={`absolute -right-8 -top-8 h-32 w-32 rounded-full blur-[40px] transition-opacity duration-500 opacity-0 group-hover:opacity-100 ${isFirst ? 'bg-kharon-blue/20' : (isLast ? 'bg-kharon-red/20' : 'bg-kharon-cyan/20')}`}></div>
              
              <div class="relative z-10">
                <div class={`mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-white shadow-sm ring-1 ring-black/5 transition-transform duration-500 group-hover:scale-110 group-hover:shadow-md`}>
                  <div set:html={iconHtml} />
                </div>
              </div>
              
              <div class="relative z-10 mt-auto">
                <span class="mb-1 block text-xs font-bold text-slate-400">0{index + 1}</span>
                <p class="text-lg font-bold text-kharon-black tracking-tight">{label}</p>
              </div>
            </div>
          );
        })}
        <!-- Empty decorative bento cell if we have only 3 items, making it 4 items total -->
        {labels.length === 3 && (
          <div class="col-span-1 row-span-1 overflow-hidden rounded-2xl border border-slate-100 bg-slate-50 p-6 flex flex-col justify-center items-center opacity-60">
            <div class="grid grid-cols-3 gap-2 opacity-20">
              {[...Array(9)].map(() => <div class="h-2 w-2 rounded-full bg-slate-400"></div>)}
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
