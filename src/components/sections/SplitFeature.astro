---
import SectionHeading from "./SectionHeading.astro";

const { title, subtitle, description, image, reverse = false } = Astro.props;
---

<section class="section-padding bg-gradient-to-b from-kharon-charcoal to-kharon-black">
  <div class="mx-auto max-w-7xl px-6">
    <SectionHeading
      title={title}
      subtitle={subtitle}
      description={description}
    />

    <div class={`mt-16 grid items-center gap-12 ${reverse ? 'lg:grid-flow-col-dense' : ''}`}>
      <div class={`${reverse ? 'lg:col-start-2' : ''}`}>
        <div class="rounded-xl border border-kharon-purple/15 bg-kharon-surface-elevated p-8 backdrop-blur-sm kharon-surface-strong">
          <div class="aspect-video bg-kharon-charcoal rounded-lg flex items-center justify-center overflow-hidden">
            {image ? (
              <img 
                src={image} 
                alt="Feature visualization" 
                class="w-full h-full object-cover"
              />
            ) : (
              <div class="text-center p-8">
                <div class="w-16 h-16 bg-kharon-purple/10 rounded-lg flex items-center justify-center mx-auto mb-4">
                  <div class="w-8 h-8 bg-kharon-purple rounded"></div>
                </div>
                <p class="text-kharon-light/50">Feature Visualization</p>
              </div>
            )}
          </div>
        </div>
      </div>
      <div class={`${reverse ? 'lg:col-start-1' : ''}`}>
        <div class="prose prose-invert max-w-none">
          <slot />
        </div>
      </div>
    </div>
  </div>
</section>
