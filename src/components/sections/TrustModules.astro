---
import SectionHeading from "./SectionHeading.astro";
import StatusIndicator from "../ui/StatusIndicator.astro";

const { items = [] } = Astro.props;
---

<section class="section-padding bg-kharon-light">
  <div class="mx-auto max-w-7xl px-6">
    <SectionHeading
      eyebrow="Trust Modules"
      title="Compliance and maintenance are shown as operating evidence."
      text="Kharon communicates system maturity through records, cadence, response logic and documentation outputs."
    />

    <div class="mt-12 grid gap-5 md:grid-cols-2">
      {items.map((item) => (
        <article class="rounded-lg border border-kharon-border bg-white p-6 transition hover:-translate-y-1 hover:shadow-xl">
          <StatusIndicator label={item.status} tone={item.tone} />
          <h3 class="mt-3 text-xl font-semibold text-kharon-black">{item.title}</h3>
          <p class="mt-3 leading-7 text-kharon-grey">{item.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
