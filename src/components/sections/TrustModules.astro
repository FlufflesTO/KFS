---
import SectionHeading from "./SectionHeading.astro";
import StatusIndicator from "../ui/StatusIndicator.astro";
import type { TrustModuleItem } from "../../data/proof";

export interface Props {
  items?: TrustModuleItem[];
}

const { items = [] } = Astro.props;
---

<section class="section-padding bg-gradient-to-b from-kharon-black to-kharon-charcoal">
  <div class="mx-auto max-w-7xl px-6">
    <SectionHeading
      subtitle="Trust Modules"
      title="Compliance and maintenance are shown as operating evidence."
      description="Kharon communicates system maturity through records, cadence, response logic and documentation outputs."
      center={true}
    />

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {items.map((item: TrustModuleItem) => (
        <article class="rounded-lg border border-kharon-purple/15 bg-kharon-surface-elevated p-6 hover:border-kharon-purple/30 backdrop-blur-sm kharon-surface">
          <StatusIndicator status={item.status === 'Records' ? 'active' : item.status === 'Cadence' ? 'processing' : item.status === 'Response' ? 'warning' : 'success'} label={item.status} />
          <h3 class="mt-4 text-xl font-semibold text-white">{item.title}</h3>
          <p class="mt-3 leading-7 text-kharon-light/70">{item.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
