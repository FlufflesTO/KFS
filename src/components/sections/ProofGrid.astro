---
/**
 * Project Sentinel - ProofGrid
 * Purpose: Grid component for capability proof signals
 * Dependencies: SectionHeading.astro
 * Structural Role: Reusable sections UI component
 */
import SectionHeading from "./SectionHeading.astro";

const { items = [], title = "Verification and Intelligence Matrix", subtitle = "Proof Signals" } = Astro.props;
---

<section class="section-padding bg-gradient-to-b from-kharon-charcoal to-kharon-black">
  <div class="mx-auto max-w-7xl px-6">
    <SectionHeading
      title={title}
      subtitle={subtitle}
      description="Engineered verification and intelligence signals that demonstrate operational capability."
      center={true}
    />

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((item: any, index: number) => (
        <div class="rounded-lg border border-kharon-purple/15 bg-kharon-surface-elevated p-6 backdrop-blur-sm kharon-surface">
          <div class="flex items-start">
            <div class="flex-shrink-0">
              <div class="flex h-10 w-10 items-center justify-center rounded-md bg-kharon-purple/20 text-kharon-purple">
                {index + 1}
              </div>
            </div>
            <div class="ml-4">
              <h3 class="text-lg font-semibold text-white">{item.title}</h3>
              <p class="mt-2 text-kharon-light/70">{item.text}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
