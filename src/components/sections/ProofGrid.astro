---
import SectionHeading from "./SectionHeading.astro";

const {
  eyebrow,
  title,
  text,
  items = [],
  dark = false
} = Astro.props;
---

<section class={`section-padding relative overflow-hidden ${dark ? "bg-kharon-black text-white" : "bg-white"}`}>
  <!-- Decorative background elements -->
  {dark ? (
    <div class="absolute inset-0 z-0">
      <div class="absolute -top-40 -right-40 h-96 w-96 rounded-full bg-kharon-purple/10 blur-[100px]"></div>
      <div class="absolute top-1/2 left-0 h-64 w-64 -translate-y-1/2 rounded-full bg-kharon-cyan/5 blur-[80px]"></div>
    </div>
  ) : (
    <div class="absolute inset-0 z-0 opacity-40">
      <div class="absolute -top-40 right-10 h-96 w-96 rounded-full bg-kharon-blue/5 blur-[80px]"></div>
      <div class="absolute bottom-10 left-10 h-64 w-64 rounded-full bg-kharon-purple/5 blur-[60px]"></div>
    </div>
  )}

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionHeading eyebrow={eyebrow} title={title} text={text} dark={dark} />

    <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-12" data-animate="slide-up">
      {items.map((item: any, index: number) => {
        // Asymmetric logic: make the first item larger if odd number of items, or alternate sizes
        let spanClass = "col-span-12 md:col-span-6 lg:col-span-4";
        if (items.length === 3) {
           spanClass = index === 0 ? "col-span-12 lg:col-span-6 lg:row-span-2" : "col-span-12 md:col-span-6 lg:col-span-6";
        } else if (items.length === 4) {
           spanClass = (index === 0 || index === 3) ? "col-span-12 lg:col-span-7" : "col-span-12 lg:col-span-5";
        }
        
        const Element = item.href ? "a" : "div";
        const isInteractive = !!item.href;

        return (
          <Element 
            href={item.href} 
            class={`group relative overflow-hidden rounded-2xl border p-6 sm:p-7 transition-all duration-500 ${spanClass} 
              ${dark 
                ? 'border-white/10 bg-white/[0.02] hover:bg-white/[0.04] hover:border-kharon-cyan/30 shadow-lg shadow-black/20' 
                : 'border-kharon-border bg-white hover:border-kharon-purple/30 hover:shadow-xl shadow-md shadow-black/5'} 
              ${isInteractive ? 'cursor-pointer' : ''}
            `}
          >
            <!-- Ambient hover glow -->
            <div class={`absolute -right-10 -top-10 h-32 w-32 rounded-full blur-[40px] transition-opacity duration-500 opacity-0 group-hover:opacity-100 ${dark ? 'bg-kharon-cyan/20' : 'bg-kharon-purple/10'}`}></div>

            <div class="relative z-10 flex h-full flex-col">
              <div class="flex items-center justify-between mb-6">
                {item.status && (
                  <span class={`inline-flex items-center rounded-full px-3 py-1 text-[10px] font-bold uppercase tracking-wider ${dark ? "bg-kharon-cyan/10 text-kharon-cyan" : "bg-kharon-purple/10 text-kharon-purple"}`}>
                    <span class={`mr-2 h-1.5 w-1.5 rounded-full ${dark ? "bg-kharon-cyan" : "bg-kharon-purple"} animate-pulse`}></span>
                    {item.status}
                  </span>
                )}
                {isInteractive && (
                  <svg class={`h-5 w-5 transition-transform duration-300 group-hover:translate-x-1 ${dark ? "text-kharon-cyan/50 group-hover:text-kharon-cyan" : "text-kharon-purple/50 group-hover:text-kharon-purple"}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
                  </svg>
                )}
              </div>

              <h3 class={`text-2xl font-bold leading-tight tracking-tight ${dark ? 'text-white' : 'text-kharon-black'}`}>
                {item.title}
              </h3>

              <p class={`mt-4 leading-relaxed ${dark ? "text-white/70" : "text-kharon-grey"} ${spanClass.includes('row-span-2') ? 'text-lg' : ''}`}>
                {item.text}
              </p>
            </div>
          </Element>
        );
      })}
    </div>
  </div>
</section>
