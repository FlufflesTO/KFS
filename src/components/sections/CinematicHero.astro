---
const trustSignals = ["SAQCC", "SANS 10139", "SANS 14520", "Commercial & Industrial Only"];
---

<section class="hero-cinematic relative isolate overflow-hidden bg-kharon-black text-white">
  <div class="hero-cinematic__atmosphere" aria-hidden="true"></div>
  <img src="/brand/kharon-mark.svg" alt="" class="hero-cinematic__titan" aria-hidden="true" loading="eager" decoding="async" width="554" height="754" />
  <div class="hero-cinematic__structure" aria-hidden="true"></div>
  <div class="hero-cinematic__floor" aria-hidden="true"></div>

  <svg class="hero-cinematic__linework" viewBox="0 0 1080 620" aria-hidden="true">
    <defs>
      <linearGradient id="hero-linework-primary" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#00C2FF" stop-opacity="0" />
        <stop offset="45%" stop-color="#00C2FF" stop-opacity="0.45" />
        <stop offset="100%" stop-color="#C4332F" stop-opacity="0.32" />
      </linearGradient>
    </defs>
    <path d="M160 440H360L472 328H660L810 214" />
    <path d="M230 272H410L520 380H730" />
    <path d="M340 506L500 450L650 506L870 356" />
    <path class="secondary" d="M660 118V492M752 150V426M844 210V386" />
    <circle cx="360" cy="440" r="5" />
    <circle cx="472" cy="328" r="5" />
    <circle cx="660" cy="328" r="5" />
    <circle class="critical" cx="810" cy="214" r="6" />
  </svg>

  <div class="relative z-10 mx-auto grid min-h-[auto] max-w-7xl items-center gap-8 px-4 py-28 sm:px-6 md:min-h-[min(680px,calc(82svh-5rem))] md:py-14 lg:grid-cols-[1.05fr_0.95fr] lg:py-16">
    <div class="max-w-4xl">
      <p class="mb-4 text-xs font-bold uppercase text-kharon-cyan">
        Commercial Fire Detection & Gaseous Suppression Specialists
      </p>

      <h1 class="kharon-h1">
        Engineering-led fire detection and gaseous suppression for critical infrastructure.
      </h1>

      <p class="mt-4 max-w-2xl text-base leading-7 text-white/72">
        Commercial and industrial systems designed, installed, serviced and maintained for lifecycle support, compliance alignment and operational continuity.
      </p>

      <div class="mt-5 grid grid-cols-2 gap-2 sm:flex sm:flex-wrap">
        {trustSignals.map((item) => (
          <span class="border border-white/10 bg-white/[0.035] px-3 py-2 text-xs font-bold uppercase leading-5 text-white/72">
            {item}
          </span>
        ))}
      </div>

      <div class="mt-6 grid gap-3 sm:flex sm:flex-wrap">
        <a href="/contact?intent=site-assessment" class="rounded-md bg-kharon-purple px-5 py-4 text-center font-semibold text-white hover:bg-kharon-blue sm:px-6">
          Request Site Assessment
        </a>
        <a href="/emergency-support" class="rounded-md border border-red-400/50 px-5 py-4 text-center font-semibold text-white hover:bg-red-500/15 sm:px-6">
          Emergency Support
        </a>
      </div>
    </div>

    <div class="hero-cinematic__void hidden lg:block" aria-hidden="true"></div>
  </div>
</section>
