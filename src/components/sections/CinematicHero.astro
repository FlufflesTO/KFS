---
/**
 * Project Sentinel - Cinematic Hero Component
 * Purpose: Hero section for landing page with animated SVGs and trust signals
 * Dependencies: None
 * Structural Role: Main landing page visual intro section
 */
const trustSignals = ["SAQCC", "SANS 10139", "SANS 14520", "Commercial & Industrial Only"];
---

<section class="hero-cinematic relative isolate overflow-hidden bg-kharon-black text-white">
  <div class="hero-cinematic__atmosphere" aria-hidden="true"></div>
  <img src="/brand/kharon-mark.svg" alt="" class="hero-cinematic__titan" aria-hidden="true" loading="eager" decoding="async" width="554" height="754" />
  <div class="hero-cinematic__structure" aria-hidden="true"></div>
  <div class="hero-cinematic__floor" aria-hidden="true"></div>

  <svg class="hero-cinematic__linework" viewBox="0 0 1080 620" aria-hidden="true">
    <defs>
      <linearGradient id="hero-linework-primary" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#00C2FF" stop-opacity="0" />
        <stop offset="45%" stop-color="#00C2FF" stop-opacity="0.45" />
        <stop offset="100%" stop-color="#C4332F" stop-opacity="0.32" />
      </linearGradient>
    </defs>
    <path d="M160 440H360L472 328H660L810 214" />
    <path d="M230 272H410L520 380H730" />
    <path d="M340 506L500 450L650 506L870 356" />
    <path class="secondary" d="M660 118V492M752 150V426M844 210V386" />
    <circle cx="360" cy="440" r="5" />
    <circle cx="472" cy="328" r="5" />
    <circle cx="660" cy="328" r="5" />
    <circle class="critical" cx="810" cy="214" r="6" />
  </svg>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl py-20 lg:py-32">
      <div class="reveal inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-kharon-cyan opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-kharon-cyan"></span>
        </span>
        <p class="text-[0.625rem] font-bold uppercase tracking-[0.2em] text-kharon-cyan">
          Commercial & Industrial Specialization
        </p>
      </div>

      <h1 class="kharon-h1 reveal reveal-delayed text-white">
        Engineering fire <span class="text-kharon-cyan">detection</span> and <span class="text-kharon-red">suppression</span> for critical infrastructure.
      </h1>

      <p class="mt-8 reveal reveal-delayed text-lg leading-relaxed text-white/80 max-w-2xl">
        High-consequence systems designed, installed, and maintained for operational continuity, life safety, and regulatory compliance.
      </p>

      <div class="mt-10 flex flex-wrap gap-2 reveal reveal-delayed">
        {trustSignals.map((item) => (
          <span class="rounded border border-white/5 bg-white/5 px-2.5 py-1 text-[0.625rem] font-bold uppercase tracking-widest text-white/60">
            {item}
          </span>
        ))}
      </div>

      <div class="mt-12 flex flex-col sm:flex-row gap-4 reveal reveal-delayed">
        <a href="/contact?intent=site-assessment" class="group relative flex items-center justify-center gap-2 overflow-hidden rounded-md bg-kharon-purple px-8 py-4 text-sm font-bold uppercase tracking-widest text-white transition-all hover:bg-kharon-blue hero-cta-button">
          Request Site Assessment
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </a>
        <a href="/emergency-support" class="flex items-center justify-center rounded-md border border-white/20 bg-transparent px-8 py-4 text-sm font-bold uppercase tracking-widest text-white backdrop-blur-sm transition-all hover:bg-white/10">
          Emergency Support
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-cta-button:hover {
    box-shadow: 0 0 20px rgba(75, 46, 131, 0.3);
  }
</style>
