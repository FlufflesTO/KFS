---
/**
 * Project Sentinel - Cinematic Hero Component
 * Purpose: Hero section for landing page with animated SVGs and trust signals
 * Dependencies: None
 * Structural Role: Main landing page visual intro section
 */
const trustSignals = ["SAQCC", "SANS 10139", "SANS 14520", "Commercial & Industrial Only"];
---

<section class="hero-cinematic relative isolate overflow-hidden bg-transparent text-white border-b border-white/5">

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl py-12 lg:py-24">
      <div class="reveal inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3.5 py-1 mb-10">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-kharon-purple opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-kharon-purple"></span>
        </span>
        <p class="text-[0.625rem] font-bold uppercase tracking-[0.25em] text-kharon-purple">
          Commercial & Industrial Specialization
        </p>
      </div>

      <h1 class="kharon-h1 reveal reveal-delayed text-white">
        Engineering fire <span class="text-kharon-purple">detection</span> and <span class="text-kharon-red">suppression</span> for critical infrastructure.
      </h1>

      <p class="mt-8 reveal reveal-delayed text-base sm:text-lg leading-relaxed text-white/70 max-w-2xl font-medium">
        High-consequence systems designed, installed, and maintained for operational continuity, life safety, and regulatory compliance.
      </p>

      <div class="mt-10 flex flex-wrap gap-2 reveal reveal-delayed">
        {trustSignals.map((item) => (
          <span class="rounded-sm border border-white/5 bg-white/5 px-3 py-1 text-[0.625rem] font-bold uppercase tracking-[0.15em] text-white/40">
            {item}
          </span>
        ))}
      </div>

      <div class="mt-14 flex flex-col sm:flex-row gap-4 reveal reveal-delayed">
        <a href="/contact?intent=site-assessment" class="group relative flex items-center justify-center gap-2 overflow-hidden rounded-md bg-kharon-purple px-8 py-4 text-xs font-bold uppercase tracking-widest text-white transition-all hover:bg-kharon-blue hero-cta-button shadow-lg">
          Request Site Assessment
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </a>
        <a href="/emergency-support" class="flex items-center justify-center rounded-md border border-white/10 bg-transparent px-8 py-4 text-xs font-bold uppercase tracking-widest text-white backdrop-blur-sm transition-all hover:bg-white/5">
          Emergency Support
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-cta-button:hover {
    box-shadow: 0 0 20px rgba(75, 46, 131, 0.3);
  }
</style>
