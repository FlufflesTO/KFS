/**
 * Project Sentinel - Infrastructure Technical Blocks
 * Purpose: Renders critical infrastructure uptime impact models, escalation dependency maps, and risk-tier matrices.
 * Dependencies: Astro section layout, SVG.
 * Structural Role: Presentation component for infrastructure page.
 */
<section class="section-padding bg-white">
  <div class="mx-auto max-w-7xl px-6">

    {/* Block 1: Uptime Impact Model */}
    <div class="max-w-4xl">
      <span class="text-sm font-bold uppercase tracking-wider text-kharon-purple">
        Uptime Impact Model
      </span>
      <h2 class="text-3xl font-bold leading-tight text-kharon-black mt-2">
        The cost of failure changes by facility tier.
      </h2>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-3">
      {/* Tier 1 */}
      <article class="rounded-lg border border-kharon-border p-6 bg-white">
        <div class="flex items-center gap-3">
          <div class="h-3 w-3 rounded-full bg-kharon-red"></div>
          <p class="text-xs font-bold uppercase text-kharon-red">Tier 1</p>
        </div>
        <h3 class="mt-3 text-xl font-bold leading-tight text-kharon-black">
          Mission Critical
        </h3>
        <p class="mt-2 text-sm text-kharon-grey">
          Data centres, hospitals, banking
        </p>
        <dl class="mt-5 space-y-4">
          <div>
            <dt class="text-xs font-bold uppercase text-kharon-grey">Financial</dt>
            <dd class="mt-1 text-sm font-semibold text-kharon-black">&gt;R500k/hour</dd>
          </div>
          <div>
            <dt class="text-xs font-bold uppercase text-kharon-grey">Operational</dt>
            <dd class="mt-1 text-sm font-semibold text-kharon-black">Full service interruption</dd>
          </div>
          <div>
            <dt class="text-xs font-bold uppercase text-kharon-grey">Reputation</dt>
            <dd class="mt-1 text-sm font-semibold text-kharon-black">Regulatory investigation + public disclosure</dd>
          </div>
        </dl>
      </article>

      {/* Tier 2 */}
      <article class="rounded-lg border border-kharon-border p-6 bg-white">
        <div class="flex items-center gap-3">
          <div class="h-3 w-3 rounded-full bg-kharon-amber"></div>
          <p class="text-xs font-bold uppercase text-kharon-amber">Tier 2</p>
        </div>
        <h3 class="mt-3 text-xl font-bold leading-tight text-kharon-black">
          Business Critical
        </h3>
        <p class="mt-2 text-sm text-kharon-grey">
          Manufacturing, warehousing, logistics
        </p>
        <dl class="mt-5 space-y-4">
          <div>
            <dt class="text-xs font-bold uppercase text-kharon-grey">Financial</dt>
            <dd class="mt-1 text-sm font-semibold text-kharon-black">R50-500k/hour</dd>
          </div>
          <div>
            <dt class="text-xs font-bold uppercase text-kharon-grey">Operational</dt>
            <dd class="mt-1 text-sm font-semibold text-kharon-black">Production halt</dd>
          </div>
          <div>
            <dt class="text-xs font-bold uppercase text-kharon-grey">Reputation</dt>
            <dd class="mt-1 text-sm font-semibold text-kharon-black">Contract penalties + client notification</dd>
          </div>
        </dl>
      </article>

      {/* Tier 3 */}
      <article class="rounded-lg border border-kharon-border p-6 bg-white">
        <div class="flex items-center gap-3">
          <div class="h-3 w-3 rounded-full bg-kharon-grey"></div>
          <p class="text-xs font-bold uppercase text-kharon-grey">Tier 3</p>
        </div>
        <h3 class="mt-3 text-xl font-bold leading-tight text-kharon-black">
          Business Important
        </h3>
        <p class="mt-2 text-sm text-kharon-grey">
          Commercial offices, retail
        </p>
        <dl class="mt-5 space-y-4">
          <div>
            <dt class="text-xs font-bold uppercase text-kharon-grey">Financial</dt>
            <dd class="mt-1 text-sm font-semibold text-kharon-black">&lt;R50k/hour</dd>
          </div>
          <div>
            <dt class="text-xs font-bold uppercase text-kharon-grey">Operational</dt>
            <dd class="mt-1 text-sm font-semibold text-kharon-black">Partial disruption</dd>
          </div>
          <div>
            <dt class="text-xs font-bold uppercase text-kharon-grey">Reputation</dt>
            <dd class="mt-1 text-sm font-semibold text-kharon-black">Internal incident report</dd>
          </div>
        </dl>
      </article>
    </div>

    {/* Block 2: Escalation and Response Dependency Map */}
    <div class="mt-16">
      <div class="max-w-4xl">
        <span class="text-sm font-bold uppercase tracking-wider text-kharon-purple">
          Escalation and Response Dependency Map
        </span>
        <h2 class="text-3xl font-bold leading-tight text-kharon-black mt-2">
          Every minute is mapped from detection to resolution.
        </h2>
      </div>

      <div class="mt-10">
        <svg
          viewBox="0 0 1200 220"
          role="img"
          aria-label="Escalation and response dependency map"
          class="h-auto w-full max-w-4xl mx-auto"
          font-family="system-ui, -apple-system, sans-serif"
        >
          <defs>
            <filter id="nodeShadow" x="-10%" y="-10%" width="120%" height="120%">
              <feDropShadow dx="0" dy="2" stdDeviation="3" flood-color="#000000" flood-opacity="0.1" />
            </filter>
          </defs>

          {/* Connector lines */}
          <line x1="140" y1="100" x2="220" y2="100" stroke="#00C2FF" stroke-width="2" />
          <line x1="340" y1="100" x2="420" y2="100" stroke="#00C2FF" stroke-width="2" />
          <line x1="540" y1="100" x2="620" y2="100" stroke="#00C2FF" stroke-width="2" />
          <line x1="740" y1="100" x2="820" y2="100" stroke="#00C2FF" stroke-width="2" />
          <line x1="940" y1="100" x2="1020" y2="100" stroke="#C4332F" stroke-width="2" stroke-dasharray="6 4" />

          {/* Node 1: Detection Event */}
          <rect x="20" y="68" width="120" height="64" rx="8" fill="#4B2E83" filter="url(#nodeShadow)" />
          <text x="80" y="100" text-anchor="middle" fill="#FFFFFF" font-size="11" font-weight="600">Detection</text>
          <text x="80" y="116" text-anchor="middle" fill="#FFFFFF" font-size="11" font-weight="600">Event</text>

          {/* Time: 2 min */}
          <rect x="155" y="90" width="50" height="20" rx="4" fill="#F59E0B" />
          <text x="180" y="104" text-anchor="middle" fill="#0B0D0F" font-size="10" font-weight="bold">2 min</text>

          {/* Node 2: Control Room Acknowledgement */}
          <rect x="220" y="68" width="120" height="64" rx="8" fill="#4B2E83" filter="url(#nodeShadow)" />
          <text x="280" y="92" text-anchor="middle" fill="#FFFFFF" font-size="10" font-weight="600">Control</text>
          <text x="280" y="106" text-anchor="middle" fill="#FFFFFF" font-size="10" font-weight="600">Room</text>
          <text x="280" y="120" text-anchor="middle" fill="#FFFFFF" font-size="10" font-weight="600">Ack</text>

          {/* Time: Tier dispatches stacked vertically to fit within gap */}
          <rect x="345" y="44" width="70" height="16" rx="3" fill="#F59E0B" />
          <text x="380" y="56" text-anchor="middle" fill="#0B0D0F" font-size="9" font-weight="bold">T1: 30min</text>
          
          <rect x="345" y="64" width="70" height="16" rx="3" fill="#F59E0B" />
          <text x="380" y="76" text-anchor="middle" fill="#0B0D0F" font-size="9" font-weight="bold">T2: 2hr</text>
          
          <rect x="345" y="84" width="70" height="16" rx="3" fill="#F59E0B" />
          <text x="380" y="96" text-anchor="middle" fill="#0B0D0F" font-size="9" font-weight="bold">T3: 4hr</text>

          {/* Node 3: Field Technician Dispatch */}
          <rect x="420" y="68" width="120" height="64" rx="8" fill="#4B2E83" filter="url(#nodeShadow)" />
          <text x="480" y="92" text-anchor="middle" fill="#FFFFFF" font-size="10" font-weight="600">Field</text>
          <text x="480" y="106" text-anchor="middle" fill="#FFFFFF" font-size="10" font-weight="600">Tech</text>
          <text x="480" y="120" text-anchor="middle" fill="#FFFFFF" font-size="10" font-weight="600">Dispatch</text>

          {/* Time label */}
          <rect x="550" y="90" width="60" height="20" rx="4" fill="#F59E0B" />
          <text x="580" y="104" text-anchor="middle" fill="#0B0D0F" font-size="10" font-weight="bold">Varies</text>

          {/* Node 4: On-Site Assessment */}
          <rect x="620" y="68" width="120" height="64" rx="8" fill="#4B2E83" filter="url(#nodeShadow)" />
          <text x="680" y="99" text-anchor="middle" fill="#FFFFFF" font-size="10" font-weight="600">On-Site</text>
          <text x="680" y="115" text-anchor="middle" fill="#FFFFFF" font-size="10" font-weight="600">Assessment</text>

          {/* Time label */}
          <rect x="745" y="90" width="70" height="20" rx="4" fill="#F59E0B" />
          <text x="780" y="104" text-anchor="middle" fill="#0B0D0F" font-size="10" font-weight="bold">Immediate</text>

          {/* Node 5: Resolution or Escalation */}
          <rect x="820" y="68" width="120" height="64" rx="8" fill="#C4332F" filter="url(#nodeShadow)" />
          <text x="880" y="92" text-anchor="middle" fill="#FFFFFF" font-size="10" font-weight="600">Resolution</text>
          <text x="880" y="106" text-anchor="middle" fill="#FFFFFF" font-size="10" font-weight="600">or</text>
          <text x="880" y="120" text-anchor="middle" fill="#FFFFFF" font-size="10" font-weight="600">Escalation</text>

          {/* Time: 24hr */}
          <rect x="950" y="90" width="60" height="20" rx="4" fill="#F59E0B" />
          <text x="980" y="104" text-anchor="middle" fill="#0B0D0F" font-size="10" font-weight="bold">24hr</text>

          {/* Node 6: Post-Incident Report */}
          <rect x="1020" y="68" width="120" height="64" rx="8" fill="#4B2E83" filter="url(#nodeShadow)" />
          <text x="1080" y="99" text-anchor="middle" fill="#FFFFFF" font-size="11" font-weight="600">Post-Incident</text>
          <text x="1080" y="115" text-anchor="middle" fill="#FFFFFF" font-size="11" font-weight="600">Report</text>
        </svg>
      </div>
    </div>

    {/* Block 3: Site Risk-Tier Matrix */}
    <div class="mt-16">
      <div class="max-w-4xl">
        <span class="text-sm font-bold uppercase tracking-wider text-kharon-purple">
          Site Risk-Tier Matrix
        </span>
        <h2 class="text-3xl font-bold leading-tight text-kharon-black mt-2">
          Protection requirements by facility classification.
        </h2>
      </div>

      <div class="mt-10 overflow-x-auto">
        <div class="min-w-[640px] rounded-lg border border-kharon-border bg-white">
          {/* Header row */}
          <div class="grid grid-cols-4 border-b border-kharon-border">
            <div class="px-5 py-4 text-xs font-bold uppercase text-kharon-grey">
              Criteria
            </div>
            <div class="px-5 py-4 text-center text-xs font-bold uppercase bg-kharon-purple text-white">
              Tier 1
            </div>
            <div class="px-5 py-4 text-center text-xs font-bold uppercase text-kharon-black bg-kharon-light">
              Tier 2
            </div>
            <div class="px-5 py-4 text-center text-xs font-bold uppercase text-kharon-black bg-kharon-light">
              Tier 3
            </div>
          </div>

          {/* Row 1: Response SLA */}
          <div class="grid grid-cols-4 border-b border-kharon-border">
            <div class="px-5 py-4 text-sm font-semibold text-kharon-black">
              Response SLA
            </div>
            <div class="px-5 py-4 text-center text-sm text-kharon-black bg-kharon-purple/5">
              30 min
            </div>
            <div class="px-5 py-4 text-center text-sm text-kharon-black">
              2 hours
            </div>
            <div class="px-5 py-4 text-center text-sm text-kharon-black">
              4 hours
            </div>
          </div>

          {/* Row 2: Inspection Frequency */}
          <div class="grid grid-cols-4 border-b border-kharon-border">
            <div class="px-5 py-4 text-sm font-semibold text-kharon-black">
              Inspection Frequency
            </div>
            <div class="px-5 py-4 text-center text-sm text-kharon-black bg-kharon-purple/5">
              Monthly
            </div>
            <div class="px-5 py-4 text-center text-sm text-kharon-black">
              Quarterly
            </div>
            <div class="px-5 py-4 text-center text-sm text-kharon-black">
              6-Monthly
            </div>
          </div>

          {/* Row 3: System Redundancy */}
          <div class="grid grid-cols-4 border-b border-kharon-border">
            <div class="px-5 py-4 text-sm font-semibold text-kharon-black">
              System Redundancy
            </div>
            <div class="px-5 py-4 text-center text-sm text-kharon-black bg-kharon-purple/5">
              N+1 mandatory
            </div>
            <div class="px-5 py-4 text-center text-sm text-kharon-black">
              Recommended
            </div>
            <div class="px-5 py-4 text-center text-sm text-kharon-black">
              Optional
            </div>
          </div>

          {/* Row 4: Monitoring */}
          <div class="grid grid-cols-4 border-b border-kharon-border">
            <div class="px-5 py-4 text-sm font-semibold text-kharon-black">
              Monitoring
            </div>
            <div class="px-5 py-4 text-center text-sm text-kharon-black bg-kharon-purple/5">
              24/7 remote + on-site
            </div>
            <div class="px-5 py-4 text-center text-sm text-kharon-black">
              24/7 remote
            </div>
            <div class="px-5 py-4 text-center text-sm text-kharon-black">
              Business hours
            </div>
          </div>

          {/* Row 5: Backup Power */}
          <div class="grid grid-cols-4 border-b border-kharon-border">
            <div class="px-5 py-4 text-sm font-semibold text-kharon-black">
              Backup Power
            </div>
            <div class="px-5 py-4 text-center text-sm text-kharon-black bg-kharon-purple/5">
              UPS + generator mandatory
            </div>
            <div class="px-5 py-4 text-center text-sm text-kharon-black">
              UPS recommended
            </div>
            <div class="px-5 py-4 text-center text-sm text-kharon-black">
              None required
            </div>
          </div>

          {/* Row 6: Documentation */}
          <div class="grid grid-cols-4">
            <div class="px-5 py-4 text-sm font-semibold text-kharon-black">
              Documentation
            </div>
            <div class="px-5 py-4 text-center text-sm text-kharon-black bg-kharon-purple/5">
              Real-time digital
            </div>
            <div class="px-5 py-4 text-center text-sm text-kharon-black">
              Digital quarterly
            </div>
            <div class="px-5 py-4 text-center text-sm text-kharon-black">
              Annual paper
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
