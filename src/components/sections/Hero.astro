---
const { title, text, proofItems = [] } = Astro.props;
---

<section class="hero-padding relative isolate overflow-hidden bg-kharon-black text-white">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_80%_20%,rgba(75,46,131,0.45),transparent_32%),linear-gradient(180deg,rgba(0,0,0,0.82),rgba(11,13,15,0.95))]"></div>
  <div class="absolute inset-0 opacity-[0.08] [background-image:linear-gradient(rgba(255,255,255,.18)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.18)_1px,transparent_1px)] [background-size:48px_48px]"></div>

  <div class="relative z-10 mx-auto grid min-h-[68vh] max-w-7xl items-center gap-12 px-6 lg:grid-cols-[1.1fr_0.9fr]">
    <div class="reveal">
      <p class="mb-4 text-sm font-bold uppercase text-kharon-cyan">
        Commercial Fire Detection & Gas Suppression Specialists
      </p>

      <h1 class="kharon-h1 max-w-5xl">
        {title}
      </h1>

      <p class="mt-6 max-w-3xl text-lg leading-8 text-white/70">
        {text}
      </p>

      <p class="mt-5 inline-flex rounded-md border border-kharon-cyan/30 bg-kharon-cyan/10 px-4 py-3 text-sm font-bold uppercase text-kharon-cyan">
        Commercial & industrial environments only
      </p>

      {
        proofItems.length > 0 && (
          <div class="mt-6 grid gap-2 sm:grid-cols-2 lg:grid-cols-4">
            {proofItems.map((item) => (
              <span class="rounded-md border border-white/10 bg-white/[0.04] px-3 py-2 text-xs font-bold uppercase text-white/75">
                {item}
              </span>
            ))}
          </div>
        )
      }

      <div class="mt-10 flex flex-wrap gap-4">
        <a href="/contact?intent=site-assessment" class="rounded-md bg-kharon-purple px-6 py-4 font-semibold text-white hover:-translate-y-0.5 hover:bg-kharon-blue">
          Request Site Assessment
        </a>

        <a href="/emergency-support" class="rounded-md border border-red-400/40 px-6 py-4 font-semibold text-white hover:-translate-y-0.5 hover:bg-red-500/15">
          Emergency Support
        </a>

        <a href="/gas-suppression" class="rounded-md border border-white/20 px-6 py-4 font-semibold text-white hover:-translate-y-0.5 hover:bg-white/10">
          View Solutions
        </a>
      </div>
    </div>

    <div class="hidden rounded-lg border border-white/10 bg-white/[0.035] p-6 shadow-2xl lg:block">
      <div class="mb-5 flex items-center justify-between">
        <span class="text-xs font-bold uppercase text-white/45">Protection Architecture</span>
        <span class="text-xs font-bold uppercase text-red-300/75">critical path</span>
      </div>

      <svg viewBox="0 0 520 390" role="img" aria-label="Fire detection and gas suppression protection architecture" class="h-auto w-full">
        <defs>
          <linearGradient id="hero-architecture-line" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#00C2FF" stop-opacity="0.2" />
            <stop offset="65%" stop-color="#00C2FF" stop-opacity="0.78" />
            <stop offset="100%" stop-color="#C4332F" stop-opacity="0.78" />
          </linearGradient>
          <filter id="hero-architecture-glow" x="-30%" y="-30%" width="160%" height="160%">
            <feGaussianBlur stdDeviation="3" result="blur" />
            <feMerge>
              <feMergeNode in="blur" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
        </defs>

        <rect x="18" y="18" width="484" height="354" rx="14" fill="#0B0D0F" stroke="#ffffff" stroke-opacity="0.08" />
        <path d="M46 86H474M46 152H474M46 218H474M46 284H474M126 46V344M260 46V344M394 46V344" stroke="#ffffff" stroke-opacity="0.06" />

        <path d="M82 96H206L260 154H362L438 226" fill="none" stroke="url(#hero-architecture-line)" stroke-width="4" stroke-linecap="round" />
        <path d="M116 264H212L260 212H342" fill="none" stroke="#00C2FF" stroke-opacity="0.45" stroke-width="2" stroke-dasharray="8 10" stroke-linecap="round" />

        <g filter="url(#hero-architecture-glow)">
          <rect x="54" y="70" width="88" height="52" rx="8" fill="#111820" stroke="#00C2FF" stroke-opacity="0.75" />
          <text x="98" y="91" text-anchor="middle" fill="#DDE4EA" font-size="13" font-family="Century Gothic, Arial">Detect</text>
          <text x="98" y="110" text-anchor="middle" fill="#7DD3FC" font-size="10" font-family="Century Gothic, Arial">addressable loop</text>

          <rect x="176" y="128" width="104" height="52" rx="8" fill="#111820" stroke="#00C2FF" stroke-opacity="0.75" />
          <text x="228" y="149" text-anchor="middle" fill="#DDE4EA" font-size="13" font-family="Century Gothic, Arial">Confirm</text>
          <text x="228" y="168" text-anchor="middle" fill="#7DD3FC" font-size="10" font-family="Century Gothic, Arial">panel logic</text>

          <rect x="324" y="198" width="106" height="58" rx="8" fill="#351416" stroke="#C4332F" stroke-opacity="0.85" />
          <text x="377" y="221" text-anchor="middle" fill="#F8FAFC" font-size="13" font-family="Century Gothic, Arial">Release</text>
          <text x="377" y="240" text-anchor="middle" fill="#FCA5A5" font-size="10" font-family="Century Gothic, Arial">gas suppression</text>

          <circle cx="116" cy="264" r="10" fill="#00C2FF" fill-opacity="0.35" stroke="#00C2FF" />
          <circle cx="260" cy="212" r="10" fill="#00C2FF" fill-opacity="0.35" stroke="#00C2FF" />
          <circle cx="342" cy="212" r="10" fill="#C4332F" fill-opacity="0.35" stroke="#C4332F" />
        </g>

        <text x="54" y="322" fill="#DDE4EA" font-size="12" font-family="Century Gothic, Arial">01 detection zoning</text>
        <text x="204" y="322" fill="#DDE4EA" font-size="12" font-family="Century Gothic, Arial">02 verified cause/effect</text>
        <text x="374" y="322" fill="#DDE4EA" font-size="12" font-family="Century Gothic, Arial">03 lifecycle evidence</text>
      </svg>
    </div>
  </div>
</section>
