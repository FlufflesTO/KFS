---
const { title, text, proofItems = [] } = Astro.props;
---

<section class="hero-padding relative isolate overflow-hidden bg-kharon-black text-white">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_80%_20%,rgba(75,46,131,0.45),transparent_32%),linear-gradient(180deg,rgba(0,0,0,0.82),rgba(11,13,15,0.95))]"></div>
  <div class="absolute inset-0 opacity-[0.08] [background-image:linear-gradient(rgba(255,255,255,.18)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.18)_1px,transparent_1px)] [background-size:48px_48px]"></div>

  <div class="relative z-10 mx-auto grid min-h-[68vh] max-w-7xl items-center gap-12 px-6 lg:grid-cols-[1.1fr_0.9fr]">
    <div class="reveal">
      <p class="mb-4 text-sm font-bold uppercase text-kharon-cyan">
        Commercial Fire Detection & Gas Suppression Specialists
      </p>

      <h1 class="kharon-h1 max-w-5xl">
        {title}
      </h1>

      <p class="mt-6 max-w-3xl text-lg leading-8 text-white/70">
        {text}
      </p>

      <p class="mt-5 inline-flex rounded-md border border-kharon-cyan/30 bg-kharon-cyan/10 px-4 py-3 text-sm font-bold uppercase text-kharon-cyan">
        Commercial & industrial environments only
      </p>

      {
        proofItems.length > 0 && (
          <div class="mt-6 grid gap-2 sm:grid-cols-2 lg:grid-cols-4">
            {proofItems.map((item) => (
              <span class="rounded-md border border-white/10 bg-white/[0.04] px-3 py-2 text-xs font-bold uppercase text-white/75">
                {item}
              </span>
            ))}
          </div>
        )
      }

      <div class="mt-10 flex flex-wrap gap-4">
        <a href="/contact?intent=site-assessment" class="rounded-md bg-kharon-purple px-6 py-4 font-semibold text-white hover:-translate-y-0.5 hover:bg-kharon-blue">
          Request Site Assessment
        </a>

        <a href="/emergency-support" class="rounded-md border border-red-400/40 px-6 py-4 font-semibold text-white hover:-translate-y-0.5 hover:bg-red-500/15">
          Emergency Support
        </a>

        <a href="/gas-suppression" class="rounded-md border border-white/20 px-6 py-4 font-semibold text-white hover:-translate-y-0.5 hover:bg-white/10">
          View Solutions
        </a>
      </div>
    </div>

    <div class="hero-page-depth hidden min-h-[28rem] lg:block" aria-hidden="true">
      <div class="hero-page-depth__mark">K</div>
      <div class="hero-page-depth__floor"></div>
      <svg viewBox="0 0 520 390" aria-hidden="true" class="hero-page-depth__linework">
        <defs>
          <linearGradient id="hero-architecture-line" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#00C2FF" stop-opacity="0" />
            <stop offset="65%" stop-color="#00C2FF" stop-opacity="0.48" />
            <stop offset="100%" stop-color="#C4332F" stop-opacity="0.34" />
          </linearGradient>
        </defs>

        <path d="M52 94H188L260 156H372L458 236" />
        <path d="M92 276H202L260 226H356" class="secondary" />
        <path d="M410 78V322M330 52V346M250 98V306" class="gridline" />
        <circle cx="188" cy="94" r="5" />
        <circle cx="260" cy="156" r="5" />
        <circle cx="372" cy="156" r="5" />
        <circle class="critical" cx="458" cy="236" r="6" />
      </svg>
    </div>
  </div>
</section>
