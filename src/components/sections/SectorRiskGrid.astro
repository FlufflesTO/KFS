---
/**
 * Project Sentinel - SectorRiskGrid
 * Purpose: Risk analysis profile grid
 * Dependencies: SectionHeading.astro
 * Structural Role: Reusable sections UI component
 */
import SectionHeading from "./SectionHeading.astro";

const { sectors = [] } = Astro.props;
---

<section class="section-padding bg-gradient-to-b from-kharon-charcoal to-kharon-black">
  <div class="mx-auto max-w-7xl px-6">
    <SectionHeading
      title="Infrastructure Risk Profile Grid"
      subtitle="Sector Analysis"
      description="Comprehensive risk analysis for critical infrastructure sectors and operational environments."
      center={true}
    />

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {sectors.map((sector: any) => (
        <div class="rounded-lg border border-kharon-cyan/15 bg-kharon-surface-elevated p-6 backdrop-blur-sm kharon-surface">
          <h3 class="text-lg font-semibold text-white">{sector.title}</h3>
          <p class="mt-2 text-kharon-light/70">{sector.risk}</p>
          <div class="mt-4 flex items-center justify-between">
            <span class="text-xs font-bold uppercase tracking-widest text-kharon-amber">
              {sector.priority}
            </span>
            <div class="h-2 flex-grow mx-2 bg-kharon-graphite rounded-full overflow-hidden">
              <div 
                class="h-full bg-kharon-cyan rounded-full" 
                style={{ width: `${Math.min(100, Math.max(0, sector.riskLevel || 75))}%` }}
              ></div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>