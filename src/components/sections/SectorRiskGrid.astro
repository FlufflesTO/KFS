---
import { industries } from "../../data/site.js";
---

<section id="sectors" class="section-padding bg-white relative overflow-hidden">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl reveal">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-1 w-8 bg-kharon-purple"></div>
        <p class="text-[0.625rem] font-bold uppercase tracking-[0.2em] text-kharon-purple">
          Sectors Served
        </p>
      </div>
      <h2 class="kharon-h2 text-kharon-black">
        Commercial and industrial environments with high operational consequence.
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-kharon-grey max-w-3xl">
        The risk profile changes by facility type. Kharon frames each environment around protected assets, detection reliability, suppression readiness, evacuation logic and service evidence.
      </p>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-2 lg:grid-cols-4 reveal reveal-delayed">
      {industries.map((industry) => (
        <article class="group flex flex-col rounded-md border border-kharon-border bg-kharon-light/50 p-6 transition-all duration-300 hover:border-kharon-purple/20 hover:shadow-md hover:bg-white">
          <p class="text-[0.625rem] font-bold uppercase tracking-[0.2em] text-kharon-purple/50 group-hover:text-kharon-purple transition-colors">{industry.priority}</p>
          <h3 class="mt-4 text-lg font-bold tracking-tight text-kharon-black">{industry.title}</h3>
          <p class="mt-3 text-[0.875rem] leading-relaxed text-kharon-grey/70">{industry.risk}</p>
        </article>
      ))}
    </div>
  </div>
</section>
