---
/**
 * Project Sentinel - SectorRiskGrid
 * Purpose: Risk analysis profile grid with sector icons and SANS tags
 * Dependencies: SectionHeading.astro
 * Structural Role: Reusable sections UI component
 */
import SectionHeading from "./SectionHeading.astro";

const { sectors = [] } = Astro.props;

// Map risk levels to static Tailwind width classes to avoid inline style CSP violations
const widthClasses: Record<number, string> = {
  65: "w-[65%]",
  78: "w-[78%]",
  82: "w-[82%]",
  85: "w-[85%]",
  88: "w-[88%]",
  90: "w-[90%]",
  92: "w-[92%]",
  94: "w-[94%]"
};
---

<section class="section-padding bg-gradient-to-b from-kharon-charcoal to-kharon-black">
  <div class="mx-auto max-w-7xl px-6">
    <SectionHeading
      title="Infrastructure Risk Profile Grid"
      subtitle="Sector Analysis"
      description="Comprehensive risk analysis for critical infrastructure sectors and operational environments."
      center={true}
    />

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {sectors.map((sector: any) => (
        <div class="rounded-lg border border-kharon-purple/15 bg-kharon-surface-elevated p-6 backdrop-blur-sm kharon-surface flex flex-col justify-between">
          <div>
            <div class="flex items-center gap-3">
              {sector.icon && (
                <div class="w-10 h-10 rounded-lg bg-kharon-purple/10 flex items-center justify-center overflow-hidden flex-none">
                  <img src={sector.icon} class="w-full h-full object-contain" alt={`${sector.title} icon`} />
                </div>
              )}
              <h3 class="text-lg font-semibold text-white">{sector.title}</h3>
            </div>
            
            <p class="mt-3 text-kharon-light/70 text-sm leading-relaxed">{sector.risk}</p>
            
            {sector.sans && sector.sans.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-1.5">
                {sector.sans.map((std: string) => (
                  <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-kharon-purple/15 text-kharon-purple border border-kharon-purple/25">
                    {std}
                  </span>
                ))}
              </div>
            )}
          </div>

          <div class="mt-6 flex items-center justify-between border-t border-white/5 pt-4">
            <span class="text-xs font-bold uppercase tracking-widest text-kharon-amber">
              {sector.priority}
            </span>
            <div class="h-2 flex-grow mx-2 bg-kharon-charcoal rounded-full overflow-hidden relative">
              <div 
                class={`h-full bg-kharon-purple rounded-full ${widthClasses[sector.riskLevel as number] || "w-[75%]"}`}
              ></div>
            </div>
            <span class="text-xs font-mono text-white/50">{sector.riskLevel}%</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
