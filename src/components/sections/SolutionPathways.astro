---
/**
 * Project Sentinel - Solution Pathways
 * Purpose: Strategic branching into Fire Protection and Integrated Security domains.
 * Note: High-contrast layout for clear user direction.
 */
import { solutionLinks } from "../../data/site.js";

const pathways = [
  {
    title: "FIRE PROTECTION",
    subtitle: "Suppression & Detection",
    description: "Specialized clean-agent suppression and addressable detection for critical infrastructure.",
    links: solutionLinks.filter(l => l.href.includes('suppression') || l.href.includes('detection')),
    accent: "purple"
  },
  {
    title: "INTEGRATED SECURITY",
    subtitle: "Access & Surveillance",
    description: "Enterprise-grade CCTV and access control integrated with site protection priorities.",
    links: solutionLinks.filter(l => l.href.includes('security')),
    accent: "cyan"
  }
];
---

<section id="pathways" class="section-padding bg-kharon-black overflow-hidden pt-0">
  <div class="container mx-auto max-w-7xl px-6">
    <div class="grid lg:grid-cols-2 gap-4">
      {pathways.map((path) => (
        <div class="group relative rounded-xl border border-kharon-purple/20 bg-kharon-charcoal/30 p-6 sm:p-8 transition-all hover:border-kharon-purple/40">
          <div class={`absolute top-0 left-0 h-1 w-full bg-gradient-to-r ${path.accent === 'purple' ? 'from-kharon-purple to-transparent' : 'from-kharon-cyan to-transparent'} opacity-30`}></div>
          
          <div class="space-y-4">
            <div>
              <p class={`text-[0.55rem] font-black uppercase tracking-[0.3em] ${path.accent === 'purple' ? 'text-kharon-purple' : 'text-kharon-cyan'}`}>{path.subtitle}</p>
              <h2 class="text-3xl font-black mt-1 text-white tracking-tighter uppercase">{path.title}</h2>
            </div>
            
            <p class="text-[0.7rem] text-kharon-light/50 leading-relaxed max-w-md font-medium uppercase tracking-wide">
              {path.description}
            </p>

            <div class="grid gap-2 pt-2">
              {path.links.map(link => (
                <a href={link.href} class="flex items-center justify-between group/link rounded border border-kharon-purple/10 bg-kharon-black/40 p-3 transition-all hover:bg-kharon-purple/10">
                  <span class="text-[0.65rem] font-black uppercase tracking-[0.2em] text-white/70 group-hover/link:text-kharon-cyan">{link.label}</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" class="text-kharon-purple/50 group-hover/link:text-kharon-cyan transition-transform group-hover/link:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-8 text-center">
      <p class="text-[0.5rem] font-bold uppercase tracking-[0.3em] text-white/10">
        Unified Maintenance & Compliance across all domains
      </p>
    </div>
  </div>
</section>
