---
/**
 * Project Sentinel - Solution Pathways
 * Purpose: Strategic branching into Fire Protection and Integrated Security domains.
 * Note: High-contrast layout for clear user direction.
 */
import { solutionLinks } from "../../data/site.js";

const pathways = [
  {
    title: "Fire Protection",
    subtitle: "Suppression & Detection",
    description: "Specialized clean-agent suppression and addressable detection for critical infrastructure.",
    links: solutionLinks.filter(l => l.href.includes('suppression') || l.href.includes('detection')),
    accent: "purple"
  },
  {
    title: "Integrated Security",
    subtitle: "Access & Surveillance",
    description: "Enterprise-grade CCTV and access control integrated with site protection priorities.",
    links: solutionLinks.filter(l => l.href.includes('security')),
    accent: "cyan"
  }
];
---

<section id="pathways" class="section-padding bg-kharon-black overflow-hidden">
  <div class="container mx-auto max-w-7xl px-6">
    <div class="grid lg:grid-cols-2 gap-8">
      {pathways.map((path) => (
        <div class="group relative rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/30 p-8 sm:p-12 transition-all hover:border-kharon-purple/40 hover:bg-kharon-charcoal/50">
          <div class={`absolute top-0 left-0 h-1 w-full bg-gradient-to-r ${path.accent === 'purple' ? 'from-kharon-purple to-transparent' : 'from-kharon-cyan to-transparent'} opacity-50`}></div>
          
          <div class="space-y-6">
            <div>
              <p class={`text-[0.65rem] font-black uppercase tracking-[0.3em] ${path.accent === 'purple' ? 'text-kharon-purple' : 'text-kharon-cyan'}`}>{path.subtitle}</p>
              <h2 class="kharon-h2 mt-2 text-white">{path.title}</h2>
            </div>
            
            <p class="text-kharon-light/60 leading-relaxed max-w-md">
              {path.description}
            </p>

            <div class="grid gap-3 pt-4">
              {path.links.map(link => (
                <a href={link.href} class="flex items-center justify-between group/link rounded-lg border border-kharon-purple/10 bg-kharon-black/20 p-4 transition-all hover:bg-kharon-purple/10">
                  <span class="text-sm font-bold uppercase tracking-widest text-white/80 group-hover/link:text-white">{link.label}</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-kharon-purple transition-transform group-hover/link:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
                </a>
              ))}
            </div>
          </div>

          <!-- Background decoration -->
          <div class={`absolute -right-8 -bottom-8 h-32 w-32 rounded-full blur-[64px] opacity-20 ${path.accent === 'purple' ? 'bg-kharon-purple' : 'bg-kharon-cyan'}`}></div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-[0.6rem] font-bold uppercase tracking-[0.25em] text-kharon-light/30">
        Unified Maintenance & Compliance across all domains
      </p>
    </div>
  </div>
</section>
