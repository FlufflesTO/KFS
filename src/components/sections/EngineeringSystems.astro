---
const systems = [
  {
    eyebrow: "Suppression Logic",
    title: "Confirmed release sequence",
    copy: "Suppression is framed as a controlled system: detection confirmation, alarm state, release logic, protected-room integrity and post-event service evidence.",
    nodes: ["Detect", "Confirm", "Alarm", "Release", "Verify"]
  },
  {
    eyebrow: "Detection Routing",
    title: "Addressable zones with fault visibility",
    copy: "Detection architecture is communicated through loops, panels, response zones and fault paths that operators can understand under pressure.",
    nodes: ["Devices", "Loop", "Panel", "Zone", "Escalate"]
  },
  {
    eyebrow: "Lifecycle Support",
    title: "Inspection-ready maintenance cadence",
    copy: "System ownership continues after installation through testing, defect logging, service records, escalation and lifecycle decisions.",
    nodes: ["Inspect", "Test", "Record", "Rectify", "Report"]
  }
];
---

<section class="section-padding bg-kharon-black text-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-1 w-8 bg-kharon-purple"></div>
        <p class="text-[0.625rem] font-bold uppercase tracking-[0.2em] text-kharon-purple">Engineering Architecture</p>
      </div>
      <h2 class="kharon-h2 text-white">
        Technical systems must be legible before, during and after an incident.
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-white/65">
        Kharon's authority is expressed through system logic: how detection, suppression, escalation, records and service response connect in commercial and industrial environments.
      </p>
    </div>

    <div class="mt-16 grid gap-8 lg:gap-10 lg:grid-cols-3">
      {systems.map((system, systemIndex) => (
        <article class="border-l border-white/10 pl-6 lg:pl-8 py-2 relative group hover:border-kharon-purple/50 transition-colors">
          <p class="text-[0.625rem] font-bold uppercase tracking-[0.2em] text-kharon-purple/80 group-hover:text-kharon-purple transition-colors">{system.eyebrow}</p>
          <h3 class="mt-3 text-xl sm:text-2xl font-bold tracking-tight">{system.title}</h3>
          <p class="mt-4 text-sm leading-relaxed text-white/60">{system.copy}</p>

          <div class="mt-10 overflow-visible">
            <svg viewBox="0 0 420 150" role="img" aria-label={`${system.title} process diagram`} class="h-auto w-full max-w-[28rem] mx-auto opacity-80 group-hover:opacity-100 transition-opacity drop-shadow-md">
              <defs>
                <linearGradient id={`line-${systemIndex}`} x1="0%" y1="0%" x2="100%" y2="0%">
                  <stop offset="0%" stop-color="#00C2FF" stop-opacity="0.1" />
                  <stop offset="60%" stop-color="#00C2FF" stop-opacity="0.5" />
                  <stop offset="100%" stop-color="#C4332F" stop-opacity="0.8" />
                </linearGradient>
                <filter id={`glow-${systemIndex}`} x="-20%" y="-20%" width="140%" height="140%">
                  <feGaussianBlur stdDeviation="4" result="blur" />
                  <feComposite in="SourceGraphic" in2="blur" operator="over" />
                </filter>
              </defs>
              
              <path d="M48 60H372" stroke={`url(#line-${systemIndex})`} stroke-width="2.5" stroke-linecap="round" />
              
              {system.nodes.map((node, index) => {
                const x = 48 + index * 81;
                const critical = index === system.nodes.length - 1;
                return (
                  <g>
                    {critical && <circle cx={x} cy="60" r="20" fill="none" stroke="#C4332F" stroke-width="1" stroke-opacity="0.3" filter={`url(#glow-${systemIndex})`} />}
                    <circle cx={x} cy="60" r="16" fill={critical ? "#3A1618" : "#0B0D0F"} stroke={critical ? "#C4332F" : "#00C2FF"} stroke-width="1.5" stroke-opacity="0.9" />
                    <text x={x} y="105" text-anchor="middle" fill="#FFFFFF" opacity="0.85" font-size="11" font-weight="700" letter-spacing="1" text-transform="uppercase" font-family="system-ui, sans-serif">{node}</text>
                    <text x={x} y="64" text-anchor="middle" fill={critical ? "#F87171" : "#00C2FF"} font-size="10" font-weight="800" font-family="system-ui, sans-serif">0{index + 1}</text>
                  </g>
                );
              })}
            </svg>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
