---
import SectionHeading from "./SectionHeading.astro";
import { industries } from "../../data/site.js";
---

<section class="section-padding bg-white relative overflow-hidden">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="High-Risk Environments"
      title="Protection for facilities where fire events become operational events."
      text="Kharon focuses on commercial and industrial environments where detection reliability, suppression readiness and service records matter to continuity."
      align="center"
    />

    <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {industries.map((industry) => (
        <div class="rounded-xl border border-kharon-border bg-kharon-light/50 p-6 sm:p-8 transition-all hover:bg-white hover:shadow-sm">
          <p class="text-[0.625rem] font-bold uppercase tracking-[0.2em] text-kharon-purple/70">{industry.priority}</p>
          <h3 class="mt-4 text-lg font-bold tracking-tight text-kharon-black">{industry.title}</h3>
          <p class="mt-4 text-sm leading-relaxed text-kharon-grey/80">{industry.risk}</p>
        </div>
      ))}
    </div>
  </div>
</section>
