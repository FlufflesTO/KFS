---
import SectionHeading from "./SectionHeading.astro";
import { industries } from "../../data/site.js";
---

<section class="section-padding bg-white">
  <div class="mx-auto max-w-7xl px-6">
    <SectionHeading
      eyebrow="High-Risk Environments"
      title="Protection for facilities where fire events become operational events."
      text="Kharon focuses on commercial and industrial environments where detection reliability, suppression readiness and service records matter to continuity."
      align="center"
    />

    <div class="mt-14 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {industries.map((industry) => (
        <div class="rounded-lg border border-kharon-border bg-kharon-light p-6">
          <p class="text-xs font-bold uppercase text-kharon-purple">{industry.priority}</p>
          <h3 class="mt-3 font-semibold text-kharon-black">{industry.title}</h3>
          <p class="mt-3 text-sm leading-7 text-kharon-grey">{industry.risk}</p>
        </div>
      ))}
    </div>
  </div>
</section>
