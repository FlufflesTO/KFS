---
/**
 * Project Sentinel - Holistic Landing Hero
 * Purpose: Provides a powerful, holistic introduction to Kharon with branching pathways.
 * Note: Designed for high-impact brand entry.
 */
import { heroProofItems } from "../../data/site.js";
---

<section class="relative min-h-[90svh] flex items-center justify-center overflow-hidden bg-kharon-black py-20 pt-32 sm:pt-40">
  <!-- Dynamic atmospheric background -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(124,93,194,0.1),transparent_70%)]"></div>
    <div class="absolute inset-0 bg-[url('/brand/kharon-mark.svg')] bg-[length:60%_auto] bg-center bg-no-repeat opacity-[0.02] filter blur-[2px]"></div>
  </div>

  <div class="container relative z-10 mx-auto max-w-7xl px-6">
    <div class="grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7 space-y-8">
        <div class="inline-flex items-center gap-3 px-3 py-1 rounded-full border border-kharon-purple/30 bg-kharon-purple/5 backdrop-blur-md">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-kharon-cyan opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-kharon-cyan"></span>
          </span>
          <span class="text-[0.65rem] font-black uppercase tracking-[0.2em] text-kharon-light/80">Mission Critical Protection</span>
        </div>

        <h1 class="kharon-h1 text-white leading-[1.05] tracking-tight">
          Precision Engineering for <span class="text-transparent bg-clip-text bg-gradient-to-r from-kharon-purple to-kharon-cyan">Critical Assets.</span>
        </h1>

        <p class="text-lg md:text-xl text-kharon-light/70 max-w-2xl leading-relaxed">
          Kharon delivers engineered fire detection, clean-agent gas suppression, and integrated security solutions for environments where failure is not an option.
        </p>

        <div class="flex flex-wrap gap-4 pt-4">
          <a href="#pathways" class="kharon-command-button px-8 py-4">
            Explore Solutions
          </a>
          <a href="/contact?intent=site-assessment" class="kharon-secondary-button px-8 py-4">
            Request Site Audit
          </a>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 pt-12 border-t border-kharon-purple/10">
          {heroProofItems.slice(0, 4).map(item => (
            <div class="space-y-1">
              <p class="text-[0.6rem] font-bold uppercase tracking-widest text-kharon-purple">{item.split(' ')[0]}</p>
              <p class="text-xs font-medium text-kharon-light/50">{item.split(' ').slice(1).join(' ') || item}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="lg:col-span-5 relative hidden lg:block">
        <div class="relative z-10 p-8 rounded-2xl border border-kharon-purple/20 bg-kharon-charcoal/40 backdrop-blur-xl shadow-2xl">
          <div class="absolute -inset-0.5 bg-gradient-to-br from-kharon-purple/20 to-kharon-cyan/20 rounded-2xl blur opacity-30"></div>
          
          <div class="space-y-6 relative">
            <div class="flex items-center justify-between border-b border-kharon-purple/10 pb-4">
              <span class="text-[0.65rem] font-bold uppercase tracking-widest text-kharon-light/40">KFS Operational Status</span>
              <span class="px-2 py-0.5 rounded bg-kharon-green/10 text-kharon-green text-[0.6rem] font-bold uppercase tracking-widest">Active</span>
            </div>
            
            <div class="space-y-4">
              <div class="h-1.5 w-full bg-kharon-black/50 rounded-full overflow-hidden">
                <div class="h-full bg-kharon-purple w-3/4 animate-pulse"></div>
              </div>
              <div class="grid grid-cols-3 gap-2">
                <div class="h-12 bg-kharon-black/30 rounded border border-kharon-purple/10"></div>
                <div class="h-12 bg-kharon-black/30 rounded border border-kharon-purple/10"></div>
                <div class="h-12 bg-kharon-black/30 rounded border border-kharon-purple/10"></div>
              </div>
            </div>

            <div class="pt-2 text-center">
              <p class="text-[0.6rem] font-medium text-kharon-light/30 leading-relaxed uppercase tracking-tighter">
                ISO 9001:2015 Compliant | SANS 10139 & 14520 Aligned
              </p>
            </div>
          </div>
        </div>
        
        <!-- Decorative elements -->
        <div class="absolute -right-20 -top-20 w-64 h-64 bg-kharon-purple/10 rounded-full blur-[100px]"></div>
        <div class="absolute -left-20 -bottom-20 w-64 h-64 bg-kharon-cyan/10 rounded-full blur-[100px]"></div>
      </div>
    </div>
  </div>
</section>
