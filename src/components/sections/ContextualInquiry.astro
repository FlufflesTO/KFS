---
/**
 * Contextual Inquiry Component
 * Purpose: Provides a themed contact intake section with dynamic field mapping and POPIA support
 * Dependencies: DESIGN_CONSTITUTION
 * Structural Role: Contextual inquiry input component
 */
const {
  eyebrow = "Operational Request",
  title = "Request a site assessment.",
  text = "Provide the operational context so Kharon can route the request correctly.",
  requestType = "Site assessment",
  fields = []
} = Astro.props;

const baseFields = [
  { label: "Name", name: "name", type: "text", autocomplete: "name", maxlength: 80 },
  { label: "Email", name: "email", type: "email", autocomplete: "email", inputmode: "email", maxlength: 120 },
  { label: "Company / Site", name: "site", type: "text", autocomplete: "organization", maxlength: 140 }
];

const formId = `ci-${requestType.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`;
---

<section class="section-padding bg-gradient-to-b from-kharon-black to-kharon-charcoal text-white border-t border-kharon-purple/10">
  <div class="mx-auto grid max-w-7xl gap-10 px-6 lg:grid-cols-[0.85fr_1.15fr]">
    <div>
      <p class="mb-4 text-xs font-bold uppercase tracking-widest text-kharon-purple">{eyebrow}</p>
      <h2 class="text-3xl font-bold leading-tight text-white sm:text-4xl lg:text-5xl">{title}</h2>
      <p class="mt-5 text-lg leading-relaxed text-kharon-light/75">{text}</p>
      <div class="mt-8 rounded-lg border border-kharon-purple/15 bg-kharon-surface-elevated p-5">
        <p class="text-xs font-bold uppercase tracking-widest text-kharon-purple">Request Type</p>
        <p class="mt-2 text-xl font-bold text-white">{requestType}</p>
      </div>
    </div>

    <form id={formId} class="grid gap-5 rounded-lg border border-kharon-purple/15 bg-kharon-surface-elevated p-6 kharon-surface">
      <label class="sr-only" for={`${formId}-website`}>Website</label>
      <input id={`${formId}-website`} style="display: none !important; position: absolute !important; left: -9999px !important;" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <input type="hidden" name="request_type" value={requestType} />

      {[...baseFields, ...fields].map((field) => (
        <div class="grid gap-1.5">
          <label for={`${formId}-${field.name}`} class="text-xs font-bold uppercase tracking-widest text-kharon-purple">
            {field.label} {field.required !== false && "*"}
          </label>
          {field.options ? (
            <select id={`${formId}-${field.name}`} class="kharon-field font-normal" name={field.name} required={field.required !== false}>
              {field.options.map((option: string) => <option value={option}>{option}</option>)}
            </select>
          ) : (
            <input
              id={`${formId}-${field.name}`}
              class="kharon-field font-normal"
              name={field.name}
              type={field.type || "text"}
              autocomplete={field.autocomplete}
              inputmode={field.inputmode}
              maxlength={field.maxlength || 160}
              required={field.required !== false}
              placeholder={`Enter your ${field.label.toLowerCase()}`}
            />
          )}
        </div>
      ))}

      <div class="grid gap-1.5">
        <label for={`${formId}-operational-notes`} class="text-xs font-bold uppercase tracking-widest text-kharon-purple">
          Operational Notes *
        </label>
        <textarea id={`${formId}-operational-notes`} class="kharon-field min-h-32 font-normal" name="operational_notes" maxlength="3000" required placeholder="Provide detail about your systems, requirements or site context..."></textarea>
      </div>

      <div class="flex items-start mt-2">
        <div class="flex items-center h-5">
          <input id={`${formId}-popia`} name="popia_consent" type="checkbox" required class="focus:ring-kharon-purple h-4 w-4 text-kharon-purple border-kharon-purple/20 bg-kharon-charcoal rounded cursor-pointer" />
        </div>
        <div class="ml-3 text-sm">
          <label for={`${formId}-popia`} class="font-medium text-kharon-light/80">
            I consent to the collection and processing of my data in accordance with POPIA for the purpose of this inquiry. *
          </label>
        </div>
      </div>

      <p class="hidden text-sm font-semibold" aria-live="polite"></p>

      <button class="w-full kharon-command-button py-3.5 mt-2">
        Submit Request
      </button>
    </form>
  </div>
</section>
<script>
  for (const form of document.querySelectorAll("[id^='ci-']")) {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const btn = form.querySelector("button");
      const resultEl = form.querySelector("[aria-live='polite']");
      if (btn) { btn.disabled = true; btn.textContent = "Sending…"; }
      if (resultEl) resultEl.className = "hidden text-sm font-semibold";

      const data = new FormData(form as HTMLFormElement);

      // Build message from Company/Site + contextual fields + operational notes
      const parts = [];
      const siteValue = String(data.get("site") || "").trim();
      if (siteValue) parts.push(`Company / Site: ${siteValue}`);

      const skip = new Set(["name", "email", "site", "website", "request_type", "operational_notes"]);
      for (const [key, value] of data.entries()) {
        if (skip.has(key) || !value) continue;
        const label = key.replace(/_/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());
        parts.push(`${label}: ${value}`);
      }

      const notes = String(data.get("operational_notes") || "").trim();
      if (notes) parts.push(`\nNotes:\n${notes}`);

      const payload = {
        website: String(data.get("website") || ""),
        name: String(data.get("name") || ""),
        email: String(data.get("email") || ""),
        requestType: String(data.get("request_type") || ""),
        popiaConsent: data.get("popia_consent") === "on",
        message: parts.join("\n")
      };

      try {
        const response = await fetch("/api/contact", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload)
        });
        const body = await response.json() as { ok?: boolean; message?: string } | null;

        if (body?.ok) {
          const success = document.createElement("p");
          success.className = "py-4 text-base font-semibold text-kharon-purple text-center";
          success.textContent = "Request received. Kharon will be in contact shortly.";
          form.replaceChildren(success);
        } else {
          if (resultEl) {
            resultEl.textContent = body?.message || "Submission failed. Try emailing admin@kharon.co.za directly.";
            resultEl.className = "text-sm font-semibold text-red-400";
            resultEl.classList.remove("hidden");
          }
          if (btn) { btn.disabled = false; btn.textContent = "Submit Request"; }
        }
      } catch {
        if (resultEl) {
          resultEl.textContent = "Could not reach the server. Try emailing admin@kharon.co.za directly.";
          resultEl.className = "text-sm font-semibold text-red-400";
          resultEl.classList.remove("hidden");
        }
        if (btn) { btn.disabled = false; btn.textContent = "Submit Request"; }
      }
    });
  }
</script>
