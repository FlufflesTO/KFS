---
import { complianceSignals } from "../../data/site.js";
---

<section class="border-y border-white/10 bg-kharon-charcoal py-5 text-white" aria-label="Compliance proof signals">
  <div class="mx-auto flex max-w-7xl flex-wrap items-center gap-3 px-6">
    <p class="mr-3 text-xs font-bold uppercase text-kharon-purple">
      Compliance Layer
    </p>
    {complianceSignals.map((item) => (
      <a href="/compliance" class="rounded-md border border-white/10 bg-white/[0.04] px-4 py-2 text-xs font-bold uppercase text-white/75 hover:bg-kharon-purple/20 hover:border-kharon-purple/40 hover:text-white transition-all cursor-pointer">
        {item}
      </a>
    ))}
    <a href="/compliance" class="ml-auto text-xs font-semibold text-white/50 hover:text-white transition-colors">
      Standards reference →
    </a>
  </div>
</section>
