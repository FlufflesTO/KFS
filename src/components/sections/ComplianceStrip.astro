---
import { complianceSignals } from "../../data/site.js";
---

<section class="border-y border-white/5 bg-kharon-charcoal py-3 text-white" aria-label="Compliance proof signals">
  <div class="mx-auto max-w-7xl px-6">
    <div class="flex flex-wrap items-center gap-2">
      <p class="mr-4 text-[0.6rem] font-black uppercase tracking-[0.2em] text-kharon-purple">
        Compliance Layer
      </p>
      {complianceSignals.map((item) => (
        <a href="/compliance" class="rounded-md border border-white/10 bg-white/[0.04] px-3 py-1.5 text-[0.65rem] font-black uppercase text-white/50 hover:bg-kharon-purple/20 hover:border-kharon-purple/40 hover:text-white transition-all cursor-pointer">
          {item}
        </a>
      ))}
      <a href="/compliance" class="ml-auto text-[0.65rem] font-bold text-white/30 hover:text-white transition-colors">
        Standards reference →
      </a>
    </div>
    
    <div class="flex flex-wrap items-center gap-x-8 gap-y-1 mt-2.5 pt-2.5 border-t border-white/5">
      {[
        { label: "Gas Suppression", icon: "✓" },
        { label: "Fire Detection", icon: "✓" },
        { label: "Commercial & Industrial", icon: "✓" },
        { label: "SANS Alignment", icon: "✓" }
      ].map(item => (
        <div class="flex items-center gap-1.5">
          <span class="text-kharon-cyan text-[0.6rem] font-black">{item.icon}</span>
          <span class="text-[0.6rem] font-black uppercase tracking-widest text-white/20">{item.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
