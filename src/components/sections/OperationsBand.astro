---
/**
 * Project Sentinel - OperationsBand
 * Purpose: Operational highlights strip
 * Dependencies: StatusIndicator.astro
 * Structural Role: Reusable sections UI component
 */
import StatusIndicator from "../ui/StatusIndicator.astro";

const rows = [
  {
    label: "Primary specialization",
    value: "Fire detection + gas suppression",
    status: "active" as const
  },
  {
    label: "Execution capability",
    value: "Assess, design, install, service",
    status: "pending" as const
  },
  {
    label: "Lifecycle control",
    value: "Testing, records, faults, maintenance",
    status: "warning" as const
  }
];
---

<section class="bg-kharon-charcoal py-10 text-white">
  <div class="mx-auto grid max-w-7xl gap-4 px-6 md:grid-cols-3">
    {rows.map((row) => (
      <div class="rounded-lg border border-white/10 bg-white/[0.04] p-5">
        <StatusIndicator label={row.label} status={row.status} />
        <p class="mt-3 text-lg font-semibold leading-snug">{row.value}</p>
      </div>
    ))}
  </div>
</section>
