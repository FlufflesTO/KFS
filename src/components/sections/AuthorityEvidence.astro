---
import { proofSignals, supportedEcosystem } from "../../data/site.js";
---

<section class="section-padding bg-kharon-charcoal relative overflow-hidden">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:gap-10 lg:grid-cols-[1fr_1.2fr] items-start">
      <div class="sticky top-32">
        <div class="flex items-center gap-3 mb-6">
          <div class="h-1 w-8 bg-kharon-purple"></div>
          <p class="text-[0.625rem] font-bold uppercase tracking-[0.2em] text-kharon-purple">Technical Authority</p>
        </div>

        <h2 class="kharon-h2 text-white">
          Authority through <span class="text-kharon-purple">competency</span> and standards.
        </h2>

        <p class="mt-8 text-lg leading-relaxed text-white/70 max-w-xl">
          Kharon operates across complex fire detection, gas suppression, and maintenance environments, delivering visible signals of technical proficiency and regulatory alignment.
        </p>
        
        <div class="mt-12 grid grid-cols-2 gap-6 lg:gap-10 border-t border-kharon-border pt-12">
          <div>
            <p class="text-3xl font-bold text-kharon-purple">100%</p>
            <p class="mt-2 text-[0.625rem] font-bold uppercase tracking-widest text-white/40">SANS Compliance</p>
          </div>
          <div>
            <p class="text-3xl font-bold text-kharon-purple">24/7</p>
            <p class="mt-2 text-[0.625rem] font-bold uppercase tracking-widest text-white/40">Support SLA</p>
          </div>
        </div>
      </div>

      <div class="grid gap-6">
        {proofSignals.map((item) => (
          <article class="group rounded-xl border border-kharon-purple/20 bg-kharon-charcoal p-6 sm:p-7 transition-all hover:border-kharon-purple/40 hover:shadow-lg">
            <div class="flex items-center justify-between mb-6">
              <span class="rounded-full bg-kharon-purple/5 px-3 py-1 text-[0.625rem] font-bold uppercase tracking-widest text-kharon-purple">
                {item.status}
              </span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-kharon-purple opacity-0 transition-opacity group-hover:opacity-100"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </div>
            <h3 class="text-xl font-bold tracking-tight text-white">{item.title}</h3>
            <p class="mt-4 text-sm leading-relaxed text-kharon-grey/80">{item.text}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="mt-20 rounded-2xl bg-kharon-black p-6 sm:p-10 text-white relative overflow-hidden">
      <div class="absolute inset-0 opacity-10" aria-hidden="true">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,#4B2E83_0%,transparent_50%)]"></div>
      </div>
      
      <div class="relative z-10 flex flex-col lg:flex-row lg:items-end justify-between gap-10">
        <div class="max-w-2xl">
          <p class="text-[0.625rem] font-bold uppercase tracking-[0.2em] text-kharon-purple mb-4">
            System Ecosystem
          </p>
          <h3 class="text-2xl lg:text-3xl font-bold tracking-tight">
            Field familiarity across leading suppression and detection platforms.
          </h3>
        </div>
        <p class="max-w-sm text-[0.7rem] font-medium leading-relaxed text-white/40 uppercase tracking-wider">
          Listed as ecosystem familiarity. Procurement should verify current approvals and product-specific authorisations.
        </p>
      </div>

      <div class="relative z-10 mt-12 grid gap-3 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4">
        {supportedEcosystem.map((item) => (
          <div class="flex items-center gap-3 rounded-lg border border-white/5 bg-white/5 px-4 py-4 text-xs font-bold uppercase tracking-widest text-white/70 transition-colors hover:bg-white/10 hover:text-white">
            <div class="h-1.5 w-1.5 rounded-full bg-kharon-purple/40"></div>
            {item}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
