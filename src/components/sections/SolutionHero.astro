---
/**
 * Project Sentinel - Solution Hero
 * Purpose: Standardized high-impact hero for solution pages.
 */
export interface Props {
  title: string;
  subtitle: string;
  description: string;
  icon: string;
}

const { title, subtitle, description, icon } = Astro.props;
---

<section class="relative min-h-[50svh] flex items-center justify-center overflow-hidden bg-kharon-black py-20 pt-32 sm:pt-40">
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(124,93,194,0.08),transparent_70%)]"></div>
    <div class="absolute inset-0 bg-[url('/brand/kharon-mark.svg')] bg-[length:40%_auto] bg-center bg-no-repeat opacity-[0.015] filter blur-[1px]"></div>
  </div>

  <div class="container relative z-10 mx-auto max-w-7xl px-6 text-center">
    <div class="inline-flex items-center justify-center h-20 w-20 rounded-2xl bg-kharon-purple/10 border border-kharon-purple/20 mb-8 p-4 shadow-2xl shadow-kharon-purple/5">
      <img src={icon} alt="" class="h-full w-full object-contain" />
    </div>

    <div class="space-y-6">
      <p class="text-[0.65rem] font-black uppercase tracking-[0.3em] text-kharon-cyan">{subtitle}</p>
      <h1 class="kharon-h1 text-white leading-none">{title}</h1>
      <p class="text-lg md:text-xl text-kharon-light/60 max-w-3xl mx-auto leading-relaxed font-medium">
        {description}
      </p>
    </div>
  </div>
</section>
