---
export interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  center?: boolean;
}

const { title, subtitle, description, center = false } = Astro.props;

const alignment = center ? "text-center mx-auto" : "";
---

<div class={`mb-12 ${alignment}`}>
  {subtitle && (
    <p class="text-base font-bold uppercase tracking-widest text-kharon-purple mb-3">
      {subtitle}
    </p>
  )}
  <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 kharon-h2">
    {title}
  </h2>
  {description && (
    <p class="text-kharon-light/70 max-w-2xl text-lg leading-relaxed">
      {description}
    </p>
  )}
</div>
