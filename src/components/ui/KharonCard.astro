---
/**
 * Project Sentinel - Kharon Card Component
 * Purpose: Consistent card component for all dashboard views with enigmatic design
 * Dependencies: None
 * Structural Role: Reusable UI component
 */

export interface Props {
  title?: string;
  subtitle?: string;
  variant?: 'default' | 'primary' | 'warning' | 'danger' | 'success';
  border?: boolean;
  padding?: 'sm' | 'md' | 'lg';
  className?: string;
}

const { 
  title, 
  subtitle, 
  variant = 'default', 
  border = true, 
  padding = 'md',
  className = '' 
} = Astro.props;

const variantClasses = {
  default: 'border-kharon-border bg-white shadow-subtle',
  primary: 'border-kharon-purple/20 bg-white shadow-md',
  warning: 'border-amber-200 bg-amber-50/30',
  danger: 'border-red-200 bg-red-50/30',
  success: 'border-green-200 bg-green-50/30'
};

const paddingClasses = {
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8'
};

const classes = [
  'rounded-lg',
  'overflow-hidden',
  border ? 'border' : '',
  variantClasses[variant],
  paddingClasses[padding],
  className
].filter(Boolean).join(' ');
---

<div class={classes}>
  {title && (
    <div class="mb-6">
      {subtitle && <p class="mb-1 text-[0.625rem] font-black uppercase tracking-[0.15em] text-kharon-purple/80">{subtitle}</p>}
      <h2 class="text-xl font-extrabold tracking-tight text-kharon-black">{title}</h2>
      <div class="mt-3 h-0.5 w-8 bg-kharon-purple/20"></div>
    </div>
  )}
  <div class="text-kharon-grey leading-relaxed">
    <slot />
  </div>
</div>