---
/**
 * Project Sentinel - Kharon Card Component
 * Purpose: Consistent card component for all dashboard views
 * Dependencies: None
 * Structural Role: Reusable UI component
 */

export interface Props {
  title?: string;
  subtitle?: string;
  variant?: 'default' | 'primary' | 'warning' | 'danger' | 'success' | 'command';
  border?: boolean;
  padding?: 'sm' | 'md' | 'lg';
  className?: string;
}

const {
  title,
  subtitle,
  variant = 'default',
  border = true,
  padding = 'md',
  className = ''
} = Astro.props;

const variantClasses = {
  default: 'border-kharon-purple/20 bg-kharon-surface-elevated backdrop-blur-sm',
  primary: 'border-kharon-purple/30 bg-kharon-surface-elevated backdrop-blur-sm',
  warning: 'border-kharon-amber/30 bg-kharon-surface-elevated backdrop-blur-sm',
  danger: 'border-kharon-red/30 bg-kharon-surface-elevated backdrop-blur-sm',
  success: 'border-kharon-green/30 bg-kharon-surface-elevated backdrop-blur-sm',
  command: 'border-kharon-purple/30 bg-kharon-surface-charcoal/80 backdrop-blur-md shadow-lg shadow-kharon-black/30'
};

const paddingClasses = {
  sm: 'p-3 sm:p-4',
  md: 'p-4 sm:p-5 lg:p-6',
  lg: 'p-5 sm:p-6 lg:p-7'
};

const classes = [
  'rounded-lg',
  'overflow-hidden',
  border ? 'border' : '',
  variantClasses[variant],
  paddingClasses[padding],
  className
].filter(Boolean).join(' ');
---

<div class={classes}>
  {title && (
    <div class="mb-5 border-b border-kharon-purple/10 pb-4">
      {subtitle && <p class="mb-1.5 text-xs font-semibold uppercase tracking-widest text-kharon-purple/70">{subtitle}</p>}
      <h2 class="text-base font-semibold tracking-tight text-white">{title}</h2>
      <div class="mt-3 h-[1px] w-6 bg-kharon-purple/30"></div>
    </div>
  )}
  <div class="text-kharon-light/80 text-sm leading-relaxed font-normal">
    <slot />
  </div>
</div>
