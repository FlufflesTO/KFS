---
/**
 * Project Sentinel - Kharon Card Component
 * Purpose: Consistent card component for all dashboard views
 * Dependencies: None
 * Structural Role: Reusable UI component
 */

export interface Props {
  title?: string;
  subtitle?: string;
  variant?: 'default' | 'primary' | 'warning' | 'danger' | 'success';
  border?: boolean;
  padding?: 'sm' | 'md' | 'lg';
  className?: string;
}

const {
  title,
  subtitle,
  variant = 'default',
  border = true,
  padding = 'md',
  className = ''
} = Astro.props;

const variantClasses = {
  default: 'border-kharon-border bg-white shadow-subtle',
  primary: 'border-kharon-purple/20 bg-white shadow-md',
  warning: 'border-amber-200 bg-amber-50/30',
  danger: 'border-red-200 bg-red-50/30',
  success: 'border-green-200 bg-green-50/30'
};

const paddingClasses = {
  sm: 'p-3 sm:p-4',
  md: 'p-4 sm:p-5 lg:p-6',
  lg: 'p-5 sm:p-6 lg:p-7'
};

const classes = [
  'rounded-md',
  'overflow-hidden',
  border ? 'border' : '',
  variantClasses[variant],
  paddingClasses[padding],
  className
].filter(Boolean).join(' ');
---

<div class={classes}>
  {title && (
    <div class="mb-5">
      {subtitle && <p class="mb-1.5 text-xs font-semibold uppercase tracking-widest text-kharon-purple/70">{subtitle}</p>}
      <h2 class="text-base font-semibold tracking-tight text-kharon-black">{title}</h2>
      <div class="mt-4 h-[1px] w-6 bg-kharon-purple/30"></div>
    </div>
  )}
  <div class="text-kharon-grey text-sm leading-relaxed font-normal">
    <slot />
  </div>
</div>