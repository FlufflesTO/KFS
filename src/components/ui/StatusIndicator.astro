---
const { label, tone = "cyan" } = Astro.props;

const tones = {
  cyan: "bg-kharon-cyan shadow-[0_0_18px_rgba(0,194,255,0.45)]",
  amber: "bg-kharon-amber shadow-[0_0_18px_rgba(245,158,11,0.35)]",
  purple: "bg-kharon-purple shadow-[0_0_18px_rgba(75,46,131,0.35)]"
};
---

<span class="inline-flex items-center gap-2 text-xs font-bold uppercase text-current">
  <span class={`h-2 w-2 rounded-full ${tones[tone] || tones.cyan}`} aria-hidden="true"></span>
  {label}
</span>
