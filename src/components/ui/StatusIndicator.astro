---
/**
 * Status Indicator Component
 * Purpose: Visual status indicator with operational telemetry styling
 * Dependencies: None
 * Structural Role: Status display component
 */
export interface Props {
  status: 'active' | 'inactive' | 'warning' | 'danger' | 'success' | 'pending' | 'processing';
  label?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { status, label, size = 'md' } = Astro.props;

const statusStyles = {
  active: 'bg-kharon-green border-kharon-green/50 text-white',
  inactive: 'bg-kharon-grey border-kharon-grey/50 text-white/70',
  warning: 'bg-kharon-amber border-kharon-amber/50 text-kharon-black',
  danger: 'bg-kharon-red border-kharon-red/50 text-white',
  success: 'bg-kharon-green border-kharon-green/50 text-white',
  pending: 'bg-kharon-purple border-kharon-purple/50 text-white',
  processing: 'bg-gradient-to-r from-kharon-purple to-kharon-blue border-kharon-purple/50 text-white'
};

const sizeClasses = {
  sm: 'text-xs px-2 py-1 rounded',
  md: 'text-xs px-3 py-1.5 rounded-md',
  lg: 'text-sm px-4 py-2 rounded-md'
};

const classes = `inline-flex items-center justify-center border kharon-status-chip ${statusStyles[status]} ${sizeClasses[size]}`;
---

<span class={classes}>
  {status === 'active' && (
    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
    </svg>
  )}
  {status === 'warning' && (
    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
      <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
    </svg>
  )}
  {status === 'danger' && (
    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
    </svg>
  )}
  {status === 'success' && (
    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
    </svg>
  )}
  {status === 'pending' && (
    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
    </svg>
  )}
  {status === 'processing' && (
    <svg class="w-3 h-3 mr-1 animate-spin" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
    </svg>
  )}
  {label || status.charAt(0).toUpperCase() + status.slice(1)}
</span>
