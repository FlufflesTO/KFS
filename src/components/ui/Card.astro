---
const {
  title,
  text,
  href,
  status,
  dark = false
} = Astro.props;

const Element = href ? "a" : "div";
const baseClass = dark
  ? "group block rounded-lg border border-kharon-purple/15 bg-kharon-surface-elevated p-6 text-white hover:border-kharon-purple/40 backdrop-blur-sm kharon-surface"
  : "group block rounded-lg border border-kharon-purple/15 bg-kharon-surface-elevated p-6 text-white hover:border-kharon-purple/40 backdrop-blur-sm kharon-surface";
---

<Element href={href} class={baseClass}>
  {status && (
    <p class={`mb-4 text-xs font-bold uppercase ${dark ? "text-kharon-purple" : "text-kharon-purple"}`}>
      {status}
    </p>
  )}

  <h3 class="text-xl font-semibold leading-snug text-white">
    {title}
  </h3>

  {text && (
    <p class={`mt-3 leading-7 ${dark ? "text-white/65" : "text-white/70"}`}>
      {text}
    </p>
  )}
</Element>
