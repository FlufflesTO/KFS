---
const {
  title,
  text,
  href,
  status,
  dark = false
} = Astro.props;

const Element = href ? "a" : "div";
const baseClass = dark
  ? "group block rounded-md border border-white/10 bg-white/[0.035] p-6 text-white hover:border-kharon-cyan/40"
  : "group block rounded-md border border-kharon-border bg-white p-6 text-kharon-black hover:border-kharon-purple/45";
---

<Element href={href} class={baseClass}>
  {status && (
    <p class={`mb-4 text-xs font-bold uppercase ${dark ? "text-kharon-cyan" : "text-kharon-purple"}`}>
      {status}
    </p>
  )}

  <h3 class="text-xl font-semibold leading-snug">
    {title}
  </h3>

  {text && (
    <p class={`mt-3 leading-7 ${dark ? "text-white/65" : "text-kharon-grey"}`}>
      {text}
    </p>
  )}
</Element>
