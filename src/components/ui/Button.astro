---
/**
 * Project Sentinel - Button
 * Purpose: Reusable UI button component
 * Dependencies: None
 * Structural Role: Base UI button
 */
export interface Props {
  variant?: 'primary' | 'secondary' | 'danger';
  size?: 'sm' | 'md' | 'lg';
  disabled?: boolean;
  href?: string;
  className?: string;
}

const {
  variant = "primary",
  size = "md",
  disabled = false,
  href,
  className = ""
} = Astro.props;

const baseClasses = "inline-flex items-center justify-center font-bold uppercase tracking-widest transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-kharon-cyan focus-visible:ring-offset-4 focus-visible:ring-offset-kharon-charcoal";

const variantClasses = {
  primary: "bg-gradient-to-r from-kharon-purple to-kharon-blue text-white border border-kharon-purple/30 hover:shadow-lg hover:shadow-kharon-purple/20 active:scale-[0.98]",
  secondary: "bg-transparent border border-kharon-purple/30 text-kharon-purple hover:bg-kharon-purple/10",
  danger: "bg-kharon-red text-white border border-kharon-red/30 hover:shadow-lg hover:shadow-kharon-red/20 active:scale-[0.98]"
};

const sizeClasses = {
  sm: "text-base px-3 py-1.5 rounded",
  md: "text-base px-4 py-2 rounded-md",
  lg: "text-base px-6 py-3 rounded-md"
};

const classes = [
  baseClasses,
  variantClasses[variant],
  sizeClasses[size],
  disabled ? "opacity-50 cursor-not-allowed" : "cursor-pointer",
  className
].filter(Boolean).join(" ");

const Element = href && !disabled ? "a" : "button";
---

<Element
  href={href}
  class={classes}
  {...(Element === "button" ? { type: "button", disabled } : {})}
>
  <slot />
</Element>
