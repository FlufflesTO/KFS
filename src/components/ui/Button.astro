---
const {
  href = "/contact?intent=site-assessment",
  label = "Request Site Assessment",
  variant = "primary"
} = Astro.props;

const styles: Record<string, string> = {
  primary: "bg-kharon-purple text-white hover:bg-kharon-blue",
  secondary: "border border-white/25 text-white hover:bg-white/10",
  dark: "bg-kharon-black text-white hover:bg-kharon-blue"
};
---

<a
  href={href}
  class={`inline-flex rounded-md px-6 py-4 font-semibold ${styles[variant] || styles.primary}`}
>
  {label}
</a>
