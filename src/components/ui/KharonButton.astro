---
/**
 * Project Sentinel - Kharon Button Component
 * Purpose: Enhanced button component with industrial command styling
 * Dependencies: None
 * Structural Role: Primary UI action component
 */

export interface Props {
  variant?: 'primary' | 'secondary' | 'danger' | 'command';
  size?: 'sm' | 'md' | 'lg';
  disabled?: boolean;
  href?: string;
  className?: string;
  type?: 'button' | 'submit' | 'reset';
  children: any;
}

const {
  variant = 'primary',
  size = 'md',
  disabled = false,
  href,
  className = '',
  type = 'button',
  children
} = Astro.props;

const baseClasses = "inline-flex items-center justify-center font-bold uppercase tracking-widest transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-kharon-purple focus:ring-offset-2 focus:ring-offset-kharon-black";

const variantClasses = {
  primary: "bg-gradient-to-r from-kharon-purple to-kharon-blue text-white border border-kharon-purple/20 hover:shadow-lg hover:shadow-kharon-purple/30 active:scale-[0.98] relative overflow-hidden",
  secondary: "bg-kharon-surface-glass border border-kharon-purple/20 text-white hover:bg-kharon-purple/10 backdrop-blur-sm",
  danger: "bg-gradient-to-r from-kharon-red to-[#a02824] text-white border border-kharon-red/30 hover:shadow-lg hover:shadow-kharon-red/30 active:scale-[0.98]",
  command: "bg-gradient-to-r from-kharon-purple to-kharon-blue border border-kharon-purple text-white px-6 py-3 text-sm font-bold uppercase tracking-widest transition-all hover:shadow-lg hover:shadow-kharon-purple/30 active:scale-[0.98] kharon-command-button"
};

const sizeClasses = {
  sm: "text-xs px-3 py-2 rounded",
  md: "text-sm px-4 py-2 rounded-md",
  lg: "text-base px-6 py-3 rounded-md"
};

const classes = [
  baseClasses,
  variantClasses[variant],
  sizeClasses[size],
  disabled ? "opacity-50 cursor-not-allowed" : "cursor-pointer",
  className
].filter(Boolean).join(" ");

const Element = href && !disabled ? "a" : "button";
---

{Element === "a" ? (
  <a href={href} class={classes}>
    <span class="relative z-10">{children}</span>
    {variant === 'primary' && (
      <div class="absolute inset-0 bg-gradient-to-r from-kharon-purple/20 to-kharon-blue/20 opacity-0 hover:opacity-100 transition-opacity"></div>
    )}
  </a>
) : (
  <button class={classes} type={type} disabled={disabled}>
    <span class="relative z-10">{children}</span>
    {variant === 'primary' && (
      <div class="absolute inset-0 bg-gradient-to-r from-kharon-purple/20 to-kharon-blue/20 opacity-0 hover:opacity-100 transition-opacity"></div>
    )}
  </button>
)}
