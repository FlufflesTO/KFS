---
/**
 * Animation Controller Component
 * Purpose: Optimizes animations by pausing them when off-screen or tab is hidden
 * Dependencies: None
 * Structural Role: Reusable animation optimization component
 */
export interface Props {
  children: any;
}

const { children } = Astro.props;
---

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Animation controller for CPU optimization
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.1
    };

    const animationObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Element is visible, resume animations
          entry.target.classList.remove('animation-paused');
          entry.target.style.animationPlayState = 'running';
        } else {
          // Element is not visible, pause animations
          entry.target.classList.add('animation-paused');
          entry.target.style.animationPlayState = 'paused';
        }
      });
    }, observerOptions);

    // Observe all animated elements
    document.querySelectorAll('.animate-drift, .titan-drift, .linework-drift').forEach(element => {
      animationObserver.observe(element);
    });

    // Handle page visibility changes
    const handleVisibilityChange = () => {
      const animatedElements = document.querySelectorAll('.animate-drift, .titan-drift, .linework-drift');
      
      if (document.hidden) {
        // Tab is hidden, pause all animations
        animatedElements.forEach(el => {
          el.classList.add('animation-paused');
          el.style.animationPlayState = 'paused';
        });
      } else {
        // Tab is visible, check if element is in viewport
        animatedElements.forEach(el => {
          if (isElementInViewport(el)) {
            el.classList.remove('animation-paused');
            el.style.animationPlayState = 'running';
          }
        });
      }
    };

    // Helper function to check if element is in viewport
    function isElementInViewport(el) {
      const rect = el.getBoundingClientRect();
      return (
        rect.top >= 0 &&
        rect.left >= 0 &&
        rect.bottom <= (window.innerHeight || document.documentElement.clientHeight) &&
        rect.right <= (window.innerWidth || document.documentElement.clientWidth)
      );
    }

    // Listen for visibility changes
    document.addEventListener('visibilitychange', handleVisibilityChange);
  });
</script>

<style>
  /* Add animation paused state */
  .animation-paused {
    animation-play-state: paused !important;
  }
  
  /* Define drift animations with optimized performance */
  @keyframes titanDrift {
    0%, 100% { transform: translate(0, 0); }
    25% { transform: translate(5px, 5px); }
    50% { transform: translate(0, 10px); }
    75% { transform: translate(-5px, 5px); }
  }
  
  @keyframes lineworkDrift {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(3px, -3px); }
  }
  
  .titan-drift {
    animation: titanDrift 8s ease-in-out infinite;
    will-change: transform;
  }
  
  .linework-drift {
    animation: lineworkDrift 6s ease-in-out infinite;
    will-change: transform;
  }
  
  /* Smooth transitions for performance */
  .animate-drift {
    will-change: transform;
  }
</style>

<slot />