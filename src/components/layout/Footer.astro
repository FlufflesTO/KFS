---
import { site, solutionLinks } from "../../data/site.js";
---

<footer class="bg-kharon-charcoal text-white">
  <div class="mx-auto max-w-7xl px-6 py-14">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-[1fr_auto]">
      <div>
        <a href="/" class="flex shrink-0 items-center gap-3">
          <img src="/brand/kharon-mark.svg" alt="" aria-hidden="true" width="36" height="49" class="flex-none" />
          <span>
            <span class="block whitespace-nowrap text-base font-bold uppercase tracking-wide">{site.shortName}</span>
            <span class="block whitespace-nowrap text-xs uppercase tracking-widest text-white/50">Fire &amp; Security Solutions</span>
          </span>
        </a>
        <p class="mt-5 max-w-sm text-sm leading-7 text-white/55">
          {site.description}
        </p>
      </div>

      <div class="text-sm text-white/60 sm:text-right">
        <p class="font-semibold text-white/80">{site.phone}</p>
        <p class="mt-1"><a href={`mailto:${site.email}`} class="hover:text-white">{site.email}</a></p>
        <p class="mt-3 leading-6 text-white/45">{site.address}</p>
        <p class="mt-1 text-xs text-white/35">Reg. {site.registration}</p>
      </div>
    </div>

    <div class="mt-10 flex flex-wrap gap-6 border-t border-white/10 pt-8 text-sm text-white/50">
      <a href="/" class="hover:text-white">Home</a>
      <a href="/about" class="hover:text-white">About</a>
      {solutionLinks.map((link) => <a href={link.href} class="hover:text-white">{link.label}</a>)}
      <a href="/contact?intent=site-assessment" class="hover:text-white">Assessment Intake</a>
      <a href={site.portalLoginPath} title={site.portalStatus} class="hover:text-white">Access Records</a>
    </div>
  </div>
</footer>
