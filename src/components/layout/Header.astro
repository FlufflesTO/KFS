---
/**
 * Project Sentinel - Header Component
 * Purpose: Header layout component with logo, navigation links, and portals entry button
 * Dependencies: data/site.js
 * Structural Role: Global header in frontend pages
 */
import { mainLinks, site, solutionLinks } from "../../data/site.js";

const { currentPath = "/" } = Astro.props;

function normalizePath(pathname) {
  if (!pathname) return "/";
  const [rawPath] = pathname.split(/[?#]/);
  if (!rawPath || rawPath === "/") return "/";
  return rawPath.endsWith("/") ? rawPath.slice(0, -1) : rawPath;
}

const activePath = normalizePath(currentPath);
const isLinkActive = (href) => href.includes("#") ? false : normalizePath(href) === activePath;
const isSolutionsActive = solutionLinks.some((item) => isLinkActive(item.href));

const solutionHrefs = new Set(solutionLinks.map((l) => l.href));
const mobilePrimaryLinks = mainLinks.filter((l) => !solutionHrefs.has(l.href));
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-white/5 bg-kharon-black/85 backdrop-blur-md">
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:bg-white focus:px-4 focus:py-2 focus:text-kharon-black"
  >
    Skip to content
  </a>

  <div class="mx-auto flex h-20 max-w-7xl items-center justify-between gap-4 px-4 sm:px-6 lg:px-8">
    <a href="/" class="group flex shrink-0 items-center gap-4 text-white">
      <div class="relative">
        <img src="/brand/kharon-mark.svg" alt="" aria-hidden="true" width="30" height="40" class="flex-none transition-transform duration-300 group-hover:scale-110" />
      </div>
      <div class="hidden sm:block">
        <span class="block whitespace-nowrap text-sm font-black uppercase tracking-[0.2em]">{site.shortName}</span>
        <span class="block whitespace-nowrap text-[0.625rem] font-bold uppercase tracking-[0.3em] text-white/40 group-hover:text-kharon-cyan/60 transition-colors">Fire &amp; Security</span>
      </div>
    </a>

    <nav class="hidden items-center gap-6 xl:gap-8 lg:flex" aria-label="Primary navigation">
      <a href="/" class={`whitespace-nowrap text-[0.8125rem] font-bold uppercase tracking-widest transition-colors ${isLinkActive("/") ? "text-kharon-cyan" : "text-white/70 hover:text-white"}`} aria-current={isLinkActive("/") ? "page" : undefined}>
        Home
      </a>

      <details class="group relative">
        <summary
          class={`flex cursor-pointer list-none items-center gap-1.5 whitespace-nowrap text-[0.8125rem] font-bold uppercase tracking-widest marker:hidden transition-colors ${isSolutionsActive ? "text-kharon-cyan" : "text-white/70 hover:text-white"}`}
        >
          Solutions
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-3.5 w-3.5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="3">
            <path d="m6 9 6 6 6-6"></path>
          </svg>
        </summary>

        <nav
          aria-label="Solutions"
          class="absolute left-1/2 -translate-x-1/2 top-10 w-80 rounded-xl border border-white/10 bg-kharon-charcoal p-2 shadow-2xl backdrop-blur-xl"
        >
          <div class="grid gap-1">
            {
              solutionLinks.map((link) => {
                const active = isLinkActive(link.href);
                return (
                  <a
                    href={link.href}
                    aria-current={active ? "page" : undefined}
                    class={`flex items-center justify-between rounded-lg px-4 py-3 text-[0.8125rem] font-bold uppercase tracking-wide transition-all ${active ? "bg-kharon-purple text-white shadow-lg" : "text-white/60 hover:bg-white/5 hover:text-white"}`}
                  >
                    {link.label}
                    {active && <div class="h-1.5 w-1.5 rounded-full bg-kharon-cyan header-active-dot"></div>}
                  </a>
                );
              })
            }
          </div>
        </nav>
      </details>

      {
        mainLinks.slice(1).map((link) => {
          const active = isLinkActive(link.href);
          return (
            <a href={link.href} class={`whitespace-nowrap text-[0.8125rem] font-bold uppercase tracking-widest transition-colors ${active ? "text-kharon-cyan" : "text-white/70 hover:text-white"}`} aria-current={active ? "page" : undefined}>
              {link.label}
            </a>
          );
        })
      }
    </nav>

    <div class="hidden items-center gap-4 lg:flex">
      <a
        href={site.portalLoginPath}
        aria-label="Open the secure Kharon portal."
        title={site.portalStatus}
        class="group relative flex items-center gap-2 overflow-hidden rounded-md border border-white/10 px-5 py-2.5 text-[0.8125rem] font-bold uppercase tracking-widest text-white/70 transition-all hover:border-white/20 hover:text-white"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/40 transition-colors group-hover:text-kharon-cyan"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
        Portal
      </a>

      <a href="/contact?intent=site-assessment" class="relative overflow-hidden rounded-md bg-kharon-purple px-6 py-2.5 text-[0.8125rem] font-black uppercase tracking-widest text-white transition-all hover:bg-kharon-blue header-cta-button">
        Inquiry
      </a>
    </div>

    <details class="mobile-menu lg:hidden">
      <summary
        class="inline-flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-lg border border-white/10 text-white marker:hidden hover:bg-white/5 active:scale-95 transition-all"
        aria-label="Toggle menu"
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 mobile-menu__open" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg aria-hidden="true" viewBox="0 0 24 24" class="hidden h-5 w-5 mobile-menu__close" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M6 6l12 12M18 6L6 18"></path>
        </svg>
      </summary>

      <div class="fixed inset-x-0 top-20 z-[90] max-h-[calc(100vh-5rem)] overflow-y-auto border-t border-white/10 bg-kharon-black/95 px-6 py-10 shadow-2xl backdrop-blur-xl animate-reveal-down">
        <nav class="flex flex-col gap-2" aria-label="Mobile navigation">
          {
            [...mobilePrimaryLinks.slice(0, 1), ...solutionLinks, ...mobilePrimaryLinks.slice(1)].map((link) => {
              const active = isLinkActive(link.href);
              return (
                <a
                  href={link.href}
                  aria-current={active ? "page" : undefined}
                  class={`flex items-center justify-between border-b border-white/5 py-5 text-sm font-black uppercase tracking-[0.15em] transition-colors ${active ? "text-kharon-cyan" : "text-white/80"}`}
                >
                  {link.label}
                  {active && <div class="h-2 w-2 rounded-full bg-kharon-cyan"></div>}
                </a>
              );
            })
          }

          <div class="mt-10 grid gap-4">
            <a href="/contact?intent=site-assessment" class="rounded-md bg-kharon-purple py-5 text-center text-sm font-black uppercase tracking-widest text-white shadow-lg active:scale-[0.98] transition-all">
              Request Site Assessment
            </a>

            <a href={site.portalLoginPath} class="rounded-md border border-white/10 py-5 text-center text-sm font-black uppercase tracking-widest text-white/80 backdrop-blur-sm active:scale-[0.98] transition-all">
              Portal Access
            </a>
          </div>
        </nav>
      </div>
    </details>
  </div>
</header>

<script>
  const solutionsDropdown = document.querySelector<HTMLDetailsElement>("details.group");
  if (solutionsDropdown) {
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && solutionsDropdown.open) {
        solutionsDropdown.removeAttribute("open");
        solutionsDropdown.querySelector("summary")?.focus();
      }
    });
    document.addEventListener("click", (event) => {
      if (!solutionsDropdown.contains(event.target as Node)) {
        solutionsDropdown.removeAttribute("open");
      }
    });
  }

  const mobileMenu = document.querySelector<HTMLDetailsElement>("details.mobile-menu");
  if (mobileMenu) {
    for (const link of mobileMenu.querySelectorAll("nav a")) {
      link.addEventListener("click", () => {
        mobileMenu.removeAttribute("open");
      });
    }
  }
</script>

<style>
  .header-active-dot {
    box-shadow: 0 0 8px rgba(0, 194, 255, 0.8);
  }
  .header-cta-button:hover {
    box-shadow: 0 0 15px rgba(75, 46, 131, 0.4);
  }
</style>
