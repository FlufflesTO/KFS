---
import { mainLinks, site, solutionLinks } from "../../data/site.js";

const { currentPath = "/" } = Astro.props;

function normalizePath(pathname) {
  if (!pathname) return "/";
  const [rawPath] = pathname.split(/[?#]/);
  if (!rawPath || rawPath === "/") return "/";
  return rawPath.endsWith("/") ? rawPath.slice(0, -1) : rawPath;
}

const activePath = normalizePath(currentPath);
const isLinkActive = (href) => href.includes("#") ? false : normalizePath(href) === activePath;
const isSolutionsActive = solutionLinks.some((item) => isLinkActive(item.href));
const desktopLinkClass = (active) =>
  `text-sm font-semibold ${active ? "text-white" : "text-white/75 hover:text-white"}`;

const solutionHrefs = new Set(solutionLinks.map((l) => l.href));
const mobilePrimaryLinks = mainLinks.filter((l) => !solutionHrefs.has(l.href));
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-kharon-black/90 backdrop-blur-xl">
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:bg-white focus:px-4 focus:py-2 focus:text-kharon-black"
  >
    Skip to content
  </a>

  <div class="mx-auto flex h-20 max-w-7xl items-center justify-between gap-3 px-4 sm:px-6">
    <a href="/" class="flex min-w-0 items-center gap-3 text-white">
      <img src="/kharon-mark.svg" alt="" aria-hidden="true" width="36" height="36" class="h-9 w-9 flex-none" />
      <span class="min-w-0">
        <span class="block text-sm font-bold uppercase tracking-wide">{site.shortName}</span>
        <span class="block text-xs uppercase tracking-widest text-white/55">Fire &amp; Security Solutions</span>
      </span>
    </a>

    <nav class="hidden items-center gap-5 lg:flex xl:gap-8" aria-label="Primary navigation">
      <a href="/" class={desktopLinkClass(isLinkActive("/"))} aria-current={isLinkActive("/") ? "page" : undefined}>
        Home
      </a>

      <details class="group relative">
        <summary
          class={`flex cursor-pointer list-none items-center gap-1 text-sm font-semibold marker:hidden ${isSolutionsActive ? "text-white" : "text-white/75 hover:text-white"}`}
        >
          Solutions
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2">
            <path d="m6 9 6 6 6-6"></path>
          </svg>
        </summary>

        <nav
          aria-label="Solutions"
          class="absolute left-0 top-8 w-72 rounded-lg border border-white/10 bg-kharon-charcoal p-3 shadow-2xl"
        >
          {
            solutionLinks.map((link) => {
              const active = isLinkActive(link.href);
              return (
                <a
                  href={link.href}
                  aria-current={active ? "page" : undefined}
                  class={`block rounded-md px-4 py-3 text-sm ${active ? "bg-white/10 text-white" : "text-white/70 hover:bg-white/5 hover:text-white"}`}
                >
                  {link.label}
                </a>
              );
            })
          }
        </nav>
      </details>

      {
        mainLinks.slice(1).map((link) => {
          const active = isLinkActive(link.href);
          return (
            <a href={link.href} class={desktopLinkClass(active)} aria-current={active ? "page" : undefined}>
              {link.label}
            </a>
          );
        })
      }
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <a
        href={site.portalLoginPath}
        aria-label="Open the secure Kharon portal."
        title={site.portalStatus}
        class="whitespace-nowrap rounded-md border border-white/15 px-4 py-3 text-sm font-semibold text-white/80 hover:bg-white/10 hover:text-white xl:px-5"
      >
        Access Records
      </a>

      <a href="/contact?intent=site-assessment" class="whitespace-nowrap rounded-md bg-kharon-purple px-4 py-3 text-sm font-semibold text-white hover:bg-kharon-blue xl:px-5">
        Request Site Assessment
      </a>
    </div>

    <details class="mobile-menu lg:hidden">
      <summary
        class="inline-flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-md border border-white/15 text-white marker:hidden"
        aria-label="Toggle menu"
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 mobile-menu__open" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg aria-hidden="true" viewBox="0 0 24 24" class="hidden h-5 w-5 mobile-menu__close" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 6l12 12M18 6L6 18"></path>
        </svg>
      </summary>

      <div class="fixed inset-x-0 top-20 z-[90] max-h-[calc(100vh-5rem)] overflow-y-auto border-t border-white/10 bg-kharon-black px-4 py-6 shadow-2xl sm:px-6 sm:py-8">
        <nav class="grid gap-1" aria-label="Mobile navigation">
          {
            [...mobilePrimaryLinks.slice(0, 1), ...solutionLinks, ...mobilePrimaryLinks.slice(1)].map((link) => {
              const active = isLinkActive(link.href);
              return (
                <a
                  href={link.href}
                  aria-current={active ? "page" : undefined}
                  class={`border-b border-white/10 py-4 text-lg font-semibold ${active ? "text-kharon-cyan" : "text-white"}`}
                >
                  {link.label}
                </a>
              );
            })
          }

          <a href="/contact?intent=site-assessment" class="mt-6 rounded-md bg-kharon-purple px-6 py-4 text-center font-semibold text-white">
            Request Site Assessment
          </a>

          <a href={site.portalLoginPath} class="rounded-md border border-white/15 px-6 py-4 text-center font-semibold text-white">
            Access Records
          </a>
        </nav>
      </div>
    </details>
  </div>
</header>

<script>
  const solutionsDropdown = document.querySelector<HTMLDetailsElement>("details.group");
  if (solutionsDropdown) {
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && solutionsDropdown.open) {
        solutionsDropdown.removeAttribute("open");
        solutionsDropdown.querySelector("summary")?.focus();
      }
    });
    document.addEventListener("click", (event) => {
      if (!solutionsDropdown.contains(event.target as Node)) {
        solutionsDropdown.removeAttribute("open");
      }
    });
  }

  const mobileMenu = document.querySelector<HTMLDetailsElement>("details.mobile-menu");
  if (mobileMenu) {
    for (const link of mobileMenu.querySelectorAll("nav a")) {
      link.addEventListener("click", () => {
        mobileMenu.removeAttribute("open");
      });
    }
  }
</script>
