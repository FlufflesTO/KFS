{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "kfs-website",
  "compatibility_date": "2026-05-20",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    {
      "pattern": "kharon.co.za/*",
      "zone_name": "kharon.co.za"
    },
    {
      "pattern": "www.kharon.co.za/*",
      "zone_name": "kharon.co.za"
    }
  ],
  "vars": {
    "ENVIRONMENT": "production"
  }
}
