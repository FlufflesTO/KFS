{
  "name": "kharon-website",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=9.6.5"
  },
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "build:sw": "node scripts/build-sw.js",
    "build:astro": "astro build",
    "build:css": "node scripts/purge-css.ts",
    "build": "npm run build:sw && npm run build:astro && npm run build:css",
    "build:staging": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-site.ps1 staging",
    "build:production:kharon": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-site.ps1 production",
    "lint": "eslint .",
    "test": "playwright test",
    "audit:site": "node scripts/audit-site.ts",
    "validate:site": "npm run build:staging && npm run audit:site",
    "portal:hash-password": "node scripts/hash-password.ts",
    "portal:monitor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/portal-monitor.ps1",
    "portal:qa:roles": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/portal-role-qa.ps1",
    "portal:backup:d1": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/portal-backup.ps1",
    "portal:retention:report": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/portal-retention-report.ps1",
    "preview": "astro preview",
    "auth:cloudflare": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cloudflare-pages.ps1 login",
    "cloudflare:whoami": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cloudflare-pages.ps1 whoami",
    "cloudflare:list-projects": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cloudflare-pages.ps1 list",
    "cloudflare:create-project": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cloudflare-pages.ps1 create",
    "cloudflare:domains": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cloudflare-pages.ps1 domains",
    "cloudflare:retry-portal": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cloudflare-pages.ps1 retry-portal",
    "cloudflare:check-portal": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cloudflare-pages.ps1 check-portal",
    "deploy:website": "npx wrangler pages deploy dist --project-name kfs-website --branch main",
    "deploy:portal": "npx wrangler deploy --config dist/server/wrangler.json",
    "deploy:cloudflare": "npm run build && npm run deploy:portal && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-site.ps1 staging && npm run deploy:website",
    "deploy:cloudflare:preview": "npx wrangler pages deploy dist --project-name kfs-website --branch preview",
    "deploy:cloudflare:ps": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cloudflare-pages.ps1 production",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.6.0",
    "@openrouter/agent": "^0.7.0",
    "@openrouter/sdk": "^0.12.79",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.3",
    "claude": "^0.1.1",
    "cli": "^1.0.1",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "@axe-core/playwright": "^4.11.3",
    "@cloudflare/workers-types": "^4.20260530.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/qrcode": "^1.5.6",
    "esbuild": "^0.27.7",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "wrangler": "^4.92.0"
  },
  "overrides": {
    "ws": "^8.20.1",
    "yaml": "^2.9.0"
  }
}
