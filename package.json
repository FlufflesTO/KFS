{
  "name": "kharon-website",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=9.6.5"
  },
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "build:sw": "node scripts/build-sw.js",
    "build:astro": "astro build",
    "build:css": "npx tsx scripts/purge-css.ts",
    "build:cron": "node scripts/wrap-worker-cron.mjs",
    "build": "npm run build:sw && npm run build:astro && npm run build:cron && npm run build:css",
    "build:portal": "./scripts/build-deploy-artifacts.sh portal",
    "build:website": "./scripts/build-deploy-artifacts.sh website",
    "build:production": "./scripts/build-deploy-artifacts.sh all",
    "lint": "eslint .",
    "test": "playwright test",
    "audit:site": "npx tsx scripts/audit-site.ts",
    "validate:site": "npm run build:production && npm run audit:site",
    "portal:hash-password": "npx tsx scripts/hash-password.ts",
    "portal:monitor": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/portal-monitor.ps1",
    "portal:qa:roles": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/portal-role-qa.ps1",
    "portal:backup:d1": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/portal-backup.ps1",
    "portal:retention:report": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/portal-retention-report.ps1",
    "preview": "astro preview",
    "auth:cloudflare": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/cloudflare-pages.ps1 login",
    "cloudflare:whoami": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/cloudflare-pages.ps1 whoami",
    "cloudflare:list-projects": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/cloudflare-pages.ps1 list",
    "cloudflare:create-project": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/cloudflare-pages.ps1 create",
    "cloudflare:domains": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/cloudflare-pages.ps1 domains",
    "cloudflare:retry-portal": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/cloudflare-pages.ps1 retry-portal",
    "cloudflare:check-portal": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/cloudflare-pages.ps1 check-portal",
    "deploy:website:artifact": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/deploy-website-artifact.ps1 -ArtifactPath .deploy/website",
    "deploy:portal:artifact": "npx wrangler deploy --config .deploy/portal/server/wrangler.json",
    "deploy:website": "npm run build:website && npm run deploy:website:artifact",
    "deploy:portal": "npm run build:portal && npm run deploy:portal:artifact",
    "deploy:cloudflare": "npm run build:production && npm run deploy:portal:artifact && npm run deploy:website:artifact",
    "deploy:cloudflare:ps": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/cloudflare-pages.ps1 production",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.6.0",
    "@openrouter/agent": "^0.7.0",
    "@openrouter/sdk": "^0.12.79",
    "@sentinel/types": "file:packages/types",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.3",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "@axe-core/playwright": "^4.11.3",
    "@cloudflare/workers-types": "^4.20260530.1",
    "@emnapi/runtime": "^1.10.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/qrcode": "^1.5.6",
    "esbuild": "^0.27.7",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "wrangler": "^4.92.0"
  },
  "overrides": {
    "ws": "^8.20.1",
    "yaml": "^2.9.0"
  }
}
